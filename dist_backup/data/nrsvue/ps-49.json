{
  "document_id": "ps-49",
  "title": "Psalms 49",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-49-1",
      "type": "verse",
      "number": 1,
      "text": "Hear this, all you peoples;"
    },
    {
      "block_id": "ps-49-2",
      "type": "verse",
      "number": 2,
      "text": "both low and high,"
    },
    {
      "block_id": "ps-49-3",
      "type": "verse",
      "number": 3,
      "text": "My mouth shall speak wisdom;"
    },
    {
      "block_id": "ps-49-4",
      "type": "verse",
      "number": 4,
      "text": "I will incline my ear to a proverb;"
    },
    {
      "block_id": "ps-49-5",
      "type": "verse",
      "number": 5,
      "text": "Why should I fear in times of trouble,"
    },
    {
      "block_id": "ps-49-6",
      "type": "verse",
      "number": 6,
      "text": "those who trust in their wealth"
    },
    {
      "block_id": "ps-49-7",
      "type": "verse",
      "number": 7,
      "text": "Truly, no ransom avails for one’s life;"
    },
    {
      "block_id": "ps-49-8",
      "type": "verse",
      "number": 8,
      "text": "For the ransom of life is costly"
    },
    {
      "block_id": "ps-49-9",
      "type": "verse",
      "number": 9,
      "text": "that one should live on forever"
    },
    {
      "block_id": "ps-49-10",
      "type": "verse",
      "number": 10,
      "text": "When we look at the wise, they die;"
    },
    {
      "block_id": "ps-49-11",
      "type": "verse",
      "number": 11,
      "text": "Their graves are their homes forever,"
    },
    {
      "block_id": "ps-49-12",
      "type": "verse",
      "number": 12,
      "text": "Mortals cannot abide in their pomp;"
    },
    {
      "block_id": "ps-49-13",
      "type": "verse",
      "number": 13,
      "text": "Such is the fate of the foolhardy,"
    },
    {
      "block_id": "ps-49-14",
      "type": "verse",
      "number": 14,
      "text": "Like sheep they are appointed for Sheol;"
    },
    {
      "block_id": "ps-49-15",
      "type": "verse",
      "number": 15,
      "text": "But God will ransom my soul from the power of Sheol,"
    },
    {
      "block_id": "ps-49-16",
      "type": "verse",
      "number": 16,
      "text": "Do not be afraid when some become rich,"
    },
    {
      "block_id": "ps-49-17",
      "type": "verse",
      "number": 17,
      "text": "For when they die they will carry nothing away;"
    },
    {
      "block_id": "ps-49-18",
      "type": "verse",
      "number": 18,
      "text": "Though in their lifetime they count themselves happy"
    },
    {
      "block_id": "ps-49-19",
      "type": "verse",
      "number": 19,
      "text": "they will go to the company of their ancestors,"
    },
    {
      "block_id": "ps-49-20",
      "type": "verse",
      "number": 20,
      "text": "Mortals cannot abide in their pomp;"
    }
  ]
}