{
  "document_id": "ps-77",
  "title": "Psalms 77",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-77-1",
      "type": "verse",
      "number": 1,
      "text": "I cry aloud to God,"
    },
    {
      "block_id": "ps-77-2",
      "type": "verse",
      "number": 2,
      "text": "In the day of my trouble I seek the Lord;"
    },
    {
      "block_id": "ps-77-3",
      "type": "verse",
      "number": 3,
      "text": "I think of God, and I moan;"
    },
    {
      "block_id": "ps-77-4",
      "type": "verse",
      "number": 4,
      "text": "You keep my eyelids from closing;"
    },
    {
      "block_id": "ps-77-5",
      "type": "verse",
      "number": 5,
      "text": "I consider the days of old"
    },
    {
      "block_id": "ps-77-6",
      "type": "verse",
      "number": 6,
      "text": "I commune with my heart in the night;"
    },
    {
      "block_id": "ps-77-7",
      "type": "verse",
      "number": 7,
      "text": "“Will the Lord spurn forever"
    },
    {
      "block_id": "ps-77-8",
      "type": "verse",
      "number": 8,
      "text": "Has his steadfast love ceased forever?"
    },
    {
      "block_id": "ps-77-9",
      "type": "verse",
      "number": 9,
      "text": "Has God forgotten to be gracious?"
    },
    {
      "block_id": "ps-77-10",
      "type": "verse",
      "number": 10,
      "text": "And I say, “It is my grief"
    },
    {
      "block_id": "ps-77-11",
      "type": "verse",
      "number": 11,
      "text": "I will call to mind the deeds of the Lord;"
    },
    {
      "block_id": "ps-77-12",
      "type": "verse",
      "number": 12,
      "text": "I will meditate on all your work"
    },
    {
      "block_id": "ps-77-13",
      "type": "verse",
      "number": 13,
      "text": "Your way, O God, is holy."
    },
    {
      "block_id": "ps-77-14",
      "type": "verse",
      "number": 14,
      "text": "You are the God who works wonders;"
    },
    {
      "block_id": "ps-77-15",
      "type": "verse",
      "number": 15,
      "text": "With your strong arm you redeemed your people,"
    },
    {
      "block_id": "ps-77-16",
      "type": "verse",
      "number": 16,
      "text": "When the waters saw you, O God,"
    },
    {
      "block_id": "ps-77-17",
      "type": "verse",
      "number": 17,
      "text": "The clouds poured out water;"
    },
    {
      "block_id": "ps-77-18",
      "type": "verse",
      "number": 18,
      "text": "The crash of your thunder was in the whirlwind;"
    },
    {
      "block_id": "ps-77-19",
      "type": "verse",
      "number": 19,
      "text": "Your way was through the sea,"
    },
    {
      "block_id": "ps-77-20",
      "type": "verse",
      "number": 20,
      "text": "You led your people like a flock"
    }
  ]
}