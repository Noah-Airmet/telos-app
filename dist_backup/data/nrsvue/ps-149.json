{
  "document_id": "ps-149",
  "title": "Psalms 149",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-149-1",
      "type": "verse",
      "number": 1,
      "text": "Praise the Lord!"
    },
    {
      "block_id": "ps-149-2",
      "type": "verse",
      "number": 2,
      "text": "Let Israel be glad in its Maker;"
    },
    {
      "block_id": "ps-149-3",
      "type": "verse",
      "number": 3,
      "text": "Let them praise his name with dancing,"
    },
    {
      "block_id": "ps-149-4",
      "type": "verse",
      "number": 4,
      "text": "For the Lord takes pleasure in his people;"
    },
    {
      "block_id": "ps-149-5",
      "type": "verse",
      "number": 5,
      "text": "Let the faithful exult in glory;"
    },
    {
      "block_id": "ps-149-6",
      "type": "verse",
      "number": 6,
      "text": "Let the high praises of God be in their throats"
    },
    {
      "block_id": "ps-149-7",
      "type": "verse",
      "number": 7,
      "text": "to execute vengeance on the nations"
    },
    {
      "block_id": "ps-149-8",
      "type": "verse",
      "number": 8,
      "text": "to bind their kings with fetters"
    },
    {
      "block_id": "ps-149-9",
      "type": "verse",
      "number": 9,
      "text": "to execute on them the judgment decreed."
    }
  ]
}