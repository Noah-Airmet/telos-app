{
  "document_id": "ps-69",
  "title": "Psalms 69",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-69-1",
      "type": "verse",
      "number": 1,
      "text": "Save me, O God,"
    },
    {
      "block_id": "ps-69-2",
      "type": "verse",
      "number": 2,
      "text": "I sink in deep mire,"
    },
    {
      "block_id": "ps-69-3",
      "type": "verse",
      "number": 3,
      "text": "I am weary with my crying;"
    },
    {
      "block_id": "ps-69-4",
      "type": "verse",
      "number": 4,
      "text": "More in number than the hairs of my head"
    },
    {
      "block_id": "ps-69-5",
      "type": "verse",
      "number": 5,
      "text": "O God, you know my folly;"
    },
    {
      "block_id": "ps-69-6",
      "type": "verse",
      "number": 6,
      "text": "Do not let those who hope in you be put to shame because of me,"
    },
    {
      "block_id": "ps-69-7",
      "type": "verse",
      "number": 7,
      "text": "It is for your sake that I have borne reproach,"
    },
    {
      "block_id": "ps-69-8",
      "type": "verse",
      "number": 8,
      "text": "I have become a stranger to my kindred,"
    },
    {
      "block_id": "ps-69-9",
      "type": "verse",
      "number": 9,
      "text": "It is zeal for your house that has consumed me;"
    },
    {
      "block_id": "ps-69-10",
      "type": "verse",
      "number": 10,
      "text": "When I humbled my soul with fasting,"
    },
    {
      "block_id": "ps-69-11",
      "type": "verse",
      "number": 11,
      "text": "When I made sackcloth my clothing,"
    },
    {
      "block_id": "ps-69-12",
      "type": "verse",
      "number": 12,
      "text": "I am the subject of gossip for those who sit in the gate,"
    },
    {
      "block_id": "ps-69-13",
      "type": "verse",
      "number": 13,
      "text": "But as for me, my prayer is to you, O Lord."
    },
    {
      "block_id": "ps-69-14",
      "type": "verse",
      "number": 14,
      "text": "rescue me"
    },
    {
      "block_id": "ps-69-15",
      "type": "verse",
      "number": 15,
      "text": "Do not let the flood sweep over me"
    },
    {
      "block_id": "ps-69-16",
      "type": "verse",
      "number": 16,
      "text": "Answer me, O Lord, for your steadfast love is good;"
    },
    {
      "block_id": "ps-69-17",
      "type": "verse",
      "number": 17,
      "text": "Do not hide your face from your servant,"
    },
    {
      "block_id": "ps-69-18",
      "type": "verse",
      "number": 18,
      "text": "Draw near to me; redeem me;"
    },
    {
      "block_id": "ps-69-19",
      "type": "verse",
      "number": 19,
      "text": "You know the insults I receive"
    },
    {
      "block_id": "ps-69-20",
      "type": "verse",
      "number": 20,
      "text": "Insults have broken my heart,"
    },
    {
      "block_id": "ps-69-21",
      "type": "verse",
      "number": 21,
      "text": "They gave me poison for food,"
    },
    {
      "block_id": "ps-69-22",
      "type": "verse",
      "number": 22,
      "text": "Let their table be a trap for them,"
    },
    {
      "block_id": "ps-69-23",
      "type": "verse",
      "number": 23,
      "text": "Let their eyes be darkened so that they cannot see,"
    },
    {
      "block_id": "ps-69-24",
      "type": "verse",
      "number": 24,
      "text": "Pour out your indignation upon them,"
    },
    {
      "block_id": "ps-69-25",
      "type": "verse",
      "number": 25,
      "text": "May their camp be a desolation;"
    },
    {
      "block_id": "ps-69-26",
      "type": "verse",
      "number": 26,
      "text": "For they persecute those whom you have struck down,"
    },
    {
      "block_id": "ps-69-27",
      "type": "verse",
      "number": 27,
      "text": "Add guilt to their guilt;"
    },
    {
      "block_id": "ps-69-28",
      "type": "verse",
      "number": 28,
      "text": "Let them be blotted out of the book of the living;"
    },
    {
      "block_id": "ps-69-29",
      "type": "verse",
      "number": 29,
      "text": "But I am lowly and in pain;"
    },
    {
      "block_id": "ps-69-30",
      "type": "verse",
      "number": 30,
      "text": "I will praise the name of God with a song;"
    },
    {
      "block_id": "ps-69-31",
      "type": "verse",
      "number": 31,
      "text": "This will please the Lord more than an ox"
    },
    {
      "block_id": "ps-69-32",
      "type": "verse",
      "number": 32,
      "text": "Let the oppressed see it and be glad;"
    },
    {
      "block_id": "ps-69-33",
      "type": "verse",
      "number": 33,
      "text": "For the Lord hears the needy"
    },
    {
      "block_id": "ps-69-34",
      "type": "verse",
      "number": 34,
      "text": "Let heaven and earth praise him,"
    },
    {
      "block_id": "ps-69-35",
      "type": "verse",
      "number": 35,
      "text": "For God will save Zion"
    },
    {
      "block_id": "ps-69-36",
      "type": "verse",
      "number": 36,
      "text": "the children of his servants shall inherit it,"
    }
  ]
}