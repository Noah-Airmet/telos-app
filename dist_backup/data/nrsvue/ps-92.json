{
  "document_id": "ps-92",
  "title": "Psalms 92",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-92-1",
      "type": "verse",
      "number": 1,
      "text": "It is good to give thanks to the Lord,"
    },
    {
      "block_id": "ps-92-2",
      "type": "verse",
      "number": 2,
      "text": "to declare your steadfast love in the morning"
    },
    {
      "block_id": "ps-92-3",
      "type": "verse",
      "number": 3,
      "text": "to the music of the lute and the harp,"
    },
    {
      "block_id": "ps-92-4",
      "type": "verse",
      "number": 4,
      "text": "For you, O Lord, have made me glad by your work;"
    },
    {
      "block_id": "ps-92-5",
      "type": "verse",
      "number": 5,
      "text": "How great are your works, O Lord!"
    },
    {
      "block_id": "ps-92-6",
      "type": "verse",
      "number": 6,
      "text": "The dullard cannot know;"
    },
    {
      "block_id": "ps-92-7",
      "type": "verse",
      "number": 7,
      "text": "though the wicked sprout like grass"
    },
    {
      "block_id": "ps-92-8",
      "type": "verse",
      "number": 8,
      "text": "but you, O Lord, are on high forever."
    },
    {
      "block_id": "ps-92-9",
      "type": "verse",
      "number": 9,
      "text": "For your enemies, O Lord,"
    },
    {
      "block_id": "ps-92-10",
      "type": "verse",
      "number": 10,
      "text": "But you have exalted my horn like that of the wild ox;"
    },
    {
      "block_id": "ps-92-11",
      "type": "verse",
      "number": 11,
      "text": "My eyes have seen the downfall of my enemies;"
    },
    {
      "block_id": "ps-92-12",
      "type": "verse",
      "number": 12,
      "text": "The righteous flourish like the palm tree"
    },
    {
      "block_id": "ps-92-13",
      "type": "verse",
      "number": 13,
      "text": "They are planted in the house of the Lord;"
    },
    {
      "block_id": "ps-92-14",
      "type": "verse",
      "number": 14,
      "text": "In old age they still produce fruit;"
    },
    {
      "block_id": "ps-92-15",
      "type": "verse",
      "number": 15,
      "text": "showing that the Lord is upright;"
    }
  ]
}