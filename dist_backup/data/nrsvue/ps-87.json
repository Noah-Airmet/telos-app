{
  "document_id": "ps-87",
  "title": "Psalms 87",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-87-1",
      "type": "verse",
      "number": 1,
      "text": "On the holy mount stands the city he founded;"
    },
    {
      "block_id": "ps-87-2",
      "type": "verse",
      "number": 2,
      "text": "the Lord loves the gates of Zion"
    },
    {
      "block_id": "ps-87-3",
      "type": "verse",
      "number": 3,
      "text": "Glorious things are spoken of you,"
    },
    {
      "block_id": "ps-87-4",
      "type": "verse",
      "number": 4,
      "text": "Among those who know me I mention Rahab and Babylon;"
    },
    {
      "block_id": "ps-87-5",
      "type": "verse",
      "number": 5,
      "text": "And of Zion it shall be said,"
    },
    {
      "block_id": "ps-87-6",
      "type": "verse",
      "number": 6,
      "text": "The Lord records, as he registers the peoples,"
    },
    {
      "block_id": "ps-87-7",
      "type": "verse",
      "number": 7,
      "text": "Singers and dancers alike say,"
    }
  ]
}