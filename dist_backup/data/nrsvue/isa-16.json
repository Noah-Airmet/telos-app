{
  "document_id": "isa-16",
  "title": "Isaiah 16",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-16-1",
      "type": "verse",
      "number": 1,
      "text": "Send lambs"
    },
    {
      "block_id": "isa-16-2",
      "type": "verse",
      "number": 2,
      "text": "Like fluttering birds,"
    },
    {
      "block_id": "isa-16-3",
      "type": "verse",
      "number": 3,
      "text": "“Give counsel;"
    },
    {
      "block_id": "isa-16-4",
      "type": "verse",
      "number": 4,
      "text": "let the outcasts of Moab"
    },
    {
      "block_id": "isa-16-5",
      "type": "verse",
      "number": 5,
      "text": "then a throne shall be established in steadfast love"
    },
    {
      "block_id": "isa-16-6",
      "type": "verse",
      "number": 6,
      "text": "We have heard of the pride of Moab"
    },
    {
      "block_id": "isa-16-7",
      "type": "verse",
      "number": 7,
      "text": "Therefore let Moab wail;"
    },
    {
      "block_id": "isa-16-8",
      "type": "verse",
      "number": 8,
      "text": "For the fields of Heshbon languish,"
    },
    {
      "block_id": "isa-16-9",
      "type": "verse",
      "number": 9,
      "text": "Therefore I weep as Jazer weeps"
    },
    {
      "block_id": "isa-16-10",
      "type": "verse",
      "number": 10,
      "text": "Joy and gladness are taken away"
    },
    {
      "block_id": "isa-16-11",
      "type": "verse",
      "number": 11,
      "text": "Therefore my heart moans like a harp for Moab"
    },
    {
      "block_id": "isa-16-12",
      "type": "verse",
      "number": 12,
      "text": "When Moab presents himself, when he wearies himself upon the high place, when he comes to his sanctuary to pray, he will not prevail."
    },
    {
      "block_id": "isa-16-13",
      "type": "verse",
      "number": 13,
      "text": "This was the word that the Lord spoke concerning Moab in the past."
    },
    {
      "block_id": "isa-16-14",
      "type": "verse",
      "number": 14,
      "text": "But now the Lord says, “In three years, like the years of a hired worker, the glory of Moab will be brought into contempt, in spite of all its great multitude, and those who survive will be very few and feeble.”"
    }
  ]
}