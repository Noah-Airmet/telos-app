{
  "document_id": "lam-2",
  "title": "Lamentations 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "lam-2-1",
      "type": "verse",
      "number": 1,
      "text": "How the Lord in his anger"
    },
    {
      "block_id": "lam-2-2",
      "type": "verse",
      "number": 2,
      "text": "The Lord has destroyed without mercy"
    },
    {
      "block_id": "lam-2-3",
      "type": "verse",
      "number": 3,
      "text": "He has cut down in fierce anger"
    },
    {
      "block_id": "lam-2-4",
      "type": "verse",
      "number": 4,
      "text": "He has bent his bow like an enemy,"
    },
    {
      "block_id": "lam-2-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord has become like an enemy;"
    },
    {
      "block_id": "lam-2-6",
      "type": "verse",
      "number": 6,
      "text": "He has broken down his booth like a garden;"
    },
    {
      "block_id": "lam-2-7",
      "type": "verse",
      "number": 7,
      "text": "The Lord has scorned his altar,"
    },
    {
      "block_id": "lam-2-8",
      "type": "verse",
      "number": 8,
      "text": "The Lord determined to lay in ruins"
    },
    {
      "block_id": "lam-2-9",
      "type": "verse",
      "number": 9,
      "text": "Her gates have sunk into the ground;"
    },
    {
      "block_id": "lam-2-10",
      "type": "verse",
      "number": 10,
      "text": "The elders of daughter Zion"
    },
    {
      "block_id": "lam-2-11",
      "type": "verse",
      "number": 11,
      "text": "My eyes are spent with weeping;"
    },
    {
      "block_id": "lam-2-12",
      "type": "verse",
      "number": 12,
      "text": "They cry to their mothers,"
    },
    {
      "block_id": "lam-2-13",
      "type": "verse",
      "number": 13,
      "text": "What can I say for you, to what compare you,"
    },
    {
      "block_id": "lam-2-14",
      "type": "verse",
      "number": 14,
      "text": "Your prophets have seen for you"
    },
    {
      "block_id": "lam-2-15",
      "type": "verse",
      "number": 15,
      "text": "All who pass along the way"
    },
    {
      "block_id": "lam-2-16",
      "type": "verse",
      "number": 16,
      "text": "All your enemies"
    },
    {
      "block_id": "lam-2-17",
      "type": "verse",
      "number": 17,
      "text": "The Lord has done what he purposed;"
    },
    {
      "block_id": "lam-2-18",
      "type": "verse",
      "number": 18,
      "text": "Cry aloud to the Lord!"
    },
    {
      "block_id": "lam-2-19",
      "type": "verse",
      "number": 19,
      "text": "Arise, cry out in the night,"
    },
    {
      "block_id": "lam-2-20",
      "type": "verse",
      "number": 20,
      "text": "Look, O Lord, and consider!"
    },
    {
      "block_id": "lam-2-21",
      "type": "verse",
      "number": 21,
      "text": "The young and the old are lying"
    },
    {
      "block_id": "lam-2-22",
      "type": "verse",
      "number": 22,
      "text": "You invited my enemies from all around"
    }
  ]
}