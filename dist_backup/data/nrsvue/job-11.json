{
  "document_id": "job-11",
  "title": "Job 11",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-11-heading-zophar-speaks:-job’s",
      "type": "heading",
      "text": "Zophar Speaks: Job’s Guilt Deserves Punishment"
    },
    {
      "block_id": "job-11-1",
      "type": "verse",
      "number": 1,
      "text": "Then Zophar the Naamathite answered:"
    },
    {
      "block_id": "job-11-2",
      "type": "verse",
      "number": 2,
      "text": "“Should a multitude of words go unanswered,"
    },
    {
      "block_id": "job-11-3",
      "type": "verse",
      "number": 3,
      "text": "Should your babble put others to silence,"
    },
    {
      "block_id": "job-11-4",
      "type": "verse",
      "number": 4,
      "text": "For you say, ‘My conduct is pure,"
    },
    {
      "block_id": "job-11-5",
      "type": "verse",
      "number": 5,
      "text": "But O that God would speak"
    },
    {
      "block_id": "job-11-6",
      "type": "verse",
      "number": 6,
      "text": "and that he would tell you the secrets of wisdom!"
    },
    {
      "block_id": "job-11-7",
      "type": "verse",
      "number": 7,
      "text": "“Can you find out the deep things of God?"
    },
    {
      "block_id": "job-11-8",
      "type": "verse",
      "number": 8,
      "text": "It is higher than heaven—what can you do?"
    },
    {
      "block_id": "job-11-9",
      "type": "verse",
      "number": 9,
      "text": "Its measure is longer than the earth"
    },
    {
      "block_id": "job-11-10",
      "type": "verse",
      "number": 10,
      "text": "If he passes through and imprisons"
    },
    {
      "block_id": "job-11-11",
      "type": "verse",
      "number": 11,
      "text": "For he knows those who are worthless;"
    },
    {
      "block_id": "job-11-12",
      "type": "verse",
      "number": 12,
      "text": "But the stupid will get understanding"
    },
    {
      "block_id": "job-11-13",
      "type": "verse",
      "number": 13,
      "text": "“If you direct your heart rightly,"
    },
    {
      "block_id": "job-11-14",
      "type": "verse",
      "number": 14,
      "text": "If iniquity is in your hand, put it far away,"
    },
    {
      "block_id": "job-11-15",
      "type": "verse",
      "number": 15,
      "text": "Surely then you will lift up your face without blemish;"
    },
    {
      "block_id": "job-11-16",
      "type": "verse",
      "number": 16,
      "text": "You will forget your misery;"
    },
    {
      "block_id": "job-11-17",
      "type": "verse",
      "number": 17,
      "text": "And your life will be brighter than the noonday;"
    },
    {
      "block_id": "job-11-18",
      "type": "verse",
      "number": 18,
      "text": "And you will have confidence because there is hope;"
    },
    {
      "block_id": "job-11-19",
      "type": "verse",
      "number": 19,
      "text": "You will lie down, and no one will make you afraid;"
    },
    {
      "block_id": "job-11-20",
      "type": "verse",
      "number": 20,
      "text": "But the eyes of the wicked will fail;"
    }
  ]
}