{
  "document_id": "job-12",
  "title": "Job 12",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-12-heading-job-replies:-i-am-a-",
      "type": "heading",
      "text": "Job Replies: I Am a Laughingstock"
    },
    {
      "block_id": "job-12-1",
      "type": "verse",
      "number": 1,
      "text": "Then Job answered:"
    },
    {
      "block_id": "job-12-2",
      "type": "verse",
      "number": 2,
      "text": "“No doubt you are the people,"
    },
    {
      "block_id": "job-12-3",
      "type": "verse",
      "number": 3,
      "text": "But I have understanding as well as you;"
    },
    {
      "block_id": "job-12-4",
      "type": "verse",
      "number": 4,
      "text": "I am a laughingstock to my friends;"
    },
    {
      "block_id": "job-12-5",
      "type": "verse",
      "number": 5,
      "text": "Those at ease have contempt for misfortune,"
    },
    {
      "block_id": "job-12-6",
      "type": "verse",
      "number": 6,
      "text": "The tents of robbers are at peace,"
    },
    {
      "block_id": "job-12-7",
      "type": "verse",
      "number": 7,
      "text": "“But ask the animals, and they will teach you,"
    },
    {
      "block_id": "job-12-8",
      "type": "verse",
      "number": 8,
      "text": "ask the plants of the earth, and they will teach you,"
    },
    {
      "block_id": "job-12-9",
      "type": "verse",
      "number": 9,
      "text": "Who among all these does not know"
    },
    {
      "block_id": "job-12-10",
      "type": "verse",
      "number": 10,
      "text": "In his hand is the life of every living thing"
    },
    {
      "block_id": "job-12-11",
      "type": "verse",
      "number": 11,
      "text": "Does not the ear test words"
    },
    {
      "block_id": "job-12-12",
      "type": "verse",
      "number": 12,
      "text": "Is wisdom with the aged"
    },
    {
      "block_id": "job-12-13",
      "type": "verse",
      "number": 13,
      "text": "“With God are wisdom and strength;"
    },
    {
      "block_id": "job-12-14",
      "type": "verse",
      "number": 14,
      "text": "If he tears down, no one can rebuild;"
    },
    {
      "block_id": "job-12-15",
      "type": "verse",
      "number": 15,
      "text": "If he withholds the waters, they dry up;"
    },
    {
      "block_id": "job-12-16",
      "type": "verse",
      "number": 16,
      "text": "With him are strength and wisdom;"
    },
    {
      "block_id": "job-12-17",
      "type": "verse",
      "number": 17,
      "text": "He leads counselors away stripped"
    },
    {
      "block_id": "job-12-18",
      "type": "verse",
      "number": 18,
      "text": "He looses the sash of kings"
    },
    {
      "block_id": "job-12-19",
      "type": "verse",
      "number": 19,
      "text": "He leads priests away stripped"
    },
    {
      "block_id": "job-12-20",
      "type": "verse",
      "number": 20,
      "text": "He deprives of speech those who are trusted"
    },
    {
      "block_id": "job-12-21",
      "type": "verse",
      "number": 21,
      "text": "He pours contempt on princes"
    },
    {
      "block_id": "job-12-22",
      "type": "verse",
      "number": 22,
      "text": "He uncovers deep things from the darkness"
    },
    {
      "block_id": "job-12-23",
      "type": "verse",
      "number": 23,
      "text": "He makes nations great, then destroys them;"
    },
    {
      "block_id": "job-12-24",
      "type": "verse",
      "number": 24,
      "text": "He strips understanding from the leaders of the earth"
    },
    {
      "block_id": "job-12-25",
      "type": "verse",
      "number": 25,
      "text": "They grope in the dark without light;"
    }
  ]
}