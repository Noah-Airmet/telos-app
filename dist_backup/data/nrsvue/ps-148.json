{
  "document_id": "ps-148",
  "title": "Psalms 148",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-148-1",
      "type": "verse",
      "number": 1,
      "text": "Praise the Lord!"
    },
    {
      "block_id": "ps-148-2",
      "type": "verse",
      "number": 2,
      "text": "Praise him, all his angels;"
    },
    {
      "block_id": "ps-148-3",
      "type": "verse",
      "number": 3,
      "text": "Praise him, sun and moon;"
    },
    {
      "block_id": "ps-148-4",
      "type": "verse",
      "number": 4,
      "text": "Praise him, you highest heavens"
    },
    {
      "block_id": "ps-148-5",
      "type": "verse",
      "number": 5,
      "text": "Let them praise the name of the Lord,"
    },
    {
      "block_id": "ps-148-6",
      "type": "verse",
      "number": 6,
      "text": "He established them forever and ever;"
    },
    {
      "block_id": "ps-148-7",
      "type": "verse",
      "number": 7,
      "text": "Praise the Lord from the earth,"
    },
    {
      "block_id": "ps-148-8",
      "type": "verse",
      "number": 8,
      "text": "fire and hail, snow and frost,"
    },
    {
      "block_id": "ps-148-9",
      "type": "verse",
      "number": 9,
      "text": "Mountains and all hills,"
    },
    {
      "block_id": "ps-148-10",
      "type": "verse",
      "number": 10,
      "text": "Wild animals and all cattle,"
    },
    {
      "block_id": "ps-148-11",
      "type": "verse",
      "number": 11,
      "text": "Kings of the earth and all peoples,"
    },
    {
      "block_id": "ps-148-12",
      "type": "verse",
      "number": 12,
      "text": "Young men and women alike,"
    },
    {
      "block_id": "ps-148-13",
      "type": "verse",
      "number": 13,
      "text": "Let them praise the name of the Lord,"
    },
    {
      "block_id": "ps-148-14",
      "type": "verse",
      "number": 14,
      "text": "He has raised up a horn for his people,"
    }
  ]
}