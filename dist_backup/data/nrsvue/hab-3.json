{
  "document_id": "hab-3",
  "title": "Habakkuk 3",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hab-3-1",
      "type": "verse",
      "number": 1,
      "text": "A prayer of the prophet Habakkuk according to Shigionoth."
    },
    {
      "block_id": "hab-3-2",
      "type": "verse",
      "number": 2,
      "text": "O Lord, I have heard of your renown,"
    },
    {
      "block_id": "hab-3-3",
      "type": "verse",
      "number": 3,
      "text": "God came from Teman,"
    },
    {
      "block_id": "hab-3-4",
      "type": "verse",
      "number": 4,
      "text": "The brightness was like the sun;"
    },
    {
      "block_id": "hab-3-5",
      "type": "verse",
      "number": 5,
      "text": "Before him went pestilence,"
    },
    {
      "block_id": "hab-3-6",
      "type": "verse",
      "number": 6,
      "text": "He stopped and shook the earth;"
    },
    {
      "block_id": "hab-3-7",
      "type": "verse",
      "number": 7,
      "text": "I saw the tents of Cushan under affliction;"
    },
    {
      "block_id": "hab-3-8",
      "type": "verse",
      "number": 8,
      "text": "Was your wrath against the rivers, O Lord,"
    },
    {
      "block_id": "hab-3-9",
      "type": "verse",
      "number": 9,
      "text": "You brandished your naked bow;"
    },
    {
      "block_id": "hab-3-10",
      "type": "verse",
      "number": 10,
      "text": "The mountains saw you and writhed;"
    },
    {
      "block_id": "hab-3-11",
      "type": "verse",
      "number": 11,
      "text": "the moon stood still in its exalted place,"
    },
    {
      "block_id": "hab-3-12",
      "type": "verse",
      "number": 12,
      "text": "In fury you marched on the earth;"
    },
    {
      "block_id": "hab-3-13",
      "type": "verse",
      "number": 13,
      "text": "You came forth to save your people,"
    },
    {
      "block_id": "hab-3-14",
      "type": "verse",
      "number": 14,
      "text": "You pierced with their own arrows the head of his warriors,"
    },
    {
      "block_id": "hab-3-15",
      "type": "verse",
      "number": 15,
      "text": "You trampled the sea with your horses,"
    },
    {
      "block_id": "hab-3-16",
      "type": "verse",
      "number": 16,
      "text": "I hear, and I tremble within;"
    },
    {
      "block_id": "hab-3-17",
      "type": "verse",
      "number": 17,
      "text": "Though the fig tree does not blossom"
    },
    {
      "block_id": "hab-3-18",
      "type": "verse",
      "number": 18,
      "text": "yet I will rejoice in the Lord;"
    },
    {
      "block_id": "hab-3-19",
      "type": "verse",
      "number": 19,
      "text": "God, the Lord, is my strength;"
    }
  ]
}