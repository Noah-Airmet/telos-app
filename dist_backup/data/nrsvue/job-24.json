{
  "document_id": "job-24",
  "title": "Job 24",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-24-1",
      "type": "verse",
      "number": 1,
      "text": "“Why are times not kept by the Almighty,"
    },
    {
      "block_id": "job-24-2",
      "type": "verse",
      "number": 2,
      "text": "The wicked remove landmarks;"
    },
    {
      "block_id": "job-24-3",
      "type": "verse",
      "number": 3,
      "text": "They drive away the donkey of the orphan;"
    },
    {
      "block_id": "job-24-4",
      "type": "verse",
      "number": 4,
      "text": "They thrust the needy off the road;"
    },
    {
      "block_id": "job-24-5",
      "type": "verse",
      "number": 5,
      "text": "Like wild asses in the desert"
    },
    {
      "block_id": "job-24-6",
      "type": "verse",
      "number": 6,
      "text": "They reap in a field not their own,"
    },
    {
      "block_id": "job-24-7",
      "type": "verse",
      "number": 7,
      "text": "They lie all night naked, without clothing,"
    },
    {
      "block_id": "job-24-8",
      "type": "verse",
      "number": 8,
      "text": "They are wet with the rain of the mountains"
    },
    {
      "block_id": "job-24-9",
      "type": "verse",
      "number": 9,
      "text": "“There are those who snatch the orphan child from the breast"
    },
    {
      "block_id": "job-24-10",
      "type": "verse",
      "number": 10,
      "text": "They go about naked, without clothing;"
    },
    {
      "block_id": "job-24-11",
      "type": "verse",
      "number": 11,
      "text": "between their terraces they press out oil;"
    },
    {
      "block_id": "job-24-12",
      "type": "verse",
      "number": 12,
      "text": "From the city the dying groan,"
    },
    {
      "block_id": "job-24-13",
      "type": "verse",
      "number": 13,
      "text": "“There are those who rebel against the light,"
    },
    {
      "block_id": "job-24-14",
      "type": "verse",
      "number": 14,
      "text": "The murderer rises at dusk"
    },
    {
      "block_id": "job-24-15",
      "type": "verse",
      "number": 15,
      "text": "The eye of the adulterer also waits for the twilight,"
    },
    {
      "block_id": "job-24-16",
      "type": "verse",
      "number": 16,
      "text": "In the dark they dig through houses;"
    },
    {
      "block_id": "job-24-17",
      "type": "verse",
      "number": 17,
      "text": "For deep darkness is morning to all of them;"
    },
    {
      "block_id": "job-24-18",
      "type": "verse",
      "number": 18,
      "text": "“Swift are they on the face of the waters;"
    },
    {
      "block_id": "job-24-19",
      "type": "verse",
      "number": 19,
      "text": "Drought and heat snatch away the snow waters;"
    },
    {
      "block_id": "job-24-20",
      "type": "verse",
      "number": 20,
      "text": "The womb forgets them;"
    },
    {
      "block_id": "job-24-21",
      "type": "verse",
      "number": 21,
      "text": "“They harm the childless woman"
    },
    {
      "block_id": "job-24-22",
      "type": "verse",
      "number": 22,
      "text": "Yet God prolongs the life of the mighty by his power;"
    },
    {
      "block_id": "job-24-23",
      "type": "verse",
      "number": 23,
      "text": "He gives them security, and they are supported;"
    },
    {
      "block_id": "job-24-24",
      "type": "verse",
      "number": 24,
      "text": "They are exalted a little while and then are gone;"
    },
    {
      "block_id": "job-24-25",
      "type": "verse",
      "number": 25,
      "text": "If it is not so, who will prove me a liar"
    }
  ]
}