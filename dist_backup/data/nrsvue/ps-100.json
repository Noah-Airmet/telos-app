  "blocks": [
    {
      "block_id": "ps-100-1",
      "type": "verse",
      "number": 1,
      "text": "Make a joyful noise to the Lord, all the earth."
    },
    {
      "block_id": "ps-100-2",
      "type": "verse",
      "number": 2,
      "text": "Serve the Lord with gladness;"
    },
    {
      "block_id": "ps-100-3",
      "type": "verse",
      "number": 3,
      "text": "Know that the Lord is God."
    },
    {
      "block_id": "ps-100-4",
      "type": "verse",
      "number": 4,
      "text": "Enter his gates with thanksgiving"
    },
    {
      "block_id": "ps-100-5",
      "type": "verse",
      "number": 5,
      "text": "For the Lord is good;"
    }
  ]
}