{
  "document_id": "prov-16",
  "title": "Proverbs 16",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-16-1",
      "type": "verse",
      "number": 1,
      "text": "The plans of the mind belong to mortals,"
    },
    {
      "block_id": "prov-16-2",
      "type": "verse",
      "number": 2,
      "text": "All one’s ways may be pure in one’s own eyes,"
    },
    {
      "block_id": "prov-16-3",
      "type": "verse",
      "number": 3,
      "text": "Commit your work to the Lord,"
    },
    {
      "block_id": "prov-16-4",
      "type": "verse",
      "number": 4,
      "text": "The Lord has made everything for its purpose,"
    },
    {
      "block_id": "prov-16-5",
      "type": "verse",
      "number": 5,
      "text": "All those who are arrogant are an abomination to the Lord;"
    },
    {
      "block_id": "prov-16-6",
      "type": "verse",
      "number": 6,
      "text": "By loyalty and faithfulness iniquity is atoned for,"
    },
    {
      "block_id": "prov-16-7",
      "type": "verse",
      "number": 7,
      "text": "When the ways of people please the Lord,"
    },
    {
      "block_id": "prov-16-8",
      "type": "verse",
      "number": 8,
      "text": "Better is a little with righteousness"
    },
    {
      "block_id": "prov-16-9",
      "type": "verse",
      "number": 9,
      "text": "The human mind plans the way,"
    },
    {
      "block_id": "prov-16-10",
      "type": "verse",
      "number": 10,
      "text": "Inspired decisions are on the lips of a king;"
    },
    {
      "block_id": "prov-16-11",
      "type": "verse",
      "number": 11,
      "text": "Honest balances and scales are the Lord’s;"
    },
    {
      "block_id": "prov-16-12",
      "type": "verse",
      "number": 12,
      "text": "It is an abomination to kings to do evil,"
    },
    {
      "block_id": "prov-16-13",
      "type": "verse",
      "number": 13,
      "text": "Righteous lips are the delight of a king,"
    },
    {
      "block_id": "prov-16-14",
      "type": "verse",
      "number": 14,
      "text": "A king’s wrath is a messenger of death,"
    },
    {
      "block_id": "prov-16-15",
      "type": "verse",
      "number": 15,
      "text": "In the light of a king’s face there is life,"
    },
    {
      "block_id": "prov-16-16",
      "type": "verse",
      "number": 16,
      "text": "How much better to get wisdom than gold!"
    },
    {
      "block_id": "prov-16-17",
      "type": "verse",
      "number": 17,
      "text": "The highway of the upright avoids evil;"
    },
    {
      "block_id": "prov-16-18",
      "type": "verse",
      "number": 18,
      "text": "Pride goes before destruction"
    },
    {
      "block_id": "prov-16-19",
      "type": "verse",
      "number": 19,
      "text": "It is better to be of a lowly spirit among the poor"
    },
    {
      "block_id": "prov-16-20",
      "type": "verse",
      "number": 20,
      "text": "Those who are attentive to a matter will prosper,"
    },
    {
      "block_id": "prov-16-21",
      "type": "verse",
      "number": 21,
      "text": "The wise of heart is called perceptive,"
    },
    {
      "block_id": "prov-16-22",
      "type": "verse",
      "number": 22,
      "text": "Wisdom is a fountain of life to one who has it,"
    },
    {
      "block_id": "prov-16-23",
      "type": "verse",
      "number": 23,
      "text": "The mind of the wise makes their speech judicious"
    },
    {
      "block_id": "prov-16-24",
      "type": "verse",
      "number": 24,
      "text": "Pleasant words are like a honeycomb,"
    },
    {
      "block_id": "prov-16-25",
      "type": "verse",
      "number": 25,
      "text": "Sometimes there is a way that seems to be right,"
    },
    {
      "block_id": "prov-16-26",
      "type": "verse",
      "number": 26,
      "text": "The appetite of workers works for them;"
    },
    {
      "block_id": "prov-16-27",
      "type": "verse",
      "number": 27,
      "text": "Scoundrels concoct evil,"
    },
    {
      "block_id": "prov-16-28",
      "type": "verse",
      "number": 28,
      "text": "A perverse person spreads strife,"
    },
    {
      "block_id": "prov-16-29",
      "type": "verse",
      "number": 29,
      "text": "The violent entice their neighbors"
    },
    {
      "block_id": "prov-16-30",
      "type": "verse",
      "number": 30,
      "text": "One who winks the eyes plans perverse things;"
    },
    {
      "block_id": "prov-16-31",
      "type": "verse",
      "number": 31,
      "text": "Gray hair is a crown of glory;"
    },
    {
      "block_id": "prov-16-32",
      "type": "verse",
      "number": 32,
      "text": "One who is slow to anger is better than the mighty,"
    },
    {
      "block_id": "prov-16-33",
      "type": "verse",
      "number": 33,
      "text": "The lot is cast into the lap,"
    }
  ]
}