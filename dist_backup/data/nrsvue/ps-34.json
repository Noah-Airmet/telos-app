{
  "document_id": "ps-34",
  "title": "Psalms 34",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-34-1",
      "type": "verse",
      "number": 1,
      "text": "I will bless the Lord at all times;"
    },
    {
      "block_id": "ps-34-2",
      "type": "verse",
      "number": 2,
      "text": "My soul makes its boast in the Lord;"
    },
    {
      "block_id": "ps-34-3",
      "type": "verse",
      "number": 3,
      "text": "O magnify the Lord with me,"
    },
    {
      "block_id": "ps-34-4",
      "type": "verse",
      "number": 4,
      "text": "I sought the Lord, and he answered me"
    },
    {
      "block_id": "ps-34-5",
      "type": "verse",
      "number": 5,
      "text": "Look to him, and be radiant,"
    },
    {
      "block_id": "ps-34-6",
      "type": "verse",
      "number": 6,
      "text": "This poor soul cried and was heard by the Lord"
    },
    {
      "block_id": "ps-34-7",
      "type": "verse",
      "number": 7,
      "text": "The angel of the Lord encamps"
    },
    {
      "block_id": "ps-34-8",
      "type": "verse",
      "number": 8,
      "text": "O taste and see that the Lord is good;"
    },
    {
      "block_id": "ps-34-9",
      "type": "verse",
      "number": 9,
      "text": "O fear the Lord, you his holy ones,"
    },
    {
      "block_id": "ps-34-10",
      "type": "verse",
      "number": 10,
      "text": "The young lions suffer want and hunger,"
    },
    {
      "block_id": "ps-34-11",
      "type": "verse",
      "number": 11,
      "text": "Come, O children, listen to me;"
    },
    {
      "block_id": "ps-34-12",
      "type": "verse",
      "number": 12,
      "text": "Which of you desires life"
    },
    {
      "block_id": "ps-34-13",
      "type": "verse",
      "number": 13,
      "text": "Keep your tongue from evil"
    },
    {
      "block_id": "ps-34-14",
      "type": "verse",
      "number": 14,
      "text": "Depart from evil, and do good;"
    },
    {
      "block_id": "ps-34-15",
      "type": "verse",
      "number": 15,
      "text": "The eyes of the Lord are on the righteous,"
    },
    {
      "block_id": "ps-34-16",
      "type": "verse",
      "number": 16,
      "text": "The face of the Lord is against evildoers,"
    },
    {
      "block_id": "ps-34-17",
      "type": "verse",
      "number": 17,
      "text": "When the righteous cry for help, the Lord hears"
    },
    {
      "block_id": "ps-34-18",
      "type": "verse",
      "number": 18,
      "text": "The Lord is near to the brokenhearted"
    },
    {
      "block_id": "ps-34-19",
      "type": "verse",
      "number": 19,
      "text": "Many are the afflictions of the righteous,"
    },
    {
      "block_id": "ps-34-20",
      "type": "verse",
      "number": 20,
      "text": "He keeps all their bones;"
    },
    {
      "block_id": "ps-34-21",
      "type": "verse",
      "number": 21,
      "text": "Evil brings death to the wicked,"
    },
    {
      "block_id": "ps-34-22",
      "type": "verse",
      "number": 22,
      "text": "The Lord redeems the life of his servants;"
    }
  ]
}