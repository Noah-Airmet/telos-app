{
  "document_id": "isa-18",
  "title": "Isaiah 18",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-18-heading-an-oracle-concerning",
      "type": "heading",
      "text": "An Oracle concerning Cush"
    },
    {
      "block_id": "isa-18-1",
      "type": "verse",
      "number": 1,
      "text": "Woe, land of buzzing wings"
    },
    {
      "block_id": "isa-18-2",
      "type": "verse",
      "number": 2,
      "text": "sending ambassadors by the Nile"
    },
    {
      "block_id": "isa-18-3",
      "type": "verse",
      "number": 3,
      "text": "All you inhabitants of the world,"
    },
    {
      "block_id": "isa-18-4",
      "type": "verse",
      "number": 4,
      "text": "For thus the Lord said to me:"
    },
    {
      "block_id": "isa-18-5",
      "type": "verse",
      "number": 5,
      "text": "For before the harvest, when the blossom is over"
    },
    {
      "block_id": "isa-18-6",
      "type": "verse",
      "number": 6,
      "text": "They shall all be left"
    },
    {
      "block_id": "isa-18-7",
      "type": "verse",
      "number": 7,
      "text": "At that time gifts will be brought to the Lord of hosts from a people tall and smooth, from a people feared near and far, a nation mighty and conquering, whose land the rivers divide, to Mount Zion, the place of the name of the Lord of hosts."
    }
  ]
}