{
  "document_id": "ps-3",
  "title": "Psalms 3",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-3-1",
      "type": "verse",
      "number": 1,
      "text": "O Lord, how many are my foes!"
    },
    {
      "block_id": "ps-3-2",
      "type": "verse",
      "number": 2,
      "text": "many are saying to me,"
    },
    {
      "block_id": "ps-3-3",
      "type": "verse",
      "number": 3,
      "text": "But you, O Lord, are a shield around me,"
    },
    {
      "block_id": "ps-3-4",
      "type": "verse",
      "number": 4,
      "text": "I cry aloud to the Lord,"
    },
    {
      "block_id": "ps-3-5",
      "type": "verse",
      "number": 5,
      "text": "I lie down and sleep;"
    },
    {
      "block_id": "ps-3-6",
      "type": "verse",
      "number": 6,
      "text": "I am not afraid of ten thousands of people"
    },
    {
      "block_id": "ps-3-7",
      "type": "verse",
      "number": 7,
      "text": "Rise up, O Lord!"
    },
    {
      "block_id": "ps-3-8",
      "type": "verse",
      "number": 8,
      "text": "Deliverance belongs to the Lord;"
    }
  ]
}