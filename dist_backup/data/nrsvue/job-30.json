{
  "document_id": "job-30",
  "title": "Job 30",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-30-1",
      "type": "verse",
      "number": 1,
      "text": "“But now they make sport of me,"
    },
    {
      "block_id": "job-30-2",
      "type": "verse",
      "number": 2,
      "text": "What could I gain from the strength of their hands?"
    },
    {
      "block_id": "job-30-3",
      "type": "verse",
      "number": 3,
      "text": "Through want and hard hunger"
    },
    {
      "block_id": "job-30-4",
      "type": "verse",
      "number": 4,
      "text": "they pick mallow and the leaves of bushes"
    },
    {
      "block_id": "job-30-5",
      "type": "verse",
      "number": 5,
      "text": "They are driven out from society;"
    },
    {
      "block_id": "job-30-6",
      "type": "verse",
      "number": 6,
      "text": "In the gullies of wadis they must live,"
    },
    {
      "block_id": "job-30-7",
      "type": "verse",
      "number": 7,
      "text": "Among the bushes they bray;"
    },
    {
      "block_id": "job-30-8",
      "type": "verse",
      "number": 8,
      "text": "A senseless, disreputable brood,"
    },
    {
      "block_id": "job-30-9",
      "type": "verse",
      "number": 9,
      "text": "“And now they mock me in song;"
    },
    {
      "block_id": "job-30-10",
      "type": "verse",
      "number": 10,
      "text": "They abhor me; they keep aloof from me;"
    },
    {
      "block_id": "job-30-11",
      "type": "verse",
      "number": 11,
      "text": "Because God has loosed my bowstring and humbled me,"
    },
    {
      "block_id": "job-30-12",
      "type": "verse",
      "number": 12,
      "text": "On my right hand the rabble rise up;"
    },
    {
      "block_id": "job-30-13",
      "type": "verse",
      "number": 13,
      "text": "They break up my path;"
    },
    {
      "block_id": "job-30-14",
      "type": "verse",
      "number": 14,
      "text": "As through a wide breach they come;"
    },
    {
      "block_id": "job-30-15",
      "type": "verse",
      "number": 15,
      "text": "Terrors are turned upon me;"
    },
    {
      "block_id": "job-30-16",
      "type": "verse",
      "number": 16,
      "text": "“And now my soul is poured out within me;"
    },
    {
      "block_id": "job-30-17",
      "type": "verse",
      "number": 17,
      "text": "The night racks my bones,"
    },
    {
      "block_id": "job-30-18",
      "type": "verse",
      "number": 18,
      "text": "With violence he seizes my garment;"
    },
    {
      "block_id": "job-30-19",
      "type": "verse",
      "number": 19,
      "text": "He has cast me into the mire,"
    },
    {
      "block_id": "job-30-20",
      "type": "verse",
      "number": 20,
      "text": "I cry to you, and you do not answer me;"
    },
    {
      "block_id": "job-30-21",
      "type": "verse",
      "number": 21,
      "text": "You have turned cruel to me;"
    },
    {
      "block_id": "job-30-22",
      "type": "verse",
      "number": 22,
      "text": "You lift me up on the wind, you make me ride on it,"
    },
    {
      "block_id": "job-30-23",
      "type": "verse",
      "number": 23,
      "text": "I know that you will bring me to death,"
    },
    {
      "block_id": "job-30-24",
      "type": "verse",
      "number": 24,
      "text": "“Surely one does not turn against the needy,"
    },
    {
      "block_id": "job-30-25",
      "type": "verse",
      "number": 25,
      "text": "Did I not weep for those whose day was hard?"
    },
    {
      "block_id": "job-30-26",
      "type": "verse",
      "number": 26,
      "text": "But when I looked for good, evil came,"
    },
    {
      "block_id": "job-30-27",
      "type": "verse",
      "number": 27,
      "text": "My inward parts are in turmoil and are never still;"
    },
    {
      "block_id": "job-30-28",
      "type": "verse",
      "number": 28,
      "text": "I go about in sunless gloom;"
    },
    {
      "block_id": "job-30-29",
      "type": "verse",
      "number": 29,
      "text": "I am a brother of jackals"
    },
    {
      "block_id": "job-30-30",
      "type": "verse",
      "number": 30,
      "text": "My skin turns black and falls from me,"
    },
    {
      "block_id": "job-30-31",
      "type": "verse",
      "number": 31,
      "text": "My lyre is turned to mourning"
    }
  ]
}