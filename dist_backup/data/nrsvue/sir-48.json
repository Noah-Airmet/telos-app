{
  "document_id": "sir-48",
  "title": "Sirach 48",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-48-1",
      "type": "verse",
      "number": 1,
      "text": "Then Elijah arose, a prophet like fire,"
    },
    {
      "block_id": "sir-48-2",
      "type": "verse",
      "number": 2,
      "text": "He brought a famine upon them,"
    },
    {
      "block_id": "sir-48-3",
      "type": "verse",
      "number": 3,
      "text": "By the word of the Lord he shut up the heavens"
    },
    {
      "block_id": "sir-48-4",
      "type": "verse",
      "number": 4,
      "text": "How glorious you were, Elijah, in your wondrous deeds!"
    },
    {
      "block_id": "sir-48-5",
      "type": "verse",
      "number": 5,
      "text": "You who raised a corpse from death"
    },
    {
      "block_id": "sir-48-6",
      "type": "verse",
      "number": 6,
      "text": "who sent kings down to destruction"
    },
    {
      "block_id": "sir-48-7",
      "type": "verse",
      "number": 7,
      "text": "who heard rebuke at Sinai"
    },
    {
      "block_id": "sir-48-8",
      "type": "verse",
      "number": 8,
      "text": "who anointed kings to inflict retribution"
    },
    {
      "block_id": "sir-48-9",
      "type": "verse",
      "number": 9,
      "text": "who were taken up by a whirlwind of fire"
    },
    {
      "block_id": "sir-48-10",
      "type": "verse",
      "number": 10,
      "text": "who were prepared at the appointed time"
    },
    {
      "block_id": "sir-48-11",
      "type": "verse",
      "number": 11,
      "text": "Happy are those who saw you"
    },
    {
      "block_id": "sir-48-12",
      "type": "verse",
      "number": 12,
      "text": "When Elijah was enveloped in the whirlwind,"
    },
    {
      "block_id": "sir-48-13",
      "type": "verse",
      "number": 13,
      "text": "Nothing was too hard for him,"
    },
    {
      "block_id": "sir-48-14",
      "type": "verse",
      "number": 14,
      "text": "In his life he did wonders,"
    },
    {
      "block_id": "sir-48-15",
      "type": "verse",
      "number": 15,
      "text": "Despite all this the people did not repent,"
    },
    {
      "block_id": "sir-48-16",
      "type": "verse",
      "number": 16,
      "text": "Some of them did what was right,"
    },
    {
      "block_id": "sir-48-17",
      "type": "verse",
      "number": 17,
      "text": "Hezekiah fortified his city"
    },
    {
      "block_id": "sir-48-18",
      "type": "verse",
      "number": 18,
      "text": "In his days Sennacherib invaded the country;"
    },
    {
      "block_id": "sir-48-19",
      "type": "verse",
      "number": 19,
      "text": "Then their hearts and hands were shaken,"
    },
    {
      "block_id": "sir-48-20",
      "type": "verse",
      "number": 20,
      "text": "But they called upon the Lord who is merciful,"
    },
    {
      "block_id": "sir-48-21",
      "type": "verse",
      "number": 21,
      "text": "The Lord struck down the camp of the Assyrians,"
    },
    {
      "block_id": "sir-48-22",
      "type": "verse",
      "number": 22,
      "text": "For Hezekiah did what was pleasing to the Lord,"
    },
    {
      "block_id": "sir-48-23",
      "type": "verse",
      "number": 23,
      "text": "In Isaiah’s days the sun went backward,"
    },
    {
      "block_id": "sir-48-24",
      "type": "verse",
      "number": 24,
      "text": "By his dauntless spirit he saw the future"
    },
    {
      "block_id": "sir-48-25",
      "type": "verse",
      "number": 25,
      "text": "He revealed what was to occur to the end of time"
    }
  ]
}