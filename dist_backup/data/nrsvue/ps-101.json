{
  "document_id": "ps-101",
  "title": "Psalms 101",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-101-1",
      "type": "verse",
      "number": 1,
      "text": "I will sing of loyalty and of justice;"
    },
    {
      "block_id": "ps-101-2",
      "type": "verse",
      "number": 2,
      "text": "I will study the way that is blameless."
    },
    {
      "block_id": "ps-101-3",
      "type": "verse",
      "number": 3,
      "text": "I will not set before my eyes"
    },
    {
      "block_id": "ps-101-4",
      "type": "verse",
      "number": 4,
      "text": "Perverseness of heart shall be far from me;"
    },
    {
      "block_id": "ps-101-5",
      "type": "verse",
      "number": 5,
      "text": "One who secretly slanders a neighbor"
    },
    {
      "block_id": "ps-101-6",
      "type": "verse",
      "number": 6,
      "text": "I will look with favor on the faithful in the land,"
    },
    {
      "block_id": "ps-101-7",
      "type": "verse",
      "number": 7,
      "text": "No one who practices deceit"
    },
    {
      "block_id": "ps-101-8",
      "type": "verse",
      "number": 8,
      "text": "Morning by morning I will destroy"
    }
  ]
}