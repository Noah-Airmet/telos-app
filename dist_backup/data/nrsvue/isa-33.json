{
  "document_id": "isa-33",
  "title": "Isaiah 33",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-33-1",
      "type": "verse",
      "number": 1,
      "text": "Woe to the destroyer,"
    },
    {
      "block_id": "isa-33-2",
      "type": "verse",
      "number": 2,
      "text": "O Lord, be gracious to us; we wait for you."
    },
    {
      "block_id": "isa-33-3",
      "type": "verse",
      "number": 3,
      "text": "At the sound of tumult, peoples fled;"
    },
    {
      "block_id": "isa-33-4",
      "type": "verse",
      "number": 4,
      "text": "Spoil was gathered as the caterpillar gathers;"
    },
    {
      "block_id": "isa-33-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord is exalted; he dwells on high;"
    },
    {
      "block_id": "isa-33-6",
      "type": "verse",
      "number": 6,
      "text": "he will be the stability of your times,"
    },
    {
      "block_id": "isa-33-7",
      "type": "verse",
      "number": 7,
      "text": "Listen! The people of Ariel cry out in the streets;"
    },
    {
      "block_id": "isa-33-8",
      "type": "verse",
      "number": 8,
      "text": "The highways are deserted;"
    },
    {
      "block_id": "isa-33-9",
      "type": "verse",
      "number": 9,
      "text": "The land mourns and languishes;"
    },
    {
      "block_id": "isa-33-10",
      "type": "verse",
      "number": 10,
      "text": "“Now I will arise,” says the Lord,"
    },
    {
      "block_id": "isa-33-11",
      "type": "verse",
      "number": 11,
      "text": "You conceive chaff; you bring forth stubble;"
    },
    {
      "block_id": "isa-33-12",
      "type": "verse",
      "number": 12,
      "text": "And the peoples will be as if burned to lime,"
    },
    {
      "block_id": "isa-33-13",
      "type": "verse",
      "number": 13,
      "text": "Hear, you who are far away, what I have done,"
    },
    {
      "block_id": "isa-33-14",
      "type": "verse",
      "number": 14,
      "text": "The sinners in Zion are afraid;"
    },
    {
      "block_id": "isa-33-15",
      "type": "verse",
      "number": 15,
      "text": "Those who walk righteously and speak uprightly,"
    },
    {
      "block_id": "isa-33-16",
      "type": "verse",
      "number": 16,
      "text": "they will live on the heights;"
    },
    {
      "block_id": "isa-33-17",
      "type": "verse",
      "number": 17,
      "text": "Your eyes will see the king in his beauty;"
    },
    {
      "block_id": "isa-33-18",
      "type": "verse",
      "number": 18,
      "text": "Your mind will muse on the terror:"
    },
    {
      "block_id": "isa-33-19",
      "type": "verse",
      "number": 19,
      "text": "No longer will you see the insolent people,"
    },
    {
      "block_id": "isa-33-20",
      "type": "verse",
      "number": 20,
      "text": "Look on Zion, the city of our appointed festivals!"
    },
    {
      "block_id": "isa-33-21",
      "type": "verse",
      "number": 21,
      "text": "But there the Lord in majesty will be for us"
    },
    {
      "block_id": "isa-33-22",
      "type": "verse",
      "number": 22,
      "text": "For the Lord is our judge; the Lord is our ruler;"
    },
    {
      "block_id": "isa-33-23",
      "type": "verse",
      "number": 23,
      "text": "Your rigging hangs loose;"
    },
    {
      "block_id": "isa-33-24",
      "type": "verse",
      "number": 24,
      "text": "And no inhabitant will say, “I am sick”;"
    }
  ]
}