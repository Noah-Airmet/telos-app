{
  "document_id": "ps-147",
  "title": "Psalms 147",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-147-1",
      "type": "verse",
      "number": 1,
      "text": "Praise the Lord!"
    },
    {
      "block_id": "ps-147-2",
      "type": "verse",
      "number": 2,
      "text": "The Lord builds up Jerusalem;"
    },
    {
      "block_id": "ps-147-3",
      "type": "verse",
      "number": 3,
      "text": "He heals the brokenhearted"
    },
    {
      "block_id": "ps-147-4",
      "type": "verse",
      "number": 4,
      "text": "He determines the number of the stars;"
    },
    {
      "block_id": "ps-147-5",
      "type": "verse",
      "number": 5,
      "text": "Great is our Lord and abundant in power;"
    },
    {
      "block_id": "ps-147-6",
      "type": "verse",
      "number": 6,
      "text": "The Lord lifts up the downtrodden;"
    },
    {
      "block_id": "ps-147-7",
      "type": "verse",
      "number": 7,
      "text": "Sing to the Lord with thanksgiving;"
    },
    {
      "block_id": "ps-147-8",
      "type": "verse",
      "number": 8,
      "text": "He covers the heavens with clouds,"
    },
    {
      "block_id": "ps-147-9",
      "type": "verse",
      "number": 9,
      "text": "He gives to the animals their food"
    },
    {
      "block_id": "ps-147-10",
      "type": "verse",
      "number": 10,
      "text": "His delight is not in the strength of the horse"
    },
    {
      "block_id": "ps-147-11",
      "type": "verse",
      "number": 11,
      "text": "but the Lord takes pleasure in those who fear him,"
    },
    {
      "block_id": "ps-147-12",
      "type": "verse",
      "number": 12,
      "text": "Extol the Lord, O Jerusalem!"
    },
    {
      "block_id": "ps-147-13",
      "type": "verse",
      "number": 13,
      "text": "For he strengthens the bars of your gates;"
    },
    {
      "block_id": "ps-147-14",
      "type": "verse",
      "number": 14,
      "text": "He grants peace within your borders;"
    },
    {
      "block_id": "ps-147-15",
      "type": "verse",
      "number": 15,
      "text": "He sends out his command to the earth;"
    },
    {
      "block_id": "ps-147-16",
      "type": "verse",
      "number": 16,
      "text": "He gives snow like wool;"
    },
    {
      "block_id": "ps-147-17",
      "type": "verse",
      "number": 17,
      "text": "He hurls down hail like crumbs—"
    },
    {
      "block_id": "ps-147-18",
      "type": "verse",
      "number": 18,
      "text": "He sends out his word and melts them;"
    },
    {
      "block_id": "ps-147-19",
      "type": "verse",
      "number": 19,
      "text": "He declares his word to Jacob,"
    },
    {
      "block_id": "ps-147-20",
      "type": "verse",
      "number": 20,
      "text": "He has not dealt thus with any other nation;"
    }
  ]
}