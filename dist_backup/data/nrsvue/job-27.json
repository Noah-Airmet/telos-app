{
  "document_id": "job-27",
  "title": "Job 27",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-27-heading-job-maintains-his-in",
      "type": "heading",
      "text": "Job Maintains His Integrity"
    },
    {
      "block_id": "job-27-1",
      "type": "verse",
      "number": 1,
      "text": "Job again took up his discourse and said:"
    },
    {
      "block_id": "job-27-2",
      "type": "verse",
      "number": 2,
      "text": "“As God lives, who has taken away my right,"
    },
    {
      "block_id": "job-27-3",
      "type": "verse",
      "number": 3,
      "text": "as long as my breath is in me"
    },
    {
      "block_id": "job-27-4",
      "type": "verse",
      "number": 4,
      "text": "my lips will not speak falsehood,"
    },
    {
      "block_id": "job-27-5",
      "type": "verse",
      "number": 5,
      "text": "Far be it from me to say that you are right;"
    },
    {
      "block_id": "job-27-6",
      "type": "verse",
      "number": 6,
      "text": "I hold fast my righteousness and will not let it go;"
    },
    {
      "block_id": "job-27-7",
      "type": "verse",
      "number": 7,
      "text": "“May my enemy be like the wicked,"
    },
    {
      "block_id": "job-27-8",
      "type": "verse",
      "number": 8,
      "text": "For what is the hope of the godless when God cuts them off,"
    },
    {
      "block_id": "job-27-9",
      "type": "verse",
      "number": 9,
      "text": "Will God hear their cry"
    },
    {
      "block_id": "job-27-10",
      "type": "verse",
      "number": 10,
      "text": "Will they take delight in the Almighty?"
    },
    {
      "block_id": "job-27-11",
      "type": "verse",
      "number": 11,
      "text": "I will teach you concerning the hand of God;"
    },
    {
      "block_id": "job-27-12",
      "type": "verse",
      "number": 12,
      "text": "All of you have seen it yourselves;"
    },
    {
      "block_id": "job-27-13",
      "type": "verse",
      "number": 13,
      "text": "“This is the portion of the wicked with God"
    },
    {
      "block_id": "job-27-14",
      "type": "verse",
      "number": 14,
      "text": "If their children are multiplied, it is for the sword,"
    },
    {
      "block_id": "job-27-15",
      "type": "verse",
      "number": 15,
      "text": "Those who survive them the pestilence buries,"
    },
    {
      "block_id": "job-27-16",
      "type": "verse",
      "number": 16,
      "text": "Though they heap up silver like dust"
    },
    {
      "block_id": "job-27-17",
      "type": "verse",
      "number": 17,
      "text": "they may pile it up, but the just will wear it,"
    },
    {
      "block_id": "job-27-18",
      "type": "verse",
      "number": 18,
      "text": "They build their houses like nests,"
    },
    {
      "block_id": "job-27-19",
      "type": "verse",
      "number": 19,
      "text": "They go to bed with wealth but will do so no more;"
    },
    {
      "block_id": "job-27-20",
      "type": "verse",
      "number": 20,
      "text": "Terrors overtake them like a flood;"
    },
    {
      "block_id": "job-27-21",
      "type": "verse",
      "number": 21,
      "text": "The east wind lifts them up, and they are gone;"
    },
    {
      "block_id": "job-27-22",
      "type": "verse",
      "number": 22,
      "text": "It hurls at them without pity;"
    },
    {
      "block_id": "job-27-23",
      "type": "verse",
      "number": 23,
      "text": "It claps its hands at them"
    }
  ]
}