{
  "document_id": "amos-9",
  "title": "Amos 9",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "amos-9-heading-the-destruction-of-i",
      "type": "heading",
      "text": "The Destruction of Israel"
    },
    {
      "block_id": "amos-9-1",
      "type": "verse",
      "number": 1,
      "text": "I saw the Lord standing beside the altar, and he said:"
    },
    {
      "block_id": "amos-9-2",
      "type": "verse",
      "number": 2,
      "text": "Though they dig into Sheol,"
    },
    {
      "block_id": "amos-9-3",
      "type": "verse",
      "number": 3,
      "text": "Though they hide themselves on the top of Carmel,"
    },
    {
      "block_id": "amos-9-4",
      "type": "verse",
      "number": 4,
      "text": "And though they go into captivity in front of their enemies,"
    },
    {
      "block_id": "amos-9-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord, God of hosts,"
    },
    {
      "block_id": "amos-9-6",
      "type": "verse",
      "number": 6,
      "text": "who builds his upper chambers in the heavens"
    },
    {
      "block_id": "amos-9-7",
      "type": "verse",
      "number": 7,
      "text": "Are you not like the Cushites to me,"
    },
    {
      "block_id": "amos-9-8",
      "type": "verse",
      "number": 8,
      "text": "The eyes of the Lord God are upon the sinful kingdom,"
    },
    {
      "block_id": "amos-9-9",
      "type": "verse",
      "number": 9,
      "text": "For I will command"
    },
    {
      "block_id": "amos-9-10",
      "type": "verse",
      "number": 10,
      "text": "All the sinners of my people shall die by the sword,"
    },
    {
      "block_id": "amos-9-11",
      "type": "verse",
      "number": 11,
      "text": "On that day I will raise up"
    },
    {
      "block_id": "amos-9-12",
      "type": "verse",
      "number": 12,
      "text": "in order that they may possess the remnant of Edom"
    },
    {
      "block_id": "amos-9-13",
      "type": "verse",
      "number": 13,
      "text": "The time is surely coming, says the Lord,"
    },
    {
      "block_id": "amos-9-14",
      "type": "verse",
      "number": 14,
      "text": "I will restore the fortunes of my people Israel,"
    },
    {
      "block_id": "amos-9-15",
      "type": "verse",
      "number": 15,
      "text": "I will plant them upon their land,"
    }
  ]
}