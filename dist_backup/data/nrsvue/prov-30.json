{
  "document_id": "prov-30",
  "title": "Proverbs 30",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-30-heading-sayings-of-agur",
      "type": "heading",
      "text": "Sayings of Agur"
    },
    {
      "block_id": "prov-30-1",
      "type": "verse",
      "number": 1,
      "text": "The words of Agur son of Jakeh. An oracle."
    },
    {
      "block_id": "prov-30-2",
      "type": "verse",
      "number": 2,
      "text": "Surely I am too stupid to be human;"
    },
    {
      "block_id": "prov-30-3",
      "type": "verse",
      "number": 3,
      "text": "I have not learned wisdom,"
    },
    {
      "block_id": "prov-30-4",
      "type": "verse",
      "number": 4,
      "text": "Who has ascended to heaven and come down?"
    },
    {
      "block_id": "prov-30-5",
      "type": "verse",
      "number": 5,
      "text": "Every word of God proves true;"
    },
    {
      "block_id": "prov-30-6",
      "type": "verse",
      "number": 6,
      "text": "Do not add to his words,"
    },
    {
      "block_id": "prov-30-7",
      "type": "verse",
      "number": 7,
      "text": "Two things I ask of you;"
    },
    {
      "block_id": "prov-30-8",
      "type": "verse",
      "number": 8,
      "text": "Remove far from me falsehood and lying;"
    },
    {
      "block_id": "prov-30-9",
      "type": "verse",
      "number": 9,
      "text": "lest I be full and deny you"
    },
    {
      "block_id": "prov-30-10",
      "type": "verse",
      "number": 10,
      "text": "Do not slander a servant to a master,"
    },
    {
      "block_id": "prov-30-11",
      "type": "verse",
      "number": 11,
      "text": "There are those who curse their fathers"
    },
    {
      "block_id": "prov-30-12",
      "type": "verse",
      "number": 12,
      "text": "There are those who are pure in their own eyes,"
    },
    {
      "block_id": "prov-30-13",
      "type": "verse",
      "number": 13,
      "text": "There are those—how lofty are their eyes,"
    },
    {
      "block_id": "prov-30-14",
      "type": "verse",
      "number": 14,
      "text": "there are those whose teeth are swords,"
    },
    {
      "block_id": "prov-30-15",
      "type": "verse",
      "number": 15,
      "text": "The leech has two daughters;"
    },
    {
      "block_id": "prov-30-16",
      "type": "verse",
      "number": 16,
      "text": "Sheol, the barren womb,"
    },
    {
      "block_id": "prov-30-17",
      "type": "verse",
      "number": 17,
      "text": "The eye that mocks a father"
    },
    {
      "block_id": "prov-30-18",
      "type": "verse",
      "number": 18,
      "text": "Three things are too wonderful for me;"
    },
    {
      "block_id": "prov-30-19",
      "type": "verse",
      "number": 19,
      "text": "the way of an eagle in the sky,"
    },
    {
      "block_id": "prov-30-20",
      "type": "verse",
      "number": 20,
      "text": "This is the way of an adulteress:"
    },
    {
      "block_id": "prov-30-21",
      "type": "verse",
      "number": 21,
      "text": "Under three things the earth trembles;"
    },
    {
      "block_id": "prov-30-22",
      "type": "verse",
      "number": 22,
      "text": "a slave when he becomes king"
    },
    {
      "block_id": "prov-30-23",
      "type": "verse",
      "number": 23,
      "text": "a contemptible woman when she gets a husband"
    },
    {
      "block_id": "prov-30-24",
      "type": "verse",
      "number": 24,
      "text": "Four things on earth are small,"
    },
    {
      "block_id": "prov-30-25",
      "type": "verse",
      "number": 25,
      "text": "the ants are a people without strength,"
    },
    {
      "block_id": "prov-30-26",
      "type": "verse",
      "number": 26,
      "text": "the badgers are a people without power,"
    },
    {
      "block_id": "prov-30-27",
      "type": "verse",
      "number": 27,
      "text": "the locusts have no king,"
    },
    {
      "block_id": "prov-30-28",
      "type": "verse",
      "number": 28,
      "text": "the lizard can be grasped in the hand,"
    },
    {
      "block_id": "prov-30-29",
      "type": "verse",
      "number": 29,
      "text": "Three things are stately in their stride;"
    },
    {
      "block_id": "prov-30-30",
      "type": "verse",
      "number": 30,
      "text": "the lion, which is mightiest among wild animals"
    },
    {
      "block_id": "prov-30-31",
      "type": "verse",
      "number": 31,
      "text": "the strutting rooster, the he-goat,"
    },
    {
      "block_id": "prov-30-32",
      "type": "verse",
      "number": 32,
      "text": "If you have been foolish, exalting yourself,"
    },
    {
      "block_id": "prov-30-33",
      "type": "verse",
      "number": 33,
      "text": "For as pressing milk produces curds"
    }
  ]
}