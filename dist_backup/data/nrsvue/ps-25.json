{
  "document_id": "ps-25",
  "title": "Psalms 25",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-25-1",
      "type": "verse",
      "number": 1,
      "text": "To you, O Lord, I lift up my soul."
    },
    {
      "block_id": "ps-25-2",
      "type": "verse",
      "number": 2,
      "text": "O my God, in you I trust;"
    },
    {
      "block_id": "ps-25-3",
      "type": "verse",
      "number": 3,
      "text": "Do not let those who wait for you be put to shame;"
    },
    {
      "block_id": "ps-25-4",
      "type": "verse",
      "number": 4,
      "text": "Make me to know your ways, O Lord;"
    },
    {
      "block_id": "ps-25-5",
      "type": "verse",
      "number": 5,
      "text": "Lead me in your truth and teach me,"
    },
    {
      "block_id": "ps-25-6",
      "type": "verse",
      "number": 6,
      "text": "Be mindful of your mercy, O Lord, and of your steadfast love,"
    },
    {
      "block_id": "ps-25-7",
      "type": "verse",
      "number": 7,
      "text": "Do not remember the sins of my youth or my transgressions;"
    },
    {
      "block_id": "ps-25-8",
      "type": "verse",
      "number": 8,
      "text": "Good and upright is the Lord;"
    },
    {
      "block_id": "ps-25-9",
      "type": "verse",
      "number": 9,
      "text": "He leads the humble in what is right"
    },
    {
      "block_id": "ps-25-10",
      "type": "verse",
      "number": 10,
      "text": "All the paths of the Lord are steadfast love and faithfulness,"
    },
    {
      "block_id": "ps-25-11",
      "type": "verse",
      "number": 11,
      "text": "For your name’s sake, O Lord,"
    },
    {
      "block_id": "ps-25-12",
      "type": "verse",
      "number": 12,
      "text": "Who are they who fear the Lord?"
    },
    {
      "block_id": "ps-25-13",
      "type": "verse",
      "number": 13,
      "text": "They will abide in prosperity,"
    },
    {
      "block_id": "ps-25-14",
      "type": "verse",
      "number": 14,
      "text": "The friendship of the Lord is for those who fear him,"
    },
    {
      "block_id": "ps-25-15",
      "type": "verse",
      "number": 15,
      "text": "My eyes are ever toward the Lord,"
    },
    {
      "block_id": "ps-25-16",
      "type": "verse",
      "number": 16,
      "text": "Turn to me and be gracious to me,"
    },
    {
      "block_id": "ps-25-17",
      "type": "verse",
      "number": 17,
      "text": "Relieve the troubles of my heart,"
    },
    {
      "block_id": "ps-25-18",
      "type": "verse",
      "number": 18,
      "text": "Consider my affliction and my trouble,"
    },
    {
      "block_id": "ps-25-19",
      "type": "verse",
      "number": 19,
      "text": "Consider how many are my foes"
    },
    {
      "block_id": "ps-25-20",
      "type": "verse",
      "number": 20,
      "text": "O guard my life and deliver me;"
    },
    {
      "block_id": "ps-25-21",
      "type": "verse",
      "number": 21,
      "text": "May integrity and uprightness preserve me,"
    },
    {
      "block_id": "ps-25-22",
      "type": "verse",
      "number": 22,
      "text": "Redeem Israel, O God,"
    }
  ]
}