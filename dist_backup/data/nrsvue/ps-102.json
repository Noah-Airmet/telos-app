{
  "document_id": "ps-102",
  "title": "Psalms 102",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-102-1",
      "type": "verse",
      "number": 1,
      "text": "Hear my prayer, O Lord;"
    },
    {
      "block_id": "ps-102-2",
      "type": "verse",
      "number": 2,
      "text": "Do not hide your face from me"
    },
    {
      "block_id": "ps-102-3",
      "type": "verse",
      "number": 3,
      "text": "For my days pass away like smoke,"
    },
    {
      "block_id": "ps-102-4",
      "type": "verse",
      "number": 4,
      "text": "My heart is stricken and withered like grass;"
    },
    {
      "block_id": "ps-102-5",
      "type": "verse",
      "number": 5,
      "text": "Because of my loud groaning,"
    },
    {
      "block_id": "ps-102-6",
      "type": "verse",
      "number": 6,
      "text": "I am like a desert owl of the wilderness,"
    },
    {
      "block_id": "ps-102-7",
      "type": "verse",
      "number": 7,
      "text": "I lie awake;"
    },
    {
      "block_id": "ps-102-8",
      "type": "verse",
      "number": 8,
      "text": "All day long my enemies taunt me;"
    },
    {
      "block_id": "ps-102-9",
      "type": "verse",
      "number": 9,
      "text": "Indeed, I eat ashes like bread"
    },
    {
      "block_id": "ps-102-10",
      "type": "verse",
      "number": 10,
      "text": "because of your indignation and anger,"
    },
    {
      "block_id": "ps-102-11",
      "type": "verse",
      "number": 11,
      "text": "My days are like a lengthening shadow;"
    },
    {
      "block_id": "ps-102-12",
      "type": "verse",
      "number": 12,
      "text": "But you, O Lord, are enthroned forever;"
    },
    {
      "block_id": "ps-102-13",
      "type": "verse",
      "number": 13,
      "text": "You will rise up and have compassion on Zion,"
    },
    {
      "block_id": "ps-102-14",
      "type": "verse",
      "number": 14,
      "text": "For your servants hold its stones dear"
    },
    {
      "block_id": "ps-102-15",
      "type": "verse",
      "number": 15,
      "text": "The nations will fear the name of the Lord"
    },
    {
      "block_id": "ps-102-16",
      "type": "verse",
      "number": 16,
      "text": "For the Lord will build up Zion;"
    },
    {
      "block_id": "ps-102-17",
      "type": "verse",
      "number": 17,
      "text": "He will regard the prayer of the destitute"
    },
    {
      "block_id": "ps-102-18",
      "type": "verse",
      "number": 18,
      "text": "Let this be recorded for a generation to come,"
    },
    {
      "block_id": "ps-102-19",
      "type": "verse",
      "number": 19,
      "text": "that he looked down from his holy height,"
    },
    {
      "block_id": "ps-102-20",
      "type": "verse",
      "number": 20,
      "text": "to hear the groans of the prisoners,"
    },
    {
      "block_id": "ps-102-21",
      "type": "verse",
      "number": 21,
      "text": "so that the name of the Lord may be declared in Zion"
    },
    {
      "block_id": "ps-102-22",
      "type": "verse",
      "number": 22,
      "text": "when peoples gather together,"
    },
    {
      "block_id": "ps-102-23",
      "type": "verse",
      "number": 23,
      "text": "He has broken my strength in midcourse;"
    },
    {
      "block_id": "ps-102-24",
      "type": "verse",
      "number": 24,
      "text": "“O my God,” I say, “do not take me away"
    },
    {
      "block_id": "ps-102-25",
      "type": "verse",
      "number": 25,
      "text": "Long ago you laid the foundation of the earth,"
    },
    {
      "block_id": "ps-102-26",
      "type": "verse",
      "number": 26,
      "text": "They will perish, but you endure;"
    },
    {
      "block_id": "ps-102-27",
      "type": "verse",
      "number": 27,
      "text": "but you are the same, and your years have no end."
    },
    {
      "block_id": "ps-102-28",
      "type": "verse",
      "number": 28,
      "text": "The children of your servants shall live secure;"
    }
  ]
}