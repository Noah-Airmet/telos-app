{
  "document_id": "prov-22",
  "title": "Proverbs 22",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-22-1",
      "type": "verse",
      "number": 1,
      "text": "A good name is to be chosen rather than great riches,"
    },
    {
      "block_id": "prov-22-2",
      "type": "verse",
      "number": 2,
      "text": "The rich and the poor have this in common:"
    },
    {
      "block_id": "prov-22-3",
      "type": "verse",
      "number": 3,
      "text": "The clever see danger and hide,"
    },
    {
      "block_id": "prov-22-4",
      "type": "verse",
      "number": 4,
      "text": "The reward for humility and fear of the Lord"
    },
    {
      "block_id": "prov-22-5",
      "type": "verse",
      "number": 5,
      "text": "Thorns and snares are in the way of the perverse;"
    },
    {
      "block_id": "prov-22-6",
      "type": "verse",
      "number": 6,
      "text": "Train children in the right way,"
    },
    {
      "block_id": "prov-22-7",
      "type": "verse",
      "number": 7,
      "text": "The rich rule over the poor,"
    },
    {
      "block_id": "prov-22-8",
      "type": "verse",
      "number": 8,
      "text": "Whoever sows injustice will reap calamity,"
    },
    {
      "block_id": "prov-22-9",
      "type": "verse",
      "number": 9,
      "text": "Those who are generous are blessed,"
    },
    {
      "block_id": "prov-22-10",
      "type": "verse",
      "number": 10,
      "text": "Drive out a scoffer, and strife goes out;"
    },
    {
      "block_id": "prov-22-11",
      "type": "verse",
      "number": 11,
      "text": "Those who love a pure heart and are gracious in speech"
    },
    {
      "block_id": "prov-22-12",
      "type": "verse",
      "number": 12,
      "text": "The eyes of the Lord keep watch over knowledge,"
    },
    {
      "block_id": "prov-22-13",
      "type": "verse",
      "number": 13,
      "text": "The lazy person says, “There is a lion outside!"
    },
    {
      "block_id": "prov-22-14",
      "type": "verse",
      "number": 14,
      "text": "The mouth of a loose woman is a deep pit;"
    },
    {
      "block_id": "prov-22-15",
      "type": "verse",
      "number": 15,
      "text": "Folly is bound up in the heart of a child,"
    },
    {
      "block_id": "prov-22-16",
      "type": "verse",
      "number": 16,
      "text": "Oppressing the poor in order to enrich oneself,"
    },
    {
      "block_id": "prov-22-17",
      "type": "verse",
      "number": 17,
      "text": "The words of the wise:"
    },
    {
      "block_id": "prov-22-18",
      "type": "verse",
      "number": 18,
      "text": "for it will be pleasant if you keep them within you,"
    },
    {
      "block_id": "prov-22-19",
      "type": "verse",
      "number": 19,
      "text": "So that your trust may be in the Lord,"
    },
    {
      "block_id": "prov-22-20",
      "type": "verse",
      "number": 20,
      "text": "Have I not written for you thirty sayings"
    },
    {
      "block_id": "prov-22-21",
      "type": "verse",
      "number": 21,
      "text": "to show you what is right and true,"
    },
    {
      "block_id": "prov-22-22",
      "type": "verse",
      "number": 22,
      "text": "Do not rob the poor because they are poor"
    },
    {
      "block_id": "prov-22-23",
      "type": "verse",
      "number": 23,
      "text": "for the Lord pleads their cause"
    },
    {
      "block_id": "prov-22-24",
      "type": "verse",
      "number": 24,
      "text": "Make no friends with those given to anger,"
    },
    {
      "block_id": "prov-22-25",
      "type": "verse",
      "number": 25,
      "text": "lest you learn their ways"
    },
    {
      "block_id": "prov-22-26",
      "type": "verse",
      "number": 26,
      "text": "Do not be one of those who give pledges,"
    },
    {
      "block_id": "prov-22-27",
      "type": "verse",
      "number": 27,
      "text": "If you have nothing with which to pay,"
    },
    {
      "block_id": "prov-22-28",
      "type": "verse",
      "number": 28,
      "text": "Do not remove the ancient landmark"
    },
    {
      "block_id": "prov-22-29",
      "type": "verse",
      "number": 29,
      "text": "Do you see those who are skillful in their work?"
    }
  ]
}