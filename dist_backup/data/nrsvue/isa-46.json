{
  "document_id": "isa-46",
  "title": "Isaiah 46",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-46-1",
      "type": "verse",
      "number": 1,
      "text": "Bel bows down; Nebo stoops;"
    },
    {
      "block_id": "isa-46-2",
      "type": "verse",
      "number": 2,
      "text": "They stoop; they bow down together;"
    },
    {
      "block_id": "isa-46-3",
      "type": "verse",
      "number": 3,
      "text": "Listen to me, O house of Jacob,"
    },
    {
      "block_id": "isa-46-4",
      "type": "verse",
      "number": 4,
      "text": "even to your old age I am he;"
    },
    {
      "block_id": "isa-46-5",
      "type": "verse",
      "number": 5,
      "text": "To whom will you liken me and make me equal"
    },
    {
      "block_id": "isa-46-6",
      "type": "verse",
      "number": 6,
      "text": "Those who lavish gold from the purse"
    },
    {
      "block_id": "isa-46-7",
      "type": "verse",
      "number": 7,
      "text": "They lift it to their shoulders; they carry it;"
    },
    {
      "block_id": "isa-46-8",
      "type": "verse",
      "number": 8,
      "text": "Remember this and consider;"
    },
    {
      "block_id": "isa-46-9",
      "type": "verse",
      "number": 9,
      "text": "remember the former things of old,"
    },
    {
      "block_id": "isa-46-10",
      "type": "verse",
      "number": 10,
      "text": "declaring the outcome from the beginning"
    },
    {
      "block_id": "isa-46-11",
      "type": "verse",
      "number": 11,
      "text": "calling a bird of prey from the east,"
    },
    {
      "block_id": "isa-46-12",
      "type": "verse",
      "number": 12,
      "text": "Listen to me, you stubborn of heart,"
    },
    {
      "block_id": "isa-46-13",
      "type": "verse",
      "number": 13,
      "text": "I bring near my deliverance; it is not far off,"
    }
  ]
}