{
  "document_id": "ps-45",
  "title": "Psalms 45",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-45-1",
      "type": "verse",
      "number": 1,
      "text": "My heart overflows with a goodly theme;"
    },
    {
      "block_id": "ps-45-2",
      "type": "verse",
      "number": 2,
      "text": "You are the most handsome of men;"
    },
    {
      "block_id": "ps-45-3",
      "type": "verse",
      "number": 3,
      "text": "Gird your sword on your thigh, O mighty one,"
    },
    {
      "block_id": "ps-45-4",
      "type": "verse",
      "number": 4,
      "text": "In your majesty ride on victoriously"
    },
    {
      "block_id": "ps-45-5",
      "type": "verse",
      "number": 5,
      "text": "Your arrows are sharp"
    },
    {
      "block_id": "ps-45-6",
      "type": "verse",
      "number": 6,
      "text": "Your throne, O God, endures forever and ever."
    },
    {
      "block_id": "ps-45-7",
      "type": "verse",
      "number": 7,
      "text": "you love righteousness and hate wickedness."
    },
    {
      "block_id": "ps-45-8",
      "type": "verse",
      "number": 8,
      "text": "your robes are all fragrant with myrrh and aloes and cassia."
    },
    {
      "block_id": "ps-45-9",
      "type": "verse",
      "number": 9,
      "text": "daughters of kings are among your ladies of honor;"
    },
    {
      "block_id": "ps-45-10",
      "type": "verse",
      "number": 10,
      "text": "Hear, O daughter, consider and incline your ear;"
    },
    {
      "block_id": "ps-45-11",
      "type": "verse",
      "number": 11,
      "text": "and the king will desire your beauty."
    },
    {
      "block_id": "ps-45-12",
      "type": "verse",
      "number": 12,
      "text": "Daughter Tyre will seek your favor with gifts,"
    },
    {
      "block_id": "ps-45-13",
      "type": "verse",
      "number": 13,
      "text": "with all kinds of wealth."
    },
    {
      "block_id": "ps-45-14",
      "type": "verse",
      "number": 14,
      "text": "in many-colored robes she is led to the king;"
    },
    {
      "block_id": "ps-45-15",
      "type": "verse",
      "number": 15,
      "text": "With joy and gladness they are led along"
    },
    {
      "block_id": "ps-45-16",
      "type": "verse",
      "number": 16,
      "text": "In the place of ancestors you, O king, shall have sons;"
    },
    {
      "block_id": "ps-45-17",
      "type": "verse",
      "number": 17,
      "text": "I will cause your name to be celebrated in all generations;"
    }
  ]
}