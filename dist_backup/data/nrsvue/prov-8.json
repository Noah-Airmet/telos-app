{
  "document_id": "prov-8",
  "title": "Proverbs 8",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-8-1",
      "type": "verse",
      "number": 1,
      "text": "Does not wisdom call"
    },
    {
      "block_id": "prov-8-2",
      "type": "verse",
      "number": 2,
      "text": "On the heights, beside the way,"
    },
    {
      "block_id": "prov-8-3",
      "type": "verse",
      "number": 3,
      "text": "beside the gates in front of the town,"
    },
    {
      "block_id": "prov-8-4",
      "type": "verse",
      "number": 4,
      "text": "“To you, O people, I call,"
    },
    {
      "block_id": "prov-8-5",
      "type": "verse",
      "number": 5,
      "text": "O simple ones, learn prudence;"
    },
    {
      "block_id": "prov-8-6",
      "type": "verse",
      "number": 6,
      "text": "Hear, for I will speak noble things,"
    },
    {
      "block_id": "prov-8-7",
      "type": "verse",
      "number": 7,
      "text": "for my mouth will utter truth;"
    },
    {
      "block_id": "prov-8-8",
      "type": "verse",
      "number": 8,
      "text": "All the words of my mouth are righteous;"
    },
    {
      "block_id": "prov-8-9",
      "type": "verse",
      "number": 9,
      "text": "They are all straight to one who understands"
    },
    {
      "block_id": "prov-8-10",
      "type": "verse",
      "number": 10,
      "text": "Take my instruction instead of silver"
    },
    {
      "block_id": "prov-8-11",
      "type": "verse",
      "number": 11,
      "text": "for wisdom is better than jewels,"
    },
    {
      "block_id": "prov-8-12",
      "type": "verse",
      "number": 12,
      "text": "I, wisdom, live with prudence,"
    },
    {
      "block_id": "prov-8-13",
      "type": "verse",
      "number": 13,
      "text": "The fear of the Lord is hatred of evil."
    },
    {
      "block_id": "prov-8-14",
      "type": "verse",
      "number": 14,
      "text": "I have good advice and sound wisdom;"
    },
    {
      "block_id": "prov-8-15",
      "type": "verse",
      "number": 15,
      "text": "By me kings reign,"
    },
    {
      "block_id": "prov-8-16",
      "type": "verse",
      "number": 16,
      "text": "by me rulers rule,"
    },
    {
      "block_id": "prov-8-17",
      "type": "verse",
      "number": 17,
      "text": "I love those who love me,"
    },
    {
      "block_id": "prov-8-18",
      "type": "verse",
      "number": 18,
      "text": "Riches and honor are with me,"
    },
    {
      "block_id": "prov-8-19",
      "type": "verse",
      "number": 19,
      "text": "My fruit is better than gold, even fine gold,"
    },
    {
      "block_id": "prov-8-20",
      "type": "verse",
      "number": 20,
      "text": "I walk in the way of righteousness,"
    },
    {
      "block_id": "prov-8-21",
      "type": "verse",
      "number": 21,
      "text": "endowing with wealth those who love me"
    },
    {
      "block_id": "prov-8-22",
      "type": "verse",
      "number": 22,
      "text": "“The Lord created me at the beginning of his work,"
    },
    {
      "block_id": "prov-8-23",
      "type": "verse",
      "number": 23,
      "text": "Ages ago I was set up,"
    },
    {
      "block_id": "prov-8-24",
      "type": "verse",
      "number": 24,
      "text": "When there were no depths I was brought forth,"
    },
    {
      "block_id": "prov-8-25",
      "type": "verse",
      "number": 25,
      "text": "Before the mountains had been shaped,"
    },
    {
      "block_id": "prov-8-26",
      "type": "verse",
      "number": 26,
      "text": "when he had not yet made earth and fields"
    },
    {
      "block_id": "prov-8-27",
      "type": "verse",
      "number": 27,
      "text": "When he established the heavens, I was there;"
    },
    {
      "block_id": "prov-8-28",
      "type": "verse",
      "number": 28,
      "text": "when he made firm the skies above,"
    },
    {
      "block_id": "prov-8-29",
      "type": "verse",
      "number": 29,
      "text": "when he assigned to the sea its limit,"
    },
    {
      "block_id": "prov-8-30",
      "type": "verse",
      "number": 30,
      "text": "then I was beside him, like a master worker,"
    },
    {
      "block_id": "prov-8-31",
      "type": "verse",
      "number": 31,
      "text": "playing in his inhabited world"
    },
    {
      "block_id": "prov-8-32",
      "type": "verse",
      "number": 32,
      "text": "“And now, my children, listen to me:"
    },
    {
      "block_id": "prov-8-33",
      "type": "verse",
      "number": 33,
      "text": "Hear instruction and be wise,"
    },
    {
      "block_id": "prov-8-34",
      "type": "verse",
      "number": 34,
      "text": "Happy is the one who listens to me,"
    },
    {
      "block_id": "prov-8-35",
      "type": "verse",
      "number": 35,
      "text": "For whoever finds me finds life"
    },
    {
      "block_id": "prov-8-36",
      "type": "verse",
      "number": 36,
      "text": "but those who miss me injure themselves;"
    }
  ]
}