{
  "document_id": "ps-107",
  "title": "Psalms 107",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-107-1",
      "type": "verse",
      "number": 1,
      "text": "O give thanks to the Lord, for he is good,"
    },
    {
      "block_id": "ps-107-2",
      "type": "verse",
      "number": 2,
      "text": "Let the redeemed of the Lord say so,"
    },
    {
      "block_id": "ps-107-3",
      "type": "verse",
      "number": 3,
      "text": "and gathered in from the lands,"
    },
    {
      "block_id": "ps-107-4",
      "type": "verse",
      "number": 4,
      "text": "Some wandered in desert wastes,"
    },
    {
      "block_id": "ps-107-5",
      "type": "verse",
      "number": 5,
      "text": "hungry and thirsty,"
    },
    {
      "block_id": "ps-107-6",
      "type": "verse",
      "number": 6,
      "text": "Then they cried to the Lord in their trouble,"
    },
    {
      "block_id": "ps-107-7",
      "type": "verse",
      "number": 7,
      "text": "he led them by a straight way,"
    },
    {
      "block_id": "ps-107-8",
      "type": "verse",
      "number": 8,
      "text": "Let them thank the Lord for his steadfast love,"
    },
    {
      "block_id": "ps-107-9",
      "type": "verse",
      "number": 9,
      "text": "For he satisfies the thirsty,"
    },
    {
      "block_id": "ps-107-10",
      "type": "verse",
      "number": 10,
      "text": "Some sat in darkness and in gloom,"
    },
    {
      "block_id": "ps-107-11",
      "type": "verse",
      "number": 11,
      "text": "for they had rebelled against the words of God"
    },
    {
      "block_id": "ps-107-12",
      "type": "verse",
      "number": 12,
      "text": "Their hearts were bowed down with hard labor;"
    },
    {
      "block_id": "ps-107-13",
      "type": "verse",
      "number": 13,
      "text": "Then they cried to the Lord in their trouble,"
    },
    {
      "block_id": "ps-107-14",
      "type": "verse",
      "number": 14,
      "text": "he brought them out of darkness and gloom,"
    },
    {
      "block_id": "ps-107-15",
      "type": "verse",
      "number": 15,
      "text": "Let them thank the Lord for his steadfast love,"
    },
    {
      "block_id": "ps-107-16",
      "type": "verse",
      "number": 16,
      "text": "For he shatters the doors of bronze"
    },
    {
      "block_id": "ps-107-17",
      "type": "verse",
      "number": 17,
      "text": "Some were sick through their sinful ways"
    },
    {
      "block_id": "ps-107-18",
      "type": "verse",
      "number": 18,
      "text": "they loathed any kind of food,"
    },
    {
      "block_id": "ps-107-19",
      "type": "verse",
      "number": 19,
      "text": "Then they cried to the Lord in their trouble,"
    },
    {
      "block_id": "ps-107-20",
      "type": "verse",
      "number": 20,
      "text": "he sent out his word and healed them"
    },
    {
      "block_id": "ps-107-21",
      "type": "verse",
      "number": 21,
      "text": "Let them thank the Lord for his steadfast love,"
    },
    {
      "block_id": "ps-107-22",
      "type": "verse",
      "number": 22,
      "text": "And let them offer thanksgiving sacrifices"
    },
    {
      "block_id": "ps-107-23",
      "type": "verse",
      "number": 23,
      "text": "Some went down to the sea in ships,"
    },
    {
      "block_id": "ps-107-24",
      "type": "verse",
      "number": 24,
      "text": "they saw the deeds of the Lord,"
    },
    {
      "block_id": "ps-107-25",
      "type": "verse",
      "number": 25,
      "text": "For he commanded and raised the stormy wind,"
    },
    {
      "block_id": "ps-107-26",
      "type": "verse",
      "number": 26,
      "text": "They mounted up to heaven; they went down to the depths;"
    },
    {
      "block_id": "ps-107-27",
      "type": "verse",
      "number": 27,
      "text": "they reeled and staggered like drunkards"
    },
    {
      "block_id": "ps-107-28",
      "type": "verse",
      "number": 28,
      "text": "Then they cried to the Lord in their trouble,"
    },
    {
      "block_id": "ps-107-29",
      "type": "verse",
      "number": 29,
      "text": "he made the storm be still,"
    },
    {
      "block_id": "ps-107-30",
      "type": "verse",
      "number": 30,
      "text": "Then they were glad because they had quiet,"
    },
    {
      "block_id": "ps-107-31",
      "type": "verse",
      "number": 31,
      "text": "Let them thank the Lord for his steadfast love,"
    },
    {
      "block_id": "ps-107-32",
      "type": "verse",
      "number": 32,
      "text": "Let them extol him in the congregation of the people"
    },
    {
      "block_id": "ps-107-33",
      "type": "verse",
      "number": 33,
      "text": "He turns rivers into a desert,"
    },
    {
      "block_id": "ps-107-34",
      "type": "verse",
      "number": 34,
      "text": "a fruitful land into a salty waste,"
    },
    {
      "block_id": "ps-107-35",
      "type": "verse",
      "number": 35,
      "text": "He turns a desert into pools of water,"
    },
    {
      "block_id": "ps-107-36",
      "type": "verse",
      "number": 36,
      "text": "And there he lets the hungry live,"
    },
    {
      "block_id": "ps-107-37",
      "type": "verse",
      "number": 37,
      "text": "they sow fields and plant vineyards"
    },
    {
      "block_id": "ps-107-38",
      "type": "verse",
      "number": 38,
      "text": "By his blessing they multiply greatly,"
    },
    {
      "block_id": "ps-107-39",
      "type": "verse",
      "number": 39,
      "text": "When they are diminished and brought low"
    },
    {
      "block_id": "ps-107-40",
      "type": "verse",
      "number": 40,
      "text": "he pours contempt on princes"
    },
    {
      "block_id": "ps-107-41",
      "type": "verse",
      "number": 41,
      "text": "but he raises up the needy out of distress"
    },
    {
      "block_id": "ps-107-42",
      "type": "verse",
      "number": 42,
      "text": "The upright see it and are glad,"
    },
    {
      "block_id": "ps-107-43",
      "type": "verse",
      "number": 43,
      "text": "Let those who are wise pay attention to these things"
    }
  ]
}