{
  "document_id": "lam-4",
  "title": "Lamentations 4",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "lam-4-1",
      "type": "verse",
      "number": 1,
      "text": "How the gold has grown dim;"
    },
    {
      "block_id": "lam-4-2",
      "type": "verse",
      "number": 2,
      "text": "The precious children of Zion,"
    },
    {
      "block_id": "lam-4-3",
      "type": "verse",
      "number": 3,
      "text": "Even the jackals offer the breast"
    },
    {
      "block_id": "lam-4-4",
      "type": "verse",
      "number": 4,
      "text": "The tongue of the infant sticks"
    },
    {
      "block_id": "lam-4-5",
      "type": "verse",
      "number": 5,
      "text": "Those who feasted on delicacies"
    },
    {
      "block_id": "lam-4-6",
      "type": "verse",
      "number": 6,
      "text": "For the chastisement of my people has been greater"
    },
    {
      "block_id": "lam-4-7",
      "type": "verse",
      "number": 7,
      "text": "Her princes were purer than snow,"
    },
    {
      "block_id": "lam-4-8",
      "type": "verse",
      "number": 8,
      "text": "Now their visage is blacker than soot;"
    },
    {
      "block_id": "lam-4-9",
      "type": "verse",
      "number": 9,
      "text": "Happier were those pierced by the sword"
    },
    {
      "block_id": "lam-4-10",
      "type": "verse",
      "number": 10,
      "text": "The hands of compassionate women"
    },
    {
      "block_id": "lam-4-11",
      "type": "verse",
      "number": 11,
      "text": "The Lord gave full vent to his wrath;"
    },
    {
      "block_id": "lam-4-12",
      "type": "verse",
      "number": 12,
      "text": "The kings of the earth did not believe,"
    },
    {
      "block_id": "lam-4-13",
      "type": "verse",
      "number": 13,
      "text": "It was for the sins of her prophets"
    },
    {
      "block_id": "lam-4-14",
      "type": "verse",
      "number": 14,
      "text": "Blindly they wandered through the streets,"
    },
    {
      "block_id": "lam-4-15",
      "type": "verse",
      "number": 15,
      "text": "“Away! Unclean!” people shouted at them;"
    },
    {
      "block_id": "lam-4-16",
      "type": "verse",
      "number": 16,
      "text": "The Lord himself has scattered them;"
    },
    {
      "block_id": "lam-4-17",
      "type": "verse",
      "number": 17,
      "text": "Our eyes failed, ever watching"
    },
    {
      "block_id": "lam-4-18",
      "type": "verse",
      "number": 18,
      "text": "They dogged our steps"
    },
    {
      "block_id": "lam-4-19",
      "type": "verse",
      "number": 19,
      "text": "Our pursuers were swifter"
    },
    {
      "block_id": "lam-4-20",
      "type": "verse",
      "number": 20,
      "text": "The Lord’s anointed, the breath of our life,"
    },
    {
      "block_id": "lam-4-21",
      "type": "verse",
      "number": 21,
      "text": "Rejoice and be glad, O daughter Edom,"
    },
    {
      "block_id": "lam-4-22",
      "type": "verse",
      "number": 22,
      "text": "The punishment of your iniquity, O daughter Zion, is accomplished;"
    }
  ]
}