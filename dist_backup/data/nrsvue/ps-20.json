{
  "document_id": "ps-20",
  "title": "Psalms 20",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-20-1",
      "type": "verse",
      "number": 1,
      "text": "The Lord answer you in the day of trouble!"
    },
    {
      "block_id": "ps-20-2",
      "type": "verse",
      "number": 2,
      "text": "May he send you help from the sanctuary"
    },
    {
      "block_id": "ps-20-3",
      "type": "verse",
      "number": 3,
      "text": "May he remember all your offerings"
    },
    {
      "block_id": "ps-20-4",
      "type": "verse",
      "number": 4,
      "text": "May he grant you your heart’s desire"
    },
    {
      "block_id": "ps-20-5",
      "type": "verse",
      "number": 5,
      "text": "May we shout for joy over your victory"
    },
    {
      "block_id": "ps-20-6",
      "type": "verse",
      "number": 6,
      "text": "Now I know that the Lord will help his anointed;"
    },
    {
      "block_id": "ps-20-7",
      "type": "verse",
      "number": 7,
      "text": "Some take pride in chariots and some in horses,"
    },
    {
      "block_id": "ps-20-8",
      "type": "verse",
      "number": 8,
      "text": "They will collapse and fall,"
    },
    {
      "block_id": "ps-20-9",
      "type": "verse",
      "number": 9,
      "text": "Give victory to the king, O Lord;"
    }
  ]
}