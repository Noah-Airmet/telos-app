{
  "document_id": "sir-30",
  "title": "Sirach 30",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-30-1",
      "type": "verse",
      "number": 1,
      "text": "He who loves his son will whip him often,"
    },
    {
      "block_id": "sir-30-2",
      "type": "verse",
      "number": 2,
      "text": "He who disciplines his son will profit by him"
    },
    {
      "block_id": "sir-30-3",
      "type": "verse",
      "number": 3,
      "text": "He who teaches his son will make his enemies envious"
    },
    {
      "block_id": "sir-30-4",
      "type": "verse",
      "number": 4,
      "text": "When the father dies, he will not seem to be dead,"
    },
    {
      "block_id": "sir-30-5",
      "type": "verse",
      "number": 5,
      "text": "whom in his life he looked upon with joy"
    },
    {
      "block_id": "sir-30-6",
      "type": "verse",
      "number": 6,
      "text": "He has left behind him an avenger against his enemies"
    },
    {
      "block_id": "sir-30-7",
      "type": "verse",
      "number": 7,
      "text": "Whoever cherishes his son will bind up his wounds,"
    },
    {
      "block_id": "sir-30-8",
      "type": "verse",
      "number": 8,
      "text": "An unbroken horse turns out stubborn,"
    },
    {
      "block_id": "sir-30-9",
      "type": "verse",
      "number": 9,
      "text": "Pamper a child, and he will terrorize you;"
    },
    {
      "block_id": "sir-30-10",
      "type": "verse",
      "number": 10,
      "text": "Do not laugh with him, or you will have sorrow with him,"
    },
    {
      "block_id": "sir-30-11",
      "type": "verse",
      "number": 11,
      "text": "Give him no freedom in his youth;"
    },
    {
      "block_id": "sir-30-12",
      "type": "verse",
      "number": 12,
      "text": "beat his sides while he is young,"
    },
    {
      "block_id": "sir-30-13",
      "type": "verse",
      "number": 13,
      "text": "Discipline your son and make his yoke heavy,"
    },
    {
      "block_id": "sir-30-14",
      "type": "verse",
      "number": 14,
      "text": "Better off poor, healthy, and fit"
    },
    {
      "block_id": "sir-30-15",
      "type": "verse",
      "number": 15,
      "text": "Health and fitness are better than any gold"
    },
    {
      "block_id": "sir-30-16",
      "type": "verse",
      "number": 16,
      "text": "There is no wealth better than health of body"
    },
    {
      "block_id": "sir-30-17",
      "type": "verse",
      "number": 17,
      "text": "Death is better than a life of misery"
    },
    {
      "block_id": "sir-30-18",
      "type": "verse",
      "number": 18,
      "text": "Good things poured out upon a mouth that is closed"
    },
    {
      "block_id": "sir-30-19",
      "type": "verse",
      "number": 19,
      "text": "Of what use to an idol is a sacrifice?"
    },
    {
      "block_id": "sir-30-20",
      "type": "verse",
      "number": 20,
      "text": "he sees with his eyes and groans"
    },
    {
      "block_id": "sir-30-21",
      "type": "verse",
      "number": 21,
      "text": "Do not give yourself over to sorrow,"
    },
    {
      "block_id": "sir-30-22",
      "type": "verse",
      "number": 22,
      "text": "A joyful heart is life itself,"
    },
    {
      "block_id": "sir-30-23",
      "type": "verse",
      "number": 23,
      "text": "Indulge yourself and take comfort,"
    },
    {
      "block_id": "sir-30-24",
      "type": "verse",
      "number": 24,
      "text": "Jealousy and anger shorten life,"
    },
    {
      "block_id": "sir-30-25",
      "type": "verse",
      "number": 25,
      "text": "Those who are cheerful and merry at table"
    }
  ]
}