{
  "document_id": "job-37",
  "title": "Job 37",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-37-1",
      "type": "verse",
      "number": 1,
      "text": "“At this also my heart trembles"
    },
    {
      "block_id": "job-37-2",
      "type": "verse",
      "number": 2,
      "text": "Listen, listen to the thunder of his voice"
    },
    {
      "block_id": "job-37-3",
      "type": "verse",
      "number": 3,
      "text": "Under the whole heaven he lets it loose,"
    },
    {
      "block_id": "job-37-4",
      "type": "verse",
      "number": 4,
      "text": "After it his voice roars;"
    },
    {
      "block_id": "job-37-5",
      "type": "verse",
      "number": 5,
      "text": "God thunders wondrously with his voice;"
    },
    {
      "block_id": "job-37-6",
      "type": "verse",
      "number": 6,
      "text": "For to the snow he says, ‘Fall on the earth’;"
    },
    {
      "block_id": "job-37-7",
      "type": "verse",
      "number": 7,
      "text": "serves as a sign on everyone’s hand,"
    },
    {
      "block_id": "job-37-8",
      "type": "verse",
      "number": 8,
      "text": "Then the animals go into their lairs"
    },
    {
      "block_id": "job-37-9",
      "type": "verse",
      "number": 9,
      "text": "From its chamber comes the whirlwind"
    },
    {
      "block_id": "job-37-10",
      "type": "verse",
      "number": 10,
      "text": "By the breath of God ice is given,"
    },
    {
      "block_id": "job-37-11",
      "type": "verse",
      "number": 11,
      "text": "He loads the thick cloud with moisture;"
    },
    {
      "block_id": "job-37-12",
      "type": "verse",
      "number": 12,
      "text": "They turn round and round by his guidance"
    },
    {
      "block_id": "job-37-13",
      "type": "verse",
      "number": 13,
      "text": "Whether for correction or for his land"
    },
    {
      "block_id": "job-37-14",
      "type": "verse",
      "number": 14,
      "text": "“Hear this, O Job;"
    },
    {
      "block_id": "job-37-15",
      "type": "verse",
      "number": 15,
      "text": "Do you know how God lays his command upon them"
    },
    {
      "block_id": "job-37-16",
      "type": "verse",
      "number": 16,
      "text": "Do you know the balancings of the clouds,"
    },
    {
      "block_id": "job-37-17",
      "type": "verse",
      "number": 17,
      "text": "you whose garments are hot"
    },
    {
      "block_id": "job-37-18",
      "type": "verse",
      "number": 18,
      "text": "Can you, like him, spread out the skies,"
    },
    {
      "block_id": "job-37-19",
      "type": "verse",
      "number": 19,
      "text": "Teach us what we shall say to him;"
    },
    {
      "block_id": "job-37-20",
      "type": "verse",
      "number": 20,
      "text": "Should he be told that I want to speak?"
    },
    {
      "block_id": "job-37-21",
      "type": "verse",
      "number": 21,
      "text": "Now, no one can look on the light"
    },
    {
      "block_id": "job-37-22",
      "type": "verse",
      "number": 22,
      "text": "Out of the north comes golden splendor;"
    },
    {
      "block_id": "job-37-23",
      "type": "verse",
      "number": 23,
      "text": "The Almighty—we cannot find him;"
    },
    {
      "block_id": "job-37-24",
      "type": "verse",
      "number": 24,
      "text": "Therefore mortals fear him;"
    }
  ]
}