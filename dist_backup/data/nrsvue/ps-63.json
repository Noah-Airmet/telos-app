{
  "document_id": "ps-63",
  "title": "Psalms 63",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-63-1",
      "type": "verse",
      "number": 1,
      "text": "O God, you are my God; I seek you;"
    },
    {
      "block_id": "ps-63-2",
      "type": "verse",
      "number": 2,
      "text": "So I have looked upon you in the sanctuary,"
    },
    {
      "block_id": "ps-63-3",
      "type": "verse",
      "number": 3,
      "text": "Because your steadfast love is better than life,"
    },
    {
      "block_id": "ps-63-4",
      "type": "verse",
      "number": 4,
      "text": "So I will bless you as long as I live;"
    },
    {
      "block_id": "ps-63-5",
      "type": "verse",
      "number": 5,
      "text": "My soul is satisfied as with a rich feast,"
    },
    {
      "block_id": "ps-63-6",
      "type": "verse",
      "number": 6,
      "text": "when I think of you on my bed"
    },
    {
      "block_id": "ps-63-7",
      "type": "verse",
      "number": 7,
      "text": "for you have been my help,"
    },
    {
      "block_id": "ps-63-8",
      "type": "verse",
      "number": 8,
      "text": "My soul clings to you;"
    },
    {
      "block_id": "ps-63-9",
      "type": "verse",
      "number": 9,
      "text": "But those who seek to destroy my life"
    },
    {
      "block_id": "ps-63-10",
      "type": "verse",
      "number": 10,
      "text": "they shall be given over to the power of the sword;"
    },
    {
      "block_id": "ps-63-11",
      "type": "verse",
      "number": 11,
      "text": "But the king shall rejoice in God;"
    }
  ]
}