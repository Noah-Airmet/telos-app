{
  "document_id": "mic-7",
  "title": "Micah 7",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "mic-7-1",
      "type": "verse",
      "number": 1,
      "text": "Woe is me! For I have become like one who,"
    },
    {
      "block_id": "mic-7-2",
      "type": "verse",
      "number": 2,
      "text": "The faithful have disappeared from the land,"
    },
    {
      "block_id": "mic-7-3",
      "type": "verse",
      "number": 3,
      "text": "Their hands are skilled to do evil;"
    },
    {
      "block_id": "mic-7-4",
      "type": "verse",
      "number": 4,
      "text": "The best of them is like a brier,"
    },
    {
      "block_id": "mic-7-5",
      "type": "verse",
      "number": 5,
      "text": "Put no trust in a friend;"
    },
    {
      "block_id": "mic-7-6",
      "type": "verse",
      "number": 6,
      "text": "for the son treats the father with contempt,"
    },
    {
      "block_id": "mic-7-7",
      "type": "verse",
      "number": 7,
      "text": "But as for me, I will look to the Lord;"
    },
    {
      "block_id": "mic-7-8",
      "type": "verse",
      "number": 8,
      "text": "Do not rejoice over me, my enemies;"
    },
    {
      "block_id": "mic-7-9",
      "type": "verse",
      "number": 9,
      "text": "I must bear the indignation of the Lord"
    },
    {
      "block_id": "mic-7-10",
      "type": "verse",
      "number": 10,
      "text": "Then my enemies will see,"
    },
    {
      "block_id": "mic-7-11",
      "type": "verse",
      "number": 11,
      "text": "A day for the building of your walls!"
    },
    {
      "block_id": "mic-7-12",
      "type": "verse",
      "number": 12,
      "text": "On that day they will come to you"
    },
    {
      "block_id": "mic-7-13",
      "type": "verse",
      "number": 13,
      "text": "But the earth will be desolate"
    },
    {
      "block_id": "mic-7-14",
      "type": "verse",
      "number": 14,
      "text": "Shepherd your people with your staff,"
    },
    {
      "block_id": "mic-7-15",
      "type": "verse",
      "number": 15,
      "text": "As in the days when you came out of the land of Egypt,"
    },
    {
      "block_id": "mic-7-16",
      "type": "verse",
      "number": 16,
      "text": "The nations shall see and be ashamed"
    },
    {
      "block_id": "mic-7-17",
      "type": "verse",
      "number": 17,
      "text": "they shall lick dust like a snake,"
    },
    {
      "block_id": "mic-7-18",
      "type": "verse",
      "number": 18,
      "text": "Who is a God like you, pardoning iniquity"
    },
    {
      "block_id": "mic-7-19",
      "type": "verse",
      "number": 19,
      "text": "He will again have compassion upon us;"
    },
    {
      "block_id": "mic-7-20",
      "type": "verse",
      "number": 20,
      "text": "You will show faithfulness to Jacob"
    }
  ]
}