{
  "document_id": "job-8",
  "title": "Job 8",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-8-heading-bildad-speaks:-job-s",
      "type": "heading",
      "text": "Bildad Speaks: Job Should Repent"
    },
    {
      "block_id": "job-8-1",
      "type": "verse",
      "number": 1,
      "text": "Then Bildad the Shuhite answered:"
    },
    {
      "block_id": "job-8-2",
      "type": "verse",
      "number": 2,
      "text": "“How long will you say these things"
    },
    {
      "block_id": "job-8-3",
      "type": "verse",
      "number": 3,
      "text": "Does God pervert justice?"
    },
    {
      "block_id": "job-8-4",
      "type": "verse",
      "number": 4,
      "text": "If your children sinned against him,"
    },
    {
      "block_id": "job-8-5",
      "type": "verse",
      "number": 5,
      "text": "If you will seek God"
    },
    {
      "block_id": "job-8-6",
      "type": "verse",
      "number": 6,
      "text": "if you are pure and upright,"
    },
    {
      "block_id": "job-8-7",
      "type": "verse",
      "number": 7,
      "text": "Though your beginning was small,"
    },
    {
      "block_id": "job-8-8",
      "type": "verse",
      "number": 8,
      "text": "“For inquire now of bygone generations"
    },
    {
      "block_id": "job-8-9",
      "type": "verse",
      "number": 9,
      "text": "for we are but of yesterday, and we know nothing,"
    },
    {
      "block_id": "job-8-10",
      "type": "verse",
      "number": 10,
      "text": "Will they not teach you and tell you"
    },
    {
      "block_id": "job-8-11",
      "type": "verse",
      "number": 11,
      "text": "“Can papyrus grow where there is no marsh?"
    },
    {
      "block_id": "job-8-12",
      "type": "verse",
      "number": 12,
      "text": "While yet in flower and not cut down,"
    },
    {
      "block_id": "job-8-13",
      "type": "verse",
      "number": 13,
      "text": "Such are the paths of all who forget God;"
    },
    {
      "block_id": "job-8-14",
      "type": "verse",
      "number": 14,
      "text": "Their confidence is gossamer,"
    },
    {
      "block_id": "job-8-15",
      "type": "verse",
      "number": 15,
      "text": "If one leans against its house, it will not stand;"
    },
    {
      "block_id": "job-8-16",
      "type": "verse",
      "number": 16,
      "text": "The wicked thrive before the sun,"
    },
    {
      "block_id": "job-8-17",
      "type": "verse",
      "number": 17,
      "text": "Their roots twine around the stoneheap;"
    },
    {
      "block_id": "job-8-18",
      "type": "verse",
      "number": 18,
      "text": "If they are destroyed from their place,"
    },
    {
      "block_id": "job-8-19",
      "type": "verse",
      "number": 19,
      "text": "See, these are their happy ways,"
    },
    {
      "block_id": "job-8-20",
      "type": "verse",
      "number": 20,
      "text": "“See, God will not reject the blameless,"
    },
    {
      "block_id": "job-8-21",
      "type": "verse",
      "number": 21,
      "text": "He will yet fill your mouth with laughter"
    },
    {
      "block_id": "job-8-22",
      "type": "verse",
      "number": 22,
      "text": "Those who hate you will be clothed with shame,"
    }
  ]
}