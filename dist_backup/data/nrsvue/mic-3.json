{
  "document_id": "mic-3",
  "title": "Micah 3",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "mic-3-1",
      "type": "verse",
      "number": 1,
      "text": "And I said:"
    },
    {
      "block_id": "mic-3-2",
      "type": "verse",
      "number": 2,
      "text": "you who hate the good and love the evil,"
    },
    {
      "block_id": "mic-3-3",
      "type": "verse",
      "number": 3,
      "text": "who eat the flesh of my people,"
    },
    {
      "block_id": "mic-3-4",
      "type": "verse",
      "number": 4,
      "text": "Then they will cry to the Lord,"
    },
    {
      "block_id": "mic-3-5",
      "type": "verse",
      "number": 5,
      "text": "Thus says the Lord concerning the prophets"
    },
    {
      "block_id": "mic-3-6",
      "type": "verse",
      "number": 6,
      "text": "Therefore it shall be night to you, without vision,"
    },
    {
      "block_id": "mic-3-7",
      "type": "verse",
      "number": 7,
      "text": "the seers shall be disgraced"
    },
    {
      "block_id": "mic-3-8",
      "type": "verse",
      "number": 8,
      "text": "But as for me, I am filled with power,"
    },
    {
      "block_id": "mic-3-9",
      "type": "verse",
      "number": 9,
      "text": "Hear this, you rulers of the house of Jacob"
    },
    {
      "block_id": "mic-3-10",
      "type": "verse",
      "number": 10,
      "text": "who build Zion with blood"
    },
    {
      "block_id": "mic-3-11",
      "type": "verse",
      "number": 11,
      "text": "Its rulers give judgment for a bribe;"
    },
    {
      "block_id": "mic-3-12",
      "type": "verse",
      "number": 12,
      "text": "Therefore because of you"
    }
  ]
}