{
  "document_id": "ps-126",
  "title": "Psalms 126",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-126-1",
      "type": "verse",
      "number": 1,
      "text": "When the Lord restored the fortunes of Zion,"
    },
    {
      "block_id": "ps-126-2",
      "type": "verse",
      "number": 2,
      "text": "Then our mouth was filled with laughter"
    },
    {
      "block_id": "ps-126-3",
      "type": "verse",
      "number": 3,
      "text": "The Lord has done great things for us,"
    },
    {
      "block_id": "ps-126-4",
      "type": "verse",
      "number": 4,
      "text": "Restore our fortunes, O Lord,"
    },
    {
      "block_id": "ps-126-5",
      "type": "verse",
      "number": 5,
      "text": "May those who sow in tears"
    },
    {
      "block_id": "ps-126-6",
      "type": "verse",
      "number": 6,
      "text": "Those who go out weeping,"
    }
  ]
}