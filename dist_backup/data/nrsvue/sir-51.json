{
  "document_id": "sir-51",
  "title": "Sirach 51",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-51-1",
      "type": "verse",
      "number": 1,
      "text": "I give you thanks, O Lord and King,"
    },
    {
      "block_id": "sir-51-2",
      "type": "verse",
      "number": 2,
      "text": "for you have been my protector and helper"
    },
    {
      "block_id": "sir-51-3",
      "type": "verse",
      "number": 3,
      "text": "and delivered me,"
    },
    {
      "block_id": "sir-51-4",
      "type": "verse",
      "number": 4,
      "text": "from choking fire on every side,"
    },
    {
      "block_id": "sir-51-5",
      "type": "verse",
      "number": 5,
      "text": "from the deep belly of Hades,"
    },
    {
      "block_id": "sir-51-6",
      "type": "verse",
      "number": 6,
      "text": "the slander of an unrighteous tongue to the king."
    },
    {
      "block_id": "sir-51-7",
      "type": "verse",
      "number": 7,
      "text": "They surrounded me on every side,"
    },
    {
      "block_id": "sir-51-8",
      "type": "verse",
      "number": 8,
      "text": "Then I remembered your mercy, O Lord,"
    },
    {
      "block_id": "sir-51-9",
      "type": "verse",
      "number": 9,
      "text": "And I sent up my prayer from the earth"
    },
    {
      "block_id": "sir-51-10",
      "type": "verse",
      "number": 10,
      "text": "I cried out, “Lord, you are my Father;"
    },
    {
      "block_id": "sir-51-11",
      "type": "verse",
      "number": 11,
      "text": "I will praise your name continually"
    },
    {
      "block_id": "sir-51-12",
      "type": "verse",
      "number": 12,
      "text": "for you saved me from destruction"
    },
    {
      "block_id": "sir-51-13",
      "type": "verse",
      "number": 13,
      "text": "While I was still young, before I went on my travels,"
    },
    {
      "block_id": "sir-51-14",
      "type": "verse",
      "number": 14,
      "text": "Before the temple I asked for her,"
    },
    {
      "block_id": "sir-51-15",
      "type": "verse",
      "number": 15,
      "text": "From the first blossom to the ripening grape,"
    },
    {
      "block_id": "sir-51-16",
      "type": "verse",
      "number": 16,
      "text": "I inclined my ear a little and received her,"
    },
    {
      "block_id": "sir-51-17",
      "type": "verse",
      "number": 17,
      "text": "I made progress in her;"
    },
    {
      "block_id": "sir-51-18",
      "type": "verse",
      "number": 18,
      "text": "For I resolved to practice wisdom,"
    },
    {
      "block_id": "sir-51-19",
      "type": "verse",
      "number": 19,
      "text": "My soul grappled with wisdom,"
    },
    {
      "block_id": "sir-51-20",
      "type": "verse",
      "number": 20,
      "text": "I directed my soul to her,"
    },
    {
      "block_id": "sir-51-21",
      "type": "verse",
      "number": 21,
      "text": "My heart was stirred to seek her;"
    },
    {
      "block_id": "sir-51-22",
      "type": "verse",
      "number": 22,
      "text": "The Lord gave me my tongue as a reward,"
    },
    {
      "block_id": "sir-51-23",
      "type": "verse",
      "number": 23,
      "text": "Draw near to me, you who are uneducated,"
    },
    {
      "block_id": "sir-51-24",
      "type": "verse",
      "number": 24,
      "text": "Why do you say you are lacking in these things,"
    },
    {
      "block_id": "sir-51-25",
      "type": "verse",
      "number": 25,
      "text": "I opened my mouth and said,"
    },
    {
      "block_id": "sir-51-26",
      "type": "verse",
      "number": 26,
      "text": "“Put your neck under her yoke,"
    },
    {
      "block_id": "sir-51-27",
      "type": "verse",
      "number": 27,
      "text": "See with your own eyes that I have labored but little"
    },
    {
      "block_id": "sir-51-28",
      "type": "verse",
      "number": 28,
      "text": "Hear but a little of my instruction,"
    },
    {
      "block_id": "sir-51-29",
      "type": "verse",
      "number": 29,
      "text": "May your soul rejoice in God’s mercy,"
    },
    {
      "block_id": "sir-51-30",
      "type": "verse",
      "number": 30,
      "text": "Do your work in good time,"
    }
  ]
}