{
  "document_id": "sir-22",
  "title": "Sirach 22",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-22-1",
      "type": "verse",
      "number": 1,
      "text": "The idler is like a filthy stone,"
    },
    {
      "block_id": "sir-22-2",
      "type": "verse",
      "number": 2,
      "text": "The idler is like a lump of dung;"
    },
    {
      "block_id": "sir-22-3",
      "type": "verse",
      "number": 3,
      "text": "It is a disgrace to be the father of an undisciplined son,"
    },
    {
      "block_id": "sir-22-4",
      "type": "verse",
      "number": 4,
      "text": "A sensible daughter obtains a husband of her own,"
    },
    {
      "block_id": "sir-22-5",
      "type": "verse",
      "number": 5,
      "text": "An impudent daughter disgraces father and husband"
    },
    {
      "block_id": "sir-22-6",
      "type": "verse",
      "number": 6,
      "text": "Like music in time of mourning is ill-timed conversation,"
    },
    {
      "block_id": "sir-22-9",
      "type": "verse",
      "number": 9,
      "text": "Whoever teaches a fool is like one who glues potsherds together"
    },
    {
      "block_id": "sir-22-10",
      "type": "verse",
      "number": 10,
      "text": "Whoever tells a story to a fool tells it to a drowsy man,"
    },
    {
      "block_id": "sir-22-11",
      "type": "verse",
      "number": 11,
      "text": "Weep for the dead, for they have left the light behind,"
    },
    {
      "block_id": "sir-22-12",
      "type": "verse",
      "number": 12,
      "text": "Mourning for the dead lasts seven days,"
    },
    {
      "block_id": "sir-22-13",
      "type": "verse",
      "number": 13,
      "text": "Do not talk much with senseless people"
    },
    {
      "block_id": "sir-22-14",
      "type": "verse",
      "number": 14,
      "text": "What is heavier than lead?"
    },
    {
      "block_id": "sir-22-15",
      "type": "verse",
      "number": 15,
      "text": "Sand, salt, and a piece of iron"
    },
    {
      "block_id": "sir-22-16",
      "type": "verse",
      "number": 16,
      "text": "A wooden beam firmly bonded into a building"
    },
    {
      "block_id": "sir-22-17",
      "type": "verse",
      "number": 17,
      "text": "A mind settled on an intelligent thought"
    },
    {
      "block_id": "sir-22-18",
      "type": "verse",
      "number": 18,
      "text": "Fences set on a high place"
    },
    {
      "block_id": "sir-22-19",
      "type": "verse",
      "number": 19,
      "text": "One who pricks the eye brings tears,"
    },
    {
      "block_id": "sir-22-20",
      "type": "verse",
      "number": 20,
      "text": "One who throws a stone at birds scares them away,"
    },
    {
      "block_id": "sir-22-21",
      "type": "verse",
      "number": 21,
      "text": "Even if you draw your sword against a friend,"
    },
    {
      "block_id": "sir-22-22",
      "type": "verse",
      "number": 22,
      "text": "If you open your mouth against your friend,"
    },
    {
      "block_id": "sir-22-23",
      "type": "verse",
      "number": 23,
      "text": "Gain the trust of your neighbor in his poverty,"
    },
    {
      "block_id": "sir-22-24",
      "type": "verse",
      "number": 24,
      "text": "The vapor and smoke of the furnace precede the fire;"
    },
    {
      "block_id": "sir-22-25",
      "type": "verse",
      "number": 25,
      "text": "I am not ashamed to shelter a friend,"
    },
    {
      "block_id": "sir-22-26",
      "type": "verse",
      "number": 26,
      "text": "but if harm should come to me because of him,"
    },
    {
      "block_id": "sir-22-27",
      "type": "verse",
      "number": 27,
      "text": "Who will set a guard over my mouth"
    }
  ]
}