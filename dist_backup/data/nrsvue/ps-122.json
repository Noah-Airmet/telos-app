{
  "document_id": "ps-122",
  "title": "Psalms 122",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-122-1",
      "type": "verse",
      "number": 1,
      "text": "I was glad when they said to me,"
    },
    {
      "block_id": "ps-122-2",
      "type": "verse",
      "number": 2,
      "text": "Our feet are standing"
    },
    {
      "block_id": "ps-122-3",
      "type": "verse",
      "number": 3,
      "text": "Jerusalem—built as a city"
    },
    {
      "block_id": "ps-122-4",
      "type": "verse",
      "number": 4,
      "text": "To it the tribes go up,"
    },
    {
      "block_id": "ps-122-5",
      "type": "verse",
      "number": 5,
      "text": "For there the thrones for judgment were set up,"
    },
    {
      "block_id": "ps-122-6",
      "type": "verse",
      "number": 6,
      "text": "Pray for the peace of Jerusalem:"
    },
    {
      "block_id": "ps-122-7",
      "type": "verse",
      "number": 7,
      "text": "Peace be within your walls"
    },
    {
      "block_id": "ps-122-8",
      "type": "verse",
      "number": 8,
      "text": "For the sake of my relatives and friends"
    },
    {
      "block_id": "ps-122-9",
      "type": "verse",
      "number": 9,
      "text": "For the sake of the house of the Lord our God,"
    }
  ]
}