{
  "document_id": "song-3",
  "title": "Song of Songs 3",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "song-3-1",
      "type": "verse",
      "number": 1,
      "text": "Upon my bed at night"
    },
    {
      "block_id": "song-3-2",
      "type": "verse",
      "number": 2,
      "text": "“I will rise now and go about the city,"
    },
    {
      "block_id": "song-3-3",
      "type": "verse",
      "number": 3,
      "text": "The sentinels found me,"
    },
    {
      "block_id": "song-3-4",
      "type": "verse",
      "number": 4,
      "text": "Scarcely had I passed them,"
    },
    {
      "block_id": "song-3-5",
      "type": "verse",
      "number": 5,
      "text": "I charge you, O daughters of Jerusalem,"
    },
    {
      "block_id": "song-3-6",
      "type": "verse",
      "number": 6,
      "text": "Who is that coming up from the wilderness"
    },
    {
      "block_id": "song-3-7",
      "type": "verse",
      "number": 7,
      "text": "Look, it is the litter of Solomon!"
    },
    {
      "block_id": "song-3-8",
      "type": "verse",
      "number": 8,
      "text": "all equipped with swords"
    },
    {
      "block_id": "song-3-9",
      "type": "verse",
      "number": 9,
      "text": "King Solomon made himself a palanquin"
    },
    {
      "block_id": "song-3-10",
      "type": "verse",
      "number": 10,
      "text": "He made its posts of silver,"
    },
    {
      "block_id": "song-3-11",
      "type": "verse",
      "number": 11,
      "text": "come out and look"
    }
  ]
}