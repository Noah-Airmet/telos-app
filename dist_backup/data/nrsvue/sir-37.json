{
  "document_id": "sir-37",
  "title": "Sirach 37",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-37-1",
      "type": "verse",
      "number": 1,
      "text": "Every friend says, “I, too, am a friend,”"
    },
    {
      "block_id": "sir-37-2",
      "type": "verse",
      "number": 2,
      "text": "Does not sorrow draw near to death"
    },
    {
      "block_id": "sir-37-3",
      "type": "verse",
      "number": 3,
      "text": "O inclination to evil, why were you formed"
    },
    {
      "block_id": "sir-37-4",
      "type": "verse",
      "number": 4,
      "text": "Some companions rejoice in the happiness of friends,"
    },
    {
      "block_id": "sir-37-5",
      "type": "verse",
      "number": 5,
      "text": "Some companions help a friend for their stomachs’ sake,"
    },
    {
      "block_id": "sir-37-6",
      "type": "verse",
      "number": 6,
      "text": "Do not forget friends during the battle,"
    },
    {
      "block_id": "sir-37-7",
      "type": "verse",
      "number": 7,
      "text": "All counselors praise the counsel they give,"
    },
    {
      "block_id": "sir-37-8",
      "type": "verse",
      "number": 8,
      "text": "Be wary of counselors"
    },
    {
      "block_id": "sir-37-9",
      "type": "verse",
      "number": 9,
      "text": "and tell you, “Your way is good,”"
    },
    {
      "block_id": "sir-37-10",
      "type": "verse",
      "number": 10,
      "text": "Do not consult the one who regards you with suspicion;"
    },
    {
      "block_id": "sir-37-11",
      "type": "verse",
      "number": 11,
      "text": "Do not consult with a woman about her rival"
    },
    {
      "block_id": "sir-37-12",
      "type": "verse",
      "number": 12,
      "text": "But associate with a godly person"
    },
    {
      "block_id": "sir-37-13",
      "type": "verse",
      "number": 13,
      "text": "And heed the counsel of your own heart,"
    },
    {
      "block_id": "sir-37-14",
      "type": "verse",
      "number": 14,
      "text": "For our own mind sometimes keeps us better informed"
    },
    {
      "block_id": "sir-37-15",
      "type": "verse",
      "number": 15,
      "text": "But above all pray to the Most High"
    },
    {
      "block_id": "sir-37-16",
      "type": "verse",
      "number": 16,
      "text": "Discussion is the beginning of every work,"
    },
    {
      "block_id": "sir-37-17",
      "type": "verse",
      "number": 17,
      "text": "The mind is the root of all counsel;"
    },
    {
      "block_id": "sir-37-18",
      "type": "verse",
      "number": 18,
      "text": "it sprouts four branches,"
    },
    {
      "block_id": "sir-37-19",
      "type": "verse",
      "number": 19,
      "text": "Some people may be clever enough to teach many"
    },
    {
      "block_id": "sir-37-20",
      "type": "verse",
      "number": 20,
      "text": "Skillful speakers may be hated;"
    },
    {
      "block_id": "sir-37-21",
      "type": "verse",
      "number": 21,
      "text": "for the Lord has withheld the gift of charm,"
    },
    {
      "block_id": "sir-37-22",
      "type": "verse",
      "number": 22,
      "text": "If people are wise to their own advantage,"
    },
    {
      "block_id": "sir-37-23",
      "type": "verse",
      "number": 23,
      "text": "The wise instruct their own people,"
    },
    {
      "block_id": "sir-37-24",
      "type": "verse",
      "number": 24,
      "text": "The wise will have praise heaped upon them,"
    },
    {
      "block_id": "sir-37-25",
      "type": "verse",
      "number": 25,
      "text": "The days of a person’s life are numbered,"
    },
    {
      "block_id": "sir-37-26",
      "type": "verse",
      "number": 26,
      "text": "Those who are wise among their people will inherit honor,"
    },
    {
      "block_id": "sir-37-27",
      "type": "verse",
      "number": 27,
      "text": "My child, test yourself while you live;"
    },
    {
      "block_id": "sir-37-28",
      "type": "verse",
      "number": 28,
      "text": "For not everything is good for everyone,"
    },
    {
      "block_id": "sir-37-29",
      "type": "verse",
      "number": 29,
      "text": "Do not be greedy for every delicacy,"
    },
    {
      "block_id": "sir-37-30",
      "type": "verse",
      "number": 30,
      "text": "for overeating brings sickness,"
    },
    {
      "block_id": "sir-37-31",
      "type": "verse",
      "number": 31,
      "text": "Many have died of gluttony,"
    }
  ]
}