{
  "document_id": "ps-84",
  "title": "Psalms 84",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-84-1",
      "type": "verse",
      "number": 1,
      "text": "How lovely is your dwelling place,"
    },
    {
      "block_id": "ps-84-2",
      "type": "verse",
      "number": 2,
      "text": "My soul longs, indeed it faints,"
    },
    {
      "block_id": "ps-84-3",
      "type": "verse",
      "number": 3,
      "text": "Even the sparrow finds a home"
    },
    {
      "block_id": "ps-84-4",
      "type": "verse",
      "number": 4,
      "text": "Happy are those who live in your house,"
    },
    {
      "block_id": "ps-84-5",
      "type": "verse",
      "number": 5,
      "text": "Happy are those whose strength is in you,"
    },
    {
      "block_id": "ps-84-6",
      "type": "verse",
      "number": 6,
      "text": "As they go through the valley of Baca,"
    },
    {
      "block_id": "ps-84-7",
      "type": "verse",
      "number": 7,
      "text": "They go from strength to strength;"
    },
    {
      "block_id": "ps-84-8",
      "type": "verse",
      "number": 8,
      "text": "O Lord God of hosts, hear my prayer;"
    },
    {
      "block_id": "ps-84-9",
      "type": "verse",
      "number": 9,
      "text": "Behold our shield, O God;"
    },
    {
      "block_id": "ps-84-10",
      "type": "verse",
      "number": 10,
      "text": "For a day in your courts is better"
    },
    {
      "block_id": "ps-84-11",
      "type": "verse",
      "number": 11,
      "text": "For the Lord God is a sun and shield;"
    },
    {
      "block_id": "ps-84-12",
      "type": "verse",
      "number": 12,
      "text": "O Lord of hosts,"
    }
  ]
}