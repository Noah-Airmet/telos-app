{
  "document_id": "prov-12",
  "title": "Proverbs 12",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-12-1",
      "type": "verse",
      "number": 1,
      "text": "Whoever loves discipline loves knowledge,"
    },
    {
      "block_id": "prov-12-2",
      "type": "verse",
      "number": 2,
      "text": "The good obtain favor from the Lord,"
    },
    {
      "block_id": "prov-12-3",
      "type": "verse",
      "number": 3,
      "text": "No one finds security by wickedness,"
    },
    {
      "block_id": "prov-12-4",
      "type": "verse",
      "number": 4,
      "text": "A good wife is the crown of her husband,"
    },
    {
      "block_id": "prov-12-5",
      "type": "verse",
      "number": 5,
      "text": "The thoughts of the righteous are just;"
    },
    {
      "block_id": "prov-12-6",
      "type": "verse",
      "number": 6,
      "text": "The words of the wicked are a deadly ambush,"
    },
    {
      "block_id": "prov-12-7",
      "type": "verse",
      "number": 7,
      "text": "The wicked are overthrown and are no more,"
    },
    {
      "block_id": "prov-12-8",
      "type": "verse",
      "number": 8,
      "text": "One is commended for good sense,"
    },
    {
      "block_id": "prov-12-9",
      "type": "verse",
      "number": 9,
      "text": "Better to be despised and have produce"
    },
    {
      "block_id": "prov-12-10",
      "type": "verse",
      "number": 10,
      "text": "The righteous know the needs of their animals,"
    },
    {
      "block_id": "prov-12-11",
      "type": "verse",
      "number": 11,
      "text": "Those who till their land will have plenty of food,"
    },
    {
      "block_id": "prov-12-12",
      "type": "verse",
      "number": 12,
      "text": "The wicked covet the proceeds of wickedness,"
    },
    {
      "block_id": "prov-12-13",
      "type": "verse",
      "number": 13,
      "text": "The evil are ensnared by the transgression of their lips,"
    },
    {
      "block_id": "prov-12-14",
      "type": "verse",
      "number": 14,
      "text": "From the fruit of the mouth one is filled with good things,"
    },
    {
      "block_id": "prov-12-15",
      "type": "verse",
      "number": 15,
      "text": "Fools think their own way is right,"
    },
    {
      "block_id": "prov-12-16",
      "type": "verse",
      "number": 16,
      "text": "Fools show their anger at once,"
    },
    {
      "block_id": "prov-12-17",
      "type": "verse",
      "number": 17,
      "text": "Whoever speaks the truth gives honest evidence,"
    },
    {
      "block_id": "prov-12-18",
      "type": "verse",
      "number": 18,
      "text": "Rash words are like sword thrusts,"
    },
    {
      "block_id": "prov-12-19",
      "type": "verse",
      "number": 19,
      "text": "Truthful lips endure forever,"
    },
    {
      "block_id": "prov-12-20",
      "type": "verse",
      "number": 20,
      "text": "Deceit is in the mind of those who plan evil,"
    },
    {
      "block_id": "prov-12-21",
      "type": "verse",
      "number": 21,
      "text": "No harm happens to the righteous,"
    },
    {
      "block_id": "prov-12-22",
      "type": "verse",
      "number": 22,
      "text": "Lying lips are an abomination to the Lord,"
    },
    {
      "block_id": "prov-12-23",
      "type": "verse",
      "number": 23,
      "text": "One who is clever conceals knowledge,"
    },
    {
      "block_id": "prov-12-24",
      "type": "verse",
      "number": 24,
      "text": "The hand of the diligent will rule,"
    },
    {
      "block_id": "prov-12-25",
      "type": "verse",
      "number": 25,
      "text": "Anxiety weighs down the human heart,"
    },
    {
      "block_id": "prov-12-26",
      "type": "verse",
      "number": 26,
      "text": "The righteous are released from misfortune,"
    },
    {
      "block_id": "prov-12-27",
      "type": "verse",
      "number": 27,
      "text": "The lazy do not roast their game,"
    },
    {
      "block_id": "prov-12-28",
      "type": "verse",
      "number": 28,
      "text": "In the path of righteousness there is life;"
    }
  ]
}