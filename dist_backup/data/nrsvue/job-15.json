{
  "document_id": "job-15",
  "title": "Job 15",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-15-heading-eliphaz-speaks:-job-",
      "type": "heading",
      "text": "Eliphaz Speaks: Job Undermines Religion"
    },
    {
      "block_id": "job-15-1",
      "type": "verse",
      "number": 1,
      "text": "Then Eliphaz the Temanite answered:"
    },
    {
      "block_id": "job-15-2",
      "type": "verse",
      "number": 2,
      "text": "“Should the wise answer with windy knowledge"
    },
    {
      "block_id": "job-15-3",
      "type": "verse",
      "number": 3,
      "text": "Should they argue in unprofitable talk"
    },
    {
      "block_id": "job-15-4",
      "type": "verse",
      "number": 4,
      "text": "But you are doing away with the fear of God"
    },
    {
      "block_id": "job-15-5",
      "type": "verse",
      "number": 5,
      "text": "For your iniquity teaches your mouth,"
    },
    {
      "block_id": "job-15-6",
      "type": "verse",
      "number": 6,
      "text": "Your own mouth condemns you, not I;"
    },
    {
      "block_id": "job-15-7",
      "type": "verse",
      "number": 7,
      "text": "“Are you the firstborn of the human race?"
    },
    {
      "block_id": "job-15-8",
      "type": "verse",
      "number": 8,
      "text": "Have you listened in the council of God?"
    },
    {
      "block_id": "job-15-9",
      "type": "verse",
      "number": 9,
      "text": "What do you know that we do not know?"
    },
    {
      "block_id": "job-15-10",
      "type": "verse",
      "number": 10,
      "text": "The gray-haired and the aged are on our side,"
    },
    {
      "block_id": "job-15-11",
      "type": "verse",
      "number": 11,
      "text": "Are the consolations of God too small for you"
    },
    {
      "block_id": "job-15-12",
      "type": "verse",
      "number": 12,
      "text": "Why does your heart carry you away,"
    },
    {
      "block_id": "job-15-13",
      "type": "verse",
      "number": 13,
      "text": "so that you turn your spirit against God,"
    },
    {
      "block_id": "job-15-14",
      "type": "verse",
      "number": 14,
      "text": "What are mortals, that they can be clean?"
    },
    {
      "block_id": "job-15-15",
      "type": "verse",
      "number": 15,
      "text": "God puts no trust even in his holy ones,"
    },
    {
      "block_id": "job-15-16",
      "type": "verse",
      "number": 16,
      "text": "how much less one who is abominable and corrupt,"
    },
    {
      "block_id": "job-15-17",
      "type": "verse",
      "number": 17,
      "text": "“I will show you; listen to me;"
    },
    {
      "block_id": "job-15-18",
      "type": "verse",
      "number": 18,
      "text": "what sages have told"
    },
    {
      "block_id": "job-15-19",
      "type": "verse",
      "number": 19,
      "text": "to whom alone the land was given,"
    },
    {
      "block_id": "job-15-20",
      "type": "verse",
      "number": 20,
      "text": "The wicked writhe in pain all their days,"
    },
    {
      "block_id": "job-15-21",
      "type": "verse",
      "number": 21,
      "text": "Terrifying sounds are in their ears;"
    },
    {
      "block_id": "job-15-22",
      "type": "verse",
      "number": 22,
      "text": "They despair of returning from darkness,"
    },
    {
      "block_id": "job-15-23",
      "type": "verse",
      "number": 23,
      "text": "They wander abroad for bread, saying, ‘Where is it?’"
    },
    {
      "block_id": "job-15-24",
      "type": "verse",
      "number": 24,
      "text": "distress and anguish terrify them;"
    },
    {
      "block_id": "job-15-25",
      "type": "verse",
      "number": 25,
      "text": "Because they stretched out their hands against God"
    },
    {
      "block_id": "job-15-26",
      "type": "verse",
      "number": 26,
      "text": "running stubbornly against him"
    },
    {
      "block_id": "job-15-27",
      "type": "verse",
      "number": 27,
      "text": "because they have covered their faces with their fat"
    },
    {
      "block_id": "job-15-28",
      "type": "verse",
      "number": 28,
      "text": "they will live in desolate cities,"
    },
    {
      "block_id": "job-15-29",
      "type": "verse",
      "number": 29,
      "text": "they will not be rich, and their wealth will not endure,"
    },
    {
      "block_id": "job-15-30",
      "type": "verse",
      "number": 30,
      "text": "they will not escape from darkness;"
    },
    {
      "block_id": "job-15-31",
      "type": "verse",
      "number": 31,
      "text": "Let them not trust in emptiness, deceiving themselves,"
    },
    {
      "block_id": "job-15-32",
      "type": "verse",
      "number": 32,
      "text": "It will be paid in full before their time,"
    },
    {
      "block_id": "job-15-33",
      "type": "verse",
      "number": 33,
      "text": "They will shake off their unripe grape, like the vine,"
    },
    {
      "block_id": "job-15-34",
      "type": "verse",
      "number": 34,
      "text": "For the company of the godless is barren,"
    },
    {
      "block_id": "job-15-35",
      "type": "verse",
      "number": 35,
      "text": "They conceive mischief and bring forth evil,"
    }
  ]
}