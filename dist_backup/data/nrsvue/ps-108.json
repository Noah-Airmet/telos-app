{
  "document_id": "ps-108",
  "title": "Psalms 108",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-108-1",
      "type": "verse",
      "number": 1,
      "text": "My heart is steadfast, O God, my heart is steadfast;"
    },
    {
      "block_id": "ps-108-2",
      "type": "verse",
      "number": 2,
      "text": "Awake, O harp and lyre!"
    },
    {
      "block_id": "ps-108-3",
      "type": "verse",
      "number": 3,
      "text": "I will give thanks to you, O Lord, among the peoples,"
    },
    {
      "block_id": "ps-108-4",
      "type": "verse",
      "number": 4,
      "text": "For your steadfast love is higher than the heavens,"
    },
    {
      "block_id": "ps-108-5",
      "type": "verse",
      "number": 5,
      "text": "Be exalted, O God, above the heavens,"
    },
    {
      "block_id": "ps-108-6",
      "type": "verse",
      "number": 6,
      "text": "Give victory with your right hand, and answer me,"
    },
    {
      "block_id": "ps-108-7",
      "type": "verse",
      "number": 7,
      "text": "God has promised in his sanctuary:"
    },
    {
      "block_id": "ps-108-8",
      "type": "verse",
      "number": 8,
      "text": "Gilead is mine; Manasseh is mine;"
    },
    {
      "block_id": "ps-108-9",
      "type": "verse",
      "number": 9,
      "text": "Moab is my washbasin;"
    },
    {
      "block_id": "ps-108-10",
      "type": "verse",
      "number": 10,
      "text": "Who will bring me to the fortified city?"
    },
    {
      "block_id": "ps-108-11",
      "type": "verse",
      "number": 11,
      "text": "Have you not rejected us, O God?"
    },
    {
      "block_id": "ps-108-12",
      "type": "verse",
      "number": 12,
      "text": "O grant us help against the foe,"
    },
    {
      "block_id": "ps-108-13",
      "type": "verse",
      "number": 13,
      "text": "With God we shall do valiantly;"
    }
  ]
}