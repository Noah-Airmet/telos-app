{
  "document_id": "prov-4",
  "title": "Proverbs 4",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-4-1",
      "type": "verse",
      "number": 1,
      "text": "Listen, children, to a father’s instruction,"
    },
    {
      "block_id": "prov-4-2",
      "type": "verse",
      "number": 2,
      "text": "for I give you good precepts:"
    },
    {
      "block_id": "prov-4-3",
      "type": "verse",
      "number": 3,
      "text": "When I was a son with my father,"
    },
    {
      "block_id": "prov-4-4",
      "type": "verse",
      "number": 4,
      "text": "he taught me and said to me,"
    },
    {
      "block_id": "prov-4-5",
      "type": "verse",
      "number": 5,
      "text": "Get wisdom; get insight: do not forget nor turn away"
    },
    {
      "block_id": "prov-4-6",
      "type": "verse",
      "number": 6,
      "text": "Do not forsake her, and she will keep you;"
    },
    {
      "block_id": "prov-4-7",
      "type": "verse",
      "number": 7,
      "text": "The beginning of wisdom is this: get wisdom,"
    },
    {
      "block_id": "prov-4-8",
      "type": "verse",
      "number": 8,
      "text": "Prize her highly, and she will exalt you;"
    },
    {
      "block_id": "prov-4-9",
      "type": "verse",
      "number": 9,
      "text": "She will place on your head a fair garland;"
    },
    {
      "block_id": "prov-4-10",
      "type": "verse",
      "number": 10,
      "text": "Hear, my child, and accept my words,"
    },
    {
      "block_id": "prov-4-11",
      "type": "verse",
      "number": 11,
      "text": "I have taught you the way of wisdom;"
    },
    {
      "block_id": "prov-4-12",
      "type": "verse",
      "number": 12,
      "text": "When you walk, your step will not be hampered,"
    },
    {
      "block_id": "prov-4-13",
      "type": "verse",
      "number": 13,
      "text": "Keep hold of instruction; do not let go;"
    },
    {
      "block_id": "prov-4-14",
      "type": "verse",
      "number": 14,
      "text": "Do not enter the path of the wicked,"
    },
    {
      "block_id": "prov-4-15",
      "type": "verse",
      "number": 15,
      "text": "Avoid it; do not go on it;"
    },
    {
      "block_id": "prov-4-16",
      "type": "verse",
      "number": 16,
      "text": "For they cannot sleep unless they have done wrong;"
    },
    {
      "block_id": "prov-4-17",
      "type": "verse",
      "number": 17,
      "text": "For they eat the bread of wickedness"
    },
    {
      "block_id": "prov-4-18",
      "type": "verse",
      "number": 18,
      "text": "But the path of the righteous is like the light of dawn,"
    },
    {
      "block_id": "prov-4-19",
      "type": "verse",
      "number": 19,
      "text": "The way of the wicked is like deep darkness;"
    },
    {
      "block_id": "prov-4-20",
      "type": "verse",
      "number": 20,
      "text": "My child, be attentive to my words;"
    },
    {
      "block_id": "prov-4-21",
      "type": "verse",
      "number": 21,
      "text": "Do not let them escape from your sight;"
    },
    {
      "block_id": "prov-4-22",
      "type": "verse",
      "number": 22,
      "text": "For they are life to those who find them"
    },
    {
      "block_id": "prov-4-23",
      "type": "verse",
      "number": 23,
      "text": "Keep your heart with all vigilance,"
    },
    {
      "block_id": "prov-4-24",
      "type": "verse",
      "number": 24,
      "text": "Put away from you crooked speech,"
    },
    {
      "block_id": "prov-4-25",
      "type": "verse",
      "number": 25,
      "text": "Let your eyes look directly forward"
    },
    {
      "block_id": "prov-4-26",
      "type": "verse",
      "number": 26,
      "text": "Keep straight the path of your feet,"
    },
    {
      "block_id": "prov-4-27",
      "type": "verse",
      "number": 27,
      "text": "Do not swerve to the right or to the left;"
    }
  ]
}