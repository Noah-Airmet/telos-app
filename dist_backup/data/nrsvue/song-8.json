{
  "document_id": "song-8",
  "title": "Song of Songs 8",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "song-8-1",
      "type": "verse",
      "number": 1,
      "text": "O that you were like a brother to me,"
    },
    {
      "block_id": "song-8-2",
      "type": "verse",
      "number": 2,
      "text": "I would lead you and bring you"
    },
    {
      "block_id": "song-8-3",
      "type": "verse",
      "number": 3,
      "text": "O that his left hand were under my head"
    },
    {
      "block_id": "song-8-4",
      "type": "verse",
      "number": 4,
      "text": "I charge you, O daughters of Jerusalem,"
    },
    {
      "block_id": "song-8-5",
      "type": "verse",
      "number": 5,
      "text": "Who is that coming up from the wilderness,"
    },
    {
      "block_id": "song-8-6",
      "type": "verse",
      "number": 6,
      "text": "Set me as a seal upon your heart,"
    },
    {
      "block_id": "song-8-7",
      "type": "verse",
      "number": 7,
      "text": "Many waters cannot quench love,"
    },
    {
      "block_id": "song-8-8",
      "type": "verse",
      "number": 8,
      "text": "We have a little sister,"
    },
    {
      "block_id": "song-8-9",
      "type": "verse",
      "number": 9,
      "text": "If she is a wall,"
    },
    {
      "block_id": "song-8-10",
      "type": "verse",
      "number": 10,
      "text": "I was a wall,"
    },
    {
      "block_id": "song-8-11",
      "type": "verse",
      "number": 11,
      "text": "Solomon had a vineyard at Baal-hamon;"
    },
    {
      "block_id": "song-8-12",
      "type": "verse",
      "number": 12,
      "text": "My vineyard, my very own, is for myself;"
    },
    {
      "block_id": "song-8-13",
      "type": "verse",
      "number": 13,
      "text": "O you who dwell in the gardens,"
    },
    {
      "block_id": "song-8-14",
      "type": "verse",
      "number": 14,
      "text": "Make haste, my beloved,"
    }
  ]
}