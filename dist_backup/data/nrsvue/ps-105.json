{
  "document_id": "ps-105",
  "title": "Psalms 105",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-105-1",
      "type": "verse",
      "number": 1,
      "text": "O give thanks to the Lord; call on his name;"
    },
    {
      "block_id": "ps-105-2",
      "type": "verse",
      "number": 2,
      "text": "Sing to him, sing praises to him;"
    },
    {
      "block_id": "ps-105-3",
      "type": "verse",
      "number": 3,
      "text": "Glory in his holy name;"
    },
    {
      "block_id": "ps-105-4",
      "type": "verse",
      "number": 4,
      "text": "Seek the Lord and his strength;"
    },
    {
      "block_id": "ps-105-5",
      "type": "verse",
      "number": 5,
      "text": "Remember the wonderful works he has done,"
    },
    {
      "block_id": "ps-105-6",
      "type": "verse",
      "number": 6,
      "text": "O offspring of his servant Abraham,"
    },
    {
      "block_id": "ps-105-7",
      "type": "verse",
      "number": 7,
      "text": "He is the Lord our God;"
    },
    {
      "block_id": "ps-105-8",
      "type": "verse",
      "number": 8,
      "text": "He is mindful of his covenant forever,"
    },
    {
      "block_id": "ps-105-9",
      "type": "verse",
      "number": 9,
      "text": "the covenant that he made with Abraham,"
    },
    {
      "block_id": "ps-105-10",
      "type": "verse",
      "number": 10,
      "text": "which he confirmed to Jacob as a statute,"
    },
    {
      "block_id": "ps-105-11",
      "type": "verse",
      "number": 11,
      "text": "saying, “To you I will give the land of Canaan"
    },
    {
      "block_id": "ps-105-12",
      "type": "verse",
      "number": 12,
      "text": "When they were few in number,"
    },
    {
      "block_id": "ps-105-13",
      "type": "verse",
      "number": 13,
      "text": "wandering from nation to nation,"
    },
    {
      "block_id": "ps-105-14",
      "type": "verse",
      "number": 14,
      "text": "he allowed no one to oppress them;"
    },
    {
      "block_id": "ps-105-15",
      "type": "verse",
      "number": 15,
      "text": "saying, “Do not touch my anointed ones;"
    },
    {
      "block_id": "ps-105-16",
      "type": "verse",
      "number": 16,
      "text": "When he summoned famine against the land"
    },
    {
      "block_id": "ps-105-17",
      "type": "verse",
      "number": 17,
      "text": "he had sent a man ahead of them,"
    },
    {
      "block_id": "ps-105-18",
      "type": "verse",
      "number": 18,
      "text": "His feet were hurt with fetters;"
    },
    {
      "block_id": "ps-105-19",
      "type": "verse",
      "number": 19,
      "text": "until what he had said came to pass,"
    },
    {
      "block_id": "ps-105-20",
      "type": "verse",
      "number": 20,
      "text": "The king sent and released him;"
    },
    {
      "block_id": "ps-105-21",
      "type": "verse",
      "number": 21,
      "text": "He made him lord of his house"
    },
    {
      "block_id": "ps-105-22",
      "type": "verse",
      "number": 22,
      "text": "to instruct his officials at his pleasure"
    },
    {
      "block_id": "ps-105-23",
      "type": "verse",
      "number": 23,
      "text": "Then Israel came to Egypt;"
    },
    {
      "block_id": "ps-105-24",
      "type": "verse",
      "number": 24,
      "text": "And the Lord made his people very fruitful"
    },
    {
      "block_id": "ps-105-25",
      "type": "verse",
      "number": 25,
      "text": "whose hearts he then turned to hate his people,"
    },
    {
      "block_id": "ps-105-26",
      "type": "verse",
      "number": 26,
      "text": "He sent his servant Moses"
    },
    {
      "block_id": "ps-105-27",
      "type": "verse",
      "number": 27,
      "text": "They performed his signs among them"
    },
    {
      "block_id": "ps-105-28",
      "type": "verse",
      "number": 28,
      "text": "He sent darkness and made the land dark;"
    },
    {
      "block_id": "ps-105-29",
      "type": "verse",
      "number": 29,
      "text": "He turned their waters into blood"
    },
    {
      "block_id": "ps-105-30",
      "type": "verse",
      "number": 30,
      "text": "Their land swarmed with frogs,"
    },
    {
      "block_id": "ps-105-31",
      "type": "verse",
      "number": 31,
      "text": "He spoke, and there came swarms of flies"
    },
    {
      "block_id": "ps-105-32",
      "type": "verse",
      "number": 32,
      "text": "He gave them hail for rain"
    },
    {
      "block_id": "ps-105-33",
      "type": "verse",
      "number": 33,
      "text": "He struck their vines and fig trees"
    },
    {
      "block_id": "ps-105-34",
      "type": "verse",
      "number": 34,
      "text": "He spoke, and the locusts came,"
    },
    {
      "block_id": "ps-105-35",
      "type": "verse",
      "number": 35,
      "text": "they devoured all the vegetation in their land"
    },
    {
      "block_id": "ps-105-36",
      "type": "verse",
      "number": 36,
      "text": "He struck down all the firstborn in their land,"
    },
    {
      "block_id": "ps-105-37",
      "type": "verse",
      "number": 37,
      "text": "Then he brought Israel out with silver and gold,"
    },
    {
      "block_id": "ps-105-38",
      "type": "verse",
      "number": 38,
      "text": "Egypt was glad when they departed,"
    },
    {
      "block_id": "ps-105-39",
      "type": "verse",
      "number": 39,
      "text": "He spread a cloud for a covering"
    },
    {
      "block_id": "ps-105-40",
      "type": "verse",
      "number": 40,
      "text": "They asked, and he brought quails"
    },
    {
      "block_id": "ps-105-41",
      "type": "verse",
      "number": 41,
      "text": "He opened the rock, and water gushed out;"
    },
    {
      "block_id": "ps-105-42",
      "type": "verse",
      "number": 42,
      "text": "For he remembered his holy promise"
    },
    {
      "block_id": "ps-105-43",
      "type": "verse",
      "number": 43,
      "text": "So he brought his people out with joy,"
    },
    {
      "block_id": "ps-105-44",
      "type": "verse",
      "number": 44,
      "text": "He gave them the lands of the nations,"
    },
    {
      "block_id": "ps-105-45",
      "type": "verse",
      "number": 45,
      "text": "that they might keep his statutes"
    }
  ]
}