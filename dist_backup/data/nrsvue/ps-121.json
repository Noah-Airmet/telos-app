{
  "document_id": "ps-121",
  "title": "Psalms 121",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-121-1",
      "type": "verse",
      "number": 1,
      "text": "I lift up my eyes to the hills—"
    },
    {
      "block_id": "ps-121-2",
      "type": "verse",
      "number": 2,
      "text": "My help comes from the Lord,"
    },
    {
      "block_id": "ps-121-3",
      "type": "verse",
      "number": 3,
      "text": "He will not let your foot be moved;"
    },
    {
      "block_id": "ps-121-4",
      "type": "verse",
      "number": 4,
      "text": "He who keeps Israel"
    },
    {
      "block_id": "ps-121-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord is your keeper;"
    },
    {
      "block_id": "ps-121-6",
      "type": "verse",
      "number": 6,
      "text": "The sun shall not strike you by day"
    },
    {
      "block_id": "ps-121-7",
      "type": "verse",
      "number": 7,
      "text": "The Lord will keep you from all evil;"
    },
    {
      "block_id": "ps-121-8",
      "type": "verse",
      "number": 8,
      "text": "The Lord will keep"
    }
  ]
}