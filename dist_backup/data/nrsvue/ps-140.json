{
  "document_id": "ps-140",
  "title": "Psalms 140",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-140-1",
      "type": "verse",
      "number": 1,
      "text": "Deliver me, O Lord, from evildoers;"
    },
    {
      "block_id": "ps-140-2",
      "type": "verse",
      "number": 2,
      "text": "who plan evil things in their minds"
    },
    {
      "block_id": "ps-140-3",
      "type": "verse",
      "number": 3,
      "text": "They make their tongue sharp as a snake’s,"
    },
    {
      "block_id": "ps-140-4",
      "type": "verse",
      "number": 4,
      "text": "Guard me, O Lord, from the hands of the wicked;"
    },
    {
      "block_id": "ps-140-5",
      "type": "verse",
      "number": 5,
      "text": "The arrogant have hidden a trap for me,"
    },
    {
      "block_id": "ps-140-6",
      "type": "verse",
      "number": 6,
      "text": "I say to the Lord, “You are my God;"
    },
    {
      "block_id": "ps-140-7",
      "type": "verse",
      "number": 7,
      "text": "O Lord, my Lord, my strong deliverer,"
    },
    {
      "block_id": "ps-140-8",
      "type": "verse",
      "number": 8,
      "text": "Do not grant, O Lord, the desires of the wicked;"
    },
    {
      "block_id": "ps-140-9",
      "type": "verse",
      "number": 9,
      "text": "Those who surround me lift up their heads;"
    },
    {
      "block_id": "ps-140-10",
      "type": "verse",
      "number": 10,
      "text": "Let burning coals fall on them!"
    },
    {
      "block_id": "ps-140-11",
      "type": "verse",
      "number": 11,
      "text": "Do not let the slanderer be established in the land;"
    },
    {
      "block_id": "ps-140-12",
      "type": "verse",
      "number": 12,
      "text": "I know that the Lord maintains the cause of the needy"
    },
    {
      "block_id": "ps-140-13",
      "type": "verse",
      "number": 13,
      "text": "Surely the righteous shall give thanks to your name;"
    }
  ]
}