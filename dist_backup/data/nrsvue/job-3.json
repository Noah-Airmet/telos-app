{
  "document_id": "job-3",
  "title": "Job 3",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-3-heading-job-curses-the-day-h",
      "type": "heading",
      "text": "Job Curses the Day He Was Born"
    },
    {
      "block_id": "job-3-1",
      "type": "verse",
      "number": 1,
      "text": "After this Job opened his mouth and cursed the day of his birth."
    },
    {
      "block_id": "job-3-2",
      "type": "verse",
      "number": 2,
      "text": "Job said:"
    },
    {
      "block_id": "job-3-3",
      "type": "verse",
      "number": 3,
      "text": "“Let the day perish in which I was born,"
    },
    {
      "block_id": "job-3-4",
      "type": "verse",
      "number": 4,
      "text": "Let that day be darkness!"
    },
    {
      "block_id": "job-3-5",
      "type": "verse",
      "number": 5,
      "text": "Let gloom and deep darkness claim it."
    },
    {
      "block_id": "job-3-6",
      "type": "verse",
      "number": 6,
      "text": "That night—let thick darkness seize it!"
    },
    {
      "block_id": "job-3-7",
      "type": "verse",
      "number": 7,
      "text": "Yes, let that night be barren;"
    },
    {
      "block_id": "job-3-8",
      "type": "verse",
      "number": 8,
      "text": "Let those curse it who curse the Sea,"
    },
    {
      "block_id": "job-3-9",
      "type": "verse",
      "number": 9,
      "text": "Let the stars of its dawn be dark;"
    },
    {
      "block_id": "job-3-10",
      "type": "verse",
      "number": 10,
      "text": "because it did not shut the doors of my mother’s womb"
    },
    {
      "block_id": "job-3-11",
      "type": "verse",
      "number": 11,
      "text": "“Why did I not die at birth,"
    },
    {
      "block_id": "job-3-12",
      "type": "verse",
      "number": 12,
      "text": "Why were there knees to receive me"
    },
    {
      "block_id": "job-3-13",
      "type": "verse",
      "number": 13,
      "text": "Now I would be lying down and quiet;"
    },
    {
      "block_id": "job-3-14",
      "type": "verse",
      "number": 14,
      "text": "with kings and counselors of the earth"
    },
    {
      "block_id": "job-3-15",
      "type": "verse",
      "number": 15,
      "text": "or with princes who have gold,"
    },
    {
      "block_id": "job-3-16",
      "type": "verse",
      "number": 16,
      "text": "Or why was I not buried like a stillborn child,"
    },
    {
      "block_id": "job-3-17",
      "type": "verse",
      "number": 17,
      "text": "There the wicked cease from troubling,"
    },
    {
      "block_id": "job-3-18",
      "type": "verse",
      "number": 18,
      "text": "There the prisoners are at ease together;"
    },
    {
      "block_id": "job-3-19",
      "type": "verse",
      "number": 19,
      "text": "The small and the great are there,"
    },
    {
      "block_id": "job-3-20",
      "type": "verse",
      "number": 20,
      "text": "“Why is light given to one in misery"
    },
    {
      "block_id": "job-3-21",
      "type": "verse",
      "number": 21,
      "text": "who long for death, but it does not come,"
    },
    {
      "block_id": "job-3-22",
      "type": "verse",
      "number": 22,
      "text": "who rejoice exceedingly"
    },
    {
      "block_id": "job-3-23",
      "type": "verse",
      "number": 23,
      "text": "Why is light given to one who cannot see the way,"
    },
    {
      "block_id": "job-3-24",
      "type": "verse",
      "number": 24,
      "text": "For my sighing comes like my bread,"
    },
    {
      "block_id": "job-3-25",
      "type": "verse",
      "number": 25,
      "text": "Truly the thing that I fear comes upon me,"
    },
    {
      "block_id": "job-3-26",
      "type": "verse",
      "number": 26,
      "text": "I am not at ease, nor am I quiet;"
    }
  ]
}