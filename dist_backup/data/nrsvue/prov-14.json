{
  "document_id": "prov-14",
  "title": "Proverbs 14",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-14-1",
      "type": "verse",
      "number": 1,
      "text": "The wise woman builds her house,"
    },
    {
      "block_id": "prov-14-2",
      "type": "verse",
      "number": 2,
      "text": "Those who walk uprightly fear the Lord,"
    },
    {
      "block_id": "prov-14-3",
      "type": "verse",
      "number": 3,
      "text": "The talk of fools is a rod for their backs,"
    },
    {
      "block_id": "prov-14-4",
      "type": "verse",
      "number": 4,
      "text": "Where there are no oxen, there is no grain;"
    },
    {
      "block_id": "prov-14-5",
      "type": "verse",
      "number": 5,
      "text": "A faithful witness does not lie,"
    },
    {
      "block_id": "prov-14-6",
      "type": "verse",
      "number": 6,
      "text": "A scoffer seeks wisdom in vain,"
    },
    {
      "block_id": "prov-14-7",
      "type": "verse",
      "number": 7,
      "text": "Leave the presence of a fool,"
    },
    {
      "block_id": "prov-14-8",
      "type": "verse",
      "number": 8,
      "text": "It is the wisdom of the clever to understand where they go,"
    },
    {
      "block_id": "prov-14-9",
      "type": "verse",
      "number": 9,
      "text": "Fools mock at the guilt offering,"
    },
    {
      "block_id": "prov-14-10",
      "type": "verse",
      "number": 10,
      "text": "The heart knows its own bitterness,"
    },
    {
      "block_id": "prov-14-11",
      "type": "verse",
      "number": 11,
      "text": "The house of the wicked is destroyed,"
    },
    {
      "block_id": "prov-14-12",
      "type": "verse",
      "number": 12,
      "text": "There is a way that seems right to a person,"
    },
    {
      "block_id": "prov-14-13",
      "type": "verse",
      "number": 13,
      "text": "Even in laughter the heart is sad,"
    },
    {
      "block_id": "prov-14-14",
      "type": "verse",
      "number": 14,
      "text": "The perverse get what their ways deserve,"
    },
    {
      "block_id": "prov-14-15",
      "type": "verse",
      "number": 15,
      "text": "The simple believe everything,"
    },
    {
      "block_id": "prov-14-16",
      "type": "verse",
      "number": 16,
      "text": "The wise are cautious and turn away from evil,"
    },
    {
      "block_id": "prov-14-17",
      "type": "verse",
      "number": 17,
      "text": "One who is quick-tempered acts foolishly,"
    },
    {
      "block_id": "prov-14-18",
      "type": "verse",
      "number": 18,
      "text": "The simple are adorned with folly,"
    },
    {
      "block_id": "prov-14-19",
      "type": "verse",
      "number": 19,
      "text": "The evil bow down before the good,"
    },
    {
      "block_id": "prov-14-20",
      "type": "verse",
      "number": 20,
      "text": "The poor are disliked even by their neighbors,"
    },
    {
      "block_id": "prov-14-21",
      "type": "verse",
      "number": 21,
      "text": "Those who despise their neighbors are sinners,"
    },
    {
      "block_id": "prov-14-22",
      "type": "verse",
      "number": 22,
      "text": "Do not those who plan evil err?"
    },
    {
      "block_id": "prov-14-23",
      "type": "verse",
      "number": 23,
      "text": "In all toil there is profit,"
    },
    {
      "block_id": "prov-14-24",
      "type": "verse",
      "number": 24,
      "text": "The crown of the wise is their wealth,"
    },
    {
      "block_id": "prov-14-25",
      "type": "verse",
      "number": 25,
      "text": "A truthful witness saves lives,"
    },
    {
      "block_id": "prov-14-26",
      "type": "verse",
      "number": 26,
      "text": "In the fear of the Lord one has strong confidence,"
    },
    {
      "block_id": "prov-14-27",
      "type": "verse",
      "number": 27,
      "text": "The fear of the Lord is a fountain of life,"
    },
    {
      "block_id": "prov-14-28",
      "type": "verse",
      "number": 28,
      "text": "The glory of a king is a multitude of people;"
    },
    {
      "block_id": "prov-14-29",
      "type": "verse",
      "number": 29,
      "text": "Whoever is slow to anger has great understanding,"
    },
    {
      "block_id": "prov-14-30",
      "type": "verse",
      "number": 30,
      "text": "A tranquil mind gives life to the flesh,"
    },
    {
      "block_id": "prov-14-31",
      "type": "verse",
      "number": 31,
      "text": "Those who oppress the poor insult their Maker,"
    },
    {
      "block_id": "prov-14-32",
      "type": "verse",
      "number": 32,
      "text": "The wicked are overthrown by their evildoing,"
    },
    {
      "block_id": "prov-14-33",
      "type": "verse",
      "number": 33,
      "text": "Wisdom is at home in the mind of one who has understanding,"
    },
    {
      "block_id": "prov-14-34",
      "type": "verse",
      "number": 34,
      "text": "Righteousness exalts a nation,"
    },
    {
      "block_id": "prov-14-35",
      "type": "verse",
      "number": 35,
      "text": "A servant who deals wisely has the king’s favor,"
    }
  ]
}