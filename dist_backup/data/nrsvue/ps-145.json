{
  "document_id": "ps-145",
  "title": "Psalms 145",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-145-1",
      "type": "verse",
      "number": 1,
      "text": "I will extol you, my God and King,"
    },
    {
      "block_id": "ps-145-2",
      "type": "verse",
      "number": 2,
      "text": "Every day I will bless you"
    },
    {
      "block_id": "ps-145-3",
      "type": "verse",
      "number": 3,
      "text": "Great is the Lord and greatly to be praised;"
    },
    {
      "block_id": "ps-145-4",
      "type": "verse",
      "number": 4,
      "text": "One generation shall extol your works to another"
    },
    {
      "block_id": "ps-145-5",
      "type": "verse",
      "number": 5,
      "text": "They will recount the glorious splendor of your majesty,"
    },
    {
      "block_id": "ps-145-6",
      "type": "verse",
      "number": 6,
      "text": "They will proclaim the might of your awesome deeds,"
    },
    {
      "block_id": "ps-145-7",
      "type": "verse",
      "number": 7,
      "text": "They shall celebrate the fame of your abundant goodness"
    },
    {
      "block_id": "ps-145-8",
      "type": "verse",
      "number": 8,
      "text": "The Lord is gracious and merciful,"
    },
    {
      "block_id": "ps-145-9",
      "type": "verse",
      "number": 9,
      "text": "The Lord is good to all,"
    },
    {
      "block_id": "ps-145-10",
      "type": "verse",
      "number": 10,
      "text": "All your works shall give thanks to you, O Lord,"
    },
    {
      "block_id": "ps-145-11",
      "type": "verse",
      "number": 11,
      "text": "They shall speak of the glory of your kingdom"
    },
    {
      "block_id": "ps-145-12",
      "type": "verse",
      "number": 12,
      "text": "to make known to all people your mighty deeds"
    },
    {
      "block_id": "ps-145-13",
      "type": "verse",
      "number": 13,
      "text": "Your kingdom is an everlasting kingdom,"
    },
    {
      "block_id": "ps-145-14",
      "type": "verse",
      "number": 14,
      "text": "The Lord upholds all who are falling"
    },
    {
      "block_id": "ps-145-15",
      "type": "verse",
      "number": 15,
      "text": "The eyes of all look to you,"
    },
    {
      "block_id": "ps-145-16",
      "type": "verse",
      "number": 16,
      "text": "You open your hand,"
    },
    {
      "block_id": "ps-145-17",
      "type": "verse",
      "number": 17,
      "text": "The Lord is just in all his ways"
    },
    {
      "block_id": "ps-145-18",
      "type": "verse",
      "number": 18,
      "text": "The Lord is near to all who call on him,"
    },
    {
      "block_id": "ps-145-19",
      "type": "verse",
      "number": 19,
      "text": "He fulfills the desire of all who fear him;"
    },
    {
      "block_id": "ps-145-20",
      "type": "verse",
      "number": 20,
      "text": "The Lord watches over all who love him,"
    },
    {
      "block_id": "ps-145-21",
      "type": "verse",
      "number": 21,
      "text": "My mouth will speak the praise of the Lord,"
    }
  ]
}