{
  "document_id": "song-7",
  "title": "Song of Songs 7",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "song-7-1",
      "type": "verse",
      "number": 1,
      "text": "How graceful are your feet in sandals,"
    },
    {
      "block_id": "song-7-2",
      "type": "verse",
      "number": 2,
      "text": "Your navel is a rounded bowl;"
    },
    {
      "block_id": "song-7-3",
      "type": "verse",
      "number": 3,
      "text": "Your two breasts are like two fawns,"
    },
    {
      "block_id": "song-7-4",
      "type": "verse",
      "number": 4,
      "text": "Your neck is like an ivory tower."
    },
    {
      "block_id": "song-7-5",
      "type": "verse",
      "number": 5,
      "text": "Your head crowns you like Carmel,"
    },
    {
      "block_id": "song-7-6",
      "type": "verse",
      "number": 6,
      "text": "How fair and pleasant you are,"
    },
    {
      "block_id": "song-7-7",
      "type": "verse",
      "number": 7,
      "text": "You are stately as a palm tree,"
    },
    {
      "block_id": "song-7-8",
      "type": "verse",
      "number": 8,
      "text": "I said, “I will climb the palm tree"
    },
    {
      "block_id": "song-7-9",
      "type": "verse",
      "number": 9,
      "text": "and your kisses like the best wine"
    },
    {
      "block_id": "song-7-10",
      "type": "verse",
      "number": 10,
      "text": "I am my beloved’s,"
    },
    {
      "block_id": "song-7-11",
      "type": "verse",
      "number": 11,
      "text": "Come, my beloved,"
    },
    {
      "block_id": "song-7-12",
      "type": "verse",
      "number": 12,
      "text": "let us go out early to the vineyards;"
    },
    {
      "block_id": "song-7-13",
      "type": "verse",
      "number": 13,
      "text": "The mandrakes give forth fragrance,"
    }
  ]
}