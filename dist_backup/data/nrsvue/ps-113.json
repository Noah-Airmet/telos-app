{
  "document_id": "ps-113",
  "title": "Psalms 113",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-113-1",
      "type": "verse",
      "number": 1,
      "text": "Praise the Lord!"
    },
    {
      "block_id": "ps-113-2",
      "type": "verse",
      "number": 2,
      "text": "Blessed be the name of the Lord"
    },
    {
      "block_id": "ps-113-3",
      "type": "verse",
      "number": 3,
      "text": "From the rising of the sun to its setting,"
    },
    {
      "block_id": "ps-113-4",
      "type": "verse",
      "number": 4,
      "text": "The Lord is high above all nations"
    },
    {
      "block_id": "ps-113-5",
      "type": "verse",
      "number": 5,
      "text": "Who is like the Lord our God,"
    },
    {
      "block_id": "ps-113-6",
      "type": "verse",
      "number": 6,
      "text": "who looks far down"
    },
    {
      "block_id": "ps-113-7",
      "type": "verse",
      "number": 7,
      "text": "He raises the poor from the dust"
    },
    {
      "block_id": "ps-113-8",
      "type": "verse",
      "number": 8,
      "text": "to make them sit with princes,"
    },
    {
      "block_id": "ps-113-9",
      "type": "verse",
      "number": 9,
      "text": "He gives the barren woman a home,"
    }
  ]
}