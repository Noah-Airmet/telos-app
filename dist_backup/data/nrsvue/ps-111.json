{
  "document_id": "ps-111",
  "title": "Psalms 111",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-111-1",
      "type": "verse",
      "number": 1,
      "text": "Praise the Lord!"
    },
    {
      "block_id": "ps-111-2",
      "type": "verse",
      "number": 2,
      "text": "Great are the works of the Lord,"
    },
    {
      "block_id": "ps-111-3",
      "type": "verse",
      "number": 3,
      "text": "Full of honor and majesty is his work,"
    },
    {
      "block_id": "ps-111-4",
      "type": "verse",
      "number": 4,
      "text": "He has gained renown by his wonderful deeds;"
    },
    {
      "block_id": "ps-111-5",
      "type": "verse",
      "number": 5,
      "text": "He provides food for those who fear him;"
    },
    {
      "block_id": "ps-111-6",
      "type": "verse",
      "number": 6,
      "text": "He has shown his people the power of his works,"
    },
    {
      "block_id": "ps-111-7",
      "type": "verse",
      "number": 7,
      "text": "The works of his hands are faithful and just;"
    },
    {
      "block_id": "ps-111-8",
      "type": "verse",
      "number": 8,
      "text": "They are established forever and ever,"
    },
    {
      "block_id": "ps-111-9",
      "type": "verse",
      "number": 9,
      "text": "He sent redemption to his people;"
    },
    {
      "block_id": "ps-111-10",
      "type": "verse",
      "number": 10,
      "text": "The fear of the Lord is the beginning of wisdom;"
    }
  ]
}