{
  "document_id": "hos-10",
  "title": "Hosea 10",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-10-1",
      "type": "verse",
      "number": 1,
      "text": "Israel is a luxuriant vine"
    },
    {
      "block_id": "hos-10-2",
      "type": "verse",
      "number": 2,
      "text": "Their heart is false;"
    },
    {
      "block_id": "hos-10-3",
      "type": "verse",
      "number": 3,
      "text": "For now they will say:"
    },
    {
      "block_id": "hos-10-4",
      "type": "verse",
      "number": 4,
      "text": "They utter mere words;"
    },
    {
      "block_id": "hos-10-5",
      "type": "verse",
      "number": 5,
      "text": "The inhabitants of Samaria tremble"
    },
    {
      "block_id": "hos-10-6",
      "type": "verse",
      "number": 6,
      "text": "The thing itself shall be carried to Assyria"
    },
    {
      "block_id": "hos-10-7",
      "type": "verse",
      "number": 7,
      "text": "Samaria’s king shall perish"
    },
    {
      "block_id": "hos-10-8",
      "type": "verse",
      "number": 8,
      "text": "The high places of Aven, the sin of Israel,"
    },
    {
      "block_id": "hos-10-9",
      "type": "verse",
      "number": 9,
      "text": "Since the days of Gibeah you have sinned, O Israel;"
    },
    {
      "block_id": "hos-10-10",
      "type": "verse",
      "number": 10,
      "text": "I will come against the wayward people to punish them,"
    },
    {
      "block_id": "hos-10-11",
      "type": "verse",
      "number": 11,
      "text": "Ephraim was a trained heifer"
    },
    {
      "block_id": "hos-10-12",
      "type": "verse",
      "number": 12,
      "text": "Sow for yourselves righteousness;"
    },
    {
      "block_id": "hos-10-13",
      "type": "verse",
      "number": 13,
      "text": "You have plowed wickedness;"
    },
    {
      "block_id": "hos-10-14",
      "type": "verse",
      "number": 14,
      "text": "therefore the tumult of war shall rise against your people,"
    },
    {
      "block_id": "hos-10-15",
      "type": "verse",
      "number": 15,
      "text": "Thus it shall be done to you, O Bethel,"
    }
  ]
}