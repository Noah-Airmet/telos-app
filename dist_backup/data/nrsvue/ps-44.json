{
  "document_id": "ps-44",
  "title": "Psalms 44",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-44-1",
      "type": "verse",
      "number": 1,
      "text": "We have heard with our ears, O God;"
    },
    {
      "block_id": "ps-44-2",
      "type": "verse",
      "number": 2,
      "text": "you with your own hand drove out the nations,"
    },
    {
      "block_id": "ps-44-3",
      "type": "verse",
      "number": 3,
      "text": "for not by their own sword did they win the land,"
    },
    {
      "block_id": "ps-44-4",
      "type": "verse",
      "number": 4,
      "text": "You are my King and my God;"
    },
    {
      "block_id": "ps-44-5",
      "type": "verse",
      "number": 5,
      "text": "Through you we push down our foes;"
    },
    {
      "block_id": "ps-44-6",
      "type": "verse",
      "number": 6,
      "text": "For not in my bow do I trust,"
    },
    {
      "block_id": "ps-44-7",
      "type": "verse",
      "number": 7,
      "text": "But you have saved us from our foes"
    },
    {
      "block_id": "ps-44-8",
      "type": "verse",
      "number": 8,
      "text": "In God we have boasted continually,"
    },
    {
      "block_id": "ps-44-9",
      "type": "verse",
      "number": 9,
      "text": "Yet you have rejected us and shamed us"
    },
    {
      "block_id": "ps-44-10",
      "type": "verse",
      "number": 10,
      "text": "You made us turn back from the foe,"
    },
    {
      "block_id": "ps-44-11",
      "type": "verse",
      "number": 11,
      "text": "You have made us like sheep for slaughter"
    },
    {
      "block_id": "ps-44-12",
      "type": "verse",
      "number": 12,
      "text": "You have sold your people for a trifle,"
    },
    {
      "block_id": "ps-44-13",
      "type": "verse",
      "number": 13,
      "text": "You have made us the taunt of our neighbors,"
    },
    {
      "block_id": "ps-44-14",
      "type": "verse",
      "number": 14,
      "text": "You have made us a byword among the nations,"
    },
    {
      "block_id": "ps-44-15",
      "type": "verse",
      "number": 15,
      "text": "All day long my disgrace is before me,"
    },
    {
      "block_id": "ps-44-16",
      "type": "verse",
      "number": 16,
      "text": "at the words of the taunters and revilers,"
    },
    {
      "block_id": "ps-44-17",
      "type": "verse",
      "number": 17,
      "text": "All this has come upon us,"
    },
    {
      "block_id": "ps-44-18",
      "type": "verse",
      "number": 18,
      "text": "Our heart has not turned back,"
    },
    {
      "block_id": "ps-44-19",
      "type": "verse",
      "number": 19,
      "text": "yet you have broken us in the haunt of jackals"
    },
    {
      "block_id": "ps-44-20",
      "type": "verse",
      "number": 20,
      "text": "If we had forgotten the name of our God"
    },
    {
      "block_id": "ps-44-21",
      "type": "verse",
      "number": 21,
      "text": "would not God discover this?"
    },
    {
      "block_id": "ps-44-22",
      "type": "verse",
      "number": 22,
      "text": "Because of you we are being killed all day long"
    },
    {
      "block_id": "ps-44-23",
      "type": "verse",
      "number": 23,
      "text": "Rouse yourself! Why do you sleep, O Lord?"
    },
    {
      "block_id": "ps-44-24",
      "type": "verse",
      "number": 24,
      "text": "Why do you hide your face?"
    },
    {
      "block_id": "ps-44-25",
      "type": "verse",
      "number": 25,
      "text": "For we sink down to the dust;"
    },
    {
      "block_id": "ps-44-26",
      "type": "verse",
      "number": 26,
      "text": "Rise up, come to our help."
    }
  ]
}