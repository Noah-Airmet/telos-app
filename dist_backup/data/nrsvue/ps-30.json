{
  "document_id": "ps-30",
  "title": "Psalms 30",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-30-1",
      "type": "verse",
      "number": 1,
      "text": "I will extol you, O Lord, for you have drawn me up"
    },
    {
      "block_id": "ps-30-2",
      "type": "verse",
      "number": 2,
      "text": "O Lord my God, I cried to you for help,"
    },
    {
      "block_id": "ps-30-3",
      "type": "verse",
      "number": 3,
      "text": "O Lord, you brought up my soul from Sheol,"
    },
    {
      "block_id": "ps-30-4",
      "type": "verse",
      "number": 4,
      "text": "Sing praises to the Lord, O you his faithful ones,"
    },
    {
      "block_id": "ps-30-5",
      "type": "verse",
      "number": 5,
      "text": "For his anger is but for a moment;"
    },
    {
      "block_id": "ps-30-6",
      "type": "verse",
      "number": 6,
      "text": "As for me, I said in my prosperity,"
    },
    {
      "block_id": "ps-30-7",
      "type": "verse",
      "number": 7,
      "text": "By your favor, O Lord,"
    },
    {
      "block_id": "ps-30-8",
      "type": "verse",
      "number": 8,
      "text": "To you, O Lord, I cried,"
    },
    {
      "block_id": "ps-30-9",
      "type": "verse",
      "number": 9,
      "text": "“What profit is there in my death,"
    },
    {
      "block_id": "ps-30-10",
      "type": "verse",
      "number": 10,
      "text": "Hear, O Lord, and be gracious to me!"
    },
    {
      "block_id": "ps-30-11",
      "type": "verse",
      "number": 11,
      "text": "You have turned my mourning into dancing;"
    },
    {
      "block_id": "ps-30-12",
      "type": "verse",
      "number": 12,
      "text": "so that my soul may praise you and not be silent."
    }
  ]
}