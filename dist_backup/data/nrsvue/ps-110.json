{
  "document_id": "ps-110",
  "title": "Psalms 110",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-110-1",
      "type": "verse",
      "number": 1,
      "text": "The Lord says to my lord,"
    },
    {
      "block_id": "ps-110-2",
      "type": "verse",
      "number": 2,
      "text": "The Lord sends out from Zion"
    },
    {
      "block_id": "ps-110-3",
      "type": "verse",
      "number": 3,
      "text": "Your people will offer themselves willingly"
    },
    {
      "block_id": "ps-110-4",
      "type": "verse",
      "number": 4,
      "text": "The Lord has sworn and will not change his mind,"
    },
    {
      "block_id": "ps-110-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord is at your right hand;"
    },
    {
      "block_id": "ps-110-6",
      "type": "verse",
      "number": 6,
      "text": "He will execute judgment among the nations,"
    },
    {
      "block_id": "ps-110-7",
      "type": "verse",
      "number": 7,
      "text": "He will drink from the stream by the path;"
    }
  ]
}