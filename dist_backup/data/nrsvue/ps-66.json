{
  "document_id": "ps-66",
  "title": "Psalms 66",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-66-1",
      "type": "verse",
      "number": 1,
      "text": "Make a joyful noise to God, all the earth;"
    },
    {
      "block_id": "ps-66-2",
      "type": "verse",
      "number": 2,
      "text": "sing the glory of his name;"
    },
    {
      "block_id": "ps-66-3",
      "type": "verse",
      "number": 3,
      "text": "Say to God, “How awesome are your deeds!"
    },
    {
      "block_id": "ps-66-4",
      "type": "verse",
      "number": 4,
      "text": "All the earth worships you;"
    },
    {
      "block_id": "ps-66-5",
      "type": "verse",
      "number": 5,
      "text": "Come and see what God has done:"
    },
    {
      "block_id": "ps-66-6",
      "type": "verse",
      "number": 6,
      "text": "He turned the sea into dry land;"
    },
    {
      "block_id": "ps-66-7",
      "type": "verse",
      "number": 7,
      "text": "who rules by his might forever,"
    },
    {
      "block_id": "ps-66-8",
      "type": "verse",
      "number": 8,
      "text": "Bless our God, O peoples;"
    },
    {
      "block_id": "ps-66-9",
      "type": "verse",
      "number": 9,
      "text": "who has kept us among the living"
    },
    {
      "block_id": "ps-66-10",
      "type": "verse",
      "number": 10,
      "text": "For you, O God, have tested us;"
    },
    {
      "block_id": "ps-66-11",
      "type": "verse",
      "number": 11,
      "text": "You brought us into the net;"
    },
    {
      "block_id": "ps-66-12",
      "type": "verse",
      "number": 12,
      "text": "you let people ride over our heads;"
    },
    {
      "block_id": "ps-66-13",
      "type": "verse",
      "number": 13,
      "text": "I will come into your house with burnt offerings;"
    },
    {
      "block_id": "ps-66-14",
      "type": "verse",
      "number": 14,
      "text": "those that my lips uttered"
    },
    {
      "block_id": "ps-66-15",
      "type": "verse",
      "number": 15,
      "text": "I will offer to you burnt offerings of fatted calves,"
    },
    {
      "block_id": "ps-66-16",
      "type": "verse",
      "number": 16,
      "text": "Come and hear, all you who fear God,"
    },
    {
      "block_id": "ps-66-17",
      "type": "verse",
      "number": 17,
      "text": "I cried aloud to him,"
    },
    {
      "block_id": "ps-66-18",
      "type": "verse",
      "number": 18,
      "text": "If I had cherished iniquity in my heart,"
    },
    {
      "block_id": "ps-66-19",
      "type": "verse",
      "number": 19,
      "text": "But truly God has listened;"
    },
    {
      "block_id": "ps-66-20",
      "type": "verse",
      "number": 20,
      "text": "Blessed be God,"
    }
  ]
}