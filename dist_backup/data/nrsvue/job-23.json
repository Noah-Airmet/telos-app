{
  "document_id": "job-23",
  "title": "Job 23",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-23-heading-job-replies:-my-comp",
      "type": "heading",
      "text": "Job Replies: My Complaint Is Bitter"
    },
    {
      "block_id": "job-23-1",
      "type": "verse",
      "number": 1,
      "text": "Then Job answered:"
    },
    {
      "block_id": "job-23-2",
      "type": "verse",
      "number": 2,
      "text": "“Today also my complaint is bitter;"
    },
    {
      "block_id": "job-23-3",
      "type": "verse",
      "number": 3,
      "text": "Oh, that I knew where I might find him,"
    },
    {
      "block_id": "job-23-4",
      "type": "verse",
      "number": 4,
      "text": "I would lay my case before him"
    },
    {
      "block_id": "job-23-5",
      "type": "verse",
      "number": 5,
      "text": "I would learn what he would answer me"
    },
    {
      "block_id": "job-23-6",
      "type": "verse",
      "number": 6,
      "text": "Would he contend with me in the greatness of his power?"
    },
    {
      "block_id": "job-23-7",
      "type": "verse",
      "number": 7,
      "text": "There the upright could reason with him,"
    },
    {
      "block_id": "job-23-8",
      "type": "verse",
      "number": 8,
      "text": "“If I go forward, he is not there;"
    },
    {
      "block_id": "job-23-9",
      "type": "verse",
      "number": 9,
      "text": "on the left he hides, and I cannot behold him;"
    },
    {
      "block_id": "job-23-10",
      "type": "verse",
      "number": 10,
      "text": "But he knows the way that I take;"
    },
    {
      "block_id": "job-23-11",
      "type": "verse",
      "number": 11,
      "text": "My foot has held fast to his steps;"
    },
    {
      "block_id": "job-23-12",
      "type": "verse",
      "number": 12,
      "text": "I have not departed from the commandment of his lips;"
    },
    {
      "block_id": "job-23-13",
      "type": "verse",
      "number": 13,
      "text": "But he stands alone, and who can dissuade him?"
    },
    {
      "block_id": "job-23-14",
      "type": "verse",
      "number": 14,
      "text": "For he will complete what he appoints for me,"
    },
    {
      "block_id": "job-23-15",
      "type": "verse",
      "number": 15,
      "text": "Therefore I am terrified at his presence;"
    },
    {
      "block_id": "job-23-16",
      "type": "verse",
      "number": 16,
      "text": "God has made my heart faint;"
    },
    {
      "block_id": "job-23-17",
      "type": "verse",
      "number": 17,
      "text": "If only I could vanish in darkness,"
    }
  ]
}