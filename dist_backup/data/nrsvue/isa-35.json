{
  "document_id": "isa-35",
  "title": "Isaiah 35",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-35-1",
      "type": "verse",
      "number": 1,
      "text": "The wilderness and the dry land shall be glad;"
    },
    {
      "block_id": "isa-35-2",
      "type": "verse",
      "number": 2,
      "text": "it shall blossom abundantly"
    },
    {
      "block_id": "isa-35-3",
      "type": "verse",
      "number": 3,
      "text": "Strengthen the weak hands"
    },
    {
      "block_id": "isa-35-4",
      "type": "verse",
      "number": 4,
      "text": "Say to those who are of a fearful heart,"
    },
    {
      "block_id": "isa-35-5",
      "type": "verse",
      "number": 5,
      "text": "Then the eyes of the blind shall be opened,"
    },
    {
      "block_id": "isa-35-6",
      "type": "verse",
      "number": 6,
      "text": "then the lame shall leap like a deer,"
    },
    {
      "block_id": "isa-35-7",
      "type": "verse",
      "number": 7,
      "text": "the burning sand shall become a pool"
    },
    {
      "block_id": "isa-35-8",
      "type": "verse",
      "number": 8,
      "text": "A highway shall be there,"
    },
    {
      "block_id": "isa-35-9",
      "type": "verse",
      "number": 9,
      "text": "No lion shall be there,"
    },
    {
      "block_id": "isa-35-10",
      "type": "verse",
      "number": 10,
      "text": "And the ransomed of the Lord shall return"
    }
  ]
}