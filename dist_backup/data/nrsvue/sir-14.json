{
  "document_id": "sir-14",
  "title": "Sirach 14",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-14-1",
      "type": "verse",
      "number": 1,
      "text": "Happy are those who do not blunder with their lips"
    },
    {
      "block_id": "sir-14-2",
      "type": "verse",
      "number": 2,
      "text": "Happy are those whose hearts do not condemn them"
    },
    {
      "block_id": "sir-14-3",
      "type": "verse",
      "number": 3,
      "text": "Riches are inappropriate for the small-minded,"
    },
    {
      "block_id": "sir-14-4",
      "type": "verse",
      "number": 4,
      "text": "What they deny themselves they collect for others,"
    },
    {
      "block_id": "sir-14-5",
      "type": "verse",
      "number": 5,
      "text": "If they are mean to themselves, to whom will they be generous?"
    },
    {
      "block_id": "sir-14-6",
      "type": "verse",
      "number": 6,
      "text": "No one is worse than those who are grudging to themselves;"
    },
    {
      "block_id": "sir-14-7",
      "type": "verse",
      "number": 7,
      "text": "If ever they do good, it is by mistake,"
    },
    {
      "block_id": "sir-14-8",
      "type": "verse",
      "number": 8,
      "text": "Misers are evil people;"
    },
    {
      "block_id": "sir-14-9",
      "type": "verse",
      "number": 9,
      "text": "The eyes of the greedy are not satisfied with their share;"
    },
    {
      "block_id": "sir-14-10",
      "type": "verse",
      "number": 10,
      "text": "Misers begrudge bread,"
    },
    {
      "block_id": "sir-14-11",
      "type": "verse",
      "number": 11,
      "text": "My child, treat yourself well, according to your means,"
    },
    {
      "block_id": "sir-14-12",
      "type": "verse",
      "number": 12,
      "text": "Remember that death does not tarry,"
    },
    {
      "block_id": "sir-14-13",
      "type": "verse",
      "number": 13,
      "text": "Do good to friends before you die,"
    },
    {
      "block_id": "sir-14-14",
      "type": "verse",
      "number": 14,
      "text": "Do not deprive yourself of a day’s enjoyment;"
    },
    {
      "block_id": "sir-14-15",
      "type": "verse",
      "number": 15,
      "text": "Will you not leave the fruit of your labors to another,"
    },
    {
      "block_id": "sir-14-16",
      "type": "verse",
      "number": 16,
      "text": "Give and take and indulge yourself,"
    },
    {
      "block_id": "sir-14-17",
      "type": "verse",
      "number": 17,
      "text": "All living beings become old like a garment,"
    },
    {
      "block_id": "sir-14-18",
      "type": "verse",
      "number": 18,
      "text": "Like abundant leaves on a spreading tree"
    },
    {
      "block_id": "sir-14-19",
      "type": "verse",
      "number": 19,
      "text": "Every work decays and ceases to exist,"
    },
    {
      "block_id": "sir-14-20",
      "type": "verse",
      "number": 20,
      "text": "Happy are those who meditate on wisdom"
    },
    {
      "block_id": "sir-14-21",
      "type": "verse",
      "number": 21,
      "text": "who reflect in their hearts on her ways"
    },
    {
      "block_id": "sir-14-22",
      "type": "verse",
      "number": 22,
      "text": "pursuing her like a hunter"
    },
    {
      "block_id": "sir-14-23",
      "type": "verse",
      "number": 23,
      "text": "who peer through her windows"
    },
    {
      "block_id": "sir-14-24",
      "type": "verse",
      "number": 24,
      "text": "who camp near her house"
    },
    {
      "block_id": "sir-14-25",
      "type": "verse",
      "number": 25,
      "text": "who pitch their tents near her"
    },
    {
      "block_id": "sir-14-26",
      "type": "verse",
      "number": 26,
      "text": "who place their children under her shelter"
    },
    {
      "block_id": "sir-14-27",
      "type": "verse",
      "number": 27,
      "text": "who are sheltered by her from the heat"
    }
  ]
}