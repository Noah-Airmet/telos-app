{
  "document_id": "ps-5",
  "title": "Psalms 5",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-5-1",
      "type": "verse",
      "number": 1,
      "text": "Listen to my words, O Lord;"
    },
    {
      "block_id": "ps-5-2",
      "type": "verse",
      "number": 2,
      "text": "Listen to the sound of my cry,"
    },
    {
      "block_id": "ps-5-3",
      "type": "verse",
      "number": 3,
      "text": "O Lord, in the morning you hear my voice;"
    },
    {
      "block_id": "ps-5-4",
      "type": "verse",
      "number": 4,
      "text": "For you are not a God who delights in wickedness;"
    },
    {
      "block_id": "ps-5-5",
      "type": "verse",
      "number": 5,
      "text": "The boastful will not stand before your eyes;"
    },
    {
      "block_id": "ps-5-6",
      "type": "verse",
      "number": 6,
      "text": "You destroy those who speak lies;"
    },
    {
      "block_id": "ps-5-7",
      "type": "verse",
      "number": 7,
      "text": "But I, through the abundance of your steadfast love,"
    },
    {
      "block_id": "ps-5-8",
      "type": "verse",
      "number": 8,
      "text": "Lead me, O Lord, in your righteousness"
    },
    {
      "block_id": "ps-5-9",
      "type": "verse",
      "number": 9,
      "text": "For there is no truth in their mouths;"
    },
    {
      "block_id": "ps-5-10",
      "type": "verse",
      "number": 10,
      "text": "Make them bear their guilt, O God;"
    },
    {
      "block_id": "ps-5-11",
      "type": "verse",
      "number": 11,
      "text": "But let all who take refuge in you rejoice;"
    },
    {
      "block_id": "ps-5-12",
      "type": "verse",
      "number": 12,
      "text": "For you bless the righteous, O Lord;"
    }
  ]
}