{
  "document_id": "isa-60",
  "title": "Isaiah 60",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-60-1",
      "type": "verse",
      "number": 1,
      "text": "Arise, shine, for your light has come,"
    },
    {
      "block_id": "isa-60-2",
      "type": "verse",
      "number": 2,
      "text": "For darkness shall cover the earth"
    },
    {
      "block_id": "isa-60-3",
      "type": "verse",
      "number": 3,
      "text": "Nations shall come to your light"
    },
    {
      "block_id": "isa-60-4",
      "type": "verse",
      "number": 4,
      "text": "Lift up your eyes and look around;"
    },
    {
      "block_id": "isa-60-5",
      "type": "verse",
      "number": 5,
      "text": "Then you shall see and be radiant;"
    },
    {
      "block_id": "isa-60-6",
      "type": "verse",
      "number": 6,
      "text": "A multitude of camels shall cover you,"
    },
    {
      "block_id": "isa-60-7",
      "type": "verse",
      "number": 7,
      "text": "All the flocks of Kedar shall be gathered to you;"
    },
    {
      "block_id": "isa-60-8",
      "type": "verse",
      "number": 8,
      "text": "Who are these that fly like a cloud"
    },
    {
      "block_id": "isa-60-9",
      "type": "verse",
      "number": 9,
      "text": "For the coastlands shall wait for me,"
    },
    {
      "block_id": "isa-60-10",
      "type": "verse",
      "number": 10,
      "text": "Foreigners shall build up your walls,"
    },
    {
      "block_id": "isa-60-11",
      "type": "verse",
      "number": 11,
      "text": "Your gates shall always be open;"
    },
    {
      "block_id": "isa-60-12",
      "type": "verse",
      "number": 12,
      "text": "For the nation and kingdom"
    },
    {
      "block_id": "isa-60-13",
      "type": "verse",
      "number": 13,
      "text": "The glory of Lebanon shall come to you,"
    },
    {
      "block_id": "isa-60-14",
      "type": "verse",
      "number": 14,
      "text": "The descendants of those who oppressed you"
    },
    {
      "block_id": "isa-60-15",
      "type": "verse",
      "number": 15,
      "text": "Whereas you have been forsaken and hated,"
    },
    {
      "block_id": "isa-60-16",
      "type": "verse",
      "number": 16,
      "text": "You shall suck the milk of nations;"
    },
    {
      "block_id": "isa-60-17",
      "type": "verse",
      "number": 17,
      "text": "Instead of bronze I will bring gold;"
    },
    {
      "block_id": "isa-60-18",
      "type": "verse",
      "number": 18,
      "text": "Violence shall no more be heard in your land,"
    },
    {
      "block_id": "isa-60-19",
      "type": "verse",
      "number": 19,
      "text": "The sun shall no longer be"
    },
    {
      "block_id": "isa-60-20",
      "type": "verse",
      "number": 20,
      "text": "Your sun shall no more go down"
    },
    {
      "block_id": "isa-60-21",
      "type": "verse",
      "number": 21,
      "text": "Your people shall all be righteous;"
    },
    {
      "block_id": "isa-60-22",
      "type": "verse",
      "number": 22,
      "text": "The least of them shall become a clan"
    }
  ]
}