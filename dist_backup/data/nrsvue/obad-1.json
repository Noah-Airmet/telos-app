{
  "document_id": "obad-1",
  "title": "Obadiah 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "obad-1-heading-proud-edom-will-be-b",
      "type": "heading",
      "text": "Proud Edom Will Be Brought Low"
    },
    {
      "block_id": "obad-1-1",
      "type": "verse",
      "number": 1,
      "text": "The vision of Obadiah."
    },
    {
      "block_id": "obad-1-2",
      "type": "verse",
      "number": 2,
      "text": "I will surely make you least among the nations;"
    },
    {
      "block_id": "obad-1-3",
      "type": "verse",
      "number": 3,
      "text": "Your proud heart has deceived you,"
    },
    {
      "block_id": "obad-1-4",
      "type": "verse",
      "number": 4,
      "text": "Though you soar aloft like the eagle,"
    },
    {
      "block_id": "obad-1-5",
      "type": "verse",
      "number": 5,
      "text": "If thieves came to you,"
    },
    {
      "block_id": "obad-1-6",
      "type": "verse",
      "number": 6,
      "text": "How Esau has been pillaged,"
    },
    {
      "block_id": "obad-1-7",
      "type": "verse",
      "number": 7,
      "text": "All your allies have deceived you;"
    },
    {
      "block_id": "obad-1-8",
      "type": "verse",
      "number": 8,
      "text": "On that day, says the Lord,"
    },
    {
      "block_id": "obad-1-9",
      "type": "verse",
      "number": 9,
      "text": "Your warriors shall be shattered, O Teman,"
    },
    {
      "block_id": "obad-1-10",
      "type": "verse",
      "number": 10,
      "text": "For the slaughter and violence done to your brother Jacob,"
    },
    {
      "block_id": "obad-1-11",
      "type": "verse",
      "number": 11,
      "text": "On the day that you stood aside,"
    },
    {
      "block_id": "obad-1-12",
      "type": "verse",
      "number": 12,
      "text": "But you should not have gloated over your brother"
    },
    {
      "block_id": "obad-1-13",
      "type": "verse",
      "number": 13,
      "text": "You should not have entered the gate of my people"
    },
    {
      "block_id": "obad-1-14",
      "type": "verse",
      "number": 14,
      "text": "You should not have stood at the crossings"
    },
    {
      "block_id": "obad-1-15",
      "type": "verse",
      "number": 15,
      "text": "For the day of the Lord is near against all the nations."
    },
    {
      "block_id": "obad-1-16",
      "type": "verse",
      "number": 16,
      "text": "For as you have drunk on my holy mountain,"
    },
    {
      "block_id": "obad-1-17",
      "type": "verse",
      "number": 17,
      "text": "But on Mount Zion there shall be those who escape,"
    },
    {
      "block_id": "obad-1-18",
      "type": "verse",
      "number": 18,
      "text": "The house of Jacob shall be a fire,"
    },
    {
      "block_id": "obad-1-19",
      "type": "verse",
      "number": 19,
      "text": "Those of the Negeb shall possess Mount Esau,"
    },
    {
      "block_id": "obad-1-20",
      "type": "verse",
      "number": 20,
      "text": "The exiles of the Israelites who are in Halah"
    },
    {
      "block_id": "obad-1-21",
      "type": "verse",
      "number": 21,
      "text": "Those who have been saved shall go up to Mount Zion"
    }
  ]
}