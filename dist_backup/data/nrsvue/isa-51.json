{
  "document_id": "isa-51",
  "title": "Isaiah 51",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-51-1",
      "type": "verse",
      "number": 1,
      "text": "Listen to me, you who pursue righteousness,"
    },
    {
      "block_id": "isa-51-2",
      "type": "verse",
      "number": 2,
      "text": "Look to Abraham your father"
    },
    {
      "block_id": "isa-51-3",
      "type": "verse",
      "number": 3,
      "text": "For the Lord will comfort Zion;"
    },
    {
      "block_id": "isa-51-4",
      "type": "verse",
      "number": 4,
      "text": "Listen to me, my people,"
    },
    {
      "block_id": "isa-51-5",
      "type": "verse",
      "number": 5,
      "text": "I will bring near my deliverance swiftly;"
    },
    {
      "block_id": "isa-51-6",
      "type": "verse",
      "number": 6,
      "text": "Lift up your eyes to the heavens"
    },
    {
      "block_id": "isa-51-7",
      "type": "verse",
      "number": 7,
      "text": "Listen to me, you who know righteousness,"
    },
    {
      "block_id": "isa-51-8",
      "type": "verse",
      "number": 8,
      "text": "For the moth will eat them up like a garment,"
    },
    {
      "block_id": "isa-51-9",
      "type": "verse",
      "number": 9,
      "text": "Awake, awake, put on strength,"
    },
    {
      "block_id": "isa-51-10",
      "type": "verse",
      "number": 10,
      "text": "Was it not you who dried up the sea,"
    },
    {
      "block_id": "isa-51-11",
      "type": "verse",
      "number": 11,
      "text": "So the ransomed of the Lord shall return"
    },
    {
      "block_id": "isa-51-12",
      "type": "verse",
      "number": 12,
      "text": "I, I am he who comforts you;"
    },
    {
      "block_id": "isa-51-13",
      "type": "verse",
      "number": 13,
      "text": "You have forgotten the Lord, your Maker,"
    },
    {
      "block_id": "isa-51-14",
      "type": "verse",
      "number": 14,
      "text": "The oppressed shall speedily be released;"
    },
    {
      "block_id": "isa-51-15",
      "type": "verse",
      "number": 15,
      "text": "For I am the Lord your God,"
    },
    {
      "block_id": "isa-51-16",
      "type": "verse",
      "number": 16,
      "text": "I have put my words in your mouth"
    },
    {
      "block_id": "isa-51-17",
      "type": "verse",
      "number": 17,
      "text": "Rouse yourself, rouse yourself!"
    },
    {
      "block_id": "isa-51-18",
      "type": "verse",
      "number": 18,
      "text": "There is no one to guide her"
    },
    {
      "block_id": "isa-51-19",
      "type": "verse",
      "number": 19,
      "text": "These two things have befallen you"
    },
    {
      "block_id": "isa-51-20",
      "type": "verse",
      "number": 20,
      "text": "Your children have fainted;"
    },
    {
      "block_id": "isa-51-21",
      "type": "verse",
      "number": 21,
      "text": "Therefore hear this, you who are wounded,"
    },
    {
      "block_id": "isa-51-22",
      "type": "verse",
      "number": 22,
      "text": "Thus says your Sovereign, the Lord,"
    },
    {
      "block_id": "isa-51-23",
      "type": "verse",
      "number": 23,
      "text": "And I will put it into the hand of your tormentors,"
    }
  ]
}