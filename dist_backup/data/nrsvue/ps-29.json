{
  "document_id": "ps-29",
  "title": "Psalms 29",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-29-1",
      "type": "verse",
      "number": 1,
      "text": "Ascribe to the Lord, O heavenly beings,"
    },
    {
      "block_id": "ps-29-2",
      "type": "verse",
      "number": 2,
      "text": "Ascribe to the Lord the glory of his name;"
    },
    {
      "block_id": "ps-29-3",
      "type": "verse",
      "number": 3,
      "text": "The voice of the Lord is over the waters;"
    },
    {
      "block_id": "ps-29-4",
      "type": "verse",
      "number": 4,
      "text": "The voice of the Lord is powerful;"
    },
    {
      "block_id": "ps-29-5",
      "type": "verse",
      "number": 5,
      "text": "The voice of the Lord breaks the cedars;"
    },
    {
      "block_id": "ps-29-6",
      "type": "verse",
      "number": 6,
      "text": "He makes Lebanon skip like a calf"
    },
    {
      "block_id": "ps-29-7",
      "type": "verse",
      "number": 7,
      "text": "The voice of the Lord flashes forth flames of fire."
    },
    {
      "block_id": "ps-29-8",
      "type": "verse",
      "number": 8,
      "text": "The voice of the Lord shakes the wilderness;"
    },
    {
      "block_id": "ps-29-9",
      "type": "verse",
      "number": 9,
      "text": "The voice of the Lord causes the oaks to whirl"
    },
    {
      "block_id": "ps-29-10",
      "type": "verse",
      "number": 10,
      "text": "The Lord sits enthroned over the flood;"
    },
    {
      "block_id": "ps-29-11",
      "type": "verse",
      "number": 11,
      "text": "May the Lord give strength to his people!"
    }
  ]
}