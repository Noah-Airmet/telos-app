{
  "document_id": "ps-139",
  "title": "Psalms 139",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-139-1",
      "type": "verse",
      "number": 1,
      "text": "O Lord, you have searched me and known me."
    },
    {
      "block_id": "ps-139-2",
      "type": "verse",
      "number": 2,
      "text": "You know when I sit down and when I rise up;"
    },
    {
      "block_id": "ps-139-3",
      "type": "verse",
      "number": 3,
      "text": "You search out my path and my lying down"
    },
    {
      "block_id": "ps-139-4",
      "type": "verse",
      "number": 4,
      "text": "Even before a word is on my tongue,"
    },
    {
      "block_id": "ps-139-5",
      "type": "verse",
      "number": 5,
      "text": "You hem me in, behind and before,"
    },
    {
      "block_id": "ps-139-6",
      "type": "verse",
      "number": 6,
      "text": "Such knowledge is too wonderful for me;"
    },
    {
      "block_id": "ps-139-7",
      "type": "verse",
      "number": 7,
      "text": "Where can I go from your spirit?"
    },
    {
      "block_id": "ps-139-8",
      "type": "verse",
      "number": 8,
      "text": "If I ascend to heaven, you are there;"
    },
    {
      "block_id": "ps-139-9",
      "type": "verse",
      "number": 9,
      "text": "If I take the wings of the morning"
    },
    {
      "block_id": "ps-139-10",
      "type": "verse",
      "number": 10,
      "text": "even there your hand shall lead me,"
    },
    {
      "block_id": "ps-139-11",
      "type": "verse",
      "number": 11,
      "text": "If I say, “Surely the darkness shall cover me,"
    },
    {
      "block_id": "ps-139-12",
      "type": "verse",
      "number": 12,
      "text": "even the darkness is not dark to you;"
    },
    {
      "block_id": "ps-139-13",
      "type": "verse",
      "number": 13,
      "text": "For it was you who formed my inward parts;"
    },
    {
      "block_id": "ps-139-14",
      "type": "verse",
      "number": 14,
      "text": "I praise you, for I am fearfully and wonderfully made."
    },
    {
      "block_id": "ps-139-15",
      "type": "verse",
      "number": 15,
      "text": "My frame was not hidden from you,"
    },
    {
      "block_id": "ps-139-16",
      "type": "verse",
      "number": 16,
      "text": "Your eyes beheld my unformed substance."
    },
    {
      "block_id": "ps-139-17",
      "type": "verse",
      "number": 17,
      "text": "How weighty to me are your thoughts, O God!"
    },
    {
      "block_id": "ps-139-18",
      "type": "verse",
      "number": 18,
      "text": "I try to count them—they are more than the sand;"
    },
    {
      "block_id": "ps-139-19",
      "type": "verse",
      "number": 19,
      "text": "O that you would kill the wicked, O God,"
    },
    {
      "block_id": "ps-139-20",
      "type": "verse",
      "number": 20,
      "text": "those who speak of you maliciously"
    },
    {
      "block_id": "ps-139-21",
      "type": "verse",
      "number": 21,
      "text": "Do I not hate those who hate you, O Lord?"
    },
    {
      "block_id": "ps-139-22",
      "type": "verse",
      "number": 22,
      "text": "I hate them with perfect hatred;"
    },
    {
      "block_id": "ps-139-23",
      "type": "verse",
      "number": 23,
      "text": "Search me, O God, and know my heart;"
    },
    {
      "block_id": "ps-139-24",
      "type": "verse",
      "number": 24,
      "text": "See if there is any wicked way in me,"
    }
  ]
}