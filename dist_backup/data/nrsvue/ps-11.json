{
  "document_id": "ps-11",
  "title": "Psalms 11",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-11-1",
      "type": "verse",
      "number": 1,
      "text": "In the Lord I take refuge; how can you say to me,"
    },
    {
      "block_id": "ps-11-2",
      "type": "verse",
      "number": 2,
      "text": "for look, the wicked bend the bow,"
    },
    {
      "block_id": "ps-11-3",
      "type": "verse",
      "number": 3,
      "text": "If the foundations are destroyed,"
    },
    {
      "block_id": "ps-11-4",
      "type": "verse",
      "number": 4,
      "text": "The Lord is in his holy temple;"
    },
    {
      "block_id": "ps-11-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord tests the righteous and the wicked,"
    },
    {
      "block_id": "ps-11-6",
      "type": "verse",
      "number": 6,
      "text": "On the wicked he will rain coals of fire and sulfur;"
    },
    {
      "block_id": "ps-11-7",
      "type": "verse",
      "number": 7,
      "text": "For the Lord is righteous;"
    }
  ]
}