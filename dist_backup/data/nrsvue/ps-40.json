{
  "document_id": "ps-40",
  "title": "Psalms 40",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-40-1",
      "type": "verse",
      "number": 1,
      "text": "I waited patiently for the Lord;"
    },
    {
      "block_id": "ps-40-2",
      "type": "verse",
      "number": 2,
      "text": "He drew me up from the desolate pit,"
    },
    {
      "block_id": "ps-40-3",
      "type": "verse",
      "number": 3,
      "text": "He put a new song in my mouth,"
    },
    {
      "block_id": "ps-40-4",
      "type": "verse",
      "number": 4,
      "text": "Happy are those who make"
    },
    {
      "block_id": "ps-40-5",
      "type": "verse",
      "number": 5,
      "text": "You have multiplied, O Lord my God,"
    },
    {
      "block_id": "ps-40-6",
      "type": "verse",
      "number": 6,
      "text": "Sacrifice and offering you do not desire,"
    },
    {
      "block_id": "ps-40-7",
      "type": "verse",
      "number": 7,
      "text": "Then I said, “Here I am;"
    },
    {
      "block_id": "ps-40-8",
      "type": "verse",
      "number": 8,
      "text": "I delight to do your will, O my God;"
    },
    {
      "block_id": "ps-40-9",
      "type": "verse",
      "number": 9,
      "text": "I have told the glad news of deliverance"
    },
    {
      "block_id": "ps-40-10",
      "type": "verse",
      "number": 10,
      "text": "I have not hidden your saving help within my heart;"
    },
    {
      "block_id": "ps-40-11",
      "type": "verse",
      "number": 11,
      "text": "Do not, O Lord, withhold"
    },
    {
      "block_id": "ps-40-12",
      "type": "verse",
      "number": 12,
      "text": "For evils have encompassed me"
    },
    {
      "block_id": "ps-40-13",
      "type": "verse",
      "number": 13,
      "text": "Be pleased, O Lord, to deliver me;"
    },
    {
      "block_id": "ps-40-14",
      "type": "verse",
      "number": 14,
      "text": "Let all those be put to shame and confusion"
    },
    {
      "block_id": "ps-40-15",
      "type": "verse",
      "number": 15,
      "text": "Let those be appalled because of their shame"
    },
    {
      "block_id": "ps-40-16",
      "type": "verse",
      "number": 16,
      "text": "But may all who seek you"
    },
    {
      "block_id": "ps-40-17",
      "type": "verse",
      "number": 17,
      "text": "As for me, I am poor and needy,"
    }
  ]
}