{
  "document_id": "sir-36",
  "title": "Sirach 36",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-36-1",
      "type": "verse",
      "number": 1,
      "text": "Have mercy upon us, O God of all,"
    },
    {
      "block_id": "sir-36-2",
      "type": "verse",
      "number": 2,
      "text": "and put all the nations in fear of you."
    },
    {
      "block_id": "sir-36-3",
      "type": "verse",
      "number": 3,
      "text": "Lift up your hand against foreign nations"
    },
    {
      "block_id": "sir-36-4",
      "type": "verse",
      "number": 4,
      "text": "As you have used us to show your holiness to them,"
    },
    {
      "block_id": "sir-36-5",
      "type": "verse",
      "number": 5,
      "text": "Then they will know, as we have known,"
    },
    {
      "block_id": "sir-36-6",
      "type": "verse",
      "number": 6,
      "text": "Give new signs and work other wonders;"
    },
    {
      "block_id": "sir-36-7",
      "type": "verse",
      "number": 7,
      "text": "make your hand and right arm glorious."
    },
    {
      "block_id": "sir-36-8",
      "type": "verse",
      "number": 8,
      "text": "Rouse your anger and pour out your wrath;"
    },
    {
      "block_id": "sir-36-9",
      "type": "verse",
      "number": 9,
      "text": "destroy the adversary and wipe out the enemy."
    },
    {
      "block_id": "sir-36-10",
      "type": "verse",
      "number": 10,
      "text": "Hasten the day, and remember the appointed time,"
    },
    {
      "block_id": "sir-36-11",
      "type": "verse",
      "number": 11,
      "text": "Let survivors be consumed in the fiery wrath,"
    },
    {
      "block_id": "sir-36-12",
      "type": "verse",
      "number": 12,
      "text": "Crush the heads of hostile rulers"
    },
    {
      "block_id": "sir-36-13",
      "type": "verse",
      "number": 13,
      "text": "Gather all the tribes of Jacob,,"
    },
    {
      "block_id": "sir-36-16",
      "type": "verse",
      "number": 16,
      "text": "and give them their inheritance, as at the beginning."
    },
    {
      "block_id": "sir-36-17",
      "type": "verse",
      "number": 17,
      "text": "Have mercy, O Lord, on the people called by your name,"
    },
    {
      "block_id": "sir-36-18",
      "type": "verse",
      "number": 18,
      "text": "Have pity on the city of your sanctuary,"
    },
    {
      "block_id": "sir-36-19",
      "type": "verse",
      "number": 19,
      "text": "Fill Zion with your majesty"
    },
    {
      "block_id": "sir-36-20",
      "type": "verse",
      "number": 20,
      "text": "Bear witness to those whom you created in the beginning,"
    },
    {
      "block_id": "sir-36-21",
      "type": "verse",
      "number": 21,
      "text": "Reward those who wait for you,"
    },
    {
      "block_id": "sir-36-22",
      "type": "verse",
      "number": 22,
      "text": "Hear, O Lord, the prayer of your servants, according to your goodwill toward your people,"
    },
    {
      "block_id": "sir-36-23",
      "type": "verse",
      "number": 23,
      "text": "The stomach will take any food,"
    },
    {
      "block_id": "sir-36-24",
      "type": "verse",
      "number": 24,
      "text": "As the palate tastes the kinds of game,"
    },
    {
      "block_id": "sir-36-25",
      "type": "verse",
      "number": 25,
      "text": "A perverse mind will cause grief,"
    },
    {
      "block_id": "sir-36-26",
      "type": "verse",
      "number": 26,
      "text": "A woman will accept any man as a husband,"
    },
    {
      "block_id": "sir-36-27",
      "type": "verse",
      "number": 27,
      "text": "A woman’s beauty lights up a man’s face,"
    },
    {
      "block_id": "sir-36-28",
      "type": "verse",
      "number": 28,
      "text": "If kindness and humility mark her speech,"
    },
    {
      "block_id": "sir-36-29",
      "type": "verse",
      "number": 29,
      "text": "He who acquires a wife gets his best possession,"
    },
    {
      "block_id": "sir-36-30",
      "type": "verse",
      "number": 30,
      "text": "Where there is no fence, the property will be plundered,"
    },
    {
      "block_id": "sir-36-31",
      "type": "verse",
      "number": 31,
      "text": "For who will trust a nimble robber"
    }
  ]
}