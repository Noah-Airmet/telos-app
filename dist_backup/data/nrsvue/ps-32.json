{
  "document_id": "ps-32",
  "title": "Psalms 32",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-32-1",
      "type": "verse",
      "number": 1,
      "text": "Happy are those whose transgression is forgiven,"
    },
    {
      "block_id": "ps-32-2",
      "type": "verse",
      "number": 2,
      "text": "Happy are those to whom the Lord imputes no iniquity"
    },
    {
      "block_id": "ps-32-3",
      "type": "verse",
      "number": 3,
      "text": "While I kept silent, my body wasted away"
    },
    {
      "block_id": "ps-32-4",
      "type": "verse",
      "number": 4,
      "text": "For day and night your hand was heavy upon me;"
    },
    {
      "block_id": "ps-32-5",
      "type": "verse",
      "number": 5,
      "text": "Then I acknowledged my sin to you,"
    },
    {
      "block_id": "ps-32-6",
      "type": "verse",
      "number": 6,
      "text": "Therefore let all who are faithful"
    },
    {
      "block_id": "ps-32-7",
      "type": "verse",
      "number": 7,
      "text": "You are a hiding place for me;"
    },
    {
      "block_id": "ps-32-8",
      "type": "verse",
      "number": 8,
      "text": "I will instruct you and teach you the way you should go;"
    },
    {
      "block_id": "ps-32-9",
      "type": "verse",
      "number": 9,
      "text": "Do not be like a horse or a mule, without understanding,"
    },
    {
      "block_id": "ps-32-10",
      "type": "verse",
      "number": 10,
      "text": "Many are the torments of the wicked,"
    },
    {
      "block_id": "ps-32-11",
      "type": "verse",
      "number": 11,
      "text": "Be glad in the Lord and rejoice, O righteous,"
    }
  ]
}