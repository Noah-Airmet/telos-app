{
  "document_id": "ps-16",
  "title": "Psalms 16",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-16-1",
      "type": "verse",
      "number": 1,
      "text": "Protect me, O God, for in you I take refuge."
    },
    {
      "block_id": "ps-16-2",
      "type": "verse",
      "number": 2,
      "text": "I say to the Lord, “You are my Lord;"
    },
    {
      "block_id": "ps-16-3",
      "type": "verse",
      "number": 3,
      "text": "As for the holy ones in the land, they are the noble ones"
    },
    {
      "block_id": "ps-16-4",
      "type": "verse",
      "number": 4,
      "text": "Those who choose another god multiply their sorrows;"
    },
    {
      "block_id": "ps-16-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord is my chosen portion and my cup;"
    },
    {
      "block_id": "ps-16-6",
      "type": "verse",
      "number": 6,
      "text": "The boundary lines have fallen for me in pleasant places;"
    },
    {
      "block_id": "ps-16-7",
      "type": "verse",
      "number": 7,
      "text": "I bless the Lord, who gives me counsel;"
    },
    {
      "block_id": "ps-16-8",
      "type": "verse",
      "number": 8,
      "text": "I keep the Lord always before me;"
    },
    {
      "block_id": "ps-16-9",
      "type": "verse",
      "number": 9,
      "text": "Therefore my heart is glad, and my soul rejoices;"
    },
    {
      "block_id": "ps-16-10",
      "type": "verse",
      "number": 10,
      "text": "For you do not give me up to Sheol"
    },
    {
      "block_id": "ps-16-11",
      "type": "verse",
      "number": 11,
      "text": "You show me the path of life."
    }
  ]
}