{
  "document_id": "ps-47",
  "title": "Psalms 47",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-47-1",
      "type": "verse",
      "number": 1,
      "text": "Clap your hands, all you peoples;"
    },
    {
      "block_id": "ps-47-2",
      "type": "verse",
      "number": 2,
      "text": "For the Lord, the Most High, is awesome,"
    },
    {
      "block_id": "ps-47-3",
      "type": "verse",
      "number": 3,
      "text": "He subdued peoples under us"
    },
    {
      "block_id": "ps-47-4",
      "type": "verse",
      "number": 4,
      "text": "He chose our heritage for us,"
    },
    {
      "block_id": "ps-47-5",
      "type": "verse",
      "number": 5,
      "text": "God has gone up with a shout,"
    },
    {
      "block_id": "ps-47-6",
      "type": "verse",
      "number": 6,
      "text": "Sing praises to God, sing praises;"
    },
    {
      "block_id": "ps-47-7",
      "type": "verse",
      "number": 7,
      "text": "For God is the king of all the earth;"
    },
    {
      "block_id": "ps-47-8",
      "type": "verse",
      "number": 8,
      "text": "God is king over the nations;"
    },
    {
      "block_id": "ps-47-9",
      "type": "verse",
      "number": 9,
      "text": "The princes of the peoples gather"
    }
  ]
}