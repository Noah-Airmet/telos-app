{
  "document_id": "hos-9",
  "title": "Hosea 9",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-9-1",
      "type": "verse",
      "number": 1,
      "text": "Do not rejoice, O Israel!"
    },
    {
      "block_id": "hos-9-2",
      "type": "verse",
      "number": 2,
      "text": "Threshing floor and wine vat shall not feed them,"
    },
    {
      "block_id": "hos-9-3",
      "type": "verse",
      "number": 3,
      "text": "They shall not remain in the land of the Lord,"
    },
    {
      "block_id": "hos-9-4",
      "type": "verse",
      "number": 4,
      "text": "They shall not pour drink offerings of wine to the Lord,"
    },
    {
      "block_id": "hos-9-5",
      "type": "verse",
      "number": 5,
      "text": "What will you do on the day of appointed festival"
    },
    {
      "block_id": "hos-9-6",
      "type": "verse",
      "number": 6,
      "text": "For even if they escape destruction,"
    },
    {
      "block_id": "hos-9-7",
      "type": "verse",
      "number": 7,
      "text": "The days of punishment have come;"
    },
    {
      "block_id": "hos-9-8",
      "type": "verse",
      "number": 8,
      "text": "The prophet is a sentinel for my God over Ephraim,"
    },
    {
      "block_id": "hos-9-9",
      "type": "verse",
      "number": 9,
      "text": "They have deeply corrupted themselves"
    },
    {
      "block_id": "hos-9-10",
      "type": "verse",
      "number": 10,
      "text": "Like grapes in the wilderness,"
    },
    {
      "block_id": "hos-9-11",
      "type": "verse",
      "number": 11,
      "text": "Ephraim’s glory shall fly away like a bird—"
    },
    {
      "block_id": "hos-9-12",
      "type": "verse",
      "number": 12,
      "text": "Even if they bring up children,"
    },
    {
      "block_id": "hos-9-13",
      "type": "verse",
      "number": 13,
      "text": "Once I saw Ephraim as a young palm planted in a lovely meadow,"
    },
    {
      "block_id": "hos-9-14",
      "type": "verse",
      "number": 14,
      "text": "Give them, O Lord—"
    },
    {
      "block_id": "hos-9-15",
      "type": "verse",
      "number": 15,
      "text": "Every evil of theirs began at Gilgal;"
    },
    {
      "block_id": "hos-9-16",
      "type": "verse",
      "number": 16,
      "text": "Ephraim is stricken,"
    },
    {
      "block_id": "hos-9-17",
      "type": "verse",
      "number": 17,
      "text": "Because they have not listened to him,"
    }
  ]
}