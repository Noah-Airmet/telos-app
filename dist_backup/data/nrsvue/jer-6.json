{
  "document_id": "jer-6",
  "title": "Jeremiah 6",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "jer-6-1",
      "type": "verse",
      "number": 1,
      "text": "Flee for safety, O children of Benjamin,"
    },
    {
      "block_id": "jer-6-2",
      "type": "verse",
      "number": 2,
      "text": "I have likened daughter Zion"
    },
    {
      "block_id": "jer-6-3",
      "type": "verse",
      "number": 3,
      "text": "Shepherds with their flocks shall come against her."
    },
    {
      "block_id": "jer-6-4",
      "type": "verse",
      "number": 4,
      "text": "“Prepare war against her;"
    },
    {
      "block_id": "jer-6-5",
      "type": "verse",
      "number": 5,
      "text": "“Up, and let us attack by night,"
    },
    {
      "block_id": "jer-6-6",
      "type": "verse",
      "number": 6,
      "text": "For thus says the Lord of hosts:"
    },
    {
      "block_id": "jer-6-7",
      "type": "verse",
      "number": 7,
      "text": "As a well keeps its water fresh,"
    },
    {
      "block_id": "jer-6-8",
      "type": "verse",
      "number": 8,
      "text": "Take warning, O Jerusalem,"
    },
    {
      "block_id": "jer-6-9",
      "type": "verse",
      "number": 9,
      "text": "Thus says the Lord of hosts:"
    },
    {
      "block_id": "jer-6-10",
      "type": "verse",
      "number": 10,
      "text": "To whom shall I speak and give warning,"
    },
    {
      "block_id": "jer-6-11",
      "type": "verse",
      "number": 11,
      "text": "But I am full of the wrath of the Lord;"
    },
    {
      "block_id": "jer-6-12",
      "type": "verse",
      "number": 12,
      "text": "Their houses shall be turned over to others,"
    },
    {
      "block_id": "jer-6-13",
      "type": "verse",
      "number": 13,
      "text": "For from the least to the greatest of them,"
    },
    {
      "block_id": "jer-6-14",
      "type": "verse",
      "number": 14,
      "text": "They have treated the wound of my people carelessly,"
    },
    {
      "block_id": "jer-6-15",
      "type": "verse",
      "number": 15,
      "text": "They acted shamefully; they committed abomination,"
    },
    {
      "block_id": "jer-6-16",
      "type": "verse",
      "number": 16,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "jer-6-17",
      "type": "verse",
      "number": 17,
      "text": "Also I raised up sentinels for you:"
    },
    {
      "block_id": "jer-6-18",
      "type": "verse",
      "number": 18,
      "text": "Therefore hear, O nations,"
    },
    {
      "block_id": "jer-6-19",
      "type": "verse",
      "number": 19,
      "text": "Hear, O earth; I am going to bring disaster on this people,"
    },
    {
      "block_id": "jer-6-20",
      "type": "verse",
      "number": 20,
      "text": "Of what use to me is frankincense that comes from Sheba"
    },
    {
      "block_id": "jer-6-21",
      "type": "verse",
      "number": 21,
      "text": "Therefore thus says the Lord:"
    },
    {
      "block_id": "jer-6-22",
      "type": "verse",
      "number": 22,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "jer-6-23",
      "type": "verse",
      "number": 23,
      "text": "They grasp the bow and the javelin;"
    },
    {
      "block_id": "jer-6-24",
      "type": "verse",
      "number": 24,
      "text": "“We have heard news of them;"
    },
    {
      "block_id": "jer-6-25",
      "type": "verse",
      "number": 25,
      "text": "Do not go out into the field"
    },
    {
      "block_id": "jer-6-26",
      "type": "verse",
      "number": 26,
      "text": "O daughter of my people, put on sackcloth"
    },
    {
      "block_id": "jer-6-27",
      "type": "verse",
      "number": 27,
      "text": "I have made you a tester and a refiner among my people"
    },
    {
      "block_id": "jer-6-28",
      "type": "verse",
      "number": 28,
      "text": "They are all stubbornly rebellious,"
    },
    {
      "block_id": "jer-6-29",
      "type": "verse",
      "number": 29,
      "text": "The bellows blow fiercely;"
    },
    {
      "block_id": "jer-6-30",
      "type": "verse",
      "number": 30,
      "text": "They are called “rejected silver,”"
    }
  ]
}