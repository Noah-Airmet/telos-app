{
  "document_id": "ps-85",
  "title": "Psalms 85",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-85-1",
      "type": "verse",
      "number": 1,
      "text": "Lord, you were favorable to your land;"
    },
    {
      "block_id": "ps-85-2",
      "type": "verse",
      "number": 2,
      "text": "You forgave the iniquity of your people;"
    },
    {
      "block_id": "ps-85-3",
      "type": "verse",
      "number": 3,
      "text": "You withdrew all your wrath;"
    },
    {
      "block_id": "ps-85-4",
      "type": "verse",
      "number": 4,
      "text": "Restore us again, O God of our salvation,"
    },
    {
      "block_id": "ps-85-5",
      "type": "verse",
      "number": 5,
      "text": "Will you be angry with us forever?"
    },
    {
      "block_id": "ps-85-6",
      "type": "verse",
      "number": 6,
      "text": "Will you not revive us again,"
    },
    {
      "block_id": "ps-85-7",
      "type": "verse",
      "number": 7,
      "text": "Show us your steadfast love, O Lord,"
    },
    {
      "block_id": "ps-85-8",
      "type": "verse",
      "number": 8,
      "text": "Let me hear what God the Lord will speak,"
    },
    {
      "block_id": "ps-85-9",
      "type": "verse",
      "number": 9,
      "text": "Surely his salvation is at hand for those who fear him,"
    },
    {
      "block_id": "ps-85-10",
      "type": "verse",
      "number": 10,
      "text": "Steadfast love and faithfulness will meet;"
    },
    {
      "block_id": "ps-85-11",
      "type": "verse",
      "number": 11,
      "text": "Faithfulness will spring up from the ground,"
    },
    {
      "block_id": "ps-85-12",
      "type": "verse",
      "number": 12,
      "text": "The Lord will give what is good,"
    },
    {
      "block_id": "ps-85-13",
      "type": "verse",
      "number": 13,
      "text": "Righteousness will go before him"
    }
  ]
}