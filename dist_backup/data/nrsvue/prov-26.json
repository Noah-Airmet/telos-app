{
  "document_id": "prov-26",
  "title": "Proverbs 26",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-26-1",
      "type": "verse",
      "number": 1,
      "text": "Like snow in summer or rain in harvest,"
    },
    {
      "block_id": "prov-26-2",
      "type": "verse",
      "number": 2,
      "text": "Like a sparrow in its flitting, like a swallow in its flying,"
    },
    {
      "block_id": "prov-26-3",
      "type": "verse",
      "number": 3,
      "text": "A whip for the horse, a bridle for the donkey,"
    },
    {
      "block_id": "prov-26-4",
      "type": "verse",
      "number": 4,
      "text": "Do not answer fools according to their folly,"
    },
    {
      "block_id": "prov-26-5",
      "type": "verse",
      "number": 5,
      "text": "Answer fools according to their folly,"
    },
    {
      "block_id": "prov-26-6",
      "type": "verse",
      "number": 6,
      "text": "It is like cutting off one’s foot and drinking down violence,"
    },
    {
      "block_id": "prov-26-7",
      "type": "verse",
      "number": 7,
      "text": "The legs of a lame person hang limp;"
    },
    {
      "block_id": "prov-26-8",
      "type": "verse",
      "number": 8,
      "text": "It is like binding a stone in a sling"
    },
    {
      "block_id": "prov-26-9",
      "type": "verse",
      "number": 9,
      "text": "Like a thornbush brandished by the hand of a drunkard"
    },
    {
      "block_id": "prov-26-10",
      "type": "verse",
      "number": 10,
      "text": "Like an archer who wounds everybody"
    },
    {
      "block_id": "prov-26-11",
      "type": "verse",
      "number": 11,
      "text": "Like a dog that returns to its vomit"
    },
    {
      "block_id": "prov-26-12",
      "type": "verse",
      "number": 12,
      "text": "Do you see people wise in their own eyes?"
    },
    {
      "block_id": "prov-26-13",
      "type": "verse",
      "number": 13,
      "text": "The lazy person says, “There is a lion in the road!"
    },
    {
      "block_id": "prov-26-14",
      "type": "verse",
      "number": 14,
      "text": "As a door turns on its hinges,"
    },
    {
      "block_id": "prov-26-15",
      "type": "verse",
      "number": 15,
      "text": "The lazy person buries a hand in the dish"
    },
    {
      "block_id": "prov-26-16",
      "type": "verse",
      "number": 16,
      "text": "The lazy person is wiser in self-esteem"
    },
    {
      "block_id": "prov-26-17",
      "type": "verse",
      "number": 17,
      "text": "Like someone who takes a passing dog by the ears"
    },
    {
      "block_id": "prov-26-18",
      "type": "verse",
      "number": 18,
      "text": "Like a maniac who shoots deadly firebrands and arrows,"
    },
    {
      "block_id": "prov-26-19",
      "type": "verse",
      "number": 19,
      "text": "so is one who deceives a neighbor"
    },
    {
      "block_id": "prov-26-20",
      "type": "verse",
      "number": 20,
      "text": "For lack of wood the fire goes out,"
    },
    {
      "block_id": "prov-26-21",
      "type": "verse",
      "number": 21,
      "text": "As charcoal is to hot embers and wood to fire,"
    },
    {
      "block_id": "prov-26-22",
      "type": "verse",
      "number": 22,
      "text": "The words of a whisperer are like delicious morsels;"
    },
    {
      "block_id": "prov-26-23",
      "type": "verse",
      "number": 23,
      "text": "Like the glaze covering an earthen vessel"
    },
    {
      "block_id": "prov-26-24",
      "type": "verse",
      "number": 24,
      "text": "An enemy dissembles in speaking"
    },
    {
      "block_id": "prov-26-25",
      "type": "verse",
      "number": 25,
      "text": "when an enemy speaks graciously, do not believe it,"
    },
    {
      "block_id": "prov-26-26",
      "type": "verse",
      "number": 26,
      "text": "though hatred is covered with guile,"
    },
    {
      "block_id": "prov-26-27",
      "type": "verse",
      "number": 27,
      "text": "Whoever digs a pit will fall into it,"
    },
    {
      "block_id": "prov-26-28",
      "type": "verse",
      "number": 28,
      "text": "A lying tongue hates its victims,"
    }
  ]
}