{
  "document_id": "job-14",
  "title": "Job 14",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-14-1",
      "type": "verse",
      "number": 1,
      "text": "“A mortal, born of woman, few of days and full of trouble,"
    },
    {
      "block_id": "job-14-2",
      "type": "verse",
      "number": 2,
      "text": "comes up like a flower and withers,"
    },
    {
      "block_id": "job-14-3",
      "type": "verse",
      "number": 3,
      "text": "Do you fix your eyes on such a one?"
    },
    {
      "block_id": "job-14-4",
      "type": "verse",
      "number": 4,
      "text": "Who can bring a clean thing out of an unclean?"
    },
    {
      "block_id": "job-14-5",
      "type": "verse",
      "number": 5,
      "text": "Since their days are determined,"
    },
    {
      "block_id": "job-14-6",
      "type": "verse",
      "number": 6,
      "text": "look away from them and desist,"
    },
    {
      "block_id": "job-14-7",
      "type": "verse",
      "number": 7,
      "text": "“For there is hope for a tree,"
    },
    {
      "block_id": "job-14-8",
      "type": "verse",
      "number": 8,
      "text": "Though its root grows old in the earth"
    },
    {
      "block_id": "job-14-9",
      "type": "verse",
      "number": 9,
      "text": "yet at the scent of water it will bud"
    },
    {
      "block_id": "job-14-10",
      "type": "verse",
      "number": 10,
      "text": "But mortals die and are laid low;"
    },
    {
      "block_id": "job-14-11",
      "type": "verse",
      "number": 11,
      "text": "As waters fail from a lake"
    },
    {
      "block_id": "job-14-12",
      "type": "verse",
      "number": 12,
      "text": "so mortals lie down and do not rise again;"
    },
    {
      "block_id": "job-14-13",
      "type": "verse",
      "number": 13,
      "text": "O that you would hide me in Sheol,"
    },
    {
      "block_id": "job-14-14",
      "type": "verse",
      "number": 14,
      "text": "If mortals die, will they live again?"
    },
    {
      "block_id": "job-14-15",
      "type": "verse",
      "number": 15,
      "text": "You would call, and I would answer you;"
    },
    {
      "block_id": "job-14-16",
      "type": "verse",
      "number": 16,
      "text": "For then you would not number my steps;"
    },
    {
      "block_id": "job-14-17",
      "type": "verse",
      "number": 17,
      "text": "my transgression would be sealed up in a bag,"
    },
    {
      "block_id": "job-14-18",
      "type": "verse",
      "number": 18,
      "text": "“But the mountain falls and crumbles away,"
    },
    {
      "block_id": "job-14-19",
      "type": "verse",
      "number": 19,
      "text": "the waters wear away the stones;"
    },
    {
      "block_id": "job-14-20",
      "type": "verse",
      "number": 20,
      "text": "You prevail forever against them, and they pass away;"
    },
    {
      "block_id": "job-14-21",
      "type": "verse",
      "number": 21,
      "text": "Their children come to honor, and they do not know it;"
    },
    {
      "block_id": "job-14-22",
      "type": "verse",
      "number": 22,
      "text": "They feel only the pain of their own bodies"
    }
  ]
}