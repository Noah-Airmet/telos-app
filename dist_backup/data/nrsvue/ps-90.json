{
  "document_id": "ps-90",
  "title": "Psalms 90",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-90-1",
      "type": "verse",
      "number": 1,
      "text": "Lord, you have been our dwelling place"
    },
    {
      "block_id": "ps-90-2",
      "type": "verse",
      "number": 2,
      "text": "Before the mountains were brought forth"
    },
    {
      "block_id": "ps-90-3",
      "type": "verse",
      "number": 3,
      "text": "You turn us back to dust"
    },
    {
      "block_id": "ps-90-4",
      "type": "verse",
      "number": 4,
      "text": "For a thousand years in your sight"
    },
    {
      "block_id": "ps-90-5",
      "type": "verse",
      "number": 5,
      "text": "You sweep them away; they are like a dream,"
    },
    {
      "block_id": "ps-90-6",
      "type": "verse",
      "number": 6,
      "text": "in the morning it flourishes and is renewed;"
    },
    {
      "block_id": "ps-90-7",
      "type": "verse",
      "number": 7,
      "text": "For we are consumed by your anger;"
    },
    {
      "block_id": "ps-90-8",
      "type": "verse",
      "number": 8,
      "text": "You have set our iniquities before you,"
    },
    {
      "block_id": "ps-90-9",
      "type": "verse",
      "number": 9,
      "text": "For all our days pass away under your wrath;"
    },
    {
      "block_id": "ps-90-10",
      "type": "verse",
      "number": 10,
      "text": "The days of our life are seventy years"
    },
    {
      "block_id": "ps-90-11",
      "type": "verse",
      "number": 11,
      "text": "Who considers the power of your anger?"
    },
    {
      "block_id": "ps-90-12",
      "type": "verse",
      "number": 12,
      "text": "So teach us to count our days"
    },
    {
      "block_id": "ps-90-13",
      "type": "verse",
      "number": 13,
      "text": "Turn, O Lord! How long?"
    },
    {
      "block_id": "ps-90-14",
      "type": "verse",
      "number": 14,
      "text": "Satisfy us in the morning with your steadfast love,"
    },
    {
      "block_id": "ps-90-15",
      "type": "verse",
      "number": 15,
      "text": "Make us glad as many days as you have afflicted us"
    },
    {
      "block_id": "ps-90-16",
      "type": "verse",
      "number": 16,
      "text": "Let your work be manifest to your servants"
    },
    {
      "block_id": "ps-90-17",
      "type": "verse",
      "number": 17,
      "text": "Let the favor of the Lord our God be upon us"
    }
  ]
}