{
  "document_id": "prov-28",
  "title": "Proverbs 28",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-28-1",
      "type": "verse",
      "number": 1,
      "text": "The wicked flee when no one pursues,"
    },
    {
      "block_id": "prov-28-2",
      "type": "verse",
      "number": 2,
      "text": "When a land rebels"
    },
    {
      "block_id": "prov-28-3",
      "type": "verse",
      "number": 3,
      "text": "A poor person who oppresses the poor"
    },
    {
      "block_id": "prov-28-4",
      "type": "verse",
      "number": 4,
      "text": "Those who forsake the law praise the wicked,"
    },
    {
      "block_id": "prov-28-5",
      "type": "verse",
      "number": 5,
      "text": "The evil do not understand justice,"
    },
    {
      "block_id": "prov-28-6",
      "type": "verse",
      "number": 6,
      "text": "Better to be poor and walk in integrity"
    },
    {
      "block_id": "prov-28-7",
      "type": "verse",
      "number": 7,
      "text": "Those who keep the law are wise children,"
    },
    {
      "block_id": "prov-28-8",
      "type": "verse",
      "number": 8,
      "text": "One who augments wealth by exorbitant interest"
    },
    {
      "block_id": "prov-28-9",
      "type": "verse",
      "number": 9,
      "text": "When one will not listen to the law,"
    },
    {
      "block_id": "prov-28-10",
      "type": "verse",
      "number": 10,
      "text": "Those who mislead the upright into evil ways"
    },
    {
      "block_id": "prov-28-11",
      "type": "verse",
      "number": 11,
      "text": "The rich is wise in self-esteem,"
    },
    {
      "block_id": "prov-28-12",
      "type": "verse",
      "number": 12,
      "text": "When the righteous rejoice, there is great glory,"
    },
    {
      "block_id": "prov-28-13",
      "type": "verse",
      "number": 13,
      "text": "No one who conceals transgressions will prosper,"
    },
    {
      "block_id": "prov-28-14",
      "type": "verse",
      "number": 14,
      "text": "Happy is the one who is never without fear,"
    },
    {
      "block_id": "prov-28-15",
      "type": "verse",
      "number": 15,
      "text": "Like a roaring lion or a charging bear"
    },
    {
      "block_id": "prov-28-16",
      "type": "verse",
      "number": 16,
      "text": "A ruler who lacks understanding is a cruel oppressor,"
    },
    {
      "block_id": "prov-28-17",
      "type": "verse",
      "number": 17,
      "text": "If someone is burdened with the blood of another,"
    },
    {
      "block_id": "prov-28-18",
      "type": "verse",
      "number": 18,
      "text": "One who walks in integrity will be safe,"
    },
    {
      "block_id": "prov-28-19",
      "type": "verse",
      "number": 19,
      "text": "Anyone who tills the land will have plenty of bread,"
    },
    {
      "block_id": "prov-28-20",
      "type": "verse",
      "number": 20,
      "text": "The faithful will abound with blessings,"
    },
    {
      "block_id": "prov-28-21",
      "type": "verse",
      "number": 21,
      "text": "To show partiality is not good,"
    },
    {
      "block_id": "prov-28-22",
      "type": "verse",
      "number": 22,
      "text": "The miser is in a hurry to get rich"
    },
    {
      "block_id": "prov-28-23",
      "type": "verse",
      "number": 23,
      "text": "Whoever rebukes a person will afterward find more favor"
    },
    {
      "block_id": "prov-28-24",
      "type": "verse",
      "number": 24,
      "text": "Anyone who robs father or mother"
    },
    {
      "block_id": "prov-28-25",
      "type": "verse",
      "number": 25,
      "text": "The greedy person stirs up strife,"
    },
    {
      "block_id": "prov-28-26",
      "type": "verse",
      "number": 26,
      "text": "Those who trust in their own wits are fools,"
    },
    {
      "block_id": "prov-28-27",
      "type": "verse",
      "number": 27,
      "text": "Whoever gives to the poor will lack nothing,"
    },
    {
      "block_id": "prov-28-28",
      "type": "verse",
      "number": 28,
      "text": "When the wicked prevail, people go into hiding,"
    }
  ]
}