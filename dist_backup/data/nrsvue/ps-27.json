{
  "document_id": "ps-27",
  "title": "Psalms 27",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-27-1",
      "type": "verse",
      "number": 1,
      "text": "The Lord is my light and my salvation;"
    },
    {
      "block_id": "ps-27-2",
      "type": "verse",
      "number": 2,
      "text": "When evildoers assail me"
    },
    {
      "block_id": "ps-27-3",
      "type": "verse",
      "number": 3,
      "text": "Though an army encamp against me,"
    },
    {
      "block_id": "ps-27-4",
      "type": "verse",
      "number": 4,
      "text": "One thing I asked of the Lord;"
    },
    {
      "block_id": "ps-27-5",
      "type": "verse",
      "number": 5,
      "text": "For he will hide me in his shelter"
    },
    {
      "block_id": "ps-27-6",
      "type": "verse",
      "number": 6,
      "text": "Now my head is lifted up"
    },
    {
      "block_id": "ps-27-7",
      "type": "verse",
      "number": 7,
      "text": "Hear, O Lord, when I cry aloud;"
    },
    {
      "block_id": "ps-27-8",
      "type": "verse",
      "number": 8,
      "text": "“Come,” my heart says, “seek his face!”"
    },
    {
      "block_id": "ps-27-9",
      "type": "verse",
      "number": 9,
      "text": "Do not hide your face from me."
    },
    {
      "block_id": "ps-27-10",
      "type": "verse",
      "number": 10,
      "text": "If my father and mother forsake me,"
    },
    {
      "block_id": "ps-27-11",
      "type": "verse",
      "number": 11,
      "text": "Teach me your way, O Lord,"
    },
    {
      "block_id": "ps-27-12",
      "type": "verse",
      "number": 12,
      "text": "Do not give me up to the will of my adversaries,"
    },
    {
      "block_id": "ps-27-13",
      "type": "verse",
      "number": 13,
      "text": "I believe that I shall see the goodness of the Lord"
    },
    {
      "block_id": "ps-27-14",
      "type": "verse",
      "number": 14,
      "text": "Wait for the Lord;"
    }
  ]
}