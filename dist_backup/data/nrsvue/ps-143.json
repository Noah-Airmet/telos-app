{
  "document_id": "ps-143",
  "title": "Psalms 143",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-143-1",
      "type": "verse",
      "number": 1,
      "text": "Hear my prayer, O Lord;"
    },
    {
      "block_id": "ps-143-2",
      "type": "verse",
      "number": 2,
      "text": "Do not enter into judgment with your servant,"
    },
    {
      "block_id": "ps-143-3",
      "type": "verse",
      "number": 3,
      "text": "For the enemy has pursued me,"
    },
    {
      "block_id": "ps-143-4",
      "type": "verse",
      "number": 4,
      "text": "Therefore my spirit faints within me;"
    },
    {
      "block_id": "ps-143-5",
      "type": "verse",
      "number": 5,
      "text": "I remember the days of old;"
    },
    {
      "block_id": "ps-143-6",
      "type": "verse",
      "number": 6,
      "text": "I stretch out my hands to you;"
    },
    {
      "block_id": "ps-143-7",
      "type": "verse",
      "number": 7,
      "text": "Answer me quickly, O Lord;"
    },
    {
      "block_id": "ps-143-8",
      "type": "verse",
      "number": 8,
      "text": "Let me hear of your steadfast love in the morning,"
    },
    {
      "block_id": "ps-143-9",
      "type": "verse",
      "number": 9,
      "text": "Save me, O Lord, from my enemies;"
    },
    {
      "block_id": "ps-143-10",
      "type": "verse",
      "number": 10,
      "text": "Teach me to do your will,"
    },
    {
      "block_id": "ps-143-11",
      "type": "verse",
      "number": 11,
      "text": "For your name’s sake, O Lord, preserve my life."
    },
    {
      "block_id": "ps-143-12",
      "type": "verse",
      "number": 12,
      "text": "In your steadfast love cut off my enemies,"
    }
  ]
}