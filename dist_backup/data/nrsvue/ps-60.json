{
  "document_id": "ps-60",
  "title": "Psalms 60",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-60-1",
      "type": "verse",
      "number": 1,
      "text": "O God, you have rejected us, broken our defenses;"
    },
    {
      "block_id": "ps-60-2",
      "type": "verse",
      "number": 2,
      "text": "You have caused the land to quake; you have torn it open;"
    },
    {
      "block_id": "ps-60-3",
      "type": "verse",
      "number": 3,
      "text": "You have made your people suffer hard things;"
    },
    {
      "block_id": "ps-60-4",
      "type": "verse",
      "number": 4,
      "text": "You have set up a banner for those who fear you,"
    },
    {
      "block_id": "ps-60-5",
      "type": "verse",
      "number": 5,
      "text": "Give victory with your right hand and answer us,"
    },
    {
      "block_id": "ps-60-6",
      "type": "verse",
      "number": 6,
      "text": "God has promised in his sanctuary,"
    },
    {
      "block_id": "ps-60-7",
      "type": "verse",
      "number": 7,
      "text": "Gilead is mine, and Manasseh is mine;"
    },
    {
      "block_id": "ps-60-8",
      "type": "verse",
      "number": 8,
      "text": "Moab is my washbasin;"
    },
    {
      "block_id": "ps-60-9",
      "type": "verse",
      "number": 9,
      "text": "Who will bring me to the fortified city?"
    },
    {
      "block_id": "ps-60-10",
      "type": "verse",
      "number": 10,
      "text": "Have you not rejected us, O God?"
    },
    {
      "block_id": "ps-60-11",
      "type": "verse",
      "number": 11,
      "text": "O grant us help against the foe,"
    },
    {
      "block_id": "ps-60-12",
      "type": "verse",
      "number": 12,
      "text": "With God we shall do valiantly;"
    }
  ]
}