{
  "document_id": "ps-39",
  "title": "Psalms 39",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-39-1",
      "type": "verse",
      "number": 1,
      "text": "I said, “I will guard my ways"
    },
    {
      "block_id": "ps-39-2",
      "type": "verse",
      "number": 2,
      "text": "I was silent and still;"
    },
    {
      "block_id": "ps-39-3",
      "type": "verse",
      "number": 3,
      "text": "my heart became hot within me."
    },
    {
      "block_id": "ps-39-4",
      "type": "verse",
      "number": 4,
      "text": "“Lord, let me know my end"
    },
    {
      "block_id": "ps-39-5",
      "type": "verse",
      "number": 5,
      "text": "You have made my days a few handbreadths,"
    },
    {
      "block_id": "ps-39-6",
      "type": "verse",
      "number": 6,
      "text": "Surely everyone goes about like a shadow."
    },
    {
      "block_id": "ps-39-7",
      "type": "verse",
      "number": 7,
      "text": "“And now, O Lord, what do I wait for?"
    },
    {
      "block_id": "ps-39-8",
      "type": "verse",
      "number": 8,
      "text": "Deliver me from all my transgressions."
    },
    {
      "block_id": "ps-39-9",
      "type": "verse",
      "number": 9,
      "text": "I am silent; I do not open my mouth,"
    },
    {
      "block_id": "ps-39-10",
      "type": "verse",
      "number": 10,
      "text": "Remove your stroke from me;"
    },
    {
      "block_id": "ps-39-11",
      "type": "verse",
      "number": 11,
      "text": "“You chastise mortals"
    },
    {
      "block_id": "ps-39-12",
      "type": "verse",
      "number": 12,
      "text": "“Hear my prayer, O Lord,"
    },
    {
      "block_id": "ps-39-13",
      "type": "verse",
      "number": 13,
      "text": "Turn your gaze away from me, that I may smile again,"
    }
  ]
}