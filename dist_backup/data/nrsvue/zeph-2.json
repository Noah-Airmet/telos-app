{
  "document_id": "zeph-2",
  "title": "Zephaniah 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "zeph-2-1",
      "type": "verse",
      "number": 1,
      "text": "Gather together, gather,"
    },
    {
      "block_id": "zeph-2-2",
      "type": "verse",
      "number": 2,
      "text": "before you are driven away"
    },
    {
      "block_id": "zeph-2-3",
      "type": "verse",
      "number": 3,
      "text": "Seek the Lord, all you humble of the land"
    },
    {
      "block_id": "zeph-2-4",
      "type": "verse",
      "number": 4,
      "text": "For Gaza shall be deserted,"
    },
    {
      "block_id": "zeph-2-5",
      "type": "verse",
      "number": 5,
      "text": "Woe, inhabitants of the seacoast,"
    },
    {
      "block_id": "zeph-2-6",
      "type": "verse",
      "number": 6,
      "text": "And you, O seacoast, shall be pastures,"
    },
    {
      "block_id": "zeph-2-7",
      "type": "verse",
      "number": 7,
      "text": "The seacoast shall become the possession"
    },
    {
      "block_id": "zeph-2-8",
      "type": "verse",
      "number": 8,
      "text": "I have heard the taunts of Moab"
    },
    {
      "block_id": "zeph-2-9",
      "type": "verse",
      "number": 9,
      "text": "Therefore, as I live, says the Lord of hosts,"
    },
    {
      "block_id": "zeph-2-10",
      "type": "verse",
      "number": 10,
      "text": "This shall be their lot in return for their pride,"
    },
    {
      "block_id": "zeph-2-11",
      "type": "verse",
      "number": 11,
      "text": "The Lord will be terrible against them;"
    },
    {
      "block_id": "zeph-2-12",
      "type": "verse",
      "number": 12,
      "text": "You also, O Cushites,"
    },
    {
      "block_id": "zeph-2-13",
      "type": "verse",
      "number": 13,
      "text": "And he will stretch out his hand against the north"
    },
    {
      "block_id": "zeph-2-14",
      "type": "verse",
      "number": 14,
      "text": "Herds shall lie down in it,"
    },
    {
      "block_id": "zeph-2-15",
      "type": "verse",
      "number": 15,
      "text": "Is this the exultant city"
    }
  ]
}