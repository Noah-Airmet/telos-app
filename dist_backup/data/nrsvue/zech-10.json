{
  "document_id": "zech-10",
  "title": "Zechariah 10",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "zech-10-1",
      "type": "verse",
      "number": 1,
      "text": "Ask rain from the Lord"
    },
    {
      "block_id": "zech-10-2",
      "type": "verse",
      "number": 2,
      "text": "For the teraphim utter nonsense,"
    },
    {
      "block_id": "zech-10-3",
      "type": "verse",
      "number": 3,
      "text": "My anger is hot against the shepherds,"
    },
    {
      "block_id": "zech-10-4",
      "type": "verse",
      "number": 4,
      "text": "Out of them shall come the cornerstone,"
    },
    {
      "block_id": "zech-10-5",
      "type": "verse",
      "number": 5,
      "text": "Together they shall be like warriors in battle,"
    },
    {
      "block_id": "zech-10-6",
      "type": "verse",
      "number": 6,
      "text": "I will strengthen the house of Judah,"
    },
    {
      "block_id": "zech-10-7",
      "type": "verse",
      "number": 7,
      "text": "Then the people of Ephraim shall become like warriors,"
    },
    {
      "block_id": "zech-10-8",
      "type": "verse",
      "number": 8,
      "text": "I will signal for them and gather them in,"
    },
    {
      "block_id": "zech-10-9",
      "type": "verse",
      "number": 9,
      "text": "Though I scattered them among the nations,"
    },
    {
      "block_id": "zech-10-10",
      "type": "verse",
      "number": 10,
      "text": "I will bring them home from the land of Egypt"
    },
    {
      "block_id": "zech-10-11",
      "type": "verse",
      "number": 11,
      "text": "They shall pass through the sea of distress,"
    },
    {
      "block_id": "zech-10-12",
      "type": "verse",
      "number": 12,
      "text": "I will make them strong in the Lord,"
    }
  ]
}