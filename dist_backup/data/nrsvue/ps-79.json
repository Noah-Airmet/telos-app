{
  "document_id": "ps-79",
  "title": "Psalms 79",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-79-1",
      "type": "verse",
      "number": 1,
      "text": "O God, the nations have come into your inheritance;"
    },
    {
      "block_id": "ps-79-2",
      "type": "verse",
      "number": 2,
      "text": "They have given the bodies of your servants"
    },
    {
      "block_id": "ps-79-3",
      "type": "verse",
      "number": 3,
      "text": "They have poured out their blood like water"
    },
    {
      "block_id": "ps-79-4",
      "type": "verse",
      "number": 4,
      "text": "We have become a taunt to our neighbors,"
    },
    {
      "block_id": "ps-79-5",
      "type": "verse",
      "number": 5,
      "text": "How long, O Lord? Will you be angry forever?"
    },
    {
      "block_id": "ps-79-6",
      "type": "verse",
      "number": 6,
      "text": "Pour out your anger on the nations"
    },
    {
      "block_id": "ps-79-7",
      "type": "verse",
      "number": 7,
      "text": "For they have devoured Jacob"
    },
    {
      "block_id": "ps-79-8",
      "type": "verse",
      "number": 8,
      "text": "Do not remember against us the iniquities of our ancestors;"
    },
    {
      "block_id": "ps-79-9",
      "type": "verse",
      "number": 9,
      "text": "Help us, O God of our salvation,"
    },
    {
      "block_id": "ps-79-10",
      "type": "verse",
      "number": 10,
      "text": "Why should the nations say,"
    },
    {
      "block_id": "ps-79-11",
      "type": "verse",
      "number": 11,
      "text": "Let the groans of the prisoners come before you;"
    },
    {
      "block_id": "ps-79-12",
      "type": "verse",
      "number": 12,
      "text": "Return sevenfold into the bosom of our neighbors"
    },
    {
      "block_id": "ps-79-13",
      "type": "verse",
      "number": 13,
      "text": "Then we your people, the flock of your pasture,"
    }
  ]
}