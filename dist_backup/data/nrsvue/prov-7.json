{
  "document_id": "prov-7",
  "title": "Proverbs 7",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-7-1",
      "type": "verse",
      "number": 1,
      "text": "My child, keep my words"
    },
    {
      "block_id": "prov-7-2",
      "type": "verse",
      "number": 2,
      "text": "keep my commandments and live;"
    },
    {
      "block_id": "prov-7-3",
      "type": "verse",
      "number": 3,
      "text": "bind them on your fingers;"
    },
    {
      "block_id": "prov-7-4",
      "type": "verse",
      "number": 4,
      "text": "Say to wisdom, “You are my sister,”"
    },
    {
      "block_id": "prov-7-5",
      "type": "verse",
      "number": 5,
      "text": "that they may keep you from the loose woman,"
    },
    {
      "block_id": "prov-7-6",
      "type": "verse",
      "number": 6,
      "text": "For at the window of my house"
    },
    {
      "block_id": "prov-7-7",
      "type": "verse",
      "number": 7,
      "text": "and I saw among the simple ones,"
    },
    {
      "block_id": "prov-7-8",
      "type": "verse",
      "number": 8,
      "text": "passing along the street near her corner,"
    },
    {
      "block_id": "prov-7-9",
      "type": "verse",
      "number": 9,
      "text": "in the twilight, in the evening,"
    },
    {
      "block_id": "prov-7-10",
      "type": "verse",
      "number": 10,
      "text": "Then a woman comes toward him"
    },
    {
      "block_id": "prov-7-11",
      "type": "verse",
      "number": 11,
      "text": "She is loud and wayward;"
    },
    {
      "block_id": "prov-7-12",
      "type": "verse",
      "number": 12,
      "text": "now in the street, now in the squares,"
    },
    {
      "block_id": "prov-7-13",
      "type": "verse",
      "number": 13,
      "text": "She seizes him and kisses him,"
    },
    {
      "block_id": "prov-7-14",
      "type": "verse",
      "number": 14,
      "text": "“I had to offer sacrifices,"
    },
    {
      "block_id": "prov-7-15",
      "type": "verse",
      "number": 15,
      "text": "so now I have come out to meet you,"
    },
    {
      "block_id": "prov-7-16",
      "type": "verse",
      "number": 16,
      "text": "I have decked my couch with coverings,"
    },
    {
      "block_id": "prov-7-17",
      "type": "verse",
      "number": 17,
      "text": "I have perfumed my bed with myrrh,"
    },
    {
      "block_id": "prov-7-18",
      "type": "verse",
      "number": 18,
      "text": "Come, let us take our fill of love until morning;"
    },
    {
      "block_id": "prov-7-19",
      "type": "verse",
      "number": 19,
      "text": "For my husband is not at home;"
    },
    {
      "block_id": "prov-7-20",
      "type": "verse",
      "number": 20,
      "text": "He took a bag of money with him;"
    },
    {
      "block_id": "prov-7-21",
      "type": "verse",
      "number": 21,
      "text": "With much seductive speech she persuades him;"
    },
    {
      "block_id": "prov-7-22",
      "type": "verse",
      "number": 22,
      "text": "Right away he follows her"
    },
    {
      "block_id": "prov-7-23",
      "type": "verse",
      "number": 23,
      "text": "until an arrow pierces its entrails."
    },
    {
      "block_id": "prov-7-24",
      "type": "verse",
      "number": 24,
      "text": "And now, my children, listen to me,"
    },
    {
      "block_id": "prov-7-25",
      "type": "verse",
      "number": 25,
      "text": "Do not let your hearts turn aside to her ways;"
    },
    {
      "block_id": "prov-7-26",
      "type": "verse",
      "number": 26,
      "text": "For many are those she has laid low,"
    },
    {
      "block_id": "prov-7-27",
      "type": "verse",
      "number": 27,
      "text": "Her house is the way to Sheol,"
    }
  ]
}