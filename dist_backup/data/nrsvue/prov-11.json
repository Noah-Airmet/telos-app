{
  "document_id": "prov-11",
  "title": "Proverbs 11",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-11-1",
      "type": "verse",
      "number": 1,
      "text": "A false balance is an abomination to the Lord,"
    },
    {
      "block_id": "prov-11-2",
      "type": "verse",
      "number": 2,
      "text": "When pride comes, then comes disgrace,"
    },
    {
      "block_id": "prov-11-3",
      "type": "verse",
      "number": 3,
      "text": "The integrity of the upright guides them,"
    },
    {
      "block_id": "prov-11-4",
      "type": "verse",
      "number": 4,
      "text": "Riches do not profit in the day of wrath,"
    },
    {
      "block_id": "prov-11-5",
      "type": "verse",
      "number": 5,
      "text": "The righteousness of the blameless keeps their ways straight,"
    },
    {
      "block_id": "prov-11-6",
      "type": "verse",
      "number": 6,
      "text": "The righteousness of the upright saves them,"
    },
    {
      "block_id": "prov-11-7",
      "type": "verse",
      "number": 7,
      "text": "When the wicked die, hope perishes,"
    },
    {
      "block_id": "prov-11-8",
      "type": "verse",
      "number": 8,
      "text": "The righteous are delivered from trouble,"
    },
    {
      "block_id": "prov-11-9",
      "type": "verse",
      "number": 9,
      "text": "With their mouths the godless would destroy their neighbors,"
    },
    {
      "block_id": "prov-11-10",
      "type": "verse",
      "number": 10,
      "text": "When it goes well with the righteous, the city rejoices,"
    },
    {
      "block_id": "prov-11-11",
      "type": "verse",
      "number": 11,
      "text": "By the blessing of the upright a city is exalted,"
    },
    {
      "block_id": "prov-11-12",
      "type": "verse",
      "number": 12,
      "text": "Whoever belittles another lacks sense,"
    },
    {
      "block_id": "prov-11-13",
      "type": "verse",
      "number": 13,
      "text": "A gossip goes about telling secrets,"
    },
    {
      "block_id": "prov-11-14",
      "type": "verse",
      "number": 14,
      "text": "Where there is no guidance, a nation falls,"
    },
    {
      "block_id": "prov-11-15",
      "type": "verse",
      "number": 15,
      "text": "To guarantee loans for a stranger brings trouble,"
    },
    {
      "block_id": "prov-11-16",
      "type": "verse",
      "number": 16,
      "text": "A gracious woman gets honor,"
    },
    {
      "block_id": "prov-11-17",
      "type": "verse",
      "number": 17,
      "text": "Those who are kind reward themselves,"
    },
    {
      "block_id": "prov-11-18",
      "type": "verse",
      "number": 18,
      "text": "The wicked earn no real gain,"
    },
    {
      "block_id": "prov-11-19",
      "type": "verse",
      "number": 19,
      "text": "Whoever is steadfast in righteousness will live,"
    },
    {
      "block_id": "prov-11-20",
      "type": "verse",
      "number": 20,
      "text": "Crooked minds are an abomination to the Lord,"
    },
    {
      "block_id": "prov-11-21",
      "type": "verse",
      "number": 21,
      "text": "Be assured, the wicked will not go unpunished,"
    },
    {
      "block_id": "prov-11-22",
      "type": "verse",
      "number": 22,
      "text": "Like a gold ring in a pig’s snout"
    },
    {
      "block_id": "prov-11-23",
      "type": "verse",
      "number": 23,
      "text": "The desire of the righteous ends only in good,"
    },
    {
      "block_id": "prov-11-24",
      "type": "verse",
      "number": 24,
      "text": "Some give freely yet grow all the richer;"
    },
    {
      "block_id": "prov-11-25",
      "type": "verse",
      "number": 25,
      "text": "A generous person will be enriched,"
    },
    {
      "block_id": "prov-11-26",
      "type": "verse",
      "number": 26,
      "text": "The people curse those who hold back grain,"
    },
    {
      "block_id": "prov-11-27",
      "type": "verse",
      "number": 27,
      "text": "Whoever diligently seeks good seeks favor,"
    },
    {
      "block_id": "prov-11-28",
      "type": "verse",
      "number": 28,
      "text": "Those who trust in their riches will wither,"
    },
    {
      "block_id": "prov-11-29",
      "type": "verse",
      "number": 29,
      "text": "Those who trouble their households will inherit wind,"
    },
    {
      "block_id": "prov-11-30",
      "type": "verse",
      "number": 30,
      "text": "The fruit of the righteous is a tree of life,"
    },
    {
      "block_id": "prov-11-31",
      "type": "verse",
      "number": 31,
      "text": "If the righteous are repaid on earth,"
    }
  ]
}