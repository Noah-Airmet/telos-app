{
  "document_id": "ps-56",
  "title": "Psalms 56",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-56-1",
      "type": "verse",
      "number": 1,
      "text": "Be gracious to me, O God, for people trample on me;"
    },
    {
      "block_id": "ps-56-2",
      "type": "verse",
      "number": 2,
      "text": "my enemies trample on me all day long,"
    },
    {
      "block_id": "ps-56-3",
      "type": "verse",
      "number": 3,
      "text": "when I am afraid,"
    },
    {
      "block_id": "ps-56-4",
      "type": "verse",
      "number": 4,
      "text": "In God, whose word I praise,"
    },
    {
      "block_id": "ps-56-5",
      "type": "verse",
      "number": 5,
      "text": "All day long they seek to injure my cause;"
    },
    {
      "block_id": "ps-56-6",
      "type": "verse",
      "number": 6,
      "text": "They stir up strife; they lurk;"
    },
    {
      "block_id": "ps-56-7",
      "type": "verse",
      "number": 7,
      "text": "Do not deliver them for any reason;"
    },
    {
      "block_id": "ps-56-8",
      "type": "verse",
      "number": 8,
      "text": "You have kept count of my tossings;"
    },
    {
      "block_id": "ps-56-9",
      "type": "verse",
      "number": 9,
      "text": "Then my enemies will retreat"
    },
    {
      "block_id": "ps-56-10",
      "type": "verse",
      "number": 10,
      "text": "In God, whose word I praise,"
    },
    {
      "block_id": "ps-56-11",
      "type": "verse",
      "number": 11,
      "text": "in God I trust; I am not afraid."
    },
    {
      "block_id": "ps-56-12",
      "type": "verse",
      "number": 12,
      "text": "My vows to you I must perform, O God;"
    },
    {
      "block_id": "ps-56-13",
      "type": "verse",
      "number": 13,
      "text": "For you have delivered my soul from death"
    }
  ]
}