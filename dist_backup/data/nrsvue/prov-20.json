{
  "document_id": "prov-20",
  "title": "Proverbs 20",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-20-1",
      "type": "verse",
      "number": 1,
      "text": "Wine is a mocker, strong drink a brawler,"
    },
    {
      "block_id": "prov-20-2",
      "type": "verse",
      "number": 2,
      "text": "The dread anger of a king is like the growling of a lion;"
    },
    {
      "block_id": "prov-20-3",
      "type": "verse",
      "number": 3,
      "text": "It is honorable to refrain from strife,"
    },
    {
      "block_id": "prov-20-4",
      "type": "verse",
      "number": 4,
      "text": "The lazy person does not plow in season;"
    },
    {
      "block_id": "prov-20-5",
      "type": "verse",
      "number": 5,
      "text": "The purposes in the human mind are like deep water,"
    },
    {
      "block_id": "prov-20-6",
      "type": "verse",
      "number": 6,
      "text": "Many proclaim themselves loyal,"
    },
    {
      "block_id": "prov-20-7",
      "type": "verse",
      "number": 7,
      "text": "The righteous walk in integrity—"
    },
    {
      "block_id": "prov-20-8",
      "type": "verse",
      "number": 8,
      "text": "A king who sits on the throne of judgment"
    },
    {
      "block_id": "prov-20-9",
      "type": "verse",
      "number": 9,
      "text": "Who can say, “I have made my heart clean;"
    },
    {
      "block_id": "prov-20-10",
      "type": "verse",
      "number": 10,
      "text": "Diverse weights and diverse measures"
    },
    {
      "block_id": "prov-20-11",
      "type": "verse",
      "number": 11,
      "text": "Even children make themselves known by their acts,"
    },
    {
      "block_id": "prov-20-12",
      "type": "verse",
      "number": 12,
      "text": "The hearing ear and the seeing eye—"
    },
    {
      "block_id": "prov-20-13",
      "type": "verse",
      "number": 13,
      "text": "Do not love sleep, or else you will come to poverty;"
    },
    {
      "block_id": "prov-20-14",
      "type": "verse",
      "number": 14,
      "text": "“Bad, bad,” says the buyer,"
    },
    {
      "block_id": "prov-20-15",
      "type": "verse",
      "number": 15,
      "text": "There is gold and abundance of costly stones,"
    },
    {
      "block_id": "prov-20-16",
      "type": "verse",
      "number": 16,
      "text": "Take the garment of one who has given surety for a stranger;"
    },
    {
      "block_id": "prov-20-17",
      "type": "verse",
      "number": 17,
      "text": "Bread gained by deceit is sweet,"
    },
    {
      "block_id": "prov-20-18",
      "type": "verse",
      "number": 18,
      "text": "Plans are established by taking advice;"
    },
    {
      "block_id": "prov-20-19",
      "type": "verse",
      "number": 19,
      "text": "A gossip reveals secrets;"
    },
    {
      "block_id": "prov-20-20",
      "type": "verse",
      "number": 20,
      "text": "If you curse father or mother,"
    },
    {
      "block_id": "prov-20-21",
      "type": "verse",
      "number": 21,
      "text": "An estate quickly acquired in the beginning"
    },
    {
      "block_id": "prov-20-22",
      "type": "verse",
      "number": 22,
      "text": "Do not say, “I will repay evil”;"
    },
    {
      "block_id": "prov-20-23",
      "type": "verse",
      "number": 23,
      "text": "Differing weights are an abomination to the Lord,"
    },
    {
      "block_id": "prov-20-24",
      "type": "verse",
      "number": 24,
      "text": "All our steps are ordered by the Lord;"
    },
    {
      "block_id": "prov-20-25",
      "type": "verse",
      "number": 25,
      "text": "It is a snare for one to say rashly, “It is holy,”"
    },
    {
      "block_id": "prov-20-26",
      "type": "verse",
      "number": 26,
      "text": "A wise king winnows the wicked"
    },
    {
      "block_id": "prov-20-27",
      "type": "verse",
      "number": 27,
      "text": "The human spirit is the lamp of the Lord,"
    },
    {
      "block_id": "prov-20-28",
      "type": "verse",
      "number": 28,
      "text": "Loyalty and faithfulness preserve the king,"
    },
    {
      "block_id": "prov-20-29",
      "type": "verse",
      "number": 29,
      "text": "The glory of youths is their strength,"
    },
    {
      "block_id": "prov-20-30",
      "type": "verse",
      "number": 30,
      "text": "Blows that wound cleanse away evil;"
    }
  ]
}