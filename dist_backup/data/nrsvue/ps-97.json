{
  "document_id": "ps-97",
  "title": "Psalms 97",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-97-1",
      "type": "verse",
      "number": 1,
      "text": "The Lord is king! Let the earth rejoice;"
    },
    {
      "block_id": "ps-97-2",
      "type": "verse",
      "number": 2,
      "text": "Clouds and thick darkness are all around him;"
    },
    {
      "block_id": "ps-97-3",
      "type": "verse",
      "number": 3,
      "text": "Fire goes before him"
    },
    {
      "block_id": "ps-97-4",
      "type": "verse",
      "number": 4,
      "text": "His lightnings light up the world;"
    },
    {
      "block_id": "ps-97-5",
      "type": "verse",
      "number": 5,
      "text": "The mountains melt like wax before the Lord,"
    },
    {
      "block_id": "ps-97-6",
      "type": "verse",
      "number": 6,
      "text": "The heavens proclaim his righteousness,"
    },
    {
      "block_id": "ps-97-7",
      "type": "verse",
      "number": 7,
      "text": "All servants of images are put to shame,"
    },
    {
      "block_id": "ps-97-8",
      "type": "verse",
      "number": 8,
      "text": "Zion hears and is glad,"
    },
    {
      "block_id": "ps-97-9",
      "type": "verse",
      "number": 9,
      "text": "For you, O Lord, are most high over all the earth;"
    },
    {
      "block_id": "ps-97-10",
      "type": "verse",
      "number": 10,
      "text": "You who love the Lord, hate evil;"
    },
    {
      "block_id": "ps-97-11",
      "type": "verse",
      "number": 11,
      "text": "Light dawns for the righteous"
    },
    {
      "block_id": "ps-97-12",
      "type": "verse",
      "number": 12,
      "text": "Rejoice in the Lord, O you righteous,"
    }
  ]
}