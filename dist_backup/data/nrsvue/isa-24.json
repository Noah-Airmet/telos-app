{
  "document_id": "isa-24",
  "title": "Isaiah 24",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-24-1",
      "type": "verse",
      "number": 1,
      "text": "Now the Lord is about to lay waste the earth and make it desolate,"
    },
    {
      "block_id": "isa-24-2",
      "type": "verse",
      "number": 2,
      "text": "And it shall be, as with the people, so with the priest;"
    },
    {
      "block_id": "isa-24-3",
      "type": "verse",
      "number": 3,
      "text": "The earth shall be utterly laid waste and utterly despoiled,"
    },
    {
      "block_id": "isa-24-4",
      "type": "verse",
      "number": 4,
      "text": "The earth dries up and withers;"
    },
    {
      "block_id": "isa-24-5",
      "type": "verse",
      "number": 5,
      "text": "The earth lies polluted"
    },
    {
      "block_id": "isa-24-6",
      "type": "verse",
      "number": 6,
      "text": "Therefore a curse devours the earth,"
    },
    {
      "block_id": "isa-24-7",
      "type": "verse",
      "number": 7,
      "text": "The wine dries up;"
    },
    {
      "block_id": "isa-24-8",
      "type": "verse",
      "number": 8,
      "text": "The mirth of the timbrels is stilled;"
    },
    {
      "block_id": "isa-24-9",
      "type": "verse",
      "number": 9,
      "text": "No longer do they drink wine with singing;"
    },
    {
      "block_id": "isa-24-10",
      "type": "verse",
      "number": 10,
      "text": "The city of chaos is broken down;"
    },
    {
      "block_id": "isa-24-11",
      "type": "verse",
      "number": 11,
      "text": "There is an outcry in the streets for lack of wine;"
    },
    {
      "block_id": "isa-24-12",
      "type": "verse",
      "number": 12,
      "text": "Desolation is left in the city;"
    },
    {
      "block_id": "isa-24-13",
      "type": "verse",
      "number": 13,
      "text": "For thus it shall be on the earth"
    },
    {
      "block_id": "isa-24-14",
      "type": "verse",
      "number": 14,
      "text": "They lift up their voices; they sing for joy;"
    },
    {
      "block_id": "isa-24-15",
      "type": "verse",
      "number": 15,
      "text": "Therefore in the east give glory to the Lord;"
    },
    {
      "block_id": "isa-24-16",
      "type": "verse",
      "number": 16,
      "text": "From the ends of the earth we hear songs of praise,"
    },
    {
      "block_id": "isa-24-17",
      "type": "verse",
      "number": 17,
      "text": "Terror, the pit, and the snare"
    },
    {
      "block_id": "isa-24-18",
      "type": "verse",
      "number": 18,
      "text": "Whoever flees at the sound of the terror"
    },
    {
      "block_id": "isa-24-19",
      "type": "verse",
      "number": 19,
      "text": "The earth is utterly broken;"
    },
    {
      "block_id": "isa-24-20",
      "type": "verse",
      "number": 20,
      "text": "The earth staggers like a drunkard;"
    },
    {
      "block_id": "isa-24-21",
      "type": "verse",
      "number": 21,
      "text": "On that day the Lord will punish"
    },
    {
      "block_id": "isa-24-22",
      "type": "verse",
      "number": 22,
      "text": "They will be gathered together"
    },
    {
      "block_id": "isa-24-23",
      "type": "verse",
      "number": 23,
      "text": "Then the moon will be abashed"
    }
  ]
}