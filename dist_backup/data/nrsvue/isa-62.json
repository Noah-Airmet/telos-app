{
  "document_id": "isa-62",
  "title": "Isaiah 62",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-62-1",
      "type": "verse",
      "number": 1,
      "text": "For Zion’s sake I will not keep silent,"
    },
    {
      "block_id": "isa-62-2",
      "type": "verse",
      "number": 2,
      "text": "The nations shall see your vindication"
    },
    {
      "block_id": "isa-62-3",
      "type": "verse",
      "number": 3,
      "text": "You shall be a beautiful crown in the hand of the Lord"
    },
    {
      "block_id": "isa-62-4",
      "type": "verse",
      "number": 4,
      "text": "You shall no more be termed Forsaken,"
    },
    {
      "block_id": "isa-62-5",
      "type": "verse",
      "number": 5,
      "text": "For as a young man marries a young woman,"
    },
    {
      "block_id": "isa-62-6",
      "type": "verse",
      "number": 6,
      "text": "Upon your walls, O Jerusalem,"
    },
    {
      "block_id": "isa-62-7",
      "type": "verse",
      "number": 7,
      "text": "and give him no rest"
    },
    {
      "block_id": "isa-62-8",
      "type": "verse",
      "number": 8,
      "text": "The Lord has sworn by his right hand"
    },
    {
      "block_id": "isa-62-9",
      "type": "verse",
      "number": 9,
      "text": "but those who harvest it shall eat it"
    },
    {
      "block_id": "isa-62-10",
      "type": "verse",
      "number": 10,
      "text": "Go through, go through the gates;"
    },
    {
      "block_id": "isa-62-11",
      "type": "verse",
      "number": 11,
      "text": "The Lord has proclaimed"
    },
    {
      "block_id": "isa-62-12",
      "type": "verse",
      "number": 12,
      "text": "They shall be called, “The Holy People,"
    }
  ]
}