{
  "document_id": "sir-1",
  "title": "Sirach 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-1-1",
      "type": "verse",
      "number": 1,
      "text": "All wisdom is from the Lord,"
    },
    {
      "block_id": "sir-1-2",
      "type": "verse",
      "number": 2,
      "text": "The sand of the sea, the drops of rain,"
    },
    {
      "block_id": "sir-1-3",
      "type": "verse",
      "number": 3,
      "text": "The height of heaven, the breadth of the earth,"
    },
    {
      "block_id": "sir-1-4",
      "type": "verse",
      "number": 4,
      "text": "Wisdom was created before all things"
    },
    {
      "block_id": "sir-1-6",
      "type": "verse",
      "number": 6,
      "text": "The root of wisdom—to whom has it been revealed?"
    },
    {
      "block_id": "sir-1-8",
      "type": "verse",
      "number": 8,
      "text": "There is but one who is wise, greatly to be feared,"
    },
    {
      "block_id": "sir-1-9",
      "type": "verse",
      "number": 9,
      "text": "It is he who created her;"
    },
    {
      "block_id": "sir-1-10",
      "type": "verse",
      "number": 10,
      "text": "upon all the living according to his gift;"
    },
    {
      "block_id": "sir-1-11",
      "type": "verse",
      "number": 11,
      "text": "The fear of the Lord is glory and exultation"
    },
    {
      "block_id": "sir-1-12",
      "type": "verse",
      "number": 12,
      "text": "The fear of the Lord delights the heart"
    },
    {
      "block_id": "sir-1-13",
      "type": "verse",
      "number": 13,
      "text": "Those who fear the Lord will have a happy end;"
    },
    {
      "block_id": "sir-1-14",
      "type": "verse",
      "number": 14,
      "text": "To fear the Lord is the beginning of wisdom;"
    },
    {
      "block_id": "sir-1-15",
      "type": "verse",
      "number": 15,
      "text": "She made among humans an eternal foundation,"
    },
    {
      "block_id": "sir-1-16",
      "type": "verse",
      "number": 16,
      "text": "To fear the Lord is fullness of wisdom;"
    },
    {
      "block_id": "sir-1-17",
      "type": "verse",
      "number": 17,
      "text": "she fills their whole house with desirable goods"
    },
    {
      "block_id": "sir-1-18",
      "type": "verse",
      "number": 18,
      "text": "The fear of the Lord is the crown of wisdom,"
    },
    {
      "block_id": "sir-1-19",
      "type": "verse",
      "number": 19,
      "text": "She rained down knowledge and discerning comprehension,"
    },
    {
      "block_id": "sir-1-20",
      "type": "verse",
      "number": 20,
      "text": "To fear the Lord is the root of wisdom,"
    },
    {
      "block_id": "sir-1-22",
      "type": "verse",
      "number": 22,
      "text": "Unjust anger cannot be justified,"
    },
    {
      "block_id": "sir-1-23",
      "type": "verse",
      "number": 23,
      "text": "Those who are patient stay calm until the right moment,"
    },
    {
      "block_id": "sir-1-24",
      "type": "verse",
      "number": 24,
      "text": "They hold back their words until the right moment,"
    },
    {
      "block_id": "sir-1-25",
      "type": "verse",
      "number": 25,
      "text": "In the treasuries of wisdom is insightful analogy,"
    },
    {
      "block_id": "sir-1-26",
      "type": "verse",
      "number": 26,
      "text": "If you desire wisdom, keep the commandments,"
    },
    {
      "block_id": "sir-1-27",
      "type": "verse",
      "number": 27,
      "text": "For the fear of the Lord is wisdom and discipline;"
    },
    {
      "block_id": "sir-1-28",
      "type": "verse",
      "number": 28,
      "text": "Do not disobey the fear of the Lord;"
    },
    {
      "block_id": "sir-1-29",
      "type": "verse",
      "number": 29,
      "text": "Do not be a hypocrite before others,"
    },
    {
      "block_id": "sir-1-30",
      "type": "verse",
      "number": 30,
      "text": "Do not exalt yourself, or you may fall"
    }
  ]
}