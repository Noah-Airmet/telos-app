  "blocks": [
    {
      "block_id": "isa-12-heading-thanksgiving-and-pra",
      "type": "heading",
      "text": "Thanksgiving and Praise"
    },
    {
      "block_id": "isa-12-1",
      "type": "verse",
      "number": 1,
      "text": "You will say on that day:"
    },
    {
      "block_id": "isa-12-2",
      "type": "verse",
      "number": 2,
      "text": "Surely God is my salvation;"
    },
    {
      "block_id": "isa-12-3",
      "type": "verse",
      "number": 3,
      "text": "With joy you will draw water from the wells of salvation."
    },
    {
      "block_id": "isa-12-4",
      "type": "verse",
      "number": 4,
      "text": "And you will say on that day:"
    },
    {
      "block_id": "isa-12-5",
      "type": "verse",
      "number": 5,
      "text": "Sing praises to the Lord, for he has done gloriously;"
    },
    {
      "block_id": "isa-12-6",
      "type": "verse",
      "number": 6,
      "text": "Shout aloud and sing for joy, O royal Zion,"
    }
  ]
}