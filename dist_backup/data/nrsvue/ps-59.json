{
  "document_id": "ps-59",
  "title": "Psalms 59",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-59-1",
      "type": "verse",
      "number": 1,
      "text": "Deliver me from my enemies, O my God;"
    },
    {
      "block_id": "ps-59-2",
      "type": "verse",
      "number": 2,
      "text": "Deliver me from those who work evil;"
    },
    {
      "block_id": "ps-59-3",
      "type": "verse",
      "number": 3,
      "text": "Even now they lie in wait for my life;"
    },
    {
      "block_id": "ps-59-4",
      "type": "verse",
      "number": 4,
      "text": "for no fault of mine, they run and make ready."
    },
    {
      "block_id": "ps-59-5",
      "type": "verse",
      "number": 5,
      "text": "You, Lord God of hosts, are God of Israel."
    },
    {
      "block_id": "ps-59-6",
      "type": "verse",
      "number": 6,
      "text": "Each evening they come back"
    },
    {
      "block_id": "ps-59-7",
      "type": "verse",
      "number": 7,
      "text": "There they are, bellowing with their mouths,"
    },
    {
      "block_id": "ps-59-8",
      "type": "verse",
      "number": 8,
      "text": "But you laugh at them, O Lord;"
    },
    {
      "block_id": "ps-59-9",
      "type": "verse",
      "number": 9,
      "text": "O my strength, I will watch for you,"
    },
    {
      "block_id": "ps-59-10",
      "type": "verse",
      "number": 10,
      "text": "My God in his steadfast love will meet me;"
    },
    {
      "block_id": "ps-59-11",
      "type": "verse",
      "number": 11,
      "text": "Do not kill them, or my people may forget;"
    },
    {
      "block_id": "ps-59-12",
      "type": "verse",
      "number": 12,
      "text": "For the sin of their mouths, the words of their lips,"
    },
    {
      "block_id": "ps-59-13",
      "type": "verse",
      "number": 13,
      "text": "consume them in wrath;"
    },
    {
      "block_id": "ps-59-14",
      "type": "verse",
      "number": 14,
      "text": "Each evening they come back"
    },
    {
      "block_id": "ps-59-15",
      "type": "verse",
      "number": 15,
      "text": "They roam about for food"
    },
    {
      "block_id": "ps-59-16",
      "type": "verse",
      "number": 16,
      "text": "But I will sing of your might;"
    },
    {
      "block_id": "ps-59-17",
      "type": "verse",
      "number": 17,
      "text": "O my strength, I will sing praises to you,"
    }
  ]
}