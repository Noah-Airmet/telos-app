{
  "document_id": "ps-80",
  "title": "Psalms 80",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-80-1",
      "type": "verse",
      "number": 1,
      "text": "Give ear, O Shepherd of Israel,"
    },
    {
      "block_id": "ps-80-2",
      "type": "verse",
      "number": 2,
      "text": "before Ephraim and Benjamin and Manasseh."
    },
    {
      "block_id": "ps-80-3",
      "type": "verse",
      "number": 3,
      "text": "Restore us, O God;"
    },
    {
      "block_id": "ps-80-4",
      "type": "verse",
      "number": 4,
      "text": "O Lord God of hosts,"
    },
    {
      "block_id": "ps-80-5",
      "type": "verse",
      "number": 5,
      "text": "You have fed them with the bread of tears"
    },
    {
      "block_id": "ps-80-6",
      "type": "verse",
      "number": 6,
      "text": "You make us the scorn of our neighbors;"
    },
    {
      "block_id": "ps-80-7",
      "type": "verse",
      "number": 7,
      "text": "Restore us, O God of hosts;"
    },
    {
      "block_id": "ps-80-8",
      "type": "verse",
      "number": 8,
      "text": "You brought a vine out of Egypt;"
    },
    {
      "block_id": "ps-80-9",
      "type": "verse",
      "number": 9,
      "text": "You cleared the ground for it;"
    },
    {
      "block_id": "ps-80-10",
      "type": "verse",
      "number": 10,
      "text": "The mountains were covered with its shade,"
    },
    {
      "block_id": "ps-80-11",
      "type": "verse",
      "number": 11,
      "text": "it sent out its branches to the sea"
    },
    {
      "block_id": "ps-80-12",
      "type": "verse",
      "number": 12,
      "text": "Why then have you broken down its walls,"
    },
    {
      "block_id": "ps-80-13",
      "type": "verse",
      "number": 13,
      "text": "The boar from the forest ravages it,"
    },
    {
      "block_id": "ps-80-14",
      "type": "verse",
      "number": 14,
      "text": "Turn again, O God of hosts;"
    },
    {
      "block_id": "ps-80-15",
      "type": "verse",
      "number": 15,
      "text": "the stock that your right hand planted."
    },
    {
      "block_id": "ps-80-16",
      "type": "verse",
      "number": 16,
      "text": "It has been burned with fire; it has been cut down;"
    },
    {
      "block_id": "ps-80-17",
      "type": "verse",
      "number": 17,
      "text": "But let your hand be upon the one at your right hand,"
    },
    {
      "block_id": "ps-80-18",
      "type": "verse",
      "number": 18,
      "text": "Then we will never turn back from you;"
    },
    {
      "block_id": "ps-80-19",
      "type": "verse",
      "number": 19,
      "text": "Restore us, O Lord God of hosts;"
    }
  ]
}