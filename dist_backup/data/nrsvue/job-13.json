{
  "document_id": "job-13",
  "title": "Job 13",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-13-1",
      "type": "verse",
      "number": 1,
      "text": "“Look, my eye has seen all this;"
    },
    {
      "block_id": "job-13-2",
      "type": "verse",
      "number": 2,
      "text": "What you know, I also know;"
    },
    {
      "block_id": "job-13-3",
      "type": "verse",
      "number": 3,
      "text": "But I would speak to the Almighty,"
    },
    {
      "block_id": "job-13-4",
      "type": "verse",
      "number": 4,
      "text": "As for you, you whitewash with lies;"
    },
    {
      "block_id": "job-13-5",
      "type": "verse",
      "number": 5,
      "text": "If you would only keep silent,"
    },
    {
      "block_id": "job-13-6",
      "type": "verse",
      "number": 6,
      "text": "Hear now my reasoning,"
    },
    {
      "block_id": "job-13-7",
      "type": "verse",
      "number": 7,
      "text": "Will you speak falsely for God"
    },
    {
      "block_id": "job-13-8",
      "type": "verse",
      "number": 8,
      "text": "Will you show partiality toward him;"
    },
    {
      "block_id": "job-13-9",
      "type": "verse",
      "number": 9,
      "text": "Will it be well with you when he searches you out?"
    },
    {
      "block_id": "job-13-10",
      "type": "verse",
      "number": 10,
      "text": "He will surely rebuke you"
    },
    {
      "block_id": "job-13-11",
      "type": "verse",
      "number": 11,
      "text": "Will not his majesty terrify you"
    },
    {
      "block_id": "job-13-12",
      "type": "verse",
      "number": 12,
      "text": "Your maxims are proverbs of ashes;"
    },
    {
      "block_id": "job-13-13",
      "type": "verse",
      "number": 13,
      "text": "“Let me have silence, and I will speak,"
    },
    {
      "block_id": "job-13-14",
      "type": "verse",
      "number": 14,
      "text": "I will take my flesh in my teeth"
    },
    {
      "block_id": "job-13-15",
      "type": "verse",
      "number": 15,
      "text": "See, he will kill me; I have no hope;"
    },
    {
      "block_id": "job-13-16",
      "type": "verse",
      "number": 16,
      "text": "This will be my salvation,"
    },
    {
      "block_id": "job-13-17",
      "type": "verse",
      "number": 17,
      "text": "Listen carefully to my words,"
    },
    {
      "block_id": "job-13-18",
      "type": "verse",
      "number": 18,
      "text": "I have indeed prepared my case;"
    },
    {
      "block_id": "job-13-19",
      "type": "verse",
      "number": 19,
      "text": "Who is there who will contend with me?"
    },
    {
      "block_id": "job-13-20",
      "type": "verse",
      "number": 20,
      "text": "“Only grant two things to me;"
    },
    {
      "block_id": "job-13-21",
      "type": "verse",
      "number": 21,
      "text": "withdraw your hand far from me,"
    },
    {
      "block_id": "job-13-22",
      "type": "verse",
      "number": 22,
      "text": "Then call, and I will answer;"
    },
    {
      "block_id": "job-13-23",
      "type": "verse",
      "number": 23,
      "text": "How many are my iniquities and my sins?"
    },
    {
      "block_id": "job-13-24",
      "type": "verse",
      "number": 24,
      "text": "Why do you hide your face"
    },
    {
      "block_id": "job-13-25",
      "type": "verse",
      "number": 25,
      "text": "Will you frighten a windblown leaf"
    },
    {
      "block_id": "job-13-26",
      "type": "verse",
      "number": 26,
      "text": "For you write bitter things against me"
    },
    {
      "block_id": "job-13-27",
      "type": "verse",
      "number": 27,
      "text": "You put my feet in the stocks"
    },
    {
      "block_id": "job-13-28",
      "type": "verse",
      "number": 28,
      "text": "One wastes away like a rotten thing,"
    }
  ]
}