{
  "document_id": "hos-14",
  "title": "Hosea 14",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-14-1",
      "type": "verse",
      "number": 1,
      "text": "Return, O Israel, to the Lord your God,"
    },
    {
      "block_id": "hos-14-2",
      "type": "verse",
      "number": 2,
      "text": "Take words with you"
    },
    {
      "block_id": "hos-14-3",
      "type": "verse",
      "number": 3,
      "text": "Assyria shall not save us;"
    },
    {
      "block_id": "hos-14-4",
      "type": "verse",
      "number": 4,
      "text": "I will heal their disloyalty;"
    },
    {
      "block_id": "hos-14-5",
      "type": "verse",
      "number": 5,
      "text": "I will be like the dew to Israel;"
    },
    {
      "block_id": "hos-14-6",
      "type": "verse",
      "number": 6,
      "text": "His shoots shall spread out;"
    },
    {
      "block_id": "hos-14-7",
      "type": "verse",
      "number": 7,
      "text": "They shall again live beneath my shadow;"
    },
    {
      "block_id": "hos-14-8",
      "type": "verse",
      "number": 8,
      "text": "O Ephraim, what have I to do with idols?"
    },
    {
      "block_id": "hos-14-9",
      "type": "verse",
      "number": 9,
      "text": "Those who are wise understand these things;"
    }
  ]
}