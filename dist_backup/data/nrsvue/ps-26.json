{
  "document_id": "ps-26",
  "title": "Psalms 26",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-26-1",
      "type": "verse",
      "number": 1,
      "text": "Vindicate me, O Lord,"
    },
    {
      "block_id": "ps-26-2",
      "type": "verse",
      "number": 2,
      "text": "Prove me, O Lord, and try me;"
    },
    {
      "block_id": "ps-26-3",
      "type": "verse",
      "number": 3,
      "text": "For your steadfast love is before my eyes,"
    },
    {
      "block_id": "ps-26-4",
      "type": "verse",
      "number": 4,
      "text": "I do not sit with the worthless,"
    },
    {
      "block_id": "ps-26-5",
      "type": "verse",
      "number": 5,
      "text": "I hate the company of evildoers"
    },
    {
      "block_id": "ps-26-6",
      "type": "verse",
      "number": 6,
      "text": "I wash my hands in innocence"
    },
    {
      "block_id": "ps-26-7",
      "type": "verse",
      "number": 7,
      "text": "singing aloud a song of thanksgiving"
    },
    {
      "block_id": "ps-26-8",
      "type": "verse",
      "number": 8,
      "text": "O Lord, I love the house in which you dwell"
    },
    {
      "block_id": "ps-26-9",
      "type": "verse",
      "number": 9,
      "text": "Do not sweep me away with sinners"
    },
    {
      "block_id": "ps-26-10",
      "type": "verse",
      "number": 10,
      "text": "those in whose hands are evil devices"
    },
    {
      "block_id": "ps-26-11",
      "type": "verse",
      "number": 11,
      "text": "But as for me, I walk in my integrity;"
    },
    {
      "block_id": "ps-26-12",
      "type": "verse",
      "number": 12,
      "text": "My foot stands on level ground;"
    }
  ]
}