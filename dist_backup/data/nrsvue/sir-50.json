{
  "document_id": "sir-50",
  "title": "Sirach 50",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-50-1",
      "type": "verse",
      "number": 1,
      "text": "The leader of his brothers and the pride of his people"
    },
    {
      "block_id": "sir-50-2",
      "type": "verse",
      "number": 2,
      "text": "He laid the foundations for the high double walls,"
    },
    {
      "block_id": "sir-50-3",
      "type": "verse",
      "number": 3,
      "text": "In his days a water cistern was dug,"
    },
    {
      "block_id": "sir-50-4",
      "type": "verse",
      "number": 4,
      "text": "He considered how to save his people from ruin"
    },
    {
      "block_id": "sir-50-5",
      "type": "verse",
      "number": 5,
      "text": "How glorious he was as he gazed from the tent,"
    },
    {
      "block_id": "sir-50-6",
      "type": "verse",
      "number": 6,
      "text": "like the morning star among the clouds,"
    },
    {
      "block_id": "sir-50-7",
      "type": "verse",
      "number": 7,
      "text": "like the sun shining on the temple of the Most High,"
    },
    {
      "block_id": "sir-50-8",
      "type": "verse",
      "number": 8,
      "text": "like roses in the days of the spring harvest,"
    },
    {
      "block_id": "sir-50-9",
      "type": "verse",
      "number": 9,
      "text": "like fire and incense in the censer,"
    },
    {
      "block_id": "sir-50-10",
      "type": "verse",
      "number": 10,
      "text": "like an olive tree laden with fruit,"
    },
    {
      "block_id": "sir-50-11",
      "type": "verse",
      "number": 11,
      "text": "When he put on his glorious robe"
    },
    {
      "block_id": "sir-50-12",
      "type": "verse",
      "number": 12,
      "text": "When he received the portions from the hands of the priests,"
    },
    {
      "block_id": "sir-50-13",
      "type": "verse",
      "number": 13,
      "text": "All the sons of Aaron in their splendor"
    },
    {
      "block_id": "sir-50-14",
      "type": "verse",
      "number": 14,
      "text": "Finishing the service at the altars"
    },
    {
      "block_id": "sir-50-15",
      "type": "verse",
      "number": 15,
      "text": "he held out his hand for the cup"
    },
    {
      "block_id": "sir-50-16",
      "type": "verse",
      "number": 16,
      "text": "Then the sons of Aaron shouted;"
    },
    {
      "block_id": "sir-50-17",
      "type": "verse",
      "number": 17,
      "text": "Then all the people together quickly"
    },
    {
      "block_id": "sir-50-18",
      "type": "verse",
      "number": 18,
      "text": "Then the singers praised him with their voices"
    },
    {
      "block_id": "sir-50-19",
      "type": "verse",
      "number": 19,
      "text": "And the people of the Lord Most High offered"
    },
    {
      "block_id": "sir-50-20",
      "type": "verse",
      "number": 20,
      "text": "Then Simon came down and raised his hands"
    },
    {
      "block_id": "sir-50-21",
      "type": "verse",
      "number": 21,
      "text": "and they bowed down in worship a second time"
    },
    {
      "block_id": "sir-50-22",
      "type": "verse",
      "number": 22,
      "text": "And now bless the God of all,"
    },
    {
      "block_id": "sir-50-23",
      "type": "verse",
      "number": 23,
      "text": "May he give us gladness of heart,"
    },
    {
      "block_id": "sir-50-24",
      "type": "verse",
      "number": 24,
      "text": "May he entrust to us his mercy,"
    },
    {
      "block_id": "sir-50-25",
      "type": "verse",
      "number": 25,
      "text": "Two nations my soul detests,"
    },
    {
      "block_id": "sir-50-26",
      "type": "verse",
      "number": 26,
      "text": "those who live in Seir and the Philistines"
    },
    {
      "block_id": "sir-50-27",
      "type": "verse",
      "number": 27,
      "text": "Instruction in understanding and knowledge"
    },
    {
      "block_id": "sir-50-28",
      "type": "verse",
      "number": 28,
      "text": "Happy are those who concern themselves with these things,"
    },
    {
      "block_id": "sir-50-29",
      "type": "verse",
      "number": 29,
      "text": "For if they put them into practice, they will be equal to anything,"
    }
  ]
}