{
  "document_id": "isa-25",
  "title": "Isaiah 25",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-25-1",
      "type": "verse",
      "number": 1,
      "text": "O Lord, you are my God;"
    },
    {
      "block_id": "isa-25-2",
      "type": "verse",
      "number": 2,
      "text": "For you have made the city a heap,"
    },
    {
      "block_id": "isa-25-3",
      "type": "verse",
      "number": 3,
      "text": "Therefore strong peoples will glorify you;"
    },
    {
      "block_id": "isa-25-4",
      "type": "verse",
      "number": 4,
      "text": "For you have been a refuge to the poor,"
    },
    {
      "block_id": "isa-25-5",
      "type": "verse",
      "number": 5,
      "text": "the noise of foreigners like heat in a dry place,"
    },
    {
      "block_id": "isa-25-6",
      "type": "verse",
      "number": 6,
      "text": "On this mountain the Lord of hosts will make for all peoples"
    },
    {
      "block_id": "isa-25-7",
      "type": "verse",
      "number": 7,
      "text": "And he will destroy on this mountain"
    },
    {
      "block_id": "isa-25-8",
      "type": "verse",
      "number": 8,
      "text": "he will swallow up death forever."
    },
    {
      "block_id": "isa-25-9",
      "type": "verse",
      "number": 9,
      "text": "It will be said on that day,"
    },
    {
      "block_id": "isa-25-10",
      "type": "verse",
      "number": 10,
      "text": "For the hand of the Lord will rest on this mountain."
    },
    {
      "block_id": "isa-25-11",
      "type": "verse",
      "number": 11,
      "text": "Though they spread out their hands in the midst of it,"
    },
    {
      "block_id": "isa-25-12",
      "type": "verse",
      "number": 12,
      "text": "The high fortifications of his walls will be brought down,"
    }
  ]
}