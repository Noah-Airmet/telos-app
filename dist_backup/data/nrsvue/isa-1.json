{
  "document_id": "isa-1",
  "title": "Isaiah 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-1-1",
      "type": "verse",
      "number": 1,
      "text": "The vision of Isaiah son of Amoz, which he saw concerning Judah and Jerusalem in the days of Uzziah, Jotham, Ahaz, and Hezekiah, kings of Judah."
    },
    {
      "block_id": "isa-1-2",
      "type": "verse",
      "number": 2,
      "text": "Hear, O heavens, and listen, O earth,"
    },
    {
      "block_id": "isa-1-3",
      "type": "verse",
      "number": 3,
      "text": "The ox knows its owner"
    },
    {
      "block_id": "isa-1-4",
      "type": "verse",
      "number": 4,
      "text": "Woe, sinful nation,"
    },
    {
      "block_id": "isa-1-5",
      "type": "verse",
      "number": 5,
      "text": "Why do you seek further beatings?"
    },
    {
      "block_id": "isa-1-6",
      "type": "verse",
      "number": 6,
      "text": "From the sole of the foot to the head,"
    },
    {
      "block_id": "isa-1-7",
      "type": "verse",
      "number": 7,
      "text": "Your country lies desolate;"
    },
    {
      "block_id": "isa-1-8",
      "type": "verse",
      "number": 8,
      "text": "And daughter Zion is left"
    },
    {
      "block_id": "isa-1-9",
      "type": "verse",
      "number": 9,
      "text": "If the Lord of hosts"
    },
    {
      "block_id": "isa-1-10",
      "type": "verse",
      "number": 10,
      "text": "Hear the word of the Lord,"
    },
    {
      "block_id": "isa-1-11",
      "type": "verse",
      "number": 11,
      "text": "What to me is the multitude of your sacrifices?"
    },
    {
      "block_id": "isa-1-12",
      "type": "verse",
      "number": 12,
      "text": "When you come to appear before me,"
    },
    {
      "block_id": "isa-1-13",
      "type": "verse",
      "number": 13,
      "text": "Bringing offerings is futile;"
    },
    {
      "block_id": "isa-1-14",
      "type": "verse",
      "number": 14,
      "text": "Your new moons and your appointed festivals"
    },
    {
      "block_id": "isa-1-15",
      "type": "verse",
      "number": 15,
      "text": "When you stretch out your hands,"
    },
    {
      "block_id": "isa-1-16",
      "type": "verse",
      "number": 16,
      "text": "Wash yourselves; make yourselves clean;"
    },
    {
      "block_id": "isa-1-17",
      "type": "verse",
      "number": 17,
      "text": "learn to do good;"
    },
    {
      "block_id": "isa-1-18",
      "type": "verse",
      "number": 18,
      "text": "Come now, let us argue it out,"
    },
    {
      "block_id": "isa-1-19",
      "type": "verse",
      "number": 19,
      "text": "If you are willing and obedient,"
    },
    {
      "block_id": "isa-1-20",
      "type": "verse",
      "number": 20,
      "text": "but if you refuse and rebel,"
    },
    {
      "block_id": "isa-1-21",
      "type": "verse",
      "number": 21,
      "text": "How the faithful city"
    },
    {
      "block_id": "isa-1-22",
      "type": "verse",
      "number": 22,
      "text": "Your silver has become dross;"
    },
    {
      "block_id": "isa-1-23",
      "type": "verse",
      "number": 23,
      "text": "Your princes are rebels"
    },
    {
      "block_id": "isa-1-24",
      "type": "verse",
      "number": 24,
      "text": "Therefore says the Sovereign, the Lord of hosts, the Mighty One of Israel:"
    },
    {
      "block_id": "isa-1-25",
      "type": "verse",
      "number": 25,
      "text": "I will turn my hand against you;"
    },
    {
      "block_id": "isa-1-26",
      "type": "verse",
      "number": 26,
      "text": "And I will restore your judges as at the first"
    },
    {
      "block_id": "isa-1-27",
      "type": "verse",
      "number": 27,
      "text": "Zion shall be redeemed by justice,"
    },
    {
      "block_id": "isa-1-28",
      "type": "verse",
      "number": 28,
      "text": "But rebels and sinners shall be destroyed together,"
    },
    {
      "block_id": "isa-1-29",
      "type": "verse",
      "number": 29,
      "text": "For you shall be ashamed of the oaks"
    },
    {
      "block_id": "isa-1-30",
      "type": "verse",
      "number": 30,
      "text": "For you shall be like an oak"
    },
    {
      "block_id": "isa-1-31",
      "type": "verse",
      "number": 31,
      "text": "The strong shall become like tinder"
    }
  ]
}