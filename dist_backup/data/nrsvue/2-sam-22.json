{
  "document_id": "2-sam-22",
  "title": "2 Samuel 22",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "2-sam-22-heading-david’s-song-of-than",
      "type": "heading",
      "text": "David’s Song of Thanksgiving"
    },
    {
      "block_id": "2-sam-22-1",
      "type": "verse",
      "number": 1,
      "text": "David spoke to the Lord the words of this song on the day when the Lord delivered him from the hand of all his enemies and from the hand of Saul."
    },
    {
      "block_id": "2-sam-22-2",
      "type": "verse",
      "number": 2,
      "text": "He said,"
    },
    {
      "block_id": "2-sam-22-3",
      "type": "verse",
      "number": 3,
      "text": "my God, my rock in whom I take refuge,"
    },
    {
      "block_id": "2-sam-22-4",
      "type": "verse",
      "number": 4,
      "text": "I call upon the Lord, who is worthy to be praised,"
    },
    {
      "block_id": "2-sam-22-5",
      "type": "verse",
      "number": 5,
      "text": "For the waves of death encompassed me;"
    },
    {
      "block_id": "2-sam-22-6",
      "type": "verse",
      "number": 6,
      "text": "the cords of Sheol entangled me;"
    },
    {
      "block_id": "2-sam-22-7",
      "type": "verse",
      "number": 7,
      "text": "In my distress I called upon the Lord;"
    },
    {
      "block_id": "2-sam-22-8",
      "type": "verse",
      "number": 8,
      "text": "Then the earth reeled and rocked;"
    },
    {
      "block_id": "2-sam-22-9",
      "type": "verse",
      "number": 9,
      "text": "Smoke went up from his nostrils"
    },
    {
      "block_id": "2-sam-22-10",
      "type": "verse",
      "number": 10,
      "text": "He bowed the heavens and came down;"
    },
    {
      "block_id": "2-sam-22-11",
      "type": "verse",
      "number": 11,
      "text": "He rode on a cherub and flew;"
    },
    {
      "block_id": "2-sam-22-12",
      "type": "verse",
      "number": 12,
      "text": "He made darkness around him a canopy,"
    },
    {
      "block_id": "2-sam-22-13",
      "type": "verse",
      "number": 13,
      "text": "Out of the brightness before him"
    },
    {
      "block_id": "2-sam-22-14",
      "type": "verse",
      "number": 14,
      "text": "The Lord thundered from heaven;"
    },
    {
      "block_id": "2-sam-22-15",
      "type": "verse",
      "number": 15,
      "text": "He sent out arrows and scattered them,"
    },
    {
      "block_id": "2-sam-22-16",
      "type": "verse",
      "number": 16,
      "text": "Then the channels of the sea were seen;"
    },
    {
      "block_id": "2-sam-22-17",
      "type": "verse",
      "number": 17,
      "text": "He reached from on high; he took me;"
    },
    {
      "block_id": "2-sam-22-18",
      "type": "verse",
      "number": 18,
      "text": "He delivered me from my strong enemy,"
    },
    {
      "block_id": "2-sam-22-19",
      "type": "verse",
      "number": 19,
      "text": "They came upon me in the day of my calamity,"
    },
    {
      "block_id": "2-sam-22-20",
      "type": "verse",
      "number": 20,
      "text": "He brought me out into a broad place;"
    },
    {
      "block_id": "2-sam-22-21",
      "type": "verse",
      "number": 21,
      "text": "The Lord rewarded me according to my righteousness;"
    },
    {
      "block_id": "2-sam-22-22",
      "type": "verse",
      "number": 22,
      "text": "For I have kept the ways of the Lord"
    },
    {
      "block_id": "2-sam-22-23",
      "type": "verse",
      "number": 23,
      "text": "For all his ordinances were before me,"
    },
    {
      "block_id": "2-sam-22-24",
      "type": "verse",
      "number": 24,
      "text": "I was blameless before him,"
    },
    {
      "block_id": "2-sam-22-25",
      "type": "verse",
      "number": 25,
      "text": "Therefore the Lord has recompensed me according to my righteousness,"
    },
    {
      "block_id": "2-sam-22-26",
      "type": "verse",
      "number": 26,
      "text": "With the loyal you show yourself loyal;"
    },
    {
      "block_id": "2-sam-22-27",
      "type": "verse",
      "number": 27,
      "text": "with the pure you show yourself pure,"
    },
    {
      "block_id": "2-sam-22-28",
      "type": "verse",
      "number": 28,
      "text": "You deliver a humble people,"
    },
    {
      "block_id": "2-sam-22-29",
      "type": "verse",
      "number": 29,
      "text": "Indeed, you are my lamp, O Lord;"
    },
    {
      "block_id": "2-sam-22-30",
      "type": "verse",
      "number": 30,
      "text": "By you I can outrun a troop,"
    },
    {
      "block_id": "2-sam-22-31",
      "type": "verse",
      "number": 31,
      "text": "This God—his way is perfect;"
    },
    {
      "block_id": "2-sam-22-32",
      "type": "verse",
      "number": 32,
      "text": "For who is God but the Lord?"
    },
    {
      "block_id": "2-sam-22-33",
      "type": "verse",
      "number": 33,
      "text": "The God who has girded me with strength"
    },
    {
      "block_id": "2-sam-22-34",
      "type": "verse",
      "number": 34,
      "text": "He made my feet like the feet of deer"
    },
    {
      "block_id": "2-sam-22-35",
      "type": "verse",
      "number": 35,
      "text": "He trains my hands for war,"
    },
    {
      "block_id": "2-sam-22-36",
      "type": "verse",
      "number": 36,
      "text": "You have given me the shield of your salvation,"
    },
    {
      "block_id": "2-sam-22-37",
      "type": "verse",
      "number": 37,
      "text": "You have made me stride freely,"
    },
    {
      "block_id": "2-sam-22-38",
      "type": "verse",
      "number": 38,
      "text": "I pursued my enemies and destroyed them"
    },
    {
      "block_id": "2-sam-22-39",
      "type": "verse",
      "number": 39,
      "text": "I consumed them; I struck them down so that they did not rise;"
    },
    {
      "block_id": "2-sam-22-40",
      "type": "verse",
      "number": 40,
      "text": "For you girded me with strength for the battle;"
    },
    {
      "block_id": "2-sam-22-41",
      "type": "verse",
      "number": 41,
      "text": "You made my enemies turn their backs to me,"
    },
    {
      "block_id": "2-sam-22-42",
      "type": "verse",
      "number": 42,
      "text": "They looked, but there was no one to save them;"
    },
    {
      "block_id": "2-sam-22-43",
      "type": "verse",
      "number": 43,
      "text": "I beat them fine like the dust of the earth;"
    },
    {
      "block_id": "2-sam-22-44",
      "type": "verse",
      "number": 44,
      "text": "You delivered me from strife with the peoples;"
    },
    {
      "block_id": "2-sam-22-45",
      "type": "verse",
      "number": 45,
      "text": "Foreigners came cringing to me;"
    },
    {
      "block_id": "2-sam-22-46",
      "type": "verse",
      "number": 46,
      "text": "Foreigners lost heart"
    },
    {
      "block_id": "2-sam-22-47",
      "type": "verse",
      "number": 47,
      "text": "The Lord lives! Blessed be my rock,"
    },
    {
      "block_id": "2-sam-22-48",
      "type": "verse",
      "number": 48,
      "text": "the God who gave me vengeance"
    },
    {
      "block_id": "2-sam-22-49",
      "type": "verse",
      "number": 49,
      "text": "who brought me out from my enemies;"
    },
    {
      "block_id": "2-sam-22-50",
      "type": "verse",
      "number": 50,
      "text": "For this I will extol you, O Lord, among the nations"
    },
    {
      "block_id": "2-sam-22-51",
      "type": "verse",
      "number": 51,
      "text": "He is a tower of salvation for his king"
    }
  ]
}