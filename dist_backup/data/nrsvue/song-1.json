{
  "document_id": "song-1",
  "title": "Song of Songs 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "song-1-1",
      "type": "verse",
      "number": 1,
      "text": "The Song of Songs, which is Solomon’s."
    },
    {
      "block_id": "song-1-2",
      "type": "verse",
      "number": 2,
      "text": "Let him kiss me with the kisses of his mouth!"
    },
    {
      "block_id": "song-1-3",
      "type": "verse",
      "number": 3,
      "text": "your anointing oils are fragrant;"
    },
    {
      "block_id": "song-1-4",
      "type": "verse",
      "number": 4,
      "text": "Draw me after you; let us make haste."
    },
    {
      "block_id": "song-1-5",
      "type": "verse",
      "number": 5,
      "text": "I am black and beautiful,"
    },
    {
      "block_id": "song-1-6",
      "type": "verse",
      "number": 6,
      "text": "Do not gaze at me because I am dark,"
    },
    {
      "block_id": "song-1-7",
      "type": "verse",
      "number": 7,
      "text": "Tell me, you whom my soul loves,"
    },
    {
      "block_id": "song-1-8",
      "type": "verse",
      "number": 8,
      "text": "If you do not know,"
    },
    {
      "block_id": "song-1-9",
      "type": "verse",
      "number": 9,
      "text": "I compare you, my love,"
    },
    {
      "block_id": "song-1-10",
      "type": "verse",
      "number": 10,
      "text": "Your cheeks are comely with ornaments,"
    },
    {
      "block_id": "song-1-11",
      "type": "verse",
      "number": 11,
      "text": "We will make you ornaments of gold,"
    },
    {
      "block_id": "song-1-12",
      "type": "verse",
      "number": 12,
      "text": "While the king was on his couch,"
    },
    {
      "block_id": "song-1-13",
      "type": "verse",
      "number": 13,
      "text": "My beloved is to me a bag of myrrh"
    },
    {
      "block_id": "song-1-14",
      "type": "verse",
      "number": 14,
      "text": "My beloved is to me a cluster of henna blossoms"
    },
    {
      "block_id": "song-1-15",
      "type": "verse",
      "number": 15,
      "text": "Ah, you are beautiful, my love;"
    },
    {
      "block_id": "song-1-16",
      "type": "verse",
      "number": 16,
      "text": "Ah, you are beautiful, my beloved,"
    },
    {
      "block_id": "song-1-17",
      "type": "verse",
      "number": 17,
      "text": "the beams of our house are cedar;"
    }
  ]
}