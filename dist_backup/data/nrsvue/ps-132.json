{
  "document_id": "ps-132",
  "title": "Psalms 132",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-132-1",
      "type": "verse",
      "number": 1,
      "text": "O Lord, remember in David’s favor"
    },
    {
      "block_id": "ps-132-2",
      "type": "verse",
      "number": 2,
      "text": "how he swore to the Lord"
    },
    {
      "block_id": "ps-132-3",
      "type": "verse",
      "number": 3,
      "text": "“I will not enter my house"
    },
    {
      "block_id": "ps-132-4",
      "type": "verse",
      "number": 4,
      "text": "I will not give sleep to my eyes"
    },
    {
      "block_id": "ps-132-5",
      "type": "verse",
      "number": 5,
      "text": "until I find a place for the Lord,"
    },
    {
      "block_id": "ps-132-6",
      "type": "verse",
      "number": 6,
      "text": "We heard of it in Ephrathah;"
    },
    {
      "block_id": "ps-132-7",
      "type": "verse",
      "number": 7,
      "text": "“Let us go to his dwelling place;"
    },
    {
      "block_id": "ps-132-8",
      "type": "verse",
      "number": 8,
      "text": "Rise up, O Lord, and go to your resting place,"
    },
    {
      "block_id": "ps-132-9",
      "type": "verse",
      "number": 9,
      "text": "Let your priests be clothed with righteousness,"
    },
    {
      "block_id": "ps-132-10",
      "type": "verse",
      "number": 10,
      "text": "For your servant David’s sake"
    },
    {
      "block_id": "ps-132-11",
      "type": "verse",
      "number": 11,
      "text": "The Lord swore to David a sure oath"
    },
    {
      "block_id": "ps-132-12",
      "type": "verse",
      "number": 12,
      "text": "If your sons keep my covenant"
    },
    {
      "block_id": "ps-132-13",
      "type": "verse",
      "number": 13,
      "text": "For the Lord has chosen Zion;"
    },
    {
      "block_id": "ps-132-14",
      "type": "verse",
      "number": 14,
      "text": "“This is my resting place forever;"
    },
    {
      "block_id": "ps-132-15",
      "type": "verse",
      "number": 15,
      "text": "I will abundantly bless its provisions;"
    },
    {
      "block_id": "ps-132-16",
      "type": "verse",
      "number": 16,
      "text": "Its priests I will clothe with salvation,"
    },
    {
      "block_id": "ps-132-17",
      "type": "verse",
      "number": 17,
      "text": "There I will cause a horn to sprout up for David;"
    },
    {
      "block_id": "ps-132-18",
      "type": "verse",
      "number": 18,
      "text": "His enemies I will clothe with disgrace,"
    }
  ]
}