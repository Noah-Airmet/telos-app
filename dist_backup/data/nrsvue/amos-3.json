{
  "document_id": "amos-3",
  "title": "Amos 3",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "amos-3-heading-israel’s-guilt-and-p",
      "type": "heading",
      "text": "Israel’s Guilt and Punishment"
    },
    {
      "block_id": "amos-3-1",
      "type": "verse",
      "number": 1,
      "text": "Hear this word that the Lord has spoken against you, O people of Israel, against the whole family that I brought up out of the land of Egypt:"
    },
    {
      "block_id": "amos-3-2",
      "type": "verse",
      "number": 2,
      "text": "You only have I known"
    },
    {
      "block_id": "amos-3-3",
      "type": "verse",
      "number": 3,
      "text": "Do two walk together"
    },
    {
      "block_id": "amos-3-4",
      "type": "verse",
      "number": 4,
      "text": "Does a lion roar in the forest"
    },
    {
      "block_id": "amos-3-5",
      "type": "verse",
      "number": 5,
      "text": "Does a bird fall into a snare on the earth"
    },
    {
      "block_id": "amos-3-6",
      "type": "verse",
      "number": 6,
      "text": "Is a trumpet blown in a city,"
    },
    {
      "block_id": "amos-3-7",
      "type": "verse",
      "number": 7,
      "text": "Surely the Lord God does nothing"
    },
    {
      "block_id": "amos-3-8",
      "type": "verse",
      "number": 8,
      "text": "The lion has roared;"
    },
    {
      "block_id": "amos-3-9",
      "type": "verse",
      "number": 9,
      "text": "Proclaim to the strongholds in Ashdod"
    },
    {
      "block_id": "amos-3-10",
      "type": "verse",
      "number": 10,
      "text": "They do not know how to do right, says the Lord,"
    },
    {
      "block_id": "amos-3-11",
      "type": "verse",
      "number": 11,
      "text": "Therefore thus says the Lord God:"
    },
    {
      "block_id": "amos-3-12",
      "type": "verse",
      "number": 12,
      "text": "Thus says the Lord: As the shepherd rescues from the mouth of the lion two legs or a piece of an ear, so shall the people of Israel who live in Samaria be rescued, with the corner of a couch and part of a bed."
    },
    {
      "block_id": "amos-3-13",
      "type": "verse",
      "number": 13,
      "text": "Hear and testify against the house of Jacob,"
    },
    {
      "block_id": "amos-3-14",
      "type": "verse",
      "number": 14,
      "text": "On the day I punish Israel for its transgressions,"
    },
    {
      "block_id": "amos-3-15",
      "type": "verse",
      "number": 15,
      "text": "I will tear down the winter house as well as the summer house,"
    }
  ]
}