{
  "document_id": "hab-2",
  "title": "Habakkuk 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hab-2-heading-god’s-reply-to-the-p",
      "type": "heading",
      "text": "God’s Reply to the Prophet’s Complaint"
    },
    {
      "block_id": "hab-2-heading-the-woes-of-the-wick",
      "type": "heading",
      "text": "The Woes of the Wicked"
    },
    {
      "block_id": "hab-2-1",
      "type": "verse",
      "number": 1,
      "text": "I will stand at my watchpost"
    },
    {
      "block_id": "hab-2-2",
      "type": "verse",
      "number": 2,
      "text": "Then the Lord answered me and said:"
    },
    {
      "block_id": "hab-2-3",
      "type": "verse",
      "number": 3,
      "text": "For there is still a vision for the appointed time;"
    },
    {
      "block_id": "hab-2-4",
      "type": "verse",
      "number": 4,
      "text": "Look at the proud!"
    },
    {
      "block_id": "hab-2-5",
      "type": "verse",
      "number": 5,
      "text": "Moreover, wealth is treacherous;"
    },
    {
      "block_id": "hab-2-6",
      "type": "verse",
      "number": 6,
      "text": "Shall not everyone taunt such people and, with mocking riddles, say about them,"
    },
    {
      "block_id": "hab-2-7",
      "type": "verse",
      "number": 7,
      "text": "Will not your own creditors suddenly rise"
    },
    {
      "block_id": "hab-2-8",
      "type": "verse",
      "number": 8,
      "text": "Because you have plundered many nations,"
    },
    {
      "block_id": "hab-2-9",
      "type": "verse",
      "number": 9,
      "text": "“Alas for you who get evil gain for your house,"
    },
    {
      "block_id": "hab-2-10",
      "type": "verse",
      "number": 10,
      "text": "You have devised shame for your house"
    },
    {
      "block_id": "hab-2-11",
      "type": "verse",
      "number": 11,
      "text": "The very stones will cry out from the wall,"
    },
    {
      "block_id": "hab-2-12",
      "type": "verse",
      "number": 12,
      "text": "“Alas for you who build a town by bloodshed"
    },
    {
      "block_id": "hab-2-13",
      "type": "verse",
      "number": 13,
      "text": "Is it not from the Lord of hosts"
    },
    {
      "block_id": "hab-2-14",
      "type": "verse",
      "number": 14,
      "text": "But the earth will be filled"
    },
    {
      "block_id": "hab-2-15",
      "type": "verse",
      "number": 15,
      "text": "“Alas for you who make your neighbors drink,"
    },
    {
      "block_id": "hab-2-16",
      "type": "verse",
      "number": 16,
      "text": "You will be sated with contempt instead of glory."
    },
    {
      "block_id": "hab-2-17",
      "type": "verse",
      "number": 17,
      "text": "For the violence done to Lebanon will overwhelm you;"
    },
    {
      "block_id": "hab-2-18",
      "type": "verse",
      "number": 18,
      "text": "What use is an idol"
    },
    {
      "block_id": "hab-2-19",
      "type": "verse",
      "number": 19,
      "text": "Alas for you who say to the wood, “Wake up!”"
    },
    {
      "block_id": "hab-2-20",
      "type": "verse",
      "number": 20,
      "text": "But the Lord is in his holy temple;"
    }
  ]
}