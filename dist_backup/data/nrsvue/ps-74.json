{
  "document_id": "ps-74",
  "title": "Psalms 74",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-74-1",
      "type": "verse",
      "number": 1,
      "text": "O God, why do you cast us off forever?"
    },
    {
      "block_id": "ps-74-2",
      "type": "verse",
      "number": 2,
      "text": "Remember your congregation, which you acquired long ago,"
    },
    {
      "block_id": "ps-74-3",
      "type": "verse",
      "number": 3,
      "text": "Direct your steps to the perpetual ruins;"
    },
    {
      "block_id": "ps-74-4",
      "type": "verse",
      "number": 4,
      "text": "Your foes have roared within your holy place;"
    },
    {
      "block_id": "ps-74-5",
      "type": "verse",
      "number": 5,
      "text": "At the upper entrance they hacked"
    },
    {
      "block_id": "ps-74-6",
      "type": "verse",
      "number": 6,
      "text": "And then, with hatchets and hammers,"
    },
    {
      "block_id": "ps-74-7",
      "type": "verse",
      "number": 7,
      "text": "They set your sanctuary on fire;"
    },
    {
      "block_id": "ps-74-8",
      "type": "verse",
      "number": 8,
      "text": "They said to themselves, “We will utterly subdue them”;"
    },
    {
      "block_id": "ps-74-9",
      "type": "verse",
      "number": 9,
      "text": "We do not see our emblems;"
    },
    {
      "block_id": "ps-74-10",
      "type": "verse",
      "number": 10,
      "text": "How long, O God, is the foe to scoff?"
    },
    {
      "block_id": "ps-74-11",
      "type": "verse",
      "number": 11,
      "text": "Why do you hold back your hand;"
    },
    {
      "block_id": "ps-74-12",
      "type": "verse",
      "number": 12,
      "text": "Yet God my King is from of old,"
    },
    {
      "block_id": "ps-74-13",
      "type": "verse",
      "number": 13,
      "text": "You divided the sea by your might;"
    },
    {
      "block_id": "ps-74-14",
      "type": "verse",
      "number": 14,
      "text": "You crushed the heads of Leviathan;"
    },
    {
      "block_id": "ps-74-15",
      "type": "verse",
      "number": 15,
      "text": "You cut openings for springs and torrents;"
    },
    {
      "block_id": "ps-74-16",
      "type": "verse",
      "number": 16,
      "text": "Yours is the day, yours also the night;"
    },
    {
      "block_id": "ps-74-17",
      "type": "verse",
      "number": 17,
      "text": "You have fixed all the bounds of the earth;"
    },
    {
      "block_id": "ps-74-18",
      "type": "verse",
      "number": 18,
      "text": "Remember this, O Lord, how the enemy scoffs,"
    },
    {
      "block_id": "ps-74-19",
      "type": "verse",
      "number": 19,
      "text": "Do not deliver the soul of your dove to the wild animals;"
    },
    {
      "block_id": "ps-74-20",
      "type": "verse",
      "number": 20,
      "text": "Have regard for your covenant,"
    },
    {
      "block_id": "ps-74-21",
      "type": "verse",
      "number": 21,
      "text": "Do not let the downtrodden be put to shame;"
    },
    {
      "block_id": "ps-74-22",
      "type": "verse",
      "number": 22,
      "text": "Rise up, O God, plead your cause;"
    },
    {
      "block_id": "ps-74-23",
      "type": "verse",
      "number": 23,
      "text": "Do not forget the clamor of your foes,"
    }
  ]
}