{
  "document_id": "ps-51",
  "title": "Psalms 51",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-51-1",
      "type": "verse",
      "number": 1,
      "text": "Have mercy on me, O God,"
    },
    {
      "block_id": "ps-51-2",
      "type": "verse",
      "number": 2,
      "text": "Wash me thoroughly from my iniquity,"
    },
    {
      "block_id": "ps-51-3",
      "type": "verse",
      "number": 3,
      "text": "For I know my transgressions,"
    },
    {
      "block_id": "ps-51-4",
      "type": "verse",
      "number": 4,
      "text": "Against you, you alone, have I sinned"
    },
    {
      "block_id": "ps-51-5",
      "type": "verse",
      "number": 5,
      "text": "Indeed, I was born guilty,"
    },
    {
      "block_id": "ps-51-6",
      "type": "verse",
      "number": 6,
      "text": "You desire truth in the inward being;"
    },
    {
      "block_id": "ps-51-7",
      "type": "verse",
      "number": 7,
      "text": "Purge me with hyssop, and I shall be clean;"
    },
    {
      "block_id": "ps-51-8",
      "type": "verse",
      "number": 8,
      "text": "Let me hear joy and gladness;"
    },
    {
      "block_id": "ps-51-9",
      "type": "verse",
      "number": 9,
      "text": "Hide your face from my sins,"
    },
    {
      "block_id": "ps-51-10",
      "type": "verse",
      "number": 10,
      "text": "Create in me a clean heart, O God,"
    },
    {
      "block_id": "ps-51-11",
      "type": "verse",
      "number": 11,
      "text": "Do not cast me away from your presence,"
    },
    {
      "block_id": "ps-51-12",
      "type": "verse",
      "number": 12,
      "text": "Restore to me the joy of your salvation,"
    },
    {
      "block_id": "ps-51-13",
      "type": "verse",
      "number": 13,
      "text": "Then I will teach transgressors your ways,"
    },
    {
      "block_id": "ps-51-14",
      "type": "verse",
      "number": 14,
      "text": "Deliver me from bloodshed, O God,"
    },
    {
      "block_id": "ps-51-15",
      "type": "verse",
      "number": 15,
      "text": "O Lord, open my lips,"
    },
    {
      "block_id": "ps-51-16",
      "type": "verse",
      "number": 16,
      "text": "For you have no delight in sacrifice;"
    },
    {
      "block_id": "ps-51-17",
      "type": "verse",
      "number": 17,
      "text": "The sacrifice acceptable to God is a broken spirit;"
    },
    {
      "block_id": "ps-51-18",
      "type": "verse",
      "number": 18,
      "text": "Do good to Zion in your good pleasure;"
    },
    {
      "block_id": "ps-51-19",
      "type": "verse",
      "number": 19,
      "text": "then you will delight in right sacrifices,"
    }
  ]
}