{
  "document_id": "ps-10",
  "title": "Psalms 10",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-10-1",
      "type": "verse",
      "number": 1,
      "text": "Why, O Lord, do you stand far off?"
    },
    {
      "block_id": "ps-10-2",
      "type": "verse",
      "number": 2,
      "text": "In arrogance the wicked persecute the poor—"
    },
    {
      "block_id": "ps-10-3",
      "type": "verse",
      "number": 3,
      "text": "For the wicked boast of the desires of their heart;"
    },
    {
      "block_id": "ps-10-4",
      "type": "verse",
      "number": 4,
      "text": "In the pride of their countenance the wicked say, “God will not seek it out”;"
    },
    {
      "block_id": "ps-10-5",
      "type": "verse",
      "number": 5,
      "text": "Their ways prosper at all times;"
    },
    {
      "block_id": "ps-10-6",
      "type": "verse",
      "number": 6,
      "text": "They think in their heart, “We shall not be moved;"
    },
    {
      "block_id": "ps-10-7",
      "type": "verse",
      "number": 7,
      "text": "Their mouths are filled with cursing and deceit and oppression;"
    },
    {
      "block_id": "ps-10-8",
      "type": "verse",
      "number": 8,
      "text": "They sit in ambush in the villages;"
    },
    {
      "block_id": "ps-10-9",
      "type": "verse",
      "number": 9,
      "text": "they lurk in secret like a lion in its den;"
    },
    {
      "block_id": "ps-10-10",
      "type": "verse",
      "number": 10,
      "text": "They stoop, they crouch,"
    },
    {
      "block_id": "ps-10-11",
      "type": "verse",
      "number": 11,
      "text": "They think in their heart, “God has forgotten;"
    },
    {
      "block_id": "ps-10-12",
      "type": "verse",
      "number": 12,
      "text": "Rise up, O Lord; O God, lift up your hand;"
    },
    {
      "block_id": "ps-10-13",
      "type": "verse",
      "number": 13,
      "text": "Why do the wicked renounce God"
    },
    {
      "block_id": "ps-10-14",
      "type": "verse",
      "number": 14,
      "text": "But you do see! Indeed, you note trouble and grief,"
    },
    {
      "block_id": "ps-10-15",
      "type": "verse",
      "number": 15,
      "text": "Break the arm of the wicked and evildoers;"
    },
    {
      "block_id": "ps-10-16",
      "type": "verse",
      "number": 16,
      "text": "The Lord is king forever and ever;"
    },
    {
      "block_id": "ps-10-17",
      "type": "verse",
      "number": 17,
      "text": "O Lord, you will hear the desire of the meek;"
    },
    {
      "block_id": "ps-10-18",
      "type": "verse",
      "number": 18,
      "text": "to do justice for the orphan and the oppressed,"
    }
  ]
}