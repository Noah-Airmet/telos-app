{
  "document_id": "ps-71",
  "title": "Psalms 71",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-71-1",
      "type": "verse",
      "number": 1,
      "text": "In you, O Lord, I take refuge;"
    },
    {
      "block_id": "ps-71-2",
      "type": "verse",
      "number": 2,
      "text": "In your righteousness deliver me and rescue me;"
    },
    {
      "block_id": "ps-71-3",
      "type": "verse",
      "number": 3,
      "text": "Be to me a rock of refuge,"
    },
    {
      "block_id": "ps-71-4",
      "type": "verse",
      "number": 4,
      "text": "Rescue me, O my God, from the hand of the wicked,"
    },
    {
      "block_id": "ps-71-5",
      "type": "verse",
      "number": 5,
      "text": "For you, O Lord, are my hope,"
    },
    {
      "block_id": "ps-71-6",
      "type": "verse",
      "number": 6,
      "text": "From my birth I have leaned upon you,"
    },
    {
      "block_id": "ps-71-7",
      "type": "verse",
      "number": 7,
      "text": "I have been like a portent to many,"
    },
    {
      "block_id": "ps-71-8",
      "type": "verse",
      "number": 8,
      "text": "My mouth is filled with your praise"
    },
    {
      "block_id": "ps-71-9",
      "type": "verse",
      "number": 9,
      "text": "Do not cast me off in the time of old age;"
    },
    {
      "block_id": "ps-71-10",
      "type": "verse",
      "number": 10,
      "text": "For my enemies speak concerning me,"
    },
    {
      "block_id": "ps-71-11",
      "type": "verse",
      "number": 11,
      "text": "They say, “Pursue and seize that person"
    },
    {
      "block_id": "ps-71-12",
      "type": "verse",
      "number": 12,
      "text": "O God, do not be far from me;"
    },
    {
      "block_id": "ps-71-13",
      "type": "verse",
      "number": 13,
      "text": "Let my accusers be put to shame and consumed;"
    },
    {
      "block_id": "ps-71-14",
      "type": "verse",
      "number": 14,
      "text": "But I will hope continually"
    },
    {
      "block_id": "ps-71-15",
      "type": "verse",
      "number": 15,
      "text": "My mouth will tell of your righteous acts,"
    },
    {
      "block_id": "ps-71-16",
      "type": "verse",
      "number": 16,
      "text": "I will come praising the mighty deeds of the Lord God;"
    },
    {
      "block_id": "ps-71-17",
      "type": "verse",
      "number": 17,
      "text": "O God, from my youth you have taught me,"
    },
    {
      "block_id": "ps-71-18",
      "type": "verse",
      "number": 18,
      "text": "So even to old age and gray hairs,"
    },
    {
      "block_id": "ps-71-19",
      "type": "verse",
      "number": 19,
      "text": "and your righteousness, O God,"
    },
    {
      "block_id": "ps-71-20",
      "type": "verse",
      "number": 20,
      "text": "You who have made me see many troubles and calamities"
    },
    {
      "block_id": "ps-71-21",
      "type": "verse",
      "number": 21,
      "text": "You will increase my honor"
    },
    {
      "block_id": "ps-71-22",
      "type": "verse",
      "number": 22,
      "text": "I will also praise you with the harp"
    },
    {
      "block_id": "ps-71-23",
      "type": "verse",
      "number": 23,
      "text": "My lips will shout for joy"
    },
    {
      "block_id": "ps-71-24",
      "type": "verse",
      "number": 24,
      "text": "All day long my tongue will talk of your righteous help,"
    }
  ]
}