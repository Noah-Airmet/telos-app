{
  "document_id": "job-29",
  "title": "Job 29",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-29-heading-job-finishes-his-def",
      "type": "heading",
      "text": "Job Finishes His Defense"
    },
    {
      "block_id": "job-29-1",
      "type": "verse",
      "number": 1,
      "text": "Job again took up his discourse and said:"
    },
    {
      "block_id": "job-29-2",
      "type": "verse",
      "number": 2,
      "text": "“O that I were as in the months of old,"
    },
    {
      "block_id": "job-29-3",
      "type": "verse",
      "number": 3,
      "text": "when his lamp shone over my head,"
    },
    {
      "block_id": "job-29-4",
      "type": "verse",
      "number": 4,
      "text": "when I was in my prime,"
    },
    {
      "block_id": "job-29-5",
      "type": "verse",
      "number": 5,
      "text": "when the Almighty was still with me,"
    },
    {
      "block_id": "job-29-6",
      "type": "verse",
      "number": 6,
      "text": "when my steps were washed with milk"
    },
    {
      "block_id": "job-29-7",
      "type": "verse",
      "number": 7,
      "text": "When I went out to the gate of the city,"
    },
    {
      "block_id": "job-29-8",
      "type": "verse",
      "number": 8,
      "text": "the young men saw me and withdrew,"
    },
    {
      "block_id": "job-29-9",
      "type": "verse",
      "number": 9,
      "text": "the nobles refrained from talking"
    },
    {
      "block_id": "job-29-10",
      "type": "verse",
      "number": 10,
      "text": "the voices of princes were hushed,"
    },
    {
      "block_id": "job-29-11",
      "type": "verse",
      "number": 11,
      "text": "When the ear heard, it commended me,"
    },
    {
      "block_id": "job-29-12",
      "type": "verse",
      "number": 12,
      "text": "because I delivered the poor who cried"
    },
    {
      "block_id": "job-29-13",
      "type": "verse",
      "number": 13,
      "text": "The blessing of the wretched came upon me,"
    },
    {
      "block_id": "job-29-14",
      "type": "verse",
      "number": 14,
      "text": "I put on righteousness, and it clothed me;"
    },
    {
      "block_id": "job-29-15",
      "type": "verse",
      "number": 15,
      "text": "I was eyes to the blind"
    },
    {
      "block_id": "job-29-16",
      "type": "verse",
      "number": 16,
      "text": "I was a father to the needy,"
    },
    {
      "block_id": "job-29-17",
      "type": "verse",
      "number": 17,
      "text": "I broke the fangs of the unrighteous"
    },
    {
      "block_id": "job-29-18",
      "type": "verse",
      "number": 18,
      "text": "Then I thought, ‘I shall die in my nest,"
    },
    {
      "block_id": "job-29-19",
      "type": "verse",
      "number": 19,
      "text": "my roots spread out to the waters,"
    },
    {
      "block_id": "job-29-20",
      "type": "verse",
      "number": 20,
      "text": "my glory was fresh with me"
    },
    {
      "block_id": "job-29-21",
      "type": "verse",
      "number": 21,
      "text": "“They listened to me and waited"
    },
    {
      "block_id": "job-29-22",
      "type": "verse",
      "number": 22,
      "text": "After I spoke they did not speak again,"
    },
    {
      "block_id": "job-29-23",
      "type": "verse",
      "number": 23,
      "text": "They waited for me as for the rain;"
    },
    {
      "block_id": "job-29-24",
      "type": "verse",
      "number": 24,
      "text": "I smiled on them when they had no confidence,"
    },
    {
      "block_id": "job-29-25",
      "type": "verse",
      "number": 25,
      "text": "I chose what they should do and sat as chief,"
    }
  ]
}