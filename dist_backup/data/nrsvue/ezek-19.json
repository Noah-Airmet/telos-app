{
  "document_id": "ezek-19",
  "title": "Ezekiel 19",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ezek-19-heading-israel-degraded",
      "type": "heading",
      "text": "Israel Degraded"
    },
    {
      "block_id": "ezek-19-1",
      "type": "verse",
      "number": 1,
      "text": "As for you, raise up a lamentation for the princes of Israel,"
    },
    {
      "block_id": "ezek-19-2",
      "type": "verse",
      "number": 2,
      "text": "and say:"
    },
    {
      "block_id": "ezek-19-3",
      "type": "verse",
      "number": 3,
      "text": "She raised up one of her cubs;"
    },
    {
      "block_id": "ezek-19-4",
      "type": "verse",
      "number": 4,
      "text": "The nations heard about him;"
    },
    {
      "block_id": "ezek-19-5",
      "type": "verse",
      "number": 5,
      "text": "When she saw that she was thwarted,"
    },
    {
      "block_id": "ezek-19-6",
      "type": "verse",
      "number": 6,
      "text": "He prowled among the lions;"
    },
    {
      "block_id": "ezek-19-7",
      "type": "verse",
      "number": 7,
      "text": "And he ravaged their strongholds"
    },
    {
      "block_id": "ezek-19-8",
      "type": "verse",
      "number": 8,
      "text": "The nations set upon him"
    },
    {
      "block_id": "ezek-19-9",
      "type": "verse",
      "number": 9,
      "text": "With hooks they put him in a neck collar"
    },
    {
      "block_id": "ezek-19-10",
      "type": "verse",
      "number": 10,
      "text": "Your mother was like a vine in a vineyard"
    },
    {
      "block_id": "ezek-19-11",
      "type": "verse",
      "number": 11,
      "text": "Its strongest stem became"
    },
    {
      "block_id": "ezek-19-12",
      "type": "verse",
      "number": 12,
      "text": "But it was plucked up in fury,"
    },
    {
      "block_id": "ezek-19-13",
      "type": "verse",
      "number": 13,
      "text": "Now it is transplanted into the wilderness,"
    },
    {
      "block_id": "ezek-19-14",
      "type": "verse",
      "number": 14,
      "text": "And fire has gone out from its stem,"
    }
  ]
}