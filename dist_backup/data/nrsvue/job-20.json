{
  "document_id": "job-20",
  "title": "Job 20",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-20-heading-zophar-speaks:-wicke",
      "type": "heading",
      "text": "Zophar Speaks: Wickedness Receives Just Retribution"
    },
    {
      "block_id": "job-20-1",
      "type": "verse",
      "number": 1,
      "text": "Then Zophar the Naamathite answered:"
    },
    {
      "block_id": "job-20-2",
      "type": "verse",
      "number": 2,
      "text": "“Listen! My thoughts urge me to answer"
    },
    {
      "block_id": "job-20-3",
      "type": "verse",
      "number": 3,
      "text": "I hear censure that insults me,"
    },
    {
      "block_id": "job-20-4",
      "type": "verse",
      "number": 4,
      "text": "Do you not know this from of old,"
    },
    {
      "block_id": "job-20-5",
      "type": "verse",
      "number": 5,
      "text": "that the exulting of the wicked is short"
    },
    {
      "block_id": "job-20-6",
      "type": "verse",
      "number": 6,
      "text": "Even though they mount up high as the heavens"
    },
    {
      "block_id": "job-20-7",
      "type": "verse",
      "number": 7,
      "text": "they will perish forever like their own dung;"
    },
    {
      "block_id": "job-20-8",
      "type": "verse",
      "number": 8,
      "text": "They will fly away like a dream and not be found;"
    },
    {
      "block_id": "job-20-9",
      "type": "verse",
      "number": 9,
      "text": "The eye that saw them will see them no more,"
    },
    {
      "block_id": "job-20-10",
      "type": "verse",
      "number": 10,
      "text": "Their children will seek the favor of the poor,"
    },
    {
      "block_id": "job-20-11",
      "type": "verse",
      "number": 11,
      "text": "Their bodies, once full of youth,"
    },
    {
      "block_id": "job-20-12",
      "type": "verse",
      "number": 12,
      "text": "“Though wickedness is sweet in their mouth,"
    },
    {
      "block_id": "job-20-13",
      "type": "verse",
      "number": 13,
      "text": "though they are loath to let it go"
    },
    {
      "block_id": "job-20-14",
      "type": "verse",
      "number": 14,
      "text": "yet their food is turned in their stomachs;"
    },
    {
      "block_id": "job-20-15",
      "type": "verse",
      "number": 15,
      "text": "They swallow down riches and vomit them up again;"
    },
    {
      "block_id": "job-20-16",
      "type": "verse",
      "number": 16,
      "text": "They will suck the poison of asps;"
    },
    {
      "block_id": "job-20-17",
      "type": "verse",
      "number": 17,
      "text": "They will not look on the rivers,"
    },
    {
      "block_id": "job-20-18",
      "type": "verse",
      "number": 18,
      "text": "They will give back the fruit of their toil"
    },
    {
      "block_id": "job-20-19",
      "type": "verse",
      "number": 19,
      "text": "For they have crushed and abandoned the poor;"
    },
    {
      "block_id": "job-20-20",
      "type": "verse",
      "number": 20,
      "text": "“For they knew no quiet in their bellies;"
    },
    {
      "block_id": "job-20-21",
      "type": "verse",
      "number": 21,
      "text": "There was nothing left after they had eaten;"
    },
    {
      "block_id": "job-20-22",
      "type": "verse",
      "number": 22,
      "text": "In full sufficiency they will be in distress;"
    },
    {
      "block_id": "job-20-23",
      "type": "verse",
      "number": 23,
      "text": "To fill their belly to the full,"
    },
    {
      "block_id": "job-20-24",
      "type": "verse",
      "number": 24,
      "text": "They will flee from an iron weapon;"
    },
    {
      "block_id": "job-20-25",
      "type": "verse",
      "number": 25,
      "text": "It is drawn forth and comes out of their body,"
    },
    {
      "block_id": "job-20-26",
      "type": "verse",
      "number": 26,
      "text": "Utter darkness is laid up for their treasures;"
    },
    {
      "block_id": "job-20-27",
      "type": "verse",
      "number": 27,
      "text": "The heavens will reveal their iniquity,"
    },
    {
      "block_id": "job-20-28",
      "type": "verse",
      "number": 28,
      "text": "The possessions of their house will be carried away,"
    },
    {
      "block_id": "job-20-29",
      "type": "verse",
      "number": 29,
      "text": "This is the portion of the wicked from God,"
    }
  ]
}