{
  "document_id": "ps-129",
  "title": "Psalms 129",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-129-1",
      "type": "verse",
      "number": 1,
      "text": "Often have they attacked me from my youth"
    },
    {
      "block_id": "ps-129-2",
      "type": "verse",
      "number": 2,
      "text": "often have they attacked me from my youth,"
    },
    {
      "block_id": "ps-129-3",
      "type": "verse",
      "number": 3,
      "text": "The plowers plowed on my back;"
    },
    {
      "block_id": "ps-129-4",
      "type": "verse",
      "number": 4,
      "text": "The Lord is righteous;"
    },
    {
      "block_id": "ps-129-5",
      "type": "verse",
      "number": 5,
      "text": "May all who hate Zion"
    },
    {
      "block_id": "ps-129-6",
      "type": "verse",
      "number": 6,
      "text": "Let them be like the grass on the housetops"
    },
    {
      "block_id": "ps-129-7",
      "type": "verse",
      "number": 7,
      "text": "with which reapers do not fill their hands"
    },
    {
      "block_id": "ps-129-8",
      "type": "verse",
      "number": 8,
      "text": "while those who pass by do not say,"
    }
  ]
}