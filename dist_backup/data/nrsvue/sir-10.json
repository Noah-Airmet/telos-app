{
  "document_id": "sir-10",
  "title": "Sirach 10",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-10-1",
      "type": "verse",
      "number": 1,
      "text": "A wise magistrate educates his people,"
    },
    {
      "block_id": "sir-10-2",
      "type": "verse",
      "number": 2,
      "text": "As the people’s judge is, so are his officials;"
    },
    {
      "block_id": "sir-10-3",
      "type": "verse",
      "number": 3,
      "text": "An undisciplined king ruins his people,"
    },
    {
      "block_id": "sir-10-4",
      "type": "verse",
      "number": 4,
      "text": "The government of the earth is in the hand of the Lord,"
    },
    {
      "block_id": "sir-10-5",
      "type": "verse",
      "number": 5,
      "text": "Human success is in the hand of the Lord,"
    },
    {
      "block_id": "sir-10-6",
      "type": "verse",
      "number": 6,
      "text": "Do not get angry with your neighbor for every injury,"
    },
    {
      "block_id": "sir-10-7",
      "type": "verse",
      "number": 7,
      "text": "Arrogance is hateful to the Lord and to mortals,"
    },
    {
      "block_id": "sir-10-8",
      "type": "verse",
      "number": 8,
      "text": "Sovereignty passes from nation to nation"
    },
    {
      "block_id": "sir-10-9",
      "type": "verse",
      "number": 9,
      "text": "How can dust and ashes be proud?"
    },
    {
      "block_id": "sir-10-10",
      "type": "verse",
      "number": 10,
      "text": "A long illness mocks the physician;"
    },
    {
      "block_id": "sir-10-11",
      "type": "verse",
      "number": 11,
      "text": "For when humans die"
    },
    {
      "block_id": "sir-10-12",
      "type": "verse",
      "number": 12,
      "text": "The beginning of human pride is to forsake the Lord;"
    },
    {
      "block_id": "sir-10-13",
      "type": "verse",
      "number": 13,
      "text": "For the beginning of pride is sin,"
    },
    {
      "block_id": "sir-10-14",
      "type": "verse",
      "number": 14,
      "text": "The Lord overthrew the thrones of rulers"
    },
    {
      "block_id": "sir-10-15",
      "type": "verse",
      "number": 15,
      "text": "The Lord plucked up the roots of the nations"
    },
    {
      "block_id": "sir-10-16",
      "type": "verse",
      "number": 16,
      "text": "The Lord laid waste the lands of the nations"
    },
    {
      "block_id": "sir-10-17",
      "type": "verse",
      "number": 17,
      "text": "He removed some of them and destroyed them"
    },
    {
      "block_id": "sir-10-18",
      "type": "verse",
      "number": 18,
      "text": "Pride was not created for human beings"
    },
    {
      "block_id": "sir-10-19",
      "type": "verse",
      "number": 19,
      "text": "Whose offspring are worthy of honor?"
    },
    {
      "block_id": "sir-10-20",
      "type": "verse",
      "number": 20,
      "text": "Among family members their leader is worthy of honor,"
    },
    {
      "block_id": "sir-10-22",
      "type": "verse",
      "number": 22,
      "text": "The guest and the stranger and the poor—"
    },
    {
      "block_id": "sir-10-23",
      "type": "verse",
      "number": 23,
      "text": "It is not right to despise one who is intelligent but poor,"
    },
    {
      "block_id": "sir-10-24",
      "type": "verse",
      "number": 24,
      "text": "The prince and the judge and the ruler are honored,"
    },
    {
      "block_id": "sir-10-25",
      "type": "verse",
      "number": 25,
      "text": "Free people will serve a wise slave,"
    },
    {
      "block_id": "sir-10-26",
      "type": "verse",
      "number": 26,
      "text": "Do not make a display of your wisdom when you do your work,"
    },
    {
      "block_id": "sir-10-27",
      "type": "verse",
      "number": 27,
      "text": "Better those who work and have plenty"
    },
    {
      "block_id": "sir-10-28",
      "type": "verse",
      "number": 28,
      "text": "My child, honor yourself with humility,"
    },
    {
      "block_id": "sir-10-29",
      "type": "verse",
      "number": 29,
      "text": "Who will acquit those who condemn themselves,"
    },
    {
      "block_id": "sir-10-30",
      "type": "verse",
      "number": 30,
      "text": "The poor are honored for their knowledge,"
    },
    {
      "block_id": "sir-10-31",
      "type": "verse",
      "number": 31,
      "text": "One who is honored in poverty, how much more in wealth!"
    }
  ]
}