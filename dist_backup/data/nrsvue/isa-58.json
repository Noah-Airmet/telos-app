{
  "document_id": "isa-58",
  "title": "Isaiah 58",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-58-1",
      "type": "verse",
      "number": 1,
      "text": "Shout out; do not hold back!"
    },
    {
      "block_id": "isa-58-2",
      "type": "verse",
      "number": 2,
      "text": "Yet day after day they seek me"
    },
    {
      "block_id": "isa-58-3",
      "type": "verse",
      "number": 3,
      "text": "“Why do we fast, but you do not see?"
    },
    {
      "block_id": "isa-58-4",
      "type": "verse",
      "number": 4,
      "text": "You fast only to quarrel and to fight"
    },
    {
      "block_id": "isa-58-5",
      "type": "verse",
      "number": 5,
      "text": "Is such the fast that I choose,"
    },
    {
      "block_id": "isa-58-6",
      "type": "verse",
      "number": 6,
      "text": "Is not this the fast that I choose:"
    },
    {
      "block_id": "isa-58-7",
      "type": "verse",
      "number": 7,
      "text": "Is it not to share your bread with the hungry"
    },
    {
      "block_id": "isa-58-8",
      "type": "verse",
      "number": 8,
      "text": "Then your light shall break forth like the dawn,"
    },
    {
      "block_id": "isa-58-9",
      "type": "verse",
      "number": 9,
      "text": "Then you shall call, and the Lord will answer;"
    },
    {
      "block_id": "isa-58-10",
      "type": "verse",
      "number": 10,
      "text": "if you offer your food to the hungry"
    },
    {
      "block_id": "isa-58-11",
      "type": "verse",
      "number": 11,
      "text": "The Lord will guide you continually"
    },
    {
      "block_id": "isa-58-12",
      "type": "verse",
      "number": 12,
      "text": "Your ancient ruins shall be rebuilt;"
    },
    {
      "block_id": "isa-58-13",
      "type": "verse",
      "number": 13,
      "text": "If you refrain from trampling the Sabbath,"
    },
    {
      "block_id": "isa-58-14",
      "type": "verse",
      "number": 14,
      "text": "then you shall take delight in the Lord,"
    }
  ]
}