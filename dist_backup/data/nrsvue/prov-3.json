{
  "document_id": "prov-3",
  "title": "Proverbs 3",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-3-1",
      "type": "verse",
      "number": 1,
      "text": "My child, do not forget my teaching,"
    },
    {
      "block_id": "prov-3-2",
      "type": "verse",
      "number": 2,
      "text": "for length of days and years of life"
    },
    {
      "block_id": "prov-3-3",
      "type": "verse",
      "number": 3,
      "text": "Do not let loyalty and faithfulness forsake you;"
    },
    {
      "block_id": "prov-3-4",
      "type": "verse",
      "number": 4,
      "text": "Then you will find favor and high regard"
    },
    {
      "block_id": "prov-3-5",
      "type": "verse",
      "number": 5,
      "text": "Trust in the Lord with all your heart,"
    },
    {
      "block_id": "prov-3-6",
      "type": "verse",
      "number": 6,
      "text": "In all your ways acknowledge him,"
    },
    {
      "block_id": "prov-3-7",
      "type": "verse",
      "number": 7,
      "text": "Do not be wise in your own eyes;"
    },
    {
      "block_id": "prov-3-8",
      "type": "verse",
      "number": 8,
      "text": "It will be a healing for your flesh"
    },
    {
      "block_id": "prov-3-9",
      "type": "verse",
      "number": 9,
      "text": "Honor the Lord with your substance"
    },
    {
      "block_id": "prov-3-10",
      "type": "verse",
      "number": 10,
      "text": "then your barns will be filled with plenty,"
    },
    {
      "block_id": "prov-3-11",
      "type": "verse",
      "number": 11,
      "text": "My child, do not despise the Lord’s discipline"
    },
    {
      "block_id": "prov-3-12",
      "type": "verse",
      "number": 12,
      "text": "for the Lord reproves the one he loves,"
    },
    {
      "block_id": "prov-3-13",
      "type": "verse",
      "number": 13,
      "text": "Happy are those who find wisdom"
    },
    {
      "block_id": "prov-3-14",
      "type": "verse",
      "number": 14,
      "text": "for her income is better than silver"
    },
    {
      "block_id": "prov-3-15",
      "type": "verse",
      "number": 15,
      "text": "She is more precious than jewels,"
    },
    {
      "block_id": "prov-3-16",
      "type": "verse",
      "number": 16,
      "text": "Long life is in her right hand;"
    },
    {
      "block_id": "prov-3-17",
      "type": "verse",
      "number": 17,
      "text": "Her ways are ways of pleasantness,"
    },
    {
      "block_id": "prov-3-18",
      "type": "verse",
      "number": 18,
      "text": "She is a tree of life to those who lay hold of her;"
    },
    {
      "block_id": "prov-3-19",
      "type": "verse",
      "number": 19,
      "text": "The Lord by wisdom founded the earth;"
    },
    {
      "block_id": "prov-3-20",
      "type": "verse",
      "number": 20,
      "text": "by his knowledge the deeps broke open,"
    },
    {
      "block_id": "prov-3-21",
      "type": "verse",
      "number": 21,
      "text": "My child, do not let these escape from your sight:"
    },
    {
      "block_id": "prov-3-22",
      "type": "verse",
      "number": 22,
      "text": "and they will be life for your soul"
    },
    {
      "block_id": "prov-3-23",
      "type": "verse",
      "number": 23,
      "text": "Then you will walk on your way securely,"
    },
    {
      "block_id": "prov-3-24",
      "type": "verse",
      "number": 24,
      "text": "If you sit down, you will not be afraid;"
    },
    {
      "block_id": "prov-3-25",
      "type": "verse",
      "number": 25,
      "text": "Then you will not be afraid of sudden panic"
    },
    {
      "block_id": "prov-3-26",
      "type": "verse",
      "number": 26,
      "text": "for the Lord will be your confidence"
    },
    {
      "block_id": "prov-3-27",
      "type": "verse",
      "number": 27,
      "text": "Do not withhold good from those to whom it is due,"
    },
    {
      "block_id": "prov-3-28",
      "type": "verse",
      "number": 28,
      "text": "Do not say to your neighbor, “Go and come again;"
    },
    {
      "block_id": "prov-3-29",
      "type": "verse",
      "number": 29,
      "text": "Do not plan harm against your neighbor"
    },
    {
      "block_id": "prov-3-30",
      "type": "verse",
      "number": 30,
      "text": "Do not quarrel with anyone without cause,"
    },
    {
      "block_id": "prov-3-31",
      "type": "verse",
      "number": 31,
      "text": "Do not envy the violent,"
    },
    {
      "block_id": "prov-3-32",
      "type": "verse",
      "number": 32,
      "text": "for the perverse are an abomination to the Lord,"
    },
    {
      "block_id": "prov-3-33",
      "type": "verse",
      "number": 33,
      "text": "The Lord’s curse is on the house of the wicked,"
    },
    {
      "block_id": "prov-3-34",
      "type": "verse",
      "number": 34,
      "text": "Toward the scorners he is scornful,"
    },
    {
      "block_id": "prov-3-35",
      "type": "verse",
      "number": 35,
      "text": "The wise will inherit honor,"
    }
  ]
}