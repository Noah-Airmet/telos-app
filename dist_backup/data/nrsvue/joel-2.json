{
  "document_id": "joel-2",
  "title": "Joel 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "joel-2-heading-god’s-response-and-p",
      "type": "heading",
      "text": "God’s Response and Promise"
    },
    {
      "block_id": "joel-2-heading-god’s-spirit-poured-",
      "type": "heading",
      "text": "God’s Spirit Poured Out"
    },
    {
      "block_id": "joel-2-1",
      "type": "verse",
      "number": 1,
      "text": "Blow the trumpet in Zion;"
    },
    {
      "block_id": "joel-2-2",
      "type": "verse",
      "number": 2,
      "text": "a day of darkness and gloom,"
    },
    {
      "block_id": "joel-2-3",
      "type": "verse",
      "number": 3,
      "text": "Fire devours in front of them,"
    },
    {
      "block_id": "joel-2-4",
      "type": "verse",
      "number": 4,
      "text": "They have the appearance of horses,"
    },
    {
      "block_id": "joel-2-5",
      "type": "verse",
      "number": 5,
      "text": "As with the rumbling of chariots,"
    },
    {
      "block_id": "joel-2-6",
      "type": "verse",
      "number": 6,
      "text": "Before them peoples are in anguish;"
    },
    {
      "block_id": "joel-2-7",
      "type": "verse",
      "number": 7,
      "text": "Like warriors they charge;"
    },
    {
      "block_id": "joel-2-8",
      "type": "verse",
      "number": 8,
      "text": "They do not jostle one another;"
    },
    {
      "block_id": "joel-2-9",
      "type": "verse",
      "number": 9,
      "text": "They leap upon the city;"
    },
    {
      "block_id": "joel-2-10",
      "type": "verse",
      "number": 10,
      "text": "The earth quakes before them;"
    },
    {
      "block_id": "joel-2-11",
      "type": "verse",
      "number": 11,
      "text": "The Lord utters his voice"
    },
    {
      "block_id": "joel-2-12",
      "type": "verse",
      "number": 12,
      "text": "Yet even now, says the Lord,"
    },
    {
      "block_id": "joel-2-13",
      "type": "verse",
      "number": 13,
      "text": "rend your hearts and not your clothing."
    },
    {
      "block_id": "joel-2-14",
      "type": "verse",
      "number": 14,
      "text": "Who knows whether he will not turn and relent"
    },
    {
      "block_id": "joel-2-15",
      "type": "verse",
      "number": 15,
      "text": "Blow the trumpet in Zion;"
    },
    {
      "block_id": "joel-2-16",
      "type": "verse",
      "number": 16,
      "text": "gather the people."
    },
    {
      "block_id": "joel-2-17",
      "type": "verse",
      "number": 17,
      "text": "Between the vestibule and the altar,"
    },
    {
      "block_id": "joel-2-18",
      "type": "verse",
      "number": 18,
      "text": "Then the Lord became jealous for his land"
    },
    {
      "block_id": "joel-2-19",
      "type": "verse",
      "number": 19,
      "text": "In response to his people the Lord said:"
    },
    {
      "block_id": "joel-2-20",
      "type": "verse",
      "number": 20,
      "text": "I will remove the northern army far from you"
    },
    {
      "block_id": "joel-2-21",
      "type": "verse",
      "number": 21,
      "text": "Do not fear, O soil;"
    },
    {
      "block_id": "joel-2-22",
      "type": "verse",
      "number": 22,
      "text": "Do not fear, you animals of the field,"
    },
    {
      "block_id": "joel-2-23",
      "type": "verse",
      "number": 23,
      "text": "O children of Zion, be glad,"
    },
    {
      "block_id": "joel-2-24",
      "type": "verse",
      "number": 24,
      "text": "The threshing floors shall be full of grain;"
    },
    {
      "block_id": "joel-2-25",
      "type": "verse",
      "number": 25,
      "text": "I will repay you for the years"
    },
    {
      "block_id": "joel-2-26",
      "type": "verse",
      "number": 26,
      "text": "You shall eat in plenty and be satisfied"
    },
    {
      "block_id": "joel-2-27",
      "type": "verse",
      "number": 27,
      "text": "You shall know that I am in the midst of Israel"
    },
    {
      "block_id": "joel-2-28",
      "type": "verse",
      "number": 28,
      "text": "Then afterward"
    },
    {
      "block_id": "joel-2-29",
      "type": "verse",
      "number": 29,
      "text": "Even on the male and female slaves,"
    },
    {
      "block_id": "joel-2-30",
      "type": "verse",
      "number": 30,
      "text": "I will show portents in the heavens and on the earth, blood and fire and columns of smoke."
    },
    {
      "block_id": "joel-2-31",
      "type": "verse",
      "number": 31,
      "text": "The sun shall be turned to darkness and the moon to blood, before the great and terrible day of the Lord comes."
    },
    {
      "block_id": "joel-2-32",
      "type": "verse",
      "number": 32,
      "text": "Then everyone who calls on the name of the Lord shall be saved, for in Mount Zion and in Jerusalem there shall be those who escape, as the Lord has said, and among the survivors shall be those whom the Lord calls."
    }
  ]
}