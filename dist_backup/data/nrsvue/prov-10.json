{
  "document_id": "prov-10",
  "title": "Proverbs 10",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-10-heading-wise-sayings-of-solo",
      "type": "heading",
      "text": "Wise Sayings of Solomon"
    },
    {
      "block_id": "prov-10-1",
      "type": "verse",
      "number": 1,
      "text": "The proverbs of Solomon."
    },
    {
      "block_id": "prov-10-2",
      "type": "verse",
      "number": 2,
      "text": "Treasures gained by wickedness do not profit,"
    },
    {
      "block_id": "prov-10-3",
      "type": "verse",
      "number": 3,
      "text": "The Lord does not let the righteous go hungry,"
    },
    {
      "block_id": "prov-10-4",
      "type": "verse",
      "number": 4,
      "text": "A slack hand causes poverty,"
    },
    {
      "block_id": "prov-10-5",
      "type": "verse",
      "number": 5,
      "text": "A child who gathers in summer is prudent,"
    },
    {
      "block_id": "prov-10-6",
      "type": "verse",
      "number": 6,
      "text": "Blessings are on the head of the righteous,"
    },
    {
      "block_id": "prov-10-7",
      "type": "verse",
      "number": 7,
      "text": "The memory of the righteous is a blessing,"
    },
    {
      "block_id": "prov-10-8",
      "type": "verse",
      "number": 8,
      "text": "The wise of heart will heed commandments,"
    },
    {
      "block_id": "prov-10-9",
      "type": "verse",
      "number": 9,
      "text": "Whoever walks in integrity walks securely,"
    },
    {
      "block_id": "prov-10-10",
      "type": "verse",
      "number": 10,
      "text": "Whoever winks the eye causes trouble,"
    },
    {
      "block_id": "prov-10-11",
      "type": "verse",
      "number": 11,
      "text": "The mouth of the righteous is a fountain of life,"
    },
    {
      "block_id": "prov-10-12",
      "type": "verse",
      "number": 12,
      "text": "Hatred stirs up strife,"
    },
    {
      "block_id": "prov-10-13",
      "type": "verse",
      "number": 13,
      "text": "On the lips of one who has understanding wisdom is found,"
    },
    {
      "block_id": "prov-10-14",
      "type": "verse",
      "number": 14,
      "text": "The wise lay up knowledge,"
    },
    {
      "block_id": "prov-10-15",
      "type": "verse",
      "number": 15,
      "text": "The wealth of the rich is their fortress;"
    },
    {
      "block_id": "prov-10-16",
      "type": "verse",
      "number": 16,
      "text": "The wage of the righteous leads to life,"
    },
    {
      "block_id": "prov-10-17",
      "type": "verse",
      "number": 17,
      "text": "Whoever heeds instruction is on the path to life,"
    },
    {
      "block_id": "prov-10-18",
      "type": "verse",
      "number": 18,
      "text": "Lying lips conceal hatred,"
    },
    {
      "block_id": "prov-10-19",
      "type": "verse",
      "number": 19,
      "text": "When words are many, transgression is not lacking,"
    },
    {
      "block_id": "prov-10-20",
      "type": "verse",
      "number": 20,
      "text": "The tongue of the righteous is choice silver;"
    },
    {
      "block_id": "prov-10-21",
      "type": "verse",
      "number": 21,
      "text": "The lips of the righteous feed many,"
    },
    {
      "block_id": "prov-10-22",
      "type": "verse",
      "number": 22,
      "text": "The blessing of the Lord makes rich,"
    },
    {
      "block_id": "prov-10-23",
      "type": "verse",
      "number": 23,
      "text": "Doing wrong is like sport to a fool,"
    },
    {
      "block_id": "prov-10-24",
      "type": "verse",
      "number": 24,
      "text": "What the wicked dread will come upon them,"
    },
    {
      "block_id": "prov-10-25",
      "type": "verse",
      "number": 25,
      "text": "When the tempest passes, the wicked are no more,"
    },
    {
      "block_id": "prov-10-26",
      "type": "verse",
      "number": 26,
      "text": "Like vinegar to the teeth and smoke to the eyes,"
    },
    {
      "block_id": "prov-10-27",
      "type": "verse",
      "number": 27,
      "text": "The fear of the Lord prolongs life,"
    },
    {
      "block_id": "prov-10-28",
      "type": "verse",
      "number": 28,
      "text": "The hope of the righteous ends in gladness,"
    },
    {
      "block_id": "prov-10-29",
      "type": "verse",
      "number": 29,
      "text": "The way of the Lord is a stronghold for the upright"
    },
    {
      "block_id": "prov-10-30",
      "type": "verse",
      "number": 30,
      "text": "The righteous will never totter,"
    },
    {
      "block_id": "prov-10-31",
      "type": "verse",
      "number": 31,
      "text": "The mouth of the righteous brings forth wisdom,"
    },
    {
      "block_id": "prov-10-32",
      "type": "verse",
      "number": 32,
      "text": "The lips of the righteous know what is acceptable,"
    }
  ]
}