{
  "document_id": "ps-81",
  "title": "Psalms 81",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-81-1",
      "type": "verse",
      "number": 1,
      "text": "Sing aloud to God our strength;"
    },
    {
      "block_id": "ps-81-2",
      "type": "verse",
      "number": 2,
      "text": "Raise a song; sound the tambourine,"
    },
    {
      "block_id": "ps-81-3",
      "type": "verse",
      "number": 3,
      "text": "Blow the trumpet at the new moon,"
    },
    {
      "block_id": "ps-81-4",
      "type": "verse",
      "number": 4,
      "text": "For it is a statute for Israel,"
    },
    {
      "block_id": "ps-81-5",
      "type": "verse",
      "number": 5,
      "text": "He made it a decree in Joseph,"
    },
    {
      "block_id": "ps-81-6",
      "type": "verse",
      "number": 6,
      "text": "“I relieved your shoulder of the burden;"
    },
    {
      "block_id": "ps-81-7",
      "type": "verse",
      "number": 7,
      "text": "In distress you called, and I rescued you;"
    },
    {
      "block_id": "ps-81-8",
      "type": "verse",
      "number": 8,
      "text": "Hear, O my people, while I admonish you;"
    },
    {
      "block_id": "ps-81-9",
      "type": "verse",
      "number": 9,
      "text": "There shall be no strange god among you;"
    },
    {
      "block_id": "ps-81-10",
      "type": "verse",
      "number": 10,
      "text": "I am the Lord your God,"
    },
    {
      "block_id": "ps-81-11",
      "type": "verse",
      "number": 11,
      "text": "“But my people did not listen to my voice;"
    },
    {
      "block_id": "ps-81-12",
      "type": "verse",
      "number": 12,
      "text": "So I gave them over to their stubborn hearts,"
    },
    {
      "block_id": "ps-81-13",
      "type": "verse",
      "number": 13,
      "text": "O that my people would listen to me,"
    },
    {
      "block_id": "ps-81-14",
      "type": "verse",
      "number": 14,
      "text": "Then I would quickly subdue their enemies"
    },
    {
      "block_id": "ps-81-15",
      "type": "verse",
      "number": 15,
      "text": "Those who hate the Lord would cringe before him,"
    },
    {
      "block_id": "ps-81-16",
      "type": "verse",
      "number": 16,
      "text": "I would feed you with the finest of the wheat,"
    }
  ]
}