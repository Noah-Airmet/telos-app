{
  "document_id": "isa-41",
  "title": "Isaiah 41",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-41-1",
      "type": "verse",
      "number": 1,
      "text": "Listen to me in silence, O coastlands;"
    },
    {
      "block_id": "isa-41-2",
      "type": "verse",
      "number": 2,
      "text": "Who has roused a victor from the east,"
    },
    {
      "block_id": "isa-41-3",
      "type": "verse",
      "number": 3,
      "text": "He pursues them and passes on safely,"
    },
    {
      "block_id": "isa-41-4",
      "type": "verse",
      "number": 4,
      "text": "Who has performed and done this,"
    },
    {
      "block_id": "isa-41-5",
      "type": "verse",
      "number": 5,
      "text": "The coastlands have seen and are afraid;"
    },
    {
      "block_id": "isa-41-6",
      "type": "verse",
      "number": 6,
      "text": "Each one helps the other,"
    },
    {
      "block_id": "isa-41-7",
      "type": "verse",
      "number": 7,
      "text": "The artisan encourages the goldsmith,"
    },
    {
      "block_id": "isa-41-8",
      "type": "verse",
      "number": 8,
      "text": "But you, Israel, my servant,"
    },
    {
      "block_id": "isa-41-9",
      "type": "verse",
      "number": 9,
      "text": "you whom I took from the ends of the earth"
    },
    {
      "block_id": "isa-41-10",
      "type": "verse",
      "number": 10,
      "text": "do not fear, for I am with you;"
    },
    {
      "block_id": "isa-41-11",
      "type": "verse",
      "number": 11,
      "text": "All who are incensed against you"
    },
    {
      "block_id": "isa-41-12",
      "type": "verse",
      "number": 12,
      "text": "You shall seek those who contend with you,"
    },
    {
      "block_id": "isa-41-13",
      "type": "verse",
      "number": 13,
      "text": "For I, the Lord your God,"
    },
    {
      "block_id": "isa-41-14",
      "type": "verse",
      "number": 14,
      "text": "Do not fear, you worm Jacob,"
    },
    {
      "block_id": "isa-41-15",
      "type": "verse",
      "number": 15,
      "text": "I will make of you a threshing sledge,"
    },
    {
      "block_id": "isa-41-16",
      "type": "verse",
      "number": 16,
      "text": "You shall winnow them, and the wind shall carry them away,"
    },
    {
      "block_id": "isa-41-17",
      "type": "verse",
      "number": 17,
      "text": "When the poor and needy seek water,"
    },
    {
      "block_id": "isa-41-18",
      "type": "verse",
      "number": 18,
      "text": "I will open rivers on the bare heights"
    },
    {
      "block_id": "isa-41-19",
      "type": "verse",
      "number": 19,
      "text": "I will put in the wilderness the cedar,"
    },
    {
      "block_id": "isa-41-20",
      "type": "verse",
      "number": 20,
      "text": "so that all may see and know,"
    },
    {
      "block_id": "isa-41-21",
      "type": "verse",
      "number": 21,
      "text": "Set forth your case, says the Lord;"
    },
    {
      "block_id": "isa-41-22",
      "type": "verse",
      "number": 22,
      "text": "Let them bring them and tell us"
    },
    {
      "block_id": "isa-41-23",
      "type": "verse",
      "number": 23,
      "text": "Tell us what is to come hereafter,"
    },
    {
      "block_id": "isa-41-24",
      "type": "verse",
      "number": 24,
      "text": "You, indeed, are nothing,"
    },
    {
      "block_id": "isa-41-25",
      "type": "verse",
      "number": 25,
      "text": "I stirred up one from the north, and he has come,"
    },
    {
      "block_id": "isa-41-26",
      "type": "verse",
      "number": 26,
      "text": "Who declared it from the beginning, so that we might know,"
    },
    {
      "block_id": "isa-41-27",
      "type": "verse",
      "number": 27,
      "text": "I first have declared it to Zion,"
    },
    {
      "block_id": "isa-41-28",
      "type": "verse",
      "number": 28,
      "text": "But when I look there is no one;"
    },
    {
      "block_id": "isa-41-29",
      "type": "verse",
      "number": 29,
      "text": "No, they are all a delusion;"
    }
  ]
}