{
  "document_id": "mic-1",
  "title": "Micah 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "mic-1-1",
      "type": "verse",
      "number": 1,
      "text": "The word of the Lord that came to Micah of Moresheth in the days of Kings Jotham, Ahaz, and Hezekiah of Judah, which he saw concerning Samaria and Jerusalem."
    },
    {
      "block_id": "mic-1-2",
      "type": "verse",
      "number": 2,
      "text": "Hear, you peoples, all of you;"
    },
    {
      "block_id": "mic-1-3",
      "type": "verse",
      "number": 3,
      "text": "For the Lord is coming out of his place"
    },
    {
      "block_id": "mic-1-4",
      "type": "verse",
      "number": 4,
      "text": "Then the mountains will melt under him,"
    },
    {
      "block_id": "mic-1-5",
      "type": "verse",
      "number": 5,
      "text": "All this is for the transgression of Jacob"
    },
    {
      "block_id": "mic-1-6",
      "type": "verse",
      "number": 6,
      "text": "Therefore I will make Samaria a heap in the open country,"
    },
    {
      "block_id": "mic-1-7",
      "type": "verse",
      "number": 7,
      "text": "All her images shall be beaten to pieces,"
    },
    {
      "block_id": "mic-1-8",
      "type": "verse",
      "number": 8,
      "text": "For this I will lament and wail;"
    },
    {
      "block_id": "mic-1-9",
      "type": "verse",
      "number": 9,
      "text": "For her wound is incurable."
    },
    {
      "block_id": "mic-1-10",
      "type": "verse",
      "number": 10,
      "text": "Tell it not in Gath;"
    },
    {
      "block_id": "mic-1-11",
      "type": "verse",
      "number": 11,
      "text": "Pass on your way,"
    },
    {
      "block_id": "mic-1-12",
      "type": "verse",
      "number": 12,
      "text": "For the inhabitants of Maroth"
    },
    {
      "block_id": "mic-1-13",
      "type": "verse",
      "number": 13,
      "text": "Harness the steeds to the chariots,"
    },
    {
      "block_id": "mic-1-14",
      "type": "verse",
      "number": 14,
      "text": "Therefore you shall give parting gifts"
    },
    {
      "block_id": "mic-1-15",
      "type": "verse",
      "number": 15,
      "text": "I will again bring a conqueror upon you,"
    },
    {
      "block_id": "mic-1-16",
      "type": "verse",
      "number": 16,
      "text": "Make yourselves bald and cut off your hair"
    }
  ]
}