{
  "document_id": "job-18",
  "title": "Job 18",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-18-heading-bildad-speaks:-god-p",
      "type": "heading",
      "text": "Bildad Speaks: God Punishes the Wicked"
    },
    {
      "block_id": "job-18-1",
      "type": "verse",
      "number": 1,
      "text": "Then Bildad the Shuhite answered:"
    },
    {
      "block_id": "job-18-2",
      "type": "verse",
      "number": 2,
      "text": "“How long will you hunt for words?"
    },
    {
      "block_id": "job-18-3",
      "type": "verse",
      "number": 3,
      "text": "Why are we counted as cattle?"
    },
    {
      "block_id": "job-18-4",
      "type": "verse",
      "number": 4,
      "text": "You who tear yourself in your anger—"
    },
    {
      "block_id": "job-18-5",
      "type": "verse",
      "number": 5,
      "text": "“Surely the light of the wicked is put out,"
    },
    {
      "block_id": "job-18-6",
      "type": "verse",
      "number": 6,
      "text": "The light is dark in their tent,"
    },
    {
      "block_id": "job-18-7",
      "type": "verse",
      "number": 7,
      "text": "Their strong steps are shortened,"
    },
    {
      "block_id": "job-18-8",
      "type": "verse",
      "number": 8,
      "text": "For they are thrust into a net by their own feet,"
    },
    {
      "block_id": "job-18-9",
      "type": "verse",
      "number": 9,
      "text": "A trap seizes them by the heel;"
    },
    {
      "block_id": "job-18-10",
      "type": "verse",
      "number": 10,
      "text": "A rope is hid for them in the ground,"
    },
    {
      "block_id": "job-18-11",
      "type": "verse",
      "number": 11,
      "text": "Terrors frighten them on every side"
    },
    {
      "block_id": "job-18-12",
      "type": "verse",
      "number": 12,
      "text": "Their strength is consumed by hunger,"
    },
    {
      "block_id": "job-18-13",
      "type": "verse",
      "number": 13,
      "text": "By disease their skin is consumed;"
    },
    {
      "block_id": "job-18-14",
      "type": "verse",
      "number": 14,
      "text": "They are torn from the tent in which they trusted"
    },
    {
      "block_id": "job-18-15",
      "type": "verse",
      "number": 15,
      "text": "In their tents nothing remains;"
    },
    {
      "block_id": "job-18-16",
      "type": "verse",
      "number": 16,
      "text": "Their roots dry up beneath,"
    },
    {
      "block_id": "job-18-17",
      "type": "verse",
      "number": 17,
      "text": "Their memory perishes from the earth,"
    },
    {
      "block_id": "job-18-18",
      "type": "verse",
      "number": 18,
      "text": "They are thrust from light into darkness"
    },
    {
      "block_id": "job-18-19",
      "type": "verse",
      "number": 19,
      "text": "They have no offspring or descendant among their people"
    },
    {
      "block_id": "job-18-20",
      "type": "verse",
      "number": 20,
      "text": "They of the west are appalled at their fate,"
    },
    {
      "block_id": "job-18-21",
      "type": "verse",
      "number": 21,
      "text": "Surely such are the dwellings of the ungodly;"
    }
  ]
}