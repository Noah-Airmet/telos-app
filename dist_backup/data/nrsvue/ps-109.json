{
  "document_id": "ps-109",
  "title": "Psalms 109",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-109-1",
      "type": "verse",
      "number": 1,
      "text": "Do not be silent, O God of my praise."
    },
    {
      "block_id": "ps-109-2",
      "type": "verse",
      "number": 2,
      "text": "For wicked and deceitful mouths are opened against me,"
    },
    {
      "block_id": "ps-109-3",
      "type": "verse",
      "number": 3,
      "text": "They surround me with words of hate"
    },
    {
      "block_id": "ps-109-4",
      "type": "verse",
      "number": 4,
      "text": "In return for my love they accuse me,"
    },
    {
      "block_id": "ps-109-5",
      "type": "verse",
      "number": 5,
      "text": "So they reward me evil for good"
    },
    {
      "block_id": "ps-109-6",
      "type": "verse",
      "number": 6,
      "text": "They say, “Appoint a wicked man against him;"
    },
    {
      "block_id": "ps-109-7",
      "type": "verse",
      "number": 7,
      "text": "When he is tried, let him be found guilty;"
    },
    {
      "block_id": "ps-109-8",
      "type": "verse",
      "number": 8,
      "text": "May his days be few;"
    },
    {
      "block_id": "ps-109-9",
      "type": "verse",
      "number": 9,
      "text": "May his children be orphans"
    },
    {
      "block_id": "ps-109-10",
      "type": "verse",
      "number": 10,
      "text": "May his children wander about and beg;"
    },
    {
      "block_id": "ps-109-11",
      "type": "verse",
      "number": 11,
      "text": "May the creditor seize all that he has;"
    },
    {
      "block_id": "ps-109-12",
      "type": "verse",
      "number": 12,
      "text": "May there be no one to do him a kindness"
    },
    {
      "block_id": "ps-109-13",
      "type": "verse",
      "number": 13,
      "text": "May his posterity be cut off;"
    },
    {
      "block_id": "ps-109-14",
      "type": "verse",
      "number": 14,
      "text": "May the iniquity of his father be remembered before the Lord,"
    },
    {
      "block_id": "ps-109-15",
      "type": "verse",
      "number": 15,
      "text": "Let them be before the Lord continually,"
    },
    {
      "block_id": "ps-109-16",
      "type": "verse",
      "number": 16,
      "text": "For he did not remember to show kindness"
    },
    {
      "block_id": "ps-109-17",
      "type": "verse",
      "number": 17,
      "text": "He loved to curse; let curses come on him."
    },
    {
      "block_id": "ps-109-18",
      "type": "verse",
      "number": 18,
      "text": "He clothed himself with cursing as his coat;"
    },
    {
      "block_id": "ps-109-19",
      "type": "verse",
      "number": 19,
      "text": "May it be like a garment that he wraps around himself,"
    },
    {
      "block_id": "ps-109-20",
      "type": "verse",
      "number": 20,
      "text": "May that be the reward of my accusers from the Lord,"
    },
    {
      "block_id": "ps-109-21",
      "type": "verse",
      "number": 21,
      "text": "But you, O Lord my Lord,"
    },
    {
      "block_id": "ps-109-22",
      "type": "verse",
      "number": 22,
      "text": "For I am poor and needy,"
    },
    {
      "block_id": "ps-109-23",
      "type": "verse",
      "number": 23,
      "text": "I am gone like a shadow at evening;"
    },
    {
      "block_id": "ps-109-24",
      "type": "verse",
      "number": 24,
      "text": "My knees are weak through fasting;"
    },
    {
      "block_id": "ps-109-25",
      "type": "verse",
      "number": 25,
      "text": "I am an object of scorn to my accusers;"
    },
    {
      "block_id": "ps-109-26",
      "type": "verse",
      "number": 26,
      "text": "Help me, O Lord my God!"
    },
    {
      "block_id": "ps-109-27",
      "type": "verse",
      "number": 27,
      "text": "Let them know that this is your hand;"
    },
    {
      "block_id": "ps-109-28",
      "type": "verse",
      "number": 28,
      "text": "Let them curse, but you will bless."
    },
    {
      "block_id": "ps-109-29",
      "type": "verse",
      "number": 29,
      "text": "May my accusers be clothed with dishonor;"
    },
    {
      "block_id": "ps-109-30",
      "type": "verse",
      "number": 30,
      "text": "With my mouth I will give great thanks to the Lord;"
    },
    {
      "block_id": "ps-109-31",
      "type": "verse",
      "number": 31,
      "text": "For he stands at the right hand of the needy,"
    }
  ]
}