{
  "document_id": "sir-23",
  "title": "Sirach 23",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-23-1",
      "type": "verse",
      "number": 1,
      "text": "O Lord, Father and Master of my life,"
    },
    {
      "block_id": "sir-23-2",
      "type": "verse",
      "number": 2,
      "text": "Who will set whips over my thoughts"
    },
    {
      "block_id": "sir-23-3",
      "type": "verse",
      "number": 3,
      "text": "Otherwise my mistakes may be multiplied,"
    },
    {
      "block_id": "sir-23-4",
      "type": "verse",
      "number": 4,
      "text": "O Lord, Father and God of my life,"
    },
    {
      "block_id": "sir-23-5",
      "type": "verse",
      "number": 5,
      "text": "and remove desire from me."
    },
    {
      "block_id": "sir-23-6",
      "type": "verse",
      "number": 6,
      "text": "Let neither gluttony nor lust overcome me,"
    },
    {
      "block_id": "sir-23-7",
      "type": "verse",
      "number": 7,
      "text": "Listen, my children, to instruction concerning the mouth;"
    },
    {
      "block_id": "sir-23-8",
      "type": "verse",
      "number": 8,
      "text": "Sinners are overtaken through their lips;"
    },
    {
      "block_id": "sir-23-9",
      "type": "verse",
      "number": 9,
      "text": "Do not accustom your mouth to oaths"
    },
    {
      "block_id": "sir-23-10",
      "type": "verse",
      "number": 10,
      "text": "for as a slave who is constantly under scrutiny"
    },
    {
      "block_id": "sir-23-11",
      "type": "verse",
      "number": 11,
      "text": "The one who swears many oaths is full of iniquity,"
    },
    {
      "block_id": "sir-23-12",
      "type": "verse",
      "number": 12,
      "text": "There is a manner of speaking comparable to death;"
    },
    {
      "block_id": "sir-23-13",
      "type": "verse",
      "number": 13,
      "text": "Do not accustom your mouth to lewd ignorance,"
    },
    {
      "block_id": "sir-23-14",
      "type": "verse",
      "number": 14,
      "text": "Remember your father and mother"
    },
    {
      "block_id": "sir-23-15",
      "type": "verse",
      "number": 15,
      "text": "Those who are accustomed to using abusive language"
    },
    {
      "block_id": "sir-23-16",
      "type": "verse",
      "number": 16,
      "text": "Two kinds of individuals multiply sins,"
    },
    {
      "block_id": "sir-23-17",
      "type": "verse",
      "number": 17,
      "text": "To the sexually immoral all bread is sweet;"
    },
    {
      "block_id": "sir-23-18",
      "type": "verse",
      "number": 18,
      "text": "The one who sins against his marriage bed"
    },
    {
      "block_id": "sir-23-19",
      "type": "verse",
      "number": 19,
      "text": "His fear is confined to human eyes,"
    },
    {
      "block_id": "sir-23-20",
      "type": "verse",
      "number": 20,
      "text": "Before the universe was created, it was known to him,"
    },
    {
      "block_id": "sir-23-21",
      "type": "verse",
      "number": 21,
      "text": "This man will be punished in the streets of the city,"
    },
    {
      "block_id": "sir-23-22",
      "type": "verse",
      "number": 22,
      "text": "So it is with a woman who leaves her husband"
    },
    {
      "block_id": "sir-23-23",
      "type": "verse",
      "number": 23,
      "text": "For, first of all, she has disobeyed the law of the Most High;"
    },
    {
      "block_id": "sir-23-24",
      "type": "verse",
      "number": 24,
      "text": "She herself will be brought before the assembly,"
    },
    {
      "block_id": "sir-23-25",
      "type": "verse",
      "number": 25,
      "text": "Her children will not take root,"
    },
    {
      "block_id": "sir-23-26",
      "type": "verse",
      "number": 26,
      "text": "She will leave behind an accursed memory,"
    },
    {
      "block_id": "sir-23-27",
      "type": "verse",
      "number": 27,
      "text": "Those who survive her will recognize"
    }
  ]
}