{
  "document_id": "sir-4",
  "title": "Sirach 4",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-4-1",
      "type": "verse",
      "number": 1,
      "text": "My child, do not cheat the poor of their living,"
    },
    {
      "block_id": "sir-4-2",
      "type": "verse",
      "number": 2,
      "text": "Do not grieve the hungry"
    },
    {
      "block_id": "sir-4-3",
      "type": "verse",
      "number": 3,
      "text": "Do not add to the troubles of the angry"
    },
    {
      "block_id": "sir-4-4",
      "type": "verse",
      "number": 4,
      "text": "Do not reject a suppliant in distress"
    },
    {
      "block_id": "sir-4-5",
      "type": "verse",
      "number": 5,
      "text": "Do not avert your eye from the needy,"
    },
    {
      "block_id": "sir-4-6",
      "type": "verse",
      "number": 6,
      "text": "for if in bitterness of soul some should curse you,"
    },
    {
      "block_id": "sir-4-7",
      "type": "verse",
      "number": 7,
      "text": "Endear yourself to the congregation;"
    },
    {
      "block_id": "sir-4-8",
      "type": "verse",
      "number": 8,
      "text": "Give a hearing to the poor,"
    },
    {
      "block_id": "sir-4-9",
      "type": "verse",
      "number": 9,
      "text": "Rescue the oppressed from the oppressor,"
    },
    {
      "block_id": "sir-4-10",
      "type": "verse",
      "number": 10,
      "text": "Be a father to orphans,"
    },
    {
      "block_id": "sir-4-11",
      "type": "verse",
      "number": 11,
      "text": "Wisdom teaches her children"
    },
    {
      "block_id": "sir-4-12",
      "type": "verse",
      "number": 12,
      "text": "Whoever loves her loves life,"
    },
    {
      "block_id": "sir-4-13",
      "type": "verse",
      "number": 13,
      "text": "Whoever holds her fast inherits glory,"
    },
    {
      "block_id": "sir-4-14",
      "type": "verse",
      "number": 14,
      "text": "Those who serve her minister to the Holy One;"
    },
    {
      "block_id": "sir-4-15",
      "type": "verse",
      "number": 15,
      "text": "Whoever obeys her will judge the nations,"
    },
    {
      "block_id": "sir-4-16",
      "type": "verse",
      "number": 16,
      "text": "If they remain faithful, they will inherit her;"
    },
    {
      "block_id": "sir-4-17",
      "type": "verse",
      "number": 17,
      "text": "For at first she will walk with them in disguise;"
    },
    {
      "block_id": "sir-4-18",
      "type": "verse",
      "number": 18,
      "text": "Then she will come straight back to them again and gladden them"
    },
    {
      "block_id": "sir-4-19",
      "type": "verse",
      "number": 19,
      "text": "If they go astray, she will forsake them"
    },
    {
      "block_id": "sir-4-20",
      "type": "verse",
      "number": 20,
      "text": "Watch for the opportune time, and beware of evil,"
    },
    {
      "block_id": "sir-4-21",
      "type": "verse",
      "number": 21,
      "text": "For there is a shame that leads to sin,"
    },
    {
      "block_id": "sir-4-22",
      "type": "verse",
      "number": 22,
      "text": "Do not show partiality to your own harm"
    },
    {
      "block_id": "sir-4-23",
      "type": "verse",
      "number": 23,
      "text": "Do not refrain from speaking at the proper moment,"
    },
    {
      "block_id": "sir-4-24",
      "type": "verse",
      "number": 24,
      "text": "For wisdom becomes known through speech"
    },
    {
      "block_id": "sir-4-25",
      "type": "verse",
      "number": 25,
      "text": "Never speak against the truth,"
    },
    {
      "block_id": "sir-4-26",
      "type": "verse",
      "number": 26,
      "text": "Do not be ashamed to confess your sins,"
    },
    {
      "block_id": "sir-4-27",
      "type": "verse",
      "number": 27,
      "text": "Do not subject yourself to a fool"
    },
    {
      "block_id": "sir-4-28",
      "type": "verse",
      "number": 28,
      "text": "Fight to the death for truth,"
    },
    {
      "block_id": "sir-4-29",
      "type": "verse",
      "number": 29,
      "text": "Do not be reckless in your speech"
    },
    {
      "block_id": "sir-4-30",
      "type": "verse",
      "number": 30,
      "text": "Do not be like a lion in your home"
    },
    {
      "block_id": "sir-4-31",
      "type": "verse",
      "number": 31,
      "text": "Do not let your hand be stretched out to receive"
    }
  ]
}