{
  "document_id": "hos-5",
  "title": "Hosea 5",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-5-1",
      "type": "verse",
      "number": 1,
      "text": "Hear this, O priests!"
    },
    {
      "block_id": "hos-5-2",
      "type": "verse",
      "number": 2,
      "text": "and a pit dug deep in Shittim,"
    },
    {
      "block_id": "hos-5-3",
      "type": "verse",
      "number": 3,
      "text": "I know Ephraim,"
    },
    {
      "block_id": "hos-5-4",
      "type": "verse",
      "number": 4,
      "text": "Their deeds do not permit them"
    },
    {
      "block_id": "hos-5-5",
      "type": "verse",
      "number": 5,
      "text": "Israel’s pride testifies against him;"
    },
    {
      "block_id": "hos-5-6",
      "type": "verse",
      "number": 6,
      "text": "With their flocks and herds they shall go"
    },
    {
      "block_id": "hos-5-7",
      "type": "verse",
      "number": 7,
      "text": "They have dealt faithlessly with the Lord,"
    },
    {
      "block_id": "hos-5-8",
      "type": "verse",
      "number": 8,
      "text": "Blow the horn in Gibeah,"
    },
    {
      "block_id": "hos-5-9",
      "type": "verse",
      "number": 9,
      "text": "Ephraim shall become a desolation"
    },
    {
      "block_id": "hos-5-10",
      "type": "verse",
      "number": 10,
      "text": "The princes of Judah have become"
    },
    {
      "block_id": "hos-5-11",
      "type": "verse",
      "number": 11,
      "text": "Ephraim is oppressed, crushed in judgment,"
    },
    {
      "block_id": "hos-5-12",
      "type": "verse",
      "number": 12,
      "text": "Therefore I am like maggots to Ephraim"
    },
    {
      "block_id": "hos-5-13",
      "type": "verse",
      "number": 13,
      "text": "When Ephraim saw his sickness"
    },
    {
      "block_id": "hos-5-14",
      "type": "verse",
      "number": 14,
      "text": "For I will be like a lion to Ephraim"
    },
    {
      "block_id": "hos-5-15",
      "type": "verse",
      "number": 15,
      "text": "I will return again to my place"
    }
  ]
}