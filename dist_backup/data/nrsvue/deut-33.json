{
  "document_id": "deut-33",
  "title": "Deuteronomy 33",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "deut-33-heading-moses’s-final-blessi",
      "type": "heading",
      "text": "Moses’s Final Blessing on Israel"
    },
    {
      "block_id": "deut-33-1",
      "type": "verse",
      "number": 1,
      "text": "This is the blessing with which Moses, the man of God, blessed the Israelites before his death."
    },
    {
      "block_id": "deut-33-2",
      "type": "verse",
      "number": 2,
      "text": "He said,"
    },
    {
      "block_id": "deut-33-3",
      "type": "verse",
      "number": 3,
      "text": "Indeed, O favorite among peoples,"
    },
    {
      "block_id": "deut-33-4",
      "type": "verse",
      "number": 4,
      "text": "Moses charged us with the law"
    },
    {
      "block_id": "deut-33-5",
      "type": "verse",
      "number": 5,
      "text": "There arose a king in Jeshurun"
    },
    {
      "block_id": "deut-33-6",
      "type": "verse",
      "number": 6,
      "text": "May Reuben live and not die out,"
    },
    {
      "block_id": "deut-33-7",
      "type": "verse",
      "number": 7,
      "text": "And this he said of Judah,"
    },
    {
      "block_id": "deut-33-8",
      "type": "verse",
      "number": 8,
      "text": "And of Levi he said,"
    },
    {
      "block_id": "deut-33-9",
      "type": "verse",
      "number": 9,
      "text": "who said of his father and mother,"
    },
    {
      "block_id": "deut-33-10",
      "type": "verse",
      "number": 10,
      "text": "They teach Jacob your ordinances"
    },
    {
      "block_id": "deut-33-11",
      "type": "verse",
      "number": 11,
      "text": "Bless, O Lord, his substance,"
    },
    {
      "block_id": "deut-33-12",
      "type": "verse",
      "number": 12,
      "text": "Of Benjamin he said,"
    },
    {
      "block_id": "deut-33-13",
      "type": "verse",
      "number": 13,
      "text": "And of Joseph he said,"
    },
    {
      "block_id": "deut-33-14",
      "type": "verse",
      "number": 14,
      "text": "with the choice fruits of the sun"
    },
    {
      "block_id": "deut-33-15",
      "type": "verse",
      "number": 15,
      "text": "with the finest produce of the ancient mountains"
    },
    {
      "block_id": "deut-33-16",
      "type": "verse",
      "number": 16,
      "text": "with the choice gifts of the earth and its fullness"
    },
    {
      "block_id": "deut-33-17",
      "type": "verse",
      "number": 17,
      "text": "A firstborn bull—majesty is his!"
    },
    {
      "block_id": "deut-33-18",
      "type": "verse",
      "number": 18,
      "text": "And of Zebulun he said,"
    },
    {
      "block_id": "deut-33-19",
      "type": "verse",
      "number": 19,
      "text": "They call peoples to the mountain;"
    },
    {
      "block_id": "deut-33-20",
      "type": "verse",
      "number": 20,
      "text": "And of Gad he said,"
    },
    {
      "block_id": "deut-33-21",
      "type": "verse",
      "number": 21,
      "text": "He chose the best for himself,"
    },
    {
      "block_id": "deut-33-22",
      "type": "verse",
      "number": 22,
      "text": "And of Dan he said,"
    },
    {
      "block_id": "deut-33-23",
      "type": "verse",
      "number": 23,
      "text": "And of Naphtali he said,"
    },
    {
      "block_id": "deut-33-24",
      "type": "verse",
      "number": 24,
      "text": "And of Asher he said,"
    },
    {
      "block_id": "deut-33-25",
      "type": "verse",
      "number": 25,
      "text": "Your bars are iron and bronze,"
    },
    {
      "block_id": "deut-33-26",
      "type": "verse",
      "number": 26,
      "text": "There is none like God, O Jeshurun,"
    },
    {
      "block_id": "deut-33-27",
      "type": "verse",
      "number": 27,
      "text": "He subdues the ancient gods,"
    },
    {
      "block_id": "deut-33-28",
      "type": "verse",
      "number": 28,
      "text": "So Israel lives in safety,"
    },
    {
      "block_id": "deut-33-29",
      "type": "verse",
      "number": 29,
      "text": "Happy are you, O Israel! Who is like you,"
    }
  ]
}