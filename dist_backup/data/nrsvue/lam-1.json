{
  "document_id": "lam-1",
  "title": "Lamentations 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "lam-1-1",
      "type": "verse",
      "number": 1,
      "text": "How lonely sits the city"
    },
    {
      "block_id": "lam-1-2",
      "type": "verse",
      "number": 2,
      "text": "She weeps bitterly in the night,"
    },
    {
      "block_id": "lam-1-3",
      "type": "verse",
      "number": 3,
      "text": "Judah has gone into exile with suffering"
    },
    {
      "block_id": "lam-1-4",
      "type": "verse",
      "number": 4,
      "text": "The roads to Zion mourn,"
    },
    {
      "block_id": "lam-1-5",
      "type": "verse",
      "number": 5,
      "text": "Her foes have become the masters;"
    },
    {
      "block_id": "lam-1-6",
      "type": "verse",
      "number": 6,
      "text": "From daughter Zion has departed"
    },
    {
      "block_id": "lam-1-7",
      "type": "verse",
      "number": 7,
      "text": "Jerusalem remembers all the precious things"
    },
    {
      "block_id": "lam-1-8",
      "type": "verse",
      "number": 8,
      "text": "Jerusalem sinned grievously,"
    },
    {
      "block_id": "lam-1-9",
      "type": "verse",
      "number": 9,
      "text": "Her uncleanness was in her skirts;"
    },
    {
      "block_id": "lam-1-10",
      "type": "verse",
      "number": 10,
      "text": "Enemies have stretched out their hands"
    },
    {
      "block_id": "lam-1-11",
      "type": "verse",
      "number": 11,
      "text": "All her people groan"
    },
    {
      "block_id": "lam-1-12",
      "type": "verse",
      "number": 12,
      "text": "Is it nothing to you, all you who pass by?"
    },
    {
      "block_id": "lam-1-13",
      "type": "verse",
      "number": 13,
      "text": "From on high he sent fire;"
    },
    {
      "block_id": "lam-1-14",
      "type": "verse",
      "number": 14,
      "text": "My transgressions were bound into a yoke;"
    },
    {
      "block_id": "lam-1-15",
      "type": "verse",
      "number": 15,
      "text": "The Lord has rejected"
    },
    {
      "block_id": "lam-1-16",
      "type": "verse",
      "number": 16,
      "text": "For these things I weep;"
    },
    {
      "block_id": "lam-1-17",
      "type": "verse",
      "number": 17,
      "text": "Zion stretches out her hands,"
    },
    {
      "block_id": "lam-1-18",
      "type": "verse",
      "number": 18,
      "text": "The Lord is in the right,"
    },
    {
      "block_id": "lam-1-19",
      "type": "verse",
      "number": 19,
      "text": "I called to my lovers,"
    },
    {
      "block_id": "lam-1-20",
      "type": "verse",
      "number": 20,
      "text": "Look, O Lord, at how distressed I am;"
    },
    {
      "block_id": "lam-1-21",
      "type": "verse",
      "number": 21,
      "text": "They heard how I was groaning,"
    },
    {
      "block_id": "lam-1-22",
      "type": "verse",
      "number": 22,
      "text": "Let all their evildoing come before you,"
    }
  ]
}