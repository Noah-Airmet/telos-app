{
  "document_id": "prov-18",
  "title": "Proverbs 18",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-18-1",
      "type": "verse",
      "number": 1,
      "text": "The one who lives alone is self-indulgent,"
    },
    {
      "block_id": "prov-18-2",
      "type": "verse",
      "number": 2,
      "text": "A fool takes no pleasure in understanding,"
    },
    {
      "block_id": "prov-18-3",
      "type": "verse",
      "number": 3,
      "text": "When wickedness comes, contempt comes also,"
    },
    {
      "block_id": "prov-18-4",
      "type": "verse",
      "number": 4,
      "text": "The words of the mouth are deep waters;"
    },
    {
      "block_id": "prov-18-5",
      "type": "verse",
      "number": 5,
      "text": "It is not right to be partial to the guilty"
    },
    {
      "block_id": "prov-18-6",
      "type": "verse",
      "number": 6,
      "text": "A fool’s lips bring strife,"
    },
    {
      "block_id": "prov-18-7",
      "type": "verse",
      "number": 7,
      "text": "The mouths of fools are their ruin,"
    },
    {
      "block_id": "prov-18-8",
      "type": "verse",
      "number": 8,
      "text": "The words of a whisperer are like delicious morsels;"
    },
    {
      "block_id": "prov-18-9",
      "type": "verse",
      "number": 9,
      "text": "One who is slack in work"
    },
    {
      "block_id": "prov-18-10",
      "type": "verse",
      "number": 10,
      "text": "The name of the Lord is a strong tower;"
    },
    {
      "block_id": "prov-18-11",
      "type": "verse",
      "number": 11,
      "text": "The wealth of the rich is their strong city;"
    },
    {
      "block_id": "prov-18-12",
      "type": "verse",
      "number": 12,
      "text": "Before destruction one’s heart is haughty,"
    },
    {
      "block_id": "prov-18-13",
      "type": "verse",
      "number": 13,
      "text": "If one gives answer before hearing,"
    },
    {
      "block_id": "prov-18-14",
      "type": "verse",
      "number": 14,
      "text": "The human spirit will endure sickness,"
    },
    {
      "block_id": "prov-18-15",
      "type": "verse",
      "number": 15,
      "text": "An intelligent mind acquires knowledge,"
    },
    {
      "block_id": "prov-18-16",
      "type": "verse",
      "number": 16,
      "text": "A gift opens doors;"
    },
    {
      "block_id": "prov-18-17",
      "type": "verse",
      "number": 17,
      "text": "The one who first states a case seems right,"
    },
    {
      "block_id": "prov-18-18",
      "type": "verse",
      "number": 18,
      "text": "Casting the lot puts an end to disputes"
    },
    {
      "block_id": "prov-18-19",
      "type": "verse",
      "number": 19,
      "text": "An ally offended is stronger than a city;"
    },
    {
      "block_id": "prov-18-20",
      "type": "verse",
      "number": 20,
      "text": "From the fruit of the mouth one’s stomach is satisfied;"
    },
    {
      "block_id": "prov-18-21",
      "type": "verse",
      "number": 21,
      "text": "Death and life are in the power of the tongue,"
    },
    {
      "block_id": "prov-18-22",
      "type": "verse",
      "number": 22,
      "text": "He who finds a wife finds a good thing"
    },
    {
      "block_id": "prov-18-23",
      "type": "verse",
      "number": 23,
      "text": "The poor use entreaties,"
    },
    {
      "block_id": "prov-18-24",
      "type": "verse",
      "number": 24,
      "text": "Some friends play at friendship,"
    }
  ]
}