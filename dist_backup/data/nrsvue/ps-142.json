{
  "document_id": "ps-142",
  "title": "Psalms 142",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-142-1",
      "type": "verse",
      "number": 1,
      "text": "With my voice I cry to the Lord;"
    },
    {
      "block_id": "ps-142-2",
      "type": "verse",
      "number": 2,
      "text": "I pour out my complaint before him;"
    },
    {
      "block_id": "ps-142-3",
      "type": "verse",
      "number": 3,
      "text": "When my spirit is faint,"
    },
    {
      "block_id": "ps-142-4",
      "type": "verse",
      "number": 4,
      "text": "Look on my right hand and see:"
    },
    {
      "block_id": "ps-142-5",
      "type": "verse",
      "number": 5,
      "text": "I cry to you, O Lord;"
    },
    {
      "block_id": "ps-142-6",
      "type": "verse",
      "number": 6,
      "text": "Listen to my cry,"
    },
    {
      "block_id": "ps-142-7",
      "type": "verse",
      "number": 7,
      "text": "Bring me out of prison,"
    }
  ]
}