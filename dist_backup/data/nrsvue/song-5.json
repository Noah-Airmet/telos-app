{
  "document_id": "song-5",
  "title": "Song of Songs 5",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "song-5-1",
      "type": "verse",
      "number": 1,
      "text": "I come to my garden, my sister, my bride;"
    },
    {
      "block_id": "song-5-2",
      "type": "verse",
      "number": 2,
      "text": "I was sleeping, but my heart was awake."
    },
    {
      "block_id": "song-5-3",
      "type": "verse",
      "number": 3,
      "text": "I had put off my garment;"
    },
    {
      "block_id": "song-5-4",
      "type": "verse",
      "number": 4,
      "text": "My beloved thrust his hand into the opening,"
    },
    {
      "block_id": "song-5-5",
      "type": "verse",
      "number": 5,
      "text": "I arose to open to my beloved,"
    },
    {
      "block_id": "song-5-6",
      "type": "verse",
      "number": 6,
      "text": "I opened to my beloved,"
    },
    {
      "block_id": "song-5-7",
      "type": "verse",
      "number": 7,
      "text": "Making their rounds in the city"
    },
    {
      "block_id": "song-5-8",
      "type": "verse",
      "number": 8,
      "text": "I charge you, O daughters of Jerusalem,"
    },
    {
      "block_id": "song-5-9",
      "type": "verse",
      "number": 9,
      "text": "What is your beloved more than another beloved,"
    },
    {
      "block_id": "song-5-10",
      "type": "verse",
      "number": 10,
      "text": "My beloved is all radiant and ruddy,"
    },
    {
      "block_id": "song-5-11",
      "type": "verse",
      "number": 11,
      "text": "His head is the finest gold;"
    },
    {
      "block_id": "song-5-12",
      "type": "verse",
      "number": 12,
      "text": "His eyes are like doves"
    },
    {
      "block_id": "song-5-13",
      "type": "verse",
      "number": 13,
      "text": "His cheeks are like beds of spices,"
    },
    {
      "block_id": "song-5-14",
      "type": "verse",
      "number": 14,
      "text": "His arms are rounded gold,"
    },
    {
      "block_id": "song-5-15",
      "type": "verse",
      "number": 15,
      "text": "His legs are alabaster columns,"
    },
    {
      "block_id": "song-5-16",
      "type": "verse",
      "number": 16,
      "text": "His speech is most sweet,"
    }
  ]
}