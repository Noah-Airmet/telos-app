{
  "document_id": "job-26",
  "title": "Job 26",
  "type": "study-bible",
  "translation": "NJPS",
  "blocks": [
    {
      "block_id": "jsb-job-26-1",
      "type": "verse",
      "number": 1,
      "text": "Then Job said in reply:"
    },
    {
      "block_id": "jsb-job-26-2",
      "type": "verse",
      "number": 2,
      "text": "You would help without having the strength; You would deliver with arms that have no power."
    },
    {
      "block_id": "jsb-job-26-3",
      "type": "verse",
      "number": 3,
      "text": "Without having the wisdom, you offer advice And freely give your counsel."
    },
    {
      "block_id": "jsb-job-26-4",
      "type": "verse",
      "number": 4,
      "text": "To whom have you addressed words? Whose breath issued from you?"
    },
    {
      "block_id": "jsb-job-26-5",
      "type": "verse",
      "number": 5,
      "text": "The shades tremble Beneath the waters and their denizens."
    },
    {
      "block_id": "jsb-job-26-6",
      "type": "verse",
      "number": 6,
      "text": "Sheol is naked before Him; Abaddon has no cover."
    },
    {
      "block_id": "jsb-job-26-7",
      "type": "verse",
      "number": 7,
      "text": "He it is who stretched out Zaphon over chaos, Who suspended earth over emptiness."
    },
    {
      "block_id": "jsb-job-26-7-commentary-1",
      "type": "commentary",
      "text": "Used for heaven; cf. Isa. 14.13; Ps. 48.3.",
      "canonical_ref": {
        "work": "bible",
        "book": "job",
        "chapter": 26,
        "verse": 7
      },
      "verse_start": 7,
      "verse_end": 7
    },
    {
      "block_id": "jsb-job-26-8",
      "type": "verse",
      "number": 8,
      "text": "He wrapped up the waters in His clouds; Yet no cloud burst under their weight."
    },
    {
      "block_id": "jsb-job-26-9",
      "type": "verse",
      "number": 9,
      "text": "He shuts off the view of His throne, Spreading His cloud over it."
    },
    {
      "block_id": "jsb-job-26-9-commentary-2",
      "type": "commentary",
      "text": "Meaning of Heb. uncertain.",
      "canonical_ref": {
        "work": "bible",
        "book": "job",
        "chapter": 26,
        "verse": 9
      },
      "verse_start": 9,
      "verse_end": 9
    },
    {
      "block_id": "jsb-job-26-10",
      "type": "verse",
      "number": 10,
      "text": "He drew a boundary on the surface of the waters, At the extreme where light and darkness meet."
    },
    {
      "block_id": "jsb-job-26-11",
      "type": "verse",
      "number": 11,
      "text": "The pillars of heaven tremble, Astounded at His blast."
    },
    {
      "block_id": "jsb-job-26-12",
      "type": "verse",
      "number": 12,
      "text": "By His power He stilled the sea; By His skill He struck down Rahab."
    },
    {
      "block_id": "jsb-job-26-13",
      "type": "verse",
      "number": 13,
      "text": "By His wind the heavens were calmed; His hand pierced the Elusive Serpent."
    },
    {
      "block_id": "jsb-job-26-13-commentary-3",
      "type": "commentary",
      "text": "Cf. Isa. 27.1.",
      "canonical_ref": {
        "work": "bible",
        "book": "job",
        "chapter": 26,
        "verse": 13
      },
      "verse_start": 13,
      "verse_end": 13
    },
    {
      "block_id": "jsb-job-26-14",
      "type": "verse",
      "number": 14,
      "text": "These are but glimpses of His rule, The mere whisper that we perceive of Him; Who can absorb the thunder of His mighty deeds?"
    }
  ]
}