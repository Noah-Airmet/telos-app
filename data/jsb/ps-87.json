{
  "document_id": "ps-87",
  "title": "Psalms 87",
  "type": "study-bible",
  "translation": "NJPS",
  "blocks": [
    {
      "block_id": "jsb-ps-87-2",
      "type": "verse",
      "number": 2,
      "text": "Of the Korahites. A psalm. A song. The Lord loves the gates of Zion, His foundation on the holy mountains, more than all the dwellings of Jacob."
    },
    {
      "block_id": "jsb-ps-87-2-commentary-2",
      "type": "commentary",
      "text": "Order of lines inverted for clarity.",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 87,
        "verse": 2
      },
      "verse_start": 2,
      "verse_end": 2
    },
    {
      "block_id": "jsb-ps-87-3",
      "type": "verse",
      "number": 3,
      "text": "Glorious things are spoken of you, O city of God. Selah."
    },
    {
      "block_id": "jsb-ps-87-4",
      "type": "verse",
      "number": 4,
      "text": "I mention Rahab and Babylon among those who acknowledge Me; Philistia, and Tyre, and Cush—each was born there."
    },
    {
      "block_id": "jsb-ps-87-4-commentary-3",
      "type": "commentary",
      "text": "A primeval monster; here, a poetic term for Egypt; cf. Isa. 30.7.",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 87,
        "verse": 4
      },
      "verse_start": 4,
      "verse_end": 4
    },
    {
      "block_id": "jsb-ps-87-5",
      "type": "verse",
      "number": 5,
      "text": "Indeed, it shall be said of Zion, “Every man was born there.” He, the Most High, will preserve it."
    },
    {
      "block_id": "jsb-ps-87-5-commentary-4",
      "type": "commentary",
      "text": "Or “He will preserve it supreme.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 87,
        "verse": 5
      },
      "verse_start": 5,
      "verse_end": 5
    },
    {
      "block_id": "jsb-ps-87-6",
      "type": "verse",
      "number": 6,
      "text": "The Lord will inscribe in the register of peoples that each was born there. Selah."
    },
    {
      "block_id": "jsb-ps-87-7",
      "type": "verse",
      "number": 7,
      "text": "Singers and dancers alike [will say]: “All my roots are in You.”"
    },
    {
      "block_id": "jsb-ps-87-7-commentary-5",
      "type": "commentary",
      "text": "Lit. “sources.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 87,
        "verse": 7
      },
      "verse_start": 7,
      "verse_end": 7
    }
  ]
}