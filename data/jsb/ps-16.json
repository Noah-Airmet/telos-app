{
  "document_id": "ps-16",
  "title": "Psalms 16",
  "type": "study-bible",
  "translation": "NJPS",
  "blocks": [
    {
      "block_id": "jsb-ps-16-1",
      "type": "verse",
      "number": 1,
      "text": "A michtam of David. Protect me, O God, for I seek refuge in You."
    },
    {
      "block_id": "jsb-ps-16-1-commentary-1",
      "type": "commentary",
      "text": "Meaning of Heb. uncertain.",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 16,
        "verse": 1
      },
      "verse_start": 1,
      "verse_end": 1
    },
    {
      "block_id": "jsb-ps-16-2",
      "type": "verse",
      "number": 2,
      "text": "I say to the Lord, “You are my Lord, my benefactor; there is none above You.”"
    },
    {
      "block_id": "jsb-ps-16-2-commentary-2",
      "type": "commentary",
      "text": "Others “I have no good but in You.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 16,
        "verse": 2
      },
      "verse_start": 2,
      "verse_end": 2
    },
    {
      "block_id": "jsb-ps-16-3",
      "type": "verse",
      "number": 3,
      "text": "As to the holy and mighty ones that are in the land, my whole desire concerning them is that"
    },
    {
      "block_id": "jsb-ps-16-3-commentary-3",
      "type": "commentary",
      "text": "Meaning of Heb. uncertain; “holy and mighty ones” taken as epithets for divine beings; cf. qedoshim in Ps. 89.6, 8, and ʾaddirim in 1 Sam. 4.8.",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 16,
        "verse": 3
      },
      "verse_start": 3,
      "verse_end": 3
    },
    {
      "block_id": "jsb-ps-16-4",
      "type": "verse",
      "number": 4,
      "text": "those who espouse another [god] may have many sorrows! I will have no part of their bloody libations; their names will not pass my lips."
    },
    {
      "block_id": "jsb-ps-16-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord is my allotted share and portion; You control my fate."
    },
    {
      "block_id": "jsb-ps-16-5-commentary-4",
      "type": "commentary",
      "text": "Lit. “cup.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 16,
        "verse": 5
      },
      "verse_start": 5,
      "verse_end": 5
    },
    {
      "block_id": "jsb-ps-16-6",
      "type": "verse",
      "number": 6,
      "text": "Delightful country has fallen to my lot; lovely indeed is my estate."
    },
    {
      "block_id": "jsb-ps-16-7",
      "type": "verse",
      "number": 7,
      "text": "I bless the Lord who has guided me; my conscience admonishes me at night."
    },
    {
      "block_id": "jsb-ps-16-7-commentary-5",
      "type": "commentary",
      "text": "Lit. “kidneys.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 16,
        "verse": 7
      },
      "verse_start": 7,
      "verse_end": 7
    },
    {
      "block_id": "jsb-ps-16-8",
      "type": "verse",
      "number": 8,
      "text": "I am ever mindful of the Lord’s presence; He is at my right hand; I shall never be shaken."
    },
    {
      "block_id": "jsb-ps-16-9",
      "type": "verse",
      "number": 9,
      "text": "So my heart rejoices, my whole being exults, and my body rests secure."
    },
    {
      "block_id": "jsb-ps-16-10",
      "type": "verse",
      "number": 10,
      "text": "For You will not abandon me to Sheol, or let Your faithful one see the Pit."
    },
    {
      "block_id": "jsb-ps-16-11",
      "type": "verse",
      "number": 11,
      "text": "You will teach me the path of life. In Your presence is perfect joy; delights are ever in Your right hand."
    }
  ]
}