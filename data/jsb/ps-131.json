    {
      "block_id": "jsb-ps-131-1",
      "type": "verse",
      "number": 1,
      "text": "A song of ascents. Of David. O Lord, my heart is not proud nor my look haughty; I do not aspire to great things or to what is beyond me;"
    },
    {
      "block_id": "jsb-ps-131-2",
      "type": "verse",
      "number": 2,
      "text": "but I have taught myself to be contented like a weaned child with its mother; like a weaned child am I in my mind."
    },
    {
      "block_id": "jsb-ps-131-2-commentary-1",
      "type": "commentary",
      "text": "Meaning of Heb. uncertain.",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
