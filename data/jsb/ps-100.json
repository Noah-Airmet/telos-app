{
  "document_id": "ps-100",
  "title": "Psalms 100",
  "type": "study-bible",
  "translation": "NJPS",
  "blocks": [
    {
      "block_id": "jsb-ps-100-1",
      "type": "verse",
      "number": 1,
      "text": "A psalm for praise. Raise a shout for the Lord, all the earth;"
    },
    {
      "block_id": "jsb-ps-100-1-commentary-1",
      "type": "commentary",
      "text": "Traditionally “for the thanksgiving offering.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 100,
        "verse": 1
      },
      "verse_start": 1,
      "verse_end": 1
    },
    {
      "block_id": "jsb-ps-100-2",
      "type": "verse",
      "number": 2,
      "text": "worship the Lord in gladness; come into His presence with shouts of joy."
    },
    {
      "block_id": "jsb-ps-100-3",
      "type": "verse",
      "number": 3,
      "text": "Acknowledge that the Lord is God; He made us and we are His, His people, the flock He tends."
    },
    {
      "block_id": "jsb-ps-100-3-commentary-2",
      "type": "commentary",
      "text": "So qere; kethib and some ancient versions “not we ourselves.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 100,
        "verse": 3
      },
      "verse_start": 3,
      "verse_end": 3
    },
    {
      "block_id": "jsb-ps-100-4",
      "type": "verse",
      "number": 4,
      "text": "Enter His gates with praise, His courts with acclamation. Praise Him! Bless His name!"
    },
    {
      "block_id": "jsb-ps-100-5",
      "type": "verse",
      "number": 5,
      "text": "For the Lord is good; His steadfast love is eternal; His faithfulness is for all generations."
    }
  ]
}