{
  "document_id": "ps-4",
  "title": "Psalms 4",
  "type": "study-bible",
  "translation": "NJPS",
  "blocks": [
    {
      "block_id": "jsb-ps-4-1",
      "type": "verse",
      "number": 1,
      "text": "For the leader; with instrumental music. A psalm of David."
    },
    {
      "block_id": "jsb-ps-4-1-commentary-1",
      "type": "commentary",
      "text": "Meaning of Heb. uncertain.",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 4,
        "verse": 1
      },
      "verse_start": 1,
      "verse_end": 1
    },
    {
      "block_id": "jsb-ps-4-2",
      "type": "verse",
      "number": 2,
      "text": "Answer me when I call, O God, my vindicator! You freed me from distress; have mercy on me and hear my prayer."
    },
    {
      "block_id": "jsb-ps-4-3",
      "type": "verse",
      "number": 3,
      "text": "You men, how long will my glory be mocked, will you love illusions, have recourse to frauds?Selah."
    },
    {
      "block_id": "jsb-ps-4-4",
      "type": "verse",
      "number": 4,
      "text": "Know that the Lord singles out the faithful for Himself; the Lord hears when I call to Him."
    },
    {
      "block_id": "jsb-ps-4-5",
      "type": "verse",
      "number": 5,
      "text": "So tremble, and sin no more; ponder it on your bed, and sigh."
    },
    {
      "block_id": "jsb-ps-4-5-commentary-2",
      "type": "commentary",
      "text": "Others “be still.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 4,
        "verse": 5
      },
      "verse_start": 5,
      "verse_end": 5
    },
    {
      "block_id": "jsb-ps-4-6",
      "type": "verse",
      "number": 6,
      "text": "Offer sacrifices in righteousness and trust in the Lord."
    },
    {
      "block_id": "jsb-ps-4-7",
      "type": "verse",
      "number": 7,
      "text": "Many say, “O for good days!” Bestow Your favor on us, O Lord."
    },
    {
      "block_id": "jsb-ps-4-7-commentary-3",
      "type": "commentary",
      "text": "Lit. “Lift up the light of Your countenance upon us”; cf. Num. 6.25 f.",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 4,
        "verse": 7
      },
      "verse_start": 7,
      "verse_end": 7
    },
    {
      "block_id": "jsb-ps-4-8",
      "type": "verse",
      "number": 8,
      "text": "You put joy into my heart when their grain and wine show increase."
    },
    {
      "block_id": "jsb-ps-4-9",
      "type": "verse",
      "number": 9,
      "text": "Safe and sound, I lie down and sleep, for You alone, O Lord, keep me secure."
    },
    {
      "block_id": "jsb-ps-4-9-commentary-4",
      "type": "commentary",
      "text": "Or “for You, O Lord, keep me alone and secure.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 4,
        "verse": 9
      },
      "verse_start": 9,
      "verse_end": 9
    }
  ]
}