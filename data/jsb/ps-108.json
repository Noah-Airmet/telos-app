{
  "document_id": "ps-108",
  "title": "Psalms 108",
  "type": "study-bible",
  "translation": "NJPS",
  "blocks": [
    {
      "block_id": "jsb-ps-108-1",
      "type": "verse",
      "number": 1,
      "text": "A song. A psalm of David."
    },
    {
      "block_id": "jsb-ps-108-2",
      "type": "verse",
      "number": 2,
      "text": "My heart is firm, O God; I will sing and chant a hymn with all my soul."
    },
    {
      "block_id": "jsb-ps-108-2-commentary-1",
      "type": "commentary",
      "text": "With vv. 2–6, cf. Ps. 57.8–12.",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 108,
        "verse": 2
      },
      "verse_start": 2,
      "verse_end": 2
    },
    {
      "block_id": "jsb-ps-108-3",
      "type": "verse",
      "number": 3,
      "text": "Awake, O harp and lyre! I will wake the dawn."
    },
    {
      "block_id": "jsb-ps-108-4",
      "type": "verse",
      "number": 4,
      "text": "I will praise You among the peoples, O Lord, sing a hymn to You among the nations;"
    },
    {
      "block_id": "jsb-ps-108-5",
      "type": "verse",
      "number": 5,
      "text": "for Your faithfulness is higher than the heavens; Your steadfastness reaches to the sky."
    },
    {
      "block_id": "jsb-ps-108-6",
      "type": "verse",
      "number": 6,
      "text": "Exalt Yourself over the heavens, O God; let Your glory be over all the earth!"
    },
    {
      "block_id": "jsb-ps-108-7",
      "type": "verse",
      "number": 7,
      "text": "That those whom You love may be rescued, deliver with Your right hand and answer me."
    },
    {
      "block_id": "jsb-ps-108-7-commentary-2",
      "type": "commentary",
      "text": "With vv. 7–14, cf. Ps. 60.7–14.",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 108,
        "verse": 7
      },
      "verse_start": 7,
      "verse_end": 7
    },
    {
      "block_id": "jsb-ps-108-8",
      "type": "verse",
      "number": 8,
      "text": "God promised in His sanctuary that I would exultingly divide up Shechem, and measure the Valley of Sukkoth;"
    },
    {
      "block_id": "jsb-ps-108-8-commentary-3",
      "type": "commentary",
      "text": "Or “by His holiness.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 108,
        "verse": 8
      },
      "verse_start": 8,
      "verse_end": 8
    },
    {
      "block_id": "jsb-ps-108-9",
      "type": "verse",
      "number": 9,
      "text": "Gilead and Manasseh would be mine, Ephraim my chief stronghold, Judah my scepter;"
    },
    {
      "block_id": "jsb-ps-108-10",
      "type": "verse",
      "number": 10,
      "text": "Moab would be my washbasin; on Edom I would cast my shoe; I would raise a shout over Philistia."
    },
    {
      "block_id": "jsb-ps-108-11",
      "type": "verse",
      "number": 11,
      "text": "Would that I were brought to the bastion! Would that I were led to Edom!"
    },
    {
      "block_id": "jsb-ps-108-12",
      "type": "verse",
      "number": 12,
      "text": "But You have rejected us, O God; God, You do not march with our armies."
    },
    {
      "block_id": "jsb-ps-108-13",
      "type": "verse",
      "number": 13,
      "text": "Grant us Your aid against the foe, for the help of man is worthless."
    },
    {
      "block_id": "jsb-ps-108-14",
      "type": "verse",
      "number": 14,
      "text": "With God we shall triumph; He will trample our foes."
    }
  ]
}