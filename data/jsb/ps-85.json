{
  "document_id": "ps-85",
  "title": "Psalms 85",
  "type": "study-bible",
  "translation": "NJPS",
  "blocks": [
    {
      "block_id": "jsb-ps-85-1",
      "type": "verse",
      "number": 1,
      "text": "For the leader. Of the Korahites. A psalm."
    },
    {
      "block_id": "jsb-ps-85-2",
      "type": "verse",
      "number": 2,
      "text": "O Lord, You will favor Your land, restore Jacob’s fortune;"
    },
    {
      "block_id": "jsb-ps-85-2-commentary-1",
      "type": "commentary",
      "text": "Or “have favored.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 85,
        "verse": 2
      },
      "verse_start": 2,
      "verse_end": 2
    },
    {
      "block_id": "jsb-ps-85-2-commentary-2",
      "type": "commentary",
      "text": "Or “have restored.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 85,
        "verse": 2
      },
      "verse_start": 2,
      "verse_end": 2
    },
    {
      "block_id": "jsb-ps-85-3",
      "type": "verse",
      "number": 3,
      "text": "You will forgive Your people’s iniquity, pardon all their sins; selah"
    },
    {
      "block_id": "jsb-ps-85-3-commentary-3",
      "type": "commentary",
      "text": "Or “have forgiven.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 85,
        "verse": 3
      },
      "verse_start": 3,
      "verse_end": 3
    },
    {
      "block_id": "jsb-ps-85-3-commentary-4",
      "type": "commentary",
      "text": "Or “have pardoned.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 85,
        "verse": 3
      },
      "verse_start": 3,
      "verse_end": 3
    },
    {
      "block_id": "jsb-ps-85-4",
      "type": "verse",
      "number": 4,
      "text": "You will withdraw all Your anger, turn away from Your rage."
    },
    {
      "block_id": "jsb-ps-85-4-commentary-5",
      "type": "commentary",
      "text": "Or “have withdrawn.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 85,
        "verse": 4
      },
      "verse_start": 4,
      "verse_end": 4
    },
    {
      "block_id": "jsb-ps-85-4-commentary-6",
      "type": "commentary",
      "text": "Or “have turned.”",
      "canonical_ref": {
        "work": "bible",
        "book": "ps",
        "chapter": 85,
        "verse": 4
      },
      "verse_start": 4,
      "verse_end": 4
    },
    {
      "block_id": "jsb-ps-85-5",
      "type": "verse",
      "number": 5,
      "text": "Turn again, O God, our helper, revoke Your displeasure with us."
    },
    {
      "block_id": "jsb-ps-85-6",
      "type": "verse",
      "number": 6,
      "text": "Will You be angry with us forever, prolong Your wrath for all generations?"
    },
    {
      "block_id": "jsb-ps-85-7",
      "type": "verse",
      "number": 7,
      "text": "Surely You will revive us again, so that Your people may rejoice in You."
    },
    {
      "block_id": "jsb-ps-85-8",
      "type": "verse",
      "number": 8,
      "text": "Show us, O Lord, Your faithfulness; grant us Your deliverance."
    },
    {
      "block_id": "jsb-ps-85-9",
      "type": "verse",
      "number": 9,
      "text": "Let me hear what God, the Lord, will speak; He will promise well-being to His people, His faithful ones; may they not turn to folly."
    },
    {
      "block_id": "jsb-ps-85-10",
      "type": "verse",
      "number": 10,
      "text": "His help is very near those who fear Him, to make His glory dwell in our land."
    },
    {
      "block_id": "jsb-ps-85-11",
      "type": "verse",
      "number": 11,
      "text": "Faithfulness and truth meet; justice and well-being kiss."
    },
    {
      "block_id": "jsb-ps-85-12",
      "type": "verse",
      "number": 12,
      "text": "Truth springs up from the earth; justice looks down from heaven."
    },
    {
      "block_id": "jsb-ps-85-13",
      "type": "verse",
      "number": 13,
      "text": "The Lord also bestows His bounty; our land yields its produce."
    },
    {
      "block_id": "jsb-ps-85-14",
      "type": "verse",
      "number": 14,
      "text": "Justice goes before Him as He sets out on His way."
    }
  ]
}