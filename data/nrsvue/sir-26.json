{
  "document_id": "sir-26",
  "title": "Sirach 26",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-26-1",
      "type": "verse",
      "number": 1,
      "text": "Happy is the husband of a good wife;"
    },
    {
      "block_id": "sir-26-2",
      "type": "verse",
      "number": 2,
      "text": "A courageous wife brings joy to her husband,"
    },
    {
      "block_id": "sir-26-3",
      "type": "verse",
      "number": 3,
      "text": "A good wife is a good portion;"
    },
    {
      "block_id": "sir-26-4",
      "type": "verse",
      "number": 4,
      "text": "Whether rich or poor, his heart is content,"
    },
    {
      "block_id": "sir-26-5",
      "type": "verse",
      "number": 5,
      "text": "Of three things my heart is frightened,"
    },
    {
      "block_id": "sir-26-6",
      "type": "verse",
      "number": 6,
      "text": "But it is heartache and sorrow when a wife has a rival,"
    },
    {
      "block_id": "sir-26-7",
      "type": "verse",
      "number": 7,
      "text": "A bad wife is a chafing yoke;"
    },
    {
      "block_id": "sir-26-8",
      "type": "verse",
      "number": 8,
      "text": "A drunken wife arouses great anger;"
    },
    {
      "block_id": "sir-26-9",
      "type": "verse",
      "number": 9,
      "text": "The haughty stare betrays a sexually immoral wife;"
    },
    {
      "block_id": "sir-26-10",
      "type": "verse",
      "number": 10,
      "text": "Keep strict watch over a headstrong daughter,"
    },
    {
      "block_id": "sir-26-11",
      "type": "verse",
      "number": 11,
      "text": "Be on guard against her impudent eye,"
    },
    {
      "block_id": "sir-26-12",
      "type": "verse",
      "number": 12,
      "text": "As a thirsty traveler opens his mouth"
    },
    {
      "block_id": "sir-26-13",
      "type": "verse",
      "number": 13,
      "text": "A wife’s charm delights her husband,"
    },
    {
      "block_id": "sir-26-14",
      "type": "verse",
      "number": 14,
      "text": "A silent wife is a gift from the Lord,"
    },
    {
      "block_id": "sir-26-15",
      "type": "verse",
      "number": 15,
      "text": "A modest wife adds charm to charm,"
    },
    {
      "block_id": "sir-26-16",
      "type": "verse",
      "number": 16,
      "text": "Like the sun rising in the heights of the Lord,"
    },
    {
      "block_id": "sir-26-17",
      "type": "verse",
      "number": 17,
      "text": "Like the shining lamp on the holy lampstand,"
    },
    {
      "block_id": "sir-26-18",
      "type": "verse",
      "number": 18,
      "text": "Like golden pillars on silver bases,"
    },
    {
      "block_id": "sir-26-19",
      "type": "verse",
      "number": 19,
      "text": "My child, keep sound the bloom of your youth,"
    },
    {
      "block_id": "sir-26-20",
      "type": "verse",
      "number": 20,
      "text": "Seek a fertile field within the whole plain,"
    },
    {
      "block_id": "sir-26-21",
      "type": "verse",
      "number": 21,
      "text": "So your offspring will prosper,"
    },
    {
      "block_id": "sir-26-22",
      "type": "verse",
      "number": 22,
      "text": "A prostitute is regarded as spittle"
    },
    {
      "block_id": "sir-26-23",
      "type": "verse",
      "number": 23,
      "text": "A godless wife is given as a portion to a lawless man,"
    },
    {
      "block_id": "sir-26-24",
      "type": "verse",
      "number": 24,
      "text": "A shameless woman constantly acts disgracefully,"
    },
    {
      "block_id": "sir-26-25",
      "type": "verse",
      "number": 25,
      "text": "A headstrong wife is regarded as a dog,"
    },
    {
      "block_id": "sir-26-26",
      "type": "verse",
      "number": 26,
      "text": "A wife honoring her husband will seem wise to all,"
    },
    {
      "block_id": "sir-26-27",
      "type": "verse",
      "number": 27,
      "text": "A loud-voiced and garrulous wife is like a trumpet sounding the charge,"
    },
    {
      "block_id": "sir-26-28",
      "type": "verse",
      "number": 28,
      "text": "At two things my heart is grieved,"
    },
    {
      "block_id": "sir-26-29",
      "type": "verse",
      "number": 29,
      "text": "A merchant can hardly keep from wrongdoing,"
    }
  ]
}