{
  "document_id": "col-9",
  "title": "Colossians 9",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-9-1",
      "type": "verse",
      "number": 1,
      "text": "Do not be jealous of the wife whom you embrace,"
    },
    {
      "block_id": "col-9-2",
      "type": "verse",
      "number": 2,
      "text": "Do not give yourself to a woman"
    },
    {
      "block_id": "col-9-3",
      "type": "verse",
      "number": 3,
      "text": "Do not go near a loose woman,"
    },
    {
      "block_id": "col-9-4",
      "type": "verse",
      "number": 4,
      "text": "Do not dally with a female singer,"
    },
    {
      "block_id": "col-9-5",
      "type": "verse",
      "number": 5,
      "text": "Do not look intently at a virgin,"
    },
    {
      "block_id": "col-9-6",
      "type": "verse",
      "number": 6,
      "text": "Do not give yourself to prostitutes,"
    },
    {
      "block_id": "col-9-7",
      "type": "verse",
      "number": 7,
      "text": "Do not look around in the streets of a city"
    },
    {
      "block_id": "col-9-8",
      "type": "verse",
      "number": 8,
      "text": "Turn away your eyes from a shapely woman,"
    },
    {
      "block_id": "col-9-9",
      "type": "verse",
      "number": 9,
      "text": "Never dine with another man’s wife"
    },
    {
      "block_id": "col-9-10",
      "type": "verse",
      "number": 10,
      "text": "Do not abandon old friends,"
    },
    {
      "block_id": "col-9-11",
      "type": "verse",
      "number": 11,
      "text": "Do not envy the notoriety of sinners,"
    },
    {
      "block_id": "col-9-12",
      "type": "verse",
      "number": 12,
      "text": "Do not delight in what pleases the ungodly;"
    },
    {
      "block_id": "col-9-13",
      "type": "verse",
      "number": 13,
      "text": "Keep far from those who have power to kill,"
    },
    {
      "block_id": "col-9-14",
      "type": "verse",
      "number": 14,
      "text": "As much as you can, aim to know your neighbors,"
    },
    {
      "block_id": "col-9-15",
      "type": "verse",
      "number": 15,
      "text": "Let your conversation be with intelligent people,"
    },
    {
      "block_id": "col-9-16",
      "type": "verse",
      "number": 16,
      "text": "Let the righteous be your dinner companions,"
    },
    {
      "block_id": "col-9-17",
      "type": "verse",
      "number": 17,
      "text": "A work is praised for the skill of the artisan,"
    },
    {
      "block_id": "col-9-18",
      "type": "verse",
      "number": 18,
      "text": "The loud of mouth are feared in their city,"
    }
  ]
}