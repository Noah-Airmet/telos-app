{
  "document_id": "prov-9",
  "title": "Proverbs 9",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-9-1",
      "type": "verse",
      "number": 1,
      "text": "Wisdom has built her house;"
    },
    {
      "block_id": "prov-9-2",
      "type": "verse",
      "number": 2,
      "text": "She has slaughtered her animals; she has mixed her wine;"
    },
    {
      "block_id": "prov-9-3",
      "type": "verse",
      "number": 3,
      "text": "She has sent out her female servants; she calls"
    },
    {
      "block_id": "prov-9-4",
      "type": "verse",
      "number": 4,
      "text": "“You who are simple, turn in here!”"
    },
    {
      "block_id": "prov-9-5",
      "type": "verse",
      "number": 5,
      "text": "“Come, eat of my bread"
    },
    {
      "block_id": "prov-9-6",
      "type": "verse",
      "number": 6,
      "text": "Lay aside immaturity and live,"
    },
    {
      "block_id": "prov-9-7",
      "type": "verse",
      "number": 7,
      "text": "Whoever corrects a scoffer wins abuse;"
    },
    {
      "block_id": "prov-9-8",
      "type": "verse",
      "number": 8,
      "text": "Do not rebuke a scoffer, lest he hate you;"
    },
    {
      "block_id": "prov-9-9",
      "type": "verse",
      "number": 9,
      "text": "Give instruction to the wise, and they will become wiser still;"
    },
    {
      "block_id": "prov-9-10",
      "type": "verse",
      "number": 10,
      "text": "The fear of the Lord is the beginning of wisdom,"
    },
    {
      "block_id": "prov-9-11",
      "type": "verse",
      "number": 11,
      "text": "For by me your days will be multiplied,"
    },
    {
      "block_id": "prov-9-12",
      "type": "verse",
      "number": 12,
      "text": "If you are wise, you are wise for yourself;"
    },
    {
      "block_id": "prov-9-13",
      "type": "verse",
      "number": 13,
      "text": "The foolish woman is loud;"
    },
    {
      "block_id": "prov-9-14",
      "type": "verse",
      "number": 14,
      "text": "She sits at the door of her house,"
    },
    {
      "block_id": "prov-9-15",
      "type": "verse",
      "number": 15,
      "text": "calling to those who pass by,"
    },
    {
      "block_id": "prov-9-16",
      "type": "verse",
      "number": 16,
      "text": "“You who are simple, turn in here!”"
    },
    {
      "block_id": "prov-9-17",
      "type": "verse",
      "number": 17,
      "text": "“Stolen water is sweet,"
    },
    {
      "block_id": "prov-9-18",
      "type": "verse",
      "number": 18,
      "text": "But they do not know that the dead are there,"
    }
  ]
}