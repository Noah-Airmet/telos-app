{
  "document_id": "ps-112",
  "title": "Psalms 112",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-112-1",
      "type": "verse",
      "number": 1,
      "text": "Praise the Lord!"
    },
    {
      "block_id": "ps-112-2",
      "type": "verse",
      "number": 2,
      "text": "Their descendants will be mighty in the land;"
    },
    {
      "block_id": "ps-112-3",
      "type": "verse",
      "number": 3,
      "text": "Wealth and riches are in their houses,"
    },
    {
      "block_id": "ps-112-4",
      "type": "verse",
      "number": 4,
      "text": "They rise in the darkness as a light for the upright;"
    },
    {
      "block_id": "ps-112-5",
      "type": "verse",
      "number": 5,
      "text": "It is well with those who deal generously and lend,"
    },
    {
      "block_id": "ps-112-6",
      "type": "verse",
      "number": 6,
      "text": "For the righteous will never be moved;"
    },
    {
      "block_id": "ps-112-7",
      "type": "verse",
      "number": 7,
      "text": "They are not afraid of evil tidings;"
    },
    {
      "block_id": "ps-112-8",
      "type": "verse",
      "number": 8,
      "text": "Their hearts are steady; they will not be afraid;"
    },
    {
      "block_id": "ps-112-9",
      "type": "verse",
      "number": 9,
      "text": "They have distributed freely; they have given to the poor;"
    },
    {
      "block_id": "ps-112-10",
      "type": "verse",
      "number": 10,
      "text": "The wicked see it and are angry;"
    }
  ]
}