{
  "document_id": "mic-2",
  "title": "Micah 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "mic-2-1",
      "type": "verse",
      "number": 1,
      "text": "Woe to those who devise wickedness"
    },
    {
      "block_id": "mic-2-2",
      "type": "verse",
      "number": 2,
      "text": "They covet fields and seize them,"
    },
    {
      "block_id": "mic-2-3",
      "type": "verse",
      "number": 3,
      "text": "Therefore thus says the Lord:"
    },
    {
      "block_id": "mic-2-4",
      "type": "verse",
      "number": 4,
      "text": "On that day they shall take up a taunt song against you"
    },
    {
      "block_id": "mic-2-5",
      "type": "verse",
      "number": 5,
      "text": "Therefore you will have no one in the Lord’s assembly"
    },
    {
      "block_id": "mic-2-6",
      "type": "verse",
      "number": 6,
      "text": "“Do not preach”—thus they preach—"
    },
    {
      "block_id": "mic-2-7",
      "type": "verse",
      "number": 7,
      "text": "Should this be said, O house of Jacob?"
    },
    {
      "block_id": "mic-2-8",
      "type": "verse",
      "number": 8,
      "text": "But you rise up against my people as an enemy;"
    },
    {
      "block_id": "mic-2-9",
      "type": "verse",
      "number": 9,
      "text": "The women of my people you drive out"
    },
    {
      "block_id": "mic-2-10",
      "type": "verse",
      "number": 10,
      "text": "Arise and go,"
    },
    {
      "block_id": "mic-2-11",
      "type": "verse",
      "number": 11,
      "text": "If someone were to go about uttering empty falsehoods,"
    },
    {
      "block_id": "mic-2-12",
      "type": "verse",
      "number": 12,
      "text": "I will surely gather all of you, O Jacob;"
    },
    {
      "block_id": "mic-2-13",
      "type": "verse",
      "number": 13,
      "text": "The one who breaks out will go up before them;"
    }
  ]
}