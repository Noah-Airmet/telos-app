{
  "document_id": "hos-8",
  "title": "Hosea 8",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-8-1",
      "type": "verse",
      "number": 1,
      "text": "Set the trumpet to your lips!"
    },
    {
      "block_id": "hos-8-2",
      "type": "verse",
      "number": 2,
      "text": "They cry to me,"
    },
    {
      "block_id": "hos-8-3",
      "type": "verse",
      "number": 3,
      "text": "Israel has spurned the good;"
    },
    {
      "block_id": "hos-8-4",
      "type": "verse",
      "number": 4,
      "text": "They made kings but not through me;"
    },
    {
      "block_id": "hos-8-5",
      "type": "verse",
      "number": 5,
      "text": "Your calf is rejected, O Samaria."
    },
    {
      "block_id": "hos-8-6",
      "type": "verse",
      "number": 6,
      "text": "For it is from Israel,"
    },
    {
      "block_id": "hos-8-7",
      "type": "verse",
      "number": 7,
      "text": "For they sow the wind,"
    },
    {
      "block_id": "hos-8-8",
      "type": "verse",
      "number": 8,
      "text": "Israel is swallowed up;"
    },
    {
      "block_id": "hos-8-9",
      "type": "verse",
      "number": 9,
      "text": "For they have gone up to Assyria,"
    },
    {
      "block_id": "hos-8-10",
      "type": "verse",
      "number": 10,
      "text": "Though they bargain with the nations,"
    },
    {
      "block_id": "hos-8-11",
      "type": "verse",
      "number": 11,
      "text": "When Ephraim multiplied altars to expiate sin,"
    },
    {
      "block_id": "hos-8-12",
      "type": "verse",
      "number": 12,
      "text": "Though I write for him the multitude of my instructions,"
    },
    {
      "block_id": "hos-8-13",
      "type": "verse",
      "number": 13,
      "text": "Though they offer choice sacrifices,"
    },
    {
      "block_id": "hos-8-14",
      "type": "verse",
      "number": 14,
      "text": "Israel has forgotten his Maker"
    }
  ]
}