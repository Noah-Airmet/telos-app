{
  "document_id": "ps-53",
  "title": "Psalms 53",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-53-1",
      "type": "verse",
      "number": 1,
      "text": "Fools say in their hearts, “There is no God.”"
    },
    {
      "block_id": "ps-53-2",
      "type": "verse",
      "number": 2,
      "text": "God looks down from heaven on humankind"
    },
    {
      "block_id": "ps-53-3",
      "type": "verse",
      "number": 3,
      "text": "They have all fallen away; they are all alike perverse;"
    },
    {
      "block_id": "ps-53-4",
      "type": "verse",
      "number": 4,
      "text": "Have they no knowledge, those evildoers,"
    },
    {
      "block_id": "ps-53-5",
      "type": "verse",
      "number": 5,
      "text": "There they shall be in great terror,"
    },
    {
      "block_id": "ps-53-6",
      "type": "verse",
      "number": 6,
      "text": "O that deliverance for Israel would come from Zion!"
    }
  ]
}