{
  "document_id": "ps-98",
  "title": "Psalms 98",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-98-1",
      "type": "verse",
      "number": 1,
      "text": "O sing to the Lord a new song,"
    },
    {
      "block_id": "ps-98-2",
      "type": "verse",
      "number": 2,
      "text": "The Lord has made known his victory;"
    },
    {
      "block_id": "ps-98-3",
      "type": "verse",
      "number": 3,
      "text": "He has remembered his steadfast love and faithfulness"
    },
    {
      "block_id": "ps-98-4",
      "type": "verse",
      "number": 4,
      "text": "Make a joyful noise to the Lord, all the earth;"
    },
    {
      "block_id": "ps-98-5",
      "type": "verse",
      "number": 5,
      "text": "Sing praises to the Lord with the lyre,"
    },
    {
      "block_id": "ps-98-6",
      "type": "verse",
      "number": 6,
      "text": "With trumpets and the sound of the horn"
    },
    {
      "block_id": "ps-98-7",
      "type": "verse",
      "number": 7,
      "text": "Let the sea roar and all that fills it,"
    },
    {
      "block_id": "ps-98-8",
      "type": "verse",
      "number": 8,
      "text": "Let the floods clap their hands;"
    },
    {
      "block_id": "ps-98-9",
      "type": "verse",
      "number": 9,
      "text": "at the presence of the Lord, for he is coming"
    }
  ]
}