{
  "document_id": "ps-64",
  "title": "Psalms 64",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-64-1",
      "type": "verse",
      "number": 1,
      "text": "Hear my voice, O God, in my complaint;"
    },
    {
      "block_id": "ps-64-2",
      "type": "verse",
      "number": 2,
      "text": "Hide me from the secret plots of the wicked,"
    },
    {
      "block_id": "ps-64-3",
      "type": "verse",
      "number": 3,
      "text": "who whet their tongues like swords,"
    },
    {
      "block_id": "ps-64-4",
      "type": "verse",
      "number": 4,
      "text": "shooting from ambush at the blameless;"
    },
    {
      "block_id": "ps-64-5",
      "type": "verse",
      "number": 5,
      "text": "They hold fast to their evil purpose;"
    },
    {
      "block_id": "ps-64-6",
      "type": "verse",
      "number": 6,
      "text": "Who can search out our crimes?"
    },
    {
      "block_id": "ps-64-7",
      "type": "verse",
      "number": 7,
      "text": "But God will shoot his arrow at them;"
    },
    {
      "block_id": "ps-64-8",
      "type": "verse",
      "number": 8,
      "text": "Because of their tongue he will bring them to ruin;"
    },
    {
      "block_id": "ps-64-9",
      "type": "verse",
      "number": 9,
      "text": "Then everyone will fear;"
    },
    {
      "block_id": "ps-64-10",
      "type": "verse",
      "number": 10,
      "text": "Let the righteous rejoice in the Lord"
    }
  ]
}