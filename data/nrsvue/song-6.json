{
  "document_id": "song-6",
  "title": "Song of Songs 6",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "song-6-1",
      "type": "verse",
      "number": 1,
      "text": "Where has your beloved gone,"
    },
    {
      "block_id": "song-6-2",
      "type": "verse",
      "number": 2,
      "text": "My beloved has gone down to his garden,"
    },
    {
      "block_id": "song-6-3",
      "type": "verse",
      "number": 3,
      "text": "I am my beloved’s, and my beloved is mine;"
    },
    {
      "block_id": "song-6-4",
      "type": "verse",
      "number": 4,
      "text": "You are beautiful as Tirzah, my love,"
    },
    {
      "block_id": "song-6-5",
      "type": "verse",
      "number": 5,
      "text": "Turn away your eyes from me,"
    },
    {
      "block_id": "song-6-6",
      "type": "verse",
      "number": 6,
      "text": "Your teeth are like a flock of ewes"
    },
    {
      "block_id": "song-6-7",
      "type": "verse",
      "number": 7,
      "text": "Your cheeks are like halves of a pomegranate"
    },
    {
      "block_id": "song-6-8",
      "type": "verse",
      "number": 8,
      "text": "There are sixty queens and eighty concubines"
    },
    {
      "block_id": "song-6-9",
      "type": "verse",
      "number": 9,
      "text": "My dove, my perfect one, is the only one,"
    },
    {
      "block_id": "song-6-10",
      "type": "verse",
      "number": 10,
      "text": "“Who is this that looks forth like the dawn,"
    },
    {
      "block_id": "song-6-11",
      "type": "verse",
      "number": 11,
      "text": "I went down to the nut orchard"
    },
    {
      "block_id": "song-6-12",
      "type": "verse",
      "number": 12,
      "text": "Before I was aware, my desire set me"
    },
    {
      "block_id": "song-6-13",
      "type": "verse",
      "number": 13,
      "text": "Return, return, O Shulammite!"
    }
  ]
}