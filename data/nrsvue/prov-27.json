{
  "document_id": "prov-27",
  "title": "Proverbs 27",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-27-1",
      "type": "verse",
      "number": 1,
      "text": "Do not boast about tomorrow,"
    },
    {
      "block_id": "prov-27-2",
      "type": "verse",
      "number": 2,
      "text": "Let another praise you and not your own mouth,"
    },
    {
      "block_id": "prov-27-3",
      "type": "verse",
      "number": 3,
      "text": "A stone is heavy, and sand is weighty,"
    },
    {
      "block_id": "prov-27-4",
      "type": "verse",
      "number": 4,
      "text": "Wrath is cruel, anger is overwhelming,"
    },
    {
      "block_id": "prov-27-5",
      "type": "verse",
      "number": 5,
      "text": "Better is open rebuke"
    },
    {
      "block_id": "prov-27-6",
      "type": "verse",
      "number": 6,
      "text": "Well meant are the wounds a friend inflicts,"
    },
    {
      "block_id": "prov-27-7",
      "type": "verse",
      "number": 7,
      "text": "The sated appetite spurns honey,"
    },
    {
      "block_id": "prov-27-8",
      "type": "verse",
      "number": 8,
      "text": "Like a bird that strays from its nest"
    },
    {
      "block_id": "prov-27-9",
      "type": "verse",
      "number": 9,
      "text": "Perfume and incense make the heart glad,"
    },
    {
      "block_id": "prov-27-10",
      "type": "verse",
      "number": 10,
      "text": "Do not forsake your friend or the friend of your parent;"
    },
    {
      "block_id": "prov-27-11",
      "type": "verse",
      "number": 11,
      "text": "Be wise, my child, and make my heart glad,"
    },
    {
      "block_id": "prov-27-12",
      "type": "verse",
      "number": 12,
      "text": "The clever see danger and hide,"
    },
    {
      "block_id": "prov-27-13",
      "type": "verse",
      "number": 13,
      "text": "Take the garment of one who has given surety for a stranger;"
    },
    {
      "block_id": "prov-27-14",
      "type": "verse",
      "number": 14,
      "text": "Whoever blesses a neighbor with a loud voice,"
    },
    {
      "block_id": "prov-27-15",
      "type": "verse",
      "number": 15,
      "text": "A continual dripping on a rainy day"
    },
    {
      "block_id": "prov-27-16",
      "type": "verse",
      "number": 16,
      "text": "to restrain her is to restrain the wind"
    },
    {
      "block_id": "prov-27-17",
      "type": "verse",
      "number": 17,
      "text": "Iron sharpens iron,"
    },
    {
      "block_id": "prov-27-18",
      "type": "verse",
      "number": 18,
      "text": "Anyone who tends a fig tree will eat its fruit,"
    },
    {
      "block_id": "prov-27-19",
      "type": "verse",
      "number": 19,
      "text": "Just as water reflects the face,"
    },
    {
      "block_id": "prov-27-20",
      "type": "verse",
      "number": 20,
      "text": "Sheol and Abaddon are never satisfied,"
    },
    {
      "block_id": "prov-27-21",
      "type": "verse",
      "number": 21,
      "text": "The crucible is for silver, and the furnace is for gold,"
    },
    {
      "block_id": "prov-27-22",
      "type": "verse",
      "number": 22,
      "text": "Crush a fool in a mortar with a pestle"
    },
    {
      "block_id": "prov-27-23",
      "type": "verse",
      "number": 23,
      "text": "Know well the condition of your flocks,"
    },
    {
      "block_id": "prov-27-24",
      "type": "verse",
      "number": 24,
      "text": "for riches do not last forever,"
    },
    {
      "block_id": "prov-27-25",
      "type": "verse",
      "number": 25,
      "text": "When the grass is gone, and new growth appears,"
    },
    {
      "block_id": "prov-27-26",
      "type": "verse",
      "number": 26,
      "text": "the lambs will provide your clothing,"
    },
    {
      "block_id": "prov-27-27",
      "type": "verse",
      "number": 27,
      "text": "there will be enough goats’ milk for your food,"
    }
  ]
}