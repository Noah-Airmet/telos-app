{
  "document_id": "isa-53",
  "title": "Isaiah 53",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-53-1",
      "type": "verse",
      "number": 1,
      "text": "Who has believed what we have heard?"
    },
    {
      "block_id": "isa-53-2",
      "type": "verse",
      "number": 2,
      "text": "For he grew up before him like a young plant"
    },
    {
      "block_id": "isa-53-3",
      "type": "verse",
      "number": 3,
      "text": "He was despised and rejected by others;"
    },
    {
      "block_id": "isa-53-4",
      "type": "verse",
      "number": 4,
      "text": "Surely he has borne our infirmities"
    },
    {
      "block_id": "isa-53-5",
      "type": "verse",
      "number": 5,
      "text": "But he was wounded for our transgressions,"
    },
    {
      "block_id": "isa-53-6",
      "type": "verse",
      "number": 6,
      "text": "All we like sheep have gone astray;"
    },
    {
      "block_id": "isa-53-7",
      "type": "verse",
      "number": 7,
      "text": "He was oppressed, and he was afflicted,"
    },
    {
      "block_id": "isa-53-8",
      "type": "verse",
      "number": 8,
      "text": "By a perversion of justice he was taken away."
    },
    {
      "block_id": "isa-53-9",
      "type": "verse",
      "number": 9,
      "text": "They made his grave with the wicked"
    },
    {
      "block_id": "isa-53-10",
      "type": "verse",
      "number": 10,
      "text": "Yet it was the will of the Lord to crush him with affliction."
    },
    {
      "block_id": "isa-53-11",
      "type": "verse",
      "number": 11,
      "text": "Out of his anguish he shall see;"
    },
    {
      "block_id": "isa-53-12",
      "type": "verse",
      "number": 12,
      "text": "Therefore I will allot him a portion with the great,"
    }
  ]
}