{
  "document_id": "col-20",
  "title": "Colossians 20",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-20-1",
      "type": "verse",
      "number": 1,
      "text": "There is a rebuke that is untimely,"
    },
    {
      "block_id": "col-20-2",
      "type": "verse",
      "number": 2,
      "text": "How much better it is to rebuke than to fume!"
    },
    {
      "block_id": "col-20-3",
      "type": "verse",
      "number": 3,
      "text": "And the one who admits his fault will be kept from ridicule."
    },
    {
      "block_id": "col-20-4",
      "type": "verse",
      "number": 4,
      "text": "Like a eunuch lusting to violate a young woman"
    },
    {
      "block_id": "col-20-5",
      "type": "verse",
      "number": 5,
      "text": "Some people keep silent and are found to be wise,"
    },
    {
      "block_id": "col-20-6",
      "type": "verse",
      "number": 6,
      "text": "Some people keep silent because they have nothing to say,"
    },
    {
      "block_id": "col-20-7",
      "type": "verse",
      "number": 7,
      "text": "The wise remain silent until the right moment,"
    },
    {
      "block_id": "col-20-8",
      "type": "verse",
      "number": 8,
      "text": "Whoever talks too much is detested,"
    },
    {
      "block_id": "col-20-9",
      "type": "verse",
      "number": 9,
      "text": "There may be good fortune for a person in adversity,"
    },
    {
      "block_id": "col-20-10",
      "type": "verse",
      "number": 10,
      "text": "There is the gift that profits you nothing"
    },
    {
      "block_id": "col-20-11",
      "type": "verse",
      "number": 11,
      "text": "There are losses for the sake of glory,"
    },
    {
      "block_id": "col-20-12",
      "type": "verse",
      "number": 12,
      "text": "Some buy much for little"
    },
    {
      "block_id": "col-20-13",
      "type": "verse",
      "number": 13,
      "text": "The wise make themselves beloved by only few words,"
    },
    {
      "block_id": "col-20-14",
      "type": "verse",
      "number": 14,
      "text": "A fool’s gift will profit you nothing,"
    },
    {
      "block_id": "col-20-15",
      "type": "verse",
      "number": 15,
      "text": "He gives little and insults much;"
    },
    {
      "block_id": "col-20-16",
      "type": "verse",
      "number": 16,
      "text": "The fool says, “I have no friends,"
    },
    {
      "block_id": "col-20-17",
      "type": "verse",
      "number": 17,
      "text": "How many will ridicule him, and how often!"
    },
    {
      "block_id": "col-20-18",
      "type": "verse",
      "number": 18,
      "text": "A slip on the pavement is better than a slip of the tongue;"
    },
    {
      "block_id": "col-20-19",
      "type": "verse",
      "number": 19,
      "text": "A coarse person is like an inappropriate story,"
    },
    {
      "block_id": "col-20-20",
      "type": "verse",
      "number": 20,
      "text": "A proverb from a fool’s lips will be rejected,"
    },
    {
      "block_id": "col-20-21",
      "type": "verse",
      "number": 21,
      "text": "One may be prevented from sinning by poverty,"
    },
    {
      "block_id": "col-20-22",
      "type": "verse",
      "number": 22,
      "text": "One may lose his life through shame"
    },
    {
      "block_id": "col-20-23",
      "type": "verse",
      "number": 23,
      "text": "One may make promises to a friend out of shame"
    },
    {
      "block_id": "col-20-24",
      "type": "verse",
      "number": 24,
      "text": "A lie is an ugly blot on a person;"
    },
    {
      "block_id": "col-20-25",
      "type": "verse",
      "number": 25,
      "text": "A thief is preferable to a habitual liar,"
    },
    {
      "block_id": "col-20-26",
      "type": "verse",
      "number": 26,
      "text": "The character of liars leads to disgrace,"
    },
    {
      "block_id": "col-20-27",
      "type": "verse",
      "number": 27,
      "text": "Wise persons advance themselves by their words,"
    },
    {
      "block_id": "col-20-28",
      "type": "verse",
      "number": 28,
      "text": "Those who cultivate the soil heap up their harvest,"
    },
    {
      "block_id": "col-20-29",
      "type": "verse",
      "number": 29,
      "text": "Favors and gifts blind the eyes of the wise;"
    },
    {
      "block_id": "col-20-30",
      "type": "verse",
      "number": 30,
      "text": "Hidden wisdom and unseen treasure—"
    },
    {
      "block_id": "col-20-31",
      "type": "verse",
      "number": 31,
      "text": "Better are those who hide their folly"
    }
  ]
}