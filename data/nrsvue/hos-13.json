{
  "document_id": "hos-13",
  "title": "Hosea 13",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-13-1",
      "type": "verse",
      "number": 1,
      "text": "When Ephraim spoke, there was trembling;"
    },
    {
      "block_id": "hos-13-2",
      "type": "verse",
      "number": 2,
      "text": "And now they keep on sinning"
    },
    {
      "block_id": "hos-13-3",
      "type": "verse",
      "number": 3,
      "text": "Therefore they shall be like the morning mist"
    },
    {
      "block_id": "hos-13-4",
      "type": "verse",
      "number": 4,
      "text": "Yet I have been the Lord your God"
    },
    {
      "block_id": "hos-13-5",
      "type": "verse",
      "number": 5,
      "text": "It was I who fed you in the wilderness,"
    },
    {
      "block_id": "hos-13-6",
      "type": "verse",
      "number": 6,
      "text": "When I fed them, they were satisfied;"
    },
    {
      "block_id": "hos-13-7",
      "type": "verse",
      "number": 7,
      "text": "So I will become like a lion to them;"
    },
    {
      "block_id": "hos-13-8",
      "type": "verse",
      "number": 8,
      "text": "I will fall upon them like a bear robbed of her cubs"
    },
    {
      "block_id": "hos-13-9",
      "type": "verse",
      "number": 9,
      "text": "I will destroy you, O Israel;"
    },
    {
      "block_id": "hos-13-10",
      "type": "verse",
      "number": 10,
      "text": "Where now is your king, that he may save you?"
    },
    {
      "block_id": "hos-13-11",
      "type": "verse",
      "number": 11,
      "text": "I gave you a king in my anger,"
    },
    {
      "block_id": "hos-13-12",
      "type": "verse",
      "number": 12,
      "text": "Ephraim’s iniquity is bound up;"
    },
    {
      "block_id": "hos-13-13",
      "type": "verse",
      "number": 13,
      "text": "The pangs of childbirth come for him,"
    },
    {
      "block_id": "hos-13-14",
      "type": "verse",
      "number": 14,
      "text": "Shall I ransom them from the power of Sheol?"
    },
    {
      "block_id": "hos-13-15",
      "type": "verse",
      "number": 15,
      "text": "Although he may flourish among rushes,"
    },
    {
      "block_id": "hos-13-16",
      "type": "verse",
      "number": 16,
      "text": "Samaria shall bear her guilt"
    }
  ]
}