{
  "document_id": "isa-45",
  "title": "Isaiah 45",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-45-1",
      "type": "verse",
      "number": 1,
      "text": "Thus says the Lord to his anointed, to Cyrus,"
    },
    {
      "block_id": "isa-45-2",
      "type": "verse",
      "number": 2,
      "text": "I will go before you"
    },
    {
      "block_id": "isa-45-3",
      "type": "verse",
      "number": 3,
      "text": "I will give you the treasures of darkness"
    },
    {
      "block_id": "isa-45-4",
      "type": "verse",
      "number": 4,
      "text": "For the sake of my servant Jacob"
    },
    {
      "block_id": "isa-45-5",
      "type": "verse",
      "number": 5,
      "text": "I am the Lord, and there is no other;"
    },
    {
      "block_id": "isa-45-6",
      "type": "verse",
      "number": 6,
      "text": "so that they may know, from the rising of the sun"
    },
    {
      "block_id": "isa-45-7",
      "type": "verse",
      "number": 7,
      "text": "I form light and create darkness,"
    },
    {
      "block_id": "isa-45-8",
      "type": "verse",
      "number": 8,
      "text": "Shower, O heavens, from above,"
    },
    {
      "block_id": "isa-45-9",
      "type": "verse",
      "number": 9,
      "text": "Woe to those who strive with their Maker,"
    },
    {
      "block_id": "isa-45-10",
      "type": "verse",
      "number": 10,
      "text": "Woe to anyone who says to a father, “What are you fathering?”"
    },
    {
      "block_id": "isa-45-11",
      "type": "verse",
      "number": 11,
      "text": "Thus says the Lord,"
    },
    {
      "block_id": "isa-45-12",
      "type": "verse",
      "number": 12,
      "text": "I made the earth"
    },
    {
      "block_id": "isa-45-13",
      "type": "verse",
      "number": 13,
      "text": "I have aroused Cyrus in righteousness,"
    },
    {
      "block_id": "isa-45-14",
      "type": "verse",
      "number": 14,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "isa-45-15",
      "type": "verse",
      "number": 15,
      "text": "Truly, you are a God who hides himself,"
    },
    {
      "block_id": "isa-45-16",
      "type": "verse",
      "number": 16,
      "text": "All of them are put to shame and confounded;"
    },
    {
      "block_id": "isa-45-17",
      "type": "verse",
      "number": 17,
      "text": "But Israel is saved by the Lord"
    },
    {
      "block_id": "isa-45-18",
      "type": "verse",
      "number": 18,
      "text": "For thus says the Lord,"
    },
    {
      "block_id": "isa-45-19",
      "type": "verse",
      "number": 19,
      "text": "I did not speak in secret"
    },
    {
      "block_id": "isa-45-20",
      "type": "verse",
      "number": 20,
      "text": "Assemble yourselves and come together;"
    },
    {
      "block_id": "isa-45-21",
      "type": "verse",
      "number": 21,
      "text": "Declare and present your case;"
    },
    {
      "block_id": "isa-45-22",
      "type": "verse",
      "number": 22,
      "text": "Turn to me and be saved,"
    },
    {
      "block_id": "isa-45-23",
      "type": "verse",
      "number": 23,
      "text": "By myself I have sworn;"
    },
    {
      "block_id": "isa-45-24",
      "type": "verse",
      "number": 24,
      "text": "Only in the Lord, it shall be said of me,"
    },
    {
      "block_id": "isa-45-25",
      "type": "verse",
      "number": 25,
      "text": "In the Lord all the offspring of Israel"
    }
  ]
}