{
  "document_id": "wis-1",
  "title": "Wisdom of Solomon 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "wis-1-1",
      "type": "verse",
      "number": 1,
      "text": "Love righteousness, you rulers of the earth;"
    },
    {
      "block_id": "wis-1-2",
      "type": "verse",
      "number": 2,
      "text": "because he is found by those who do not put him to the test"
    },
    {
      "block_id": "wis-1-3",
      "type": "verse",
      "number": 3,
      "text": "For perverse thoughts separate people from God,"
    },
    {
      "block_id": "wis-1-4",
      "type": "verse",
      "number": 4,
      "text": "because wisdom will not enter a deceitful soul"
    },
    {
      "block_id": "wis-1-5",
      "type": "verse",
      "number": 5,
      "text": "For a holy and disciplined spirit will flee from deceit"
    },
    {
      "block_id": "wis-1-6",
      "type": "verse",
      "number": 6,
      "text": "For wisdom is a kindly spirit,"
    },
    {
      "block_id": "wis-1-7",
      "type": "verse",
      "number": 7,
      "text": "Because the spirit of the Lord has filled the world"
    },
    {
      "block_id": "wis-1-8",
      "type": "verse",
      "number": 8,
      "text": "therefore those who utter unrighteous things will not escape notice,"
    },
    {
      "block_id": "wis-1-9",
      "type": "verse",
      "number": 9,
      "text": "For inquiry will be made into the counsels of the ungodly,"
    },
    {
      "block_id": "wis-1-10",
      "type": "verse",
      "number": 10,
      "text": "because a jealous ear hears all things,"
    },
    {
      "block_id": "wis-1-11",
      "type": "verse",
      "number": 11,
      "text": "Beware, then, of useless grumbling,"
    },
    {
      "block_id": "wis-1-12",
      "type": "verse",
      "number": 12,
      "text": "Do not court death by the error of your life"
    },
    {
      "block_id": "wis-1-13",
      "type": "verse",
      "number": 13,
      "text": "because God did not make death,"
    },
    {
      "block_id": "wis-1-14",
      "type": "verse",
      "number": 14,
      "text": "For he created all things so that they might exist;"
    },
    {
      "block_id": "wis-1-15",
      "type": "verse",
      "number": 15,
      "text": "For righteousness is immortal."
    },
    {
      "block_id": "wis-1-16",
      "type": "verse",
      "number": 16,
      "text": "But the ungodly by their words and deeds summoned death;"
    }
  ]
}