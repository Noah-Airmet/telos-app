  "document_id": "ps-70",
  "title": "Psalms 70",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-70-1",
      "type": "verse",
      "number": 1,
      "text": "Be pleased, O God, to deliver me."
    },
    {
      "block_id": "ps-70-2",
      "type": "verse",
      "number": 2,
      "text": "Let those be put to shame and confusion"
    },
    {
      "block_id": "ps-70-3",
      "type": "verse",
      "number": 3,
      "text": "Let those who say, “Aha, Aha!”"
    },
    {
      "block_id": "ps-70-4",
      "type": "verse",
      "number": 4,
      "text": "Let all who seek you"
    },
    {
      "block_id": "ps-70-5",
      "type": "verse",
      "number": 5,
      "text": "But I am poor and needy;"
    }
  ]
}