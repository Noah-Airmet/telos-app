{
  "document_id": "ps-57",
  "title": "Psalms 57",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-57-1",
      "type": "verse",
      "number": 1,
      "text": "Be merciful to me, O God; be merciful to me,"
    },
    {
      "block_id": "ps-57-2",
      "type": "verse",
      "number": 2,
      "text": "I cry to God Most High,"
    },
    {
      "block_id": "ps-57-3",
      "type": "verse",
      "number": 3,
      "text": "He will send from heaven and save me;"
    },
    {
      "block_id": "ps-57-4",
      "type": "verse",
      "number": 4,
      "text": "I lie down among lions"
    },
    {
      "block_id": "ps-57-5",
      "type": "verse",
      "number": 5,
      "text": "Be exalted, O God, above the heavens."
    },
    {
      "block_id": "ps-57-6",
      "type": "verse",
      "number": 6,
      "text": "They set a net for my steps;"
    },
    {
      "block_id": "ps-57-7",
      "type": "verse",
      "number": 7,
      "text": "My heart is steadfast, O God;"
    },
    {
      "block_id": "ps-57-8",
      "type": "verse",
      "number": 8,
      "text": "Awake, my soul!"
    },
    {
      "block_id": "ps-57-9",
      "type": "verse",
      "number": 9,
      "text": "I will give thanks to you, O Lord, among the peoples;"
    },
    {
      "block_id": "ps-57-10",
      "type": "verse",
      "number": 10,
      "text": "For your steadfast love is as high as the heavens;"
    },
    {
      "block_id": "ps-57-11",
      "type": "verse",
      "number": 11,
      "text": "Be exalted, O God, above the heavens."
    }
  ]
}