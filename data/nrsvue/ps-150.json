{
  "document_id": "ps-150",
  "title": "Psalms 150",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-150-1",
      "type": "verse",
      "number": 1,
      "text": "Praise the Lord!"
    },
    {
      "block_id": "ps-150-2",
      "type": "verse",
      "number": 2,
      "text": "Praise him for his mighty deeds;"
    },
    {
      "block_id": "ps-150-3",
      "type": "verse",
      "number": 3,
      "text": "Praise him with trumpet sound;"
    },
    {
      "block_id": "ps-150-4",
      "type": "verse",
      "number": 4,
      "text": "Praise him with tambourine and dance;"
    },
    {
      "block_id": "ps-150-5",
      "type": "verse",
      "number": 5,
      "text": "Praise him with clanging cymbals;"
    },
    {
      "block_id": "ps-150-6",
      "type": "verse",
      "number": 6,
      "text": "Let everything that breathes praise the Lord!"
    }
  ]
}