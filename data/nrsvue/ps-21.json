{
  "document_id": "ps-21",
  "title": "Psalms 21",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-21-1",
      "type": "verse",
      "number": 1,
      "text": "In your strength the king rejoices, O Lord,"
    },
    {
      "block_id": "ps-21-2",
      "type": "verse",
      "number": 2,
      "text": "You have given him his heart’s desire"
    },
    {
      "block_id": "ps-21-3",
      "type": "verse",
      "number": 3,
      "text": "For you meet him with rich blessings;"
    },
    {
      "block_id": "ps-21-4",
      "type": "verse",
      "number": 4,
      "text": "He asked you for life; you gave it to him—"
    },
    {
      "block_id": "ps-21-5",
      "type": "verse",
      "number": 5,
      "text": "His glory is great through your help;"
    },
    {
      "block_id": "ps-21-6",
      "type": "verse",
      "number": 6,
      "text": "You bestow on him blessings forever;"
    },
    {
      "block_id": "ps-21-7",
      "type": "verse",
      "number": 7,
      "text": "For the king trusts in the Lord,"
    },
    {
      "block_id": "ps-21-8",
      "type": "verse",
      "number": 8,
      "text": "Your hand will find out all your enemies;"
    },
    {
      "block_id": "ps-21-9",
      "type": "verse",
      "number": 9,
      "text": "You will make them like a fiery furnace"
    },
    {
      "block_id": "ps-21-10",
      "type": "verse",
      "number": 10,
      "text": "You will destroy their offspring from the earth"
    },
    {
      "block_id": "ps-21-11",
      "type": "verse",
      "number": 11,
      "text": "If they plan evil against you,"
    },
    {
      "block_id": "ps-21-12",
      "type": "verse",
      "number": 12,
      "text": "For you will put them to flight;"
    },
    {
      "block_id": "ps-21-13",
      "type": "verse",
      "number": 13,
      "text": "Be exalted, O Lord, in your strength!"
    }
  ]
}