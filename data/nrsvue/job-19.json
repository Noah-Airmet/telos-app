{
  "document_id": "job-19",
  "title": "Job 19",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-19-heading-job-replies:-i-know-",
      "type": "heading",
      "text": "Job Replies: I Know That My Vindicator Lives"
    },
    {
      "block_id": "job-19-1",
      "type": "verse",
      "number": 1,
      "text": "Then Job answered:"
    },
    {
      "block_id": "job-19-2",
      "type": "verse",
      "number": 2,
      "text": "“How long will you torment me"
    },
    {
      "block_id": "job-19-3",
      "type": "verse",
      "number": 3,
      "text": "These ten times you have cast reproach upon me;"
    },
    {
      "block_id": "job-19-4",
      "type": "verse",
      "number": 4,
      "text": "And even if it is true that I have erred,"
    },
    {
      "block_id": "job-19-5",
      "type": "verse",
      "number": 5,
      "text": "If indeed you magnify yourselves against me"
    },
    {
      "block_id": "job-19-6",
      "type": "verse",
      "number": 6,
      "text": "know then that God has put me in the wrong"
    },
    {
      "block_id": "job-19-7",
      "type": "verse",
      "number": 7,
      "text": "Even when I cry out, ‘Violence!’ I am not answered;"
    },
    {
      "block_id": "job-19-8",
      "type": "verse",
      "number": 8,
      "text": "He has walled up my way so that I cannot pass,"
    },
    {
      "block_id": "job-19-9",
      "type": "verse",
      "number": 9,
      "text": "He has stripped my glory from me"
    },
    {
      "block_id": "job-19-10",
      "type": "verse",
      "number": 10,
      "text": "He breaks me down on every side, and I am gone;"
    },
    {
      "block_id": "job-19-11",
      "type": "verse",
      "number": 11,
      "text": "He has kindled his wrath against me"
    },
    {
      "block_id": "job-19-12",
      "type": "verse",
      "number": 12,
      "text": "His troops come on together;"
    },
    {
      "block_id": "job-19-13",
      "type": "verse",
      "number": 13,
      "text": "“He has put my family far from me,"
    },
    {
      "block_id": "job-19-14",
      "type": "verse",
      "number": 14,
      "text": "My relatives and my close friends have failed me;"
    },
    {
      "block_id": "job-19-15",
      "type": "verse",
      "number": 15,
      "text": "the guests in my house have forgotten me;"
    },
    {
      "block_id": "job-19-16",
      "type": "verse",
      "number": 16,
      "text": "I call to my servant, but he gives me no answer;"
    },
    {
      "block_id": "job-19-17",
      "type": "verse",
      "number": 17,
      "text": "My breath is repulsive to my wife;"
    },
    {
      "block_id": "job-19-18",
      "type": "verse",
      "number": 18,
      "text": "Even young children despise me;"
    },
    {
      "block_id": "job-19-19",
      "type": "verse",
      "number": 19,
      "text": "All my intimate friends abhor me,"
    },
    {
      "block_id": "job-19-20",
      "type": "verse",
      "number": 20,
      "text": "My bones cling to my skin and to my flesh,"
    },
    {
      "block_id": "job-19-21",
      "type": "verse",
      "number": 21,
      "text": "Have pity on me, have pity on me, O you my friends,"
    },
    {
      "block_id": "job-19-22",
      "type": "verse",
      "number": 22,
      "text": "Why do you, like God, pursue me,"
    },
    {
      "block_id": "job-19-23",
      "type": "verse",
      "number": 23,
      "text": "“O that my words were written down!"
    },
    {
      "block_id": "job-19-24",
      "type": "verse",
      "number": 24,
      "text": "O that with an iron pen and with lead"
    },
    {
      "block_id": "job-19-25",
      "type": "verse",
      "number": 25,
      "text": "For I know that my vindicator lives"
    },
    {
      "block_id": "job-19-26",
      "type": "verse",
      "number": 26,
      "text": "and after my skin has been destroyed,"
    },
    {
      "block_id": "job-19-27",
      "type": "verse",
      "number": 27,
      "text": "whom I shall see on my side,"
    },
    {
      "block_id": "job-19-28",
      "type": "verse",
      "number": 28,
      "text": "If you say, ‘How we will persecute him!’"
    },
    {
      "block_id": "job-19-29",
      "type": "verse",
      "number": 29,
      "text": "be afraid of the sword,"
    }
  ]
}