{
  "document_id": "prov-15",
  "title": "Proverbs 15",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-15-1",
      "type": "verse",
      "number": 1,
      "text": "A soft answer turns away wrath,"
    },
    {
      "block_id": "prov-15-2",
      "type": "verse",
      "number": 2,
      "text": "The tongue of the wise adorns knowledge,"
    },
    {
      "block_id": "prov-15-3",
      "type": "verse",
      "number": 3,
      "text": "The eyes of the Lord are in every place,"
    },
    {
      "block_id": "prov-15-4",
      "type": "verse",
      "number": 4,
      "text": "A gentle tongue is a tree of life,"
    },
    {
      "block_id": "prov-15-5",
      "type": "verse",
      "number": 5,
      "text": "A fool despises a parent’s instruction,"
    },
    {
      "block_id": "prov-15-6",
      "type": "verse",
      "number": 6,
      "text": "In the house of the righteous there is much treasure,"
    },
    {
      "block_id": "prov-15-7",
      "type": "verse",
      "number": 7,
      "text": "The lips of the wise spread knowledge;"
    },
    {
      "block_id": "prov-15-8",
      "type": "verse",
      "number": 8,
      "text": "The sacrifice of the wicked is an abomination to the Lord,"
    },
    {
      "block_id": "prov-15-9",
      "type": "verse",
      "number": 9,
      "text": "The way of the wicked is an abomination to the Lord,"
    },
    {
      "block_id": "prov-15-10",
      "type": "verse",
      "number": 10,
      "text": "There is severe discipline for one who forsakes the way;"
    },
    {
      "block_id": "prov-15-11",
      "type": "verse",
      "number": 11,
      "text": "Sheol and Abaddon lie open before the Lord;"
    },
    {
      "block_id": "prov-15-12",
      "type": "verse",
      "number": 12,
      "text": "Scoffers do not like to be rebuked;"
    },
    {
      "block_id": "prov-15-13",
      "type": "verse",
      "number": 13,
      "text": "A glad heart makes a cheerful countenance,"
    },
    {
      "block_id": "prov-15-14",
      "type": "verse",
      "number": 14,
      "text": "The mind of one who has understanding seeks knowledge,"
    },
    {
      "block_id": "prov-15-15",
      "type": "verse",
      "number": 15,
      "text": "All the days of the poor are hard,"
    },
    {
      "block_id": "prov-15-16",
      "type": "verse",
      "number": 16,
      "text": "Better is a little with the fear of the Lord"
    },
    {
      "block_id": "prov-15-17",
      "type": "verse",
      "number": 17,
      "text": "Better is a dinner of vegetables where love is"
    },
    {
      "block_id": "prov-15-18",
      "type": "verse",
      "number": 18,
      "text": "Those who are hot-tempered stir up strife,"
    },
    {
      "block_id": "prov-15-19",
      "type": "verse",
      "number": 19,
      "text": "The way of the lazy is overgrown with thorns,"
    },
    {
      "block_id": "prov-15-20",
      "type": "verse",
      "number": 20,
      "text": "A wise child makes a glad father,"
    },
    {
      "block_id": "prov-15-21",
      "type": "verse",
      "number": 21,
      "text": "Folly is a joy to one who has no sense,"
    },
    {
      "block_id": "prov-15-22",
      "type": "verse",
      "number": 22,
      "text": "Without counsel, plans go wrong,"
    },
    {
      "block_id": "prov-15-23",
      "type": "verse",
      "number": 23,
      "text": "To make an apt answer is a joy to anyone,"
    },
    {
      "block_id": "prov-15-24",
      "type": "verse",
      "number": 24,
      "text": "For the wise the path of life leads upward,"
    },
    {
      "block_id": "prov-15-25",
      "type": "verse",
      "number": 25,
      "text": "The Lord tears down the house of the proud"
    },
    {
      "block_id": "prov-15-26",
      "type": "verse",
      "number": 26,
      "text": "Evil plans are an abomination to the Lord,"
    },
    {
      "block_id": "prov-15-27",
      "type": "verse",
      "number": 27,
      "text": "Those greedy for unjust gain make trouble for their households,"
    },
    {
      "block_id": "prov-15-28",
      "type": "verse",
      "number": 28,
      "text": "The mind of the righteous ponders how to answer,"
    },
    {
      "block_id": "prov-15-29",
      "type": "verse",
      "number": 29,
      "text": "The Lord is far from the wicked,"
    },
    {
      "block_id": "prov-15-30",
      "type": "verse",
      "number": 30,
      "text": "The light of the eyes rejoices the heart,"
    },
    {
      "block_id": "prov-15-31",
      "type": "verse",
      "number": 31,
      "text": "The ear that heeds wholesome admonition"
    },
    {
      "block_id": "prov-15-32",
      "type": "verse",
      "number": 32,
      "text": "Those who ignore instruction despise themselves,"
    },
    {
      "block_id": "prov-15-33",
      "type": "verse",
      "number": 33,
      "text": "The fear of the Lord is instruction in wisdom,"
    }
  ]
}