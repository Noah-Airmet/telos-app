{
  "document_id": "isa-48",
  "title": "Isaiah 48",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-48-1",
      "type": "verse",
      "number": 1,
      "text": "Hear this, O house of Jacob,"
    },
    {
      "block_id": "isa-48-2",
      "type": "verse",
      "number": 2,
      "text": "For they call themselves after the holy city"
    },
    {
      "block_id": "isa-48-3",
      "type": "verse",
      "number": 3,
      "text": "The former things I declared long ago;"
    },
    {
      "block_id": "isa-48-4",
      "type": "verse",
      "number": 4,
      "text": "Because I know that you are obstinate,"
    },
    {
      "block_id": "isa-48-5",
      "type": "verse",
      "number": 5,
      "text": "I declared them to you from long ago,"
    },
    {
      "block_id": "isa-48-6",
      "type": "verse",
      "number": 6,
      "text": "You have heard; now see all this;"
    },
    {
      "block_id": "isa-48-7",
      "type": "verse",
      "number": 7,
      "text": "They are created now, not long ago;"
    },
    {
      "block_id": "isa-48-8",
      "type": "verse",
      "number": 8,
      "text": "You have never heard; you have never known;"
    },
    {
      "block_id": "isa-48-9",
      "type": "verse",
      "number": 9,
      "text": "For my name’s sake I defer my anger;"
    },
    {
      "block_id": "isa-48-10",
      "type": "verse",
      "number": 10,
      "text": "See, I have refined you but not like silver;"
    },
    {
      "block_id": "isa-48-11",
      "type": "verse",
      "number": 11,
      "text": "For my own sake, for my own sake, I do it,"
    },
    {
      "block_id": "isa-48-12",
      "type": "verse",
      "number": 12,
      "text": "Listen to me, O Jacob,"
    },
    {
      "block_id": "isa-48-13",
      "type": "verse",
      "number": 13,
      "text": "My hand laid the foundation of the earth,"
    },
    {
      "block_id": "isa-48-14",
      "type": "verse",
      "number": 14,
      "text": "Assemble, all of you, and hear!"
    },
    {
      "block_id": "isa-48-15",
      "type": "verse",
      "number": 15,
      "text": "I, even I, have spoken and called him;"
    },
    {
      "block_id": "isa-48-16",
      "type": "verse",
      "number": 16,
      "text": "Draw near to me; hear this!"
    },
    {
      "block_id": "isa-48-17",
      "type": "verse",
      "number": 17,
      "text": "Thus says the Lord,"
    },
    {
      "block_id": "isa-48-18",
      "type": "verse",
      "number": 18,
      "text": "O that you had paid attention to my commandments!"
    },
    {
      "block_id": "isa-48-19",
      "type": "verse",
      "number": 19,
      "text": "your offspring would have been like the sand"
    },
    {
      "block_id": "isa-48-20",
      "type": "verse",
      "number": 20,
      "text": "Go out from Babylon; flee from Chaldea;"
    },
    {
      "block_id": "isa-48-21",
      "type": "verse",
      "number": 21,
      "text": "They did not thirst when he led them through the deserts;"
    },
    {
      "block_id": "isa-48-22",
      "type": "verse",
      "number": 22,
      "text": "“There is no peace,” says the Lord, “for the wicked.”"
    }
  ]
}