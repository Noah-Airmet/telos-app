{
  "document_id": "ps-141",
  "title": "Psalms 141",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-141-1",
      "type": "verse",
      "number": 1,
      "text": "I call upon you, O Lord; come quickly to me;"
    },
    {
      "block_id": "ps-141-2",
      "type": "verse",
      "number": 2,
      "text": "Let my prayer be counted as incense before you"
    },
    {
      "block_id": "ps-141-3",
      "type": "verse",
      "number": 3,
      "text": "Set a guard over my mouth, O Lord;"
    },
    {
      "block_id": "ps-141-4",
      "type": "verse",
      "number": 4,
      "text": "Do not turn my heart to any evil,"
    },
    {
      "block_id": "ps-141-5",
      "type": "verse",
      "number": 5,
      "text": "Let the righteous strike me;"
    },
    {
      "block_id": "ps-141-6",
      "type": "verse",
      "number": 6,
      "text": "When they are given over to those who shall condemn them,"
    },
    {
      "block_id": "ps-141-7",
      "type": "verse",
      "number": 7,
      "text": "Like a rock that one breaks apart and shatters on the land,"
    },
    {
      "block_id": "ps-141-8",
      "type": "verse",
      "number": 8,
      "text": "But my eyes are turned toward you, O God, my Lord;"
    },
    {
      "block_id": "ps-141-9",
      "type": "verse",
      "number": 9,
      "text": "Keep me from the trap that they have laid for me"
    },
    {
      "block_id": "ps-141-10",
      "type": "verse",
      "number": 10,
      "text": "Let the wicked fall into their own nets,"
    }
  ]
}