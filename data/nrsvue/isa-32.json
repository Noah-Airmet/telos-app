{
  "document_id": "isa-32",
  "title": "Isaiah 32",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-32-1",
      "type": "verse",
      "number": 1,
      "text": "See, a king will reign in righteousness,"
    },
    {
      "block_id": "isa-32-2",
      "type": "verse",
      "number": 2,
      "text": "Each will be like a hiding place from the wind,"
    },
    {
      "block_id": "isa-32-3",
      "type": "verse",
      "number": 3,
      "text": "Then the eyes of those who have sight will not be closed,"
    },
    {
      "block_id": "isa-32-4",
      "type": "verse",
      "number": 4,
      "text": "The minds of the rash will have good judgment,"
    },
    {
      "block_id": "isa-32-5",
      "type": "verse",
      "number": 5,
      "text": "A fool will no longer be called noble"
    },
    {
      "block_id": "isa-32-6",
      "type": "verse",
      "number": 6,
      "text": "For fools speak folly,"
    },
    {
      "block_id": "isa-32-7",
      "type": "verse",
      "number": 7,
      "text": "The villainies of villains are evil;"
    },
    {
      "block_id": "isa-32-8",
      "type": "verse",
      "number": 8,
      "text": "But those who are noble plan noble things,"
    },
    {
      "block_id": "isa-32-9",
      "type": "verse",
      "number": 9,
      "text": "Rise up, you women who are at ease, hear my voice;"
    },
    {
      "block_id": "isa-32-10",
      "type": "verse",
      "number": 10,
      "text": "In little more than a year"
    },
    {
      "block_id": "isa-32-11",
      "type": "verse",
      "number": 11,
      "text": "Tremble, you women who are at ease;"
    },
    {
      "block_id": "isa-32-12",
      "type": "verse",
      "number": 12,
      "text": "Beat your breasts for the pleasant fields,"
    },
    {
      "block_id": "isa-32-13",
      "type": "verse",
      "number": 13,
      "text": "for the soil of my people"
    },
    {
      "block_id": "isa-32-14",
      "type": "verse",
      "number": 14,
      "text": "For the palace will be forsaken,"
    },
    {
      "block_id": "isa-32-15",
      "type": "verse",
      "number": 15,
      "text": "until a spirit from on high is poured out on us,"
    },
    {
      "block_id": "isa-32-16",
      "type": "verse",
      "number": 16,
      "text": "Then justice will dwell in the wilderness"
    },
    {
      "block_id": "isa-32-17",
      "type": "verse",
      "number": 17,
      "text": "The effect of righteousness will be peace,"
    },
    {
      "block_id": "isa-32-18",
      "type": "verse",
      "number": 18,
      "text": "My people will abide in a peaceful habitation,"
    },
    {
      "block_id": "isa-32-19",
      "type": "verse",
      "number": 19,
      "text": "The forest will disappear completely,"
    },
    {
      "block_id": "isa-32-20",
      "type": "verse",
      "number": 20,
      "text": "Happy will you be who sow beside every stream,"
    }
  ]
}