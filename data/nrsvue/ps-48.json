{
  "document_id": "ps-48",
  "title": "Psalms 48",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-48-1",
      "type": "verse",
      "number": 1,
      "text": "Great is the Lord and greatly to be praised"
    },
    {
      "block_id": "ps-48-2",
      "type": "verse",
      "number": 2,
      "text": "beautiful in elevation,"
    },
    {
      "block_id": "ps-48-3",
      "type": "verse",
      "number": 3,
      "text": "Within its citadels God"
    },
    {
      "block_id": "ps-48-4",
      "type": "verse",
      "number": 4,
      "text": "Then the kings assembled;"
    },
    {
      "block_id": "ps-48-5",
      "type": "verse",
      "number": 5,
      "text": "As soon as they saw it, they were astounded;"
    },
    {
      "block_id": "ps-48-6",
      "type": "verse",
      "number": 6,
      "text": "trembling took hold of them there,"
    },
    {
      "block_id": "ps-48-7",
      "type": "verse",
      "number": 7,
      "text": "as when an east wind shatters"
    },
    {
      "block_id": "ps-48-8",
      "type": "verse",
      "number": 8,
      "text": "As we have heard, so have we seen"
    },
    {
      "block_id": "ps-48-9",
      "type": "verse",
      "number": 9,
      "text": "We ponder your steadfast love, O God,"
    },
    {
      "block_id": "ps-48-10",
      "type": "verse",
      "number": 10,
      "text": "Your name, O God, like your praise,"
    },
    {
      "block_id": "ps-48-11",
      "type": "verse",
      "number": 11,
      "text": "Let Mount Zion be glad;"
    },
    {
      "block_id": "ps-48-12",
      "type": "verse",
      "number": 12,
      "text": "Walk about Zion; go all around it;"
    },
    {
      "block_id": "ps-48-13",
      "type": "verse",
      "number": 13,
      "text": "consider well its ramparts;"
    },
    {
      "block_id": "ps-48-14",
      "type": "verse",
      "number": 14,
      "text": "that this is God,"
    }
  ]
}