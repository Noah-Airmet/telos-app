{
  "document_id": "ps-37",
  "title": "Psalms 37",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-37-1",
      "type": "verse",
      "number": 1,
      "text": "Do not fret because of the wicked;"
    },
    {
      "block_id": "ps-37-2",
      "type": "verse",
      "number": 2,
      "text": "for they will soon fade like the grass"
    },
    {
      "block_id": "ps-37-3",
      "type": "verse",
      "number": 3,
      "text": "Trust in the Lord and do good;"
    },
    {
      "block_id": "ps-37-4",
      "type": "verse",
      "number": 4,
      "text": "Take delight in the Lord,"
    },
    {
      "block_id": "ps-37-5",
      "type": "verse",
      "number": 5,
      "text": "Commit your way to the Lord;"
    },
    {
      "block_id": "ps-37-6",
      "type": "verse",
      "number": 6,
      "text": "He will make your vindication shine like the light"
    },
    {
      "block_id": "ps-37-7",
      "type": "verse",
      "number": 7,
      "text": "Be still before the Lord, and wait patiently for him;"
    },
    {
      "block_id": "ps-37-8",
      "type": "verse",
      "number": 8,
      "text": "Refrain from anger and forsake wrath."
    },
    {
      "block_id": "ps-37-9",
      "type": "verse",
      "number": 9,
      "text": "For the wicked shall be cut off,"
    },
    {
      "block_id": "ps-37-10",
      "type": "verse",
      "number": 10,
      "text": "Yet a little while, and the wicked will be no more;"
    },
    {
      "block_id": "ps-37-11",
      "type": "verse",
      "number": 11,
      "text": "But the meek shall inherit the land"
    },
    {
      "block_id": "ps-37-12",
      "type": "verse",
      "number": 12,
      "text": "The wicked plot against the righteous"
    },
    {
      "block_id": "ps-37-13",
      "type": "verse",
      "number": 13,
      "text": "but the Lord laughs at the wicked,"
    },
    {
      "block_id": "ps-37-14",
      "type": "verse",
      "number": 14,
      "text": "The wicked draw the sword and bend their bows"
    },
    {
      "block_id": "ps-37-15",
      "type": "verse",
      "number": 15,
      "text": "their sword shall enter their own heart,"
    },
    {
      "block_id": "ps-37-16",
      "type": "verse",
      "number": 16,
      "text": "Better is a little that the righteous person has"
    },
    {
      "block_id": "ps-37-17",
      "type": "verse",
      "number": 17,
      "text": "For the arms of the wicked shall be broken,"
    },
    {
      "block_id": "ps-37-18",
      "type": "verse",
      "number": 18,
      "text": "The Lord knows the days of the blameless,"
    },
    {
      "block_id": "ps-37-19",
      "type": "verse",
      "number": 19,
      "text": "they are not put to shame in evil times;"
    },
    {
      "block_id": "ps-37-20",
      "type": "verse",
      "number": 20,
      "text": "But the wicked perish,"
    },
    {
      "block_id": "ps-37-21",
      "type": "verse",
      "number": 21,
      "text": "The wicked borrow and do not pay back,"
    },
    {
      "block_id": "ps-37-22",
      "type": "verse",
      "number": 22,
      "text": "surely those blessed by the Lord shall inherit the land,"
    },
    {
      "block_id": "ps-37-23",
      "type": "verse",
      "number": 23,
      "text": "Our steps are made firm by the Lord"
    },
    {
      "block_id": "ps-37-24",
      "type": "verse",
      "number": 24,
      "text": "though we stumble, we shall not fall headlong,"
    },
    {
      "block_id": "ps-37-25",
      "type": "verse",
      "number": 25,
      "text": "I have been young and now am old,"
    },
    {
      "block_id": "ps-37-26",
      "type": "verse",
      "number": 26,
      "text": "They are ever giving liberally and lending,"
    },
    {
      "block_id": "ps-37-27",
      "type": "verse",
      "number": 27,
      "text": "Depart from evil, and do good;"
    },
    {
      "block_id": "ps-37-28",
      "type": "verse",
      "number": 28,
      "text": "For the Lord loves justice;"
    },
    {
      "block_id": "ps-37-29",
      "type": "verse",
      "number": 29,
      "text": "The righteous shall inherit the land"
    },
    {
      "block_id": "ps-37-30",
      "type": "verse",
      "number": 30,
      "text": "The mouths of the righteous utter wisdom,"
    },
    {
      "block_id": "ps-37-31",
      "type": "verse",
      "number": 31,
      "text": "The law of their God is in their hearts;"
    },
    {
      "block_id": "ps-37-32",
      "type": "verse",
      "number": 32,
      "text": "The wicked watch for the righteous"
    },
    {
      "block_id": "ps-37-33",
      "type": "verse",
      "number": 33,
      "text": "The Lord will not abandon them to their power"
    },
    {
      "block_id": "ps-37-34",
      "type": "verse",
      "number": 34,
      "text": "Wait for the Lord and keep to his way,"
    },
    {
      "block_id": "ps-37-35",
      "type": "verse",
      "number": 35,
      "text": "I have seen the wicked oppressing"
    },
    {
      "block_id": "ps-37-36",
      "type": "verse",
      "number": 36,
      "text": "Again I passed by, and they were no more;"
    },
    {
      "block_id": "ps-37-37",
      "type": "verse",
      "number": 37,
      "text": "Mark the blameless and behold the upright,"
    },
    {
      "block_id": "ps-37-38",
      "type": "verse",
      "number": 38,
      "text": "But transgressors shall be altogether destroyed;"
    },
    {
      "block_id": "ps-37-39",
      "type": "verse",
      "number": 39,
      "text": "The salvation of the righteous is from the Lord;"
    },
    {
      "block_id": "ps-37-40",
      "type": "verse",
      "number": 40,
      "text": "The Lord helps them and rescues them;"
    }
  ]
}