{
  "document_id": "2-pet-151",
  "title": "2 Peter 151",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "2-pet-151-1",
      "type": "verse",
      "number": 1,
      "text": "I was small among my brothers"
    },
    {
      "block_id": "2-pet-151-2",
      "type": "verse",
      "number": 2,
      "text": "My hands made a harp;"
    },
    {
      "block_id": "2-pet-151-3",
      "type": "verse",
      "number": 3,
      "text": "And who will tell my Lord?"
    },
    {
      "block_id": "2-pet-151-4",
      "type": "verse",
      "number": 4,
      "text": "It was he who sent his messenger"
    },
    {
      "block_id": "2-pet-151-5",
      "type": "verse",
      "number": 5,
      "text": "My brothers were handsome and tall,"
    },
    {
      "block_id": "2-pet-151-6",
      "type": "verse",
      "number": 6,
      "text": "I went out to meet the foreigner,"
    },
    {
      "block_id": "2-pet-151-7",
      "type": "verse",
      "number": 7,
      "text": "But I drew his own sword;"
    }
  ]
}