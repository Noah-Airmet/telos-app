{
  "document_id": "ps-144",
  "title": "Psalms 144",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-144-1",
      "type": "verse",
      "number": 1,
      "text": "Blessed be the Lord, my rock,"
    },
    {
      "block_id": "ps-144-2",
      "type": "verse",
      "number": 2,
      "text": "my rock and my fortress,"
    },
    {
      "block_id": "ps-144-3",
      "type": "verse",
      "number": 3,
      "text": "O Lord, what are humans that you regard them,"
    },
    {
      "block_id": "ps-144-4",
      "type": "verse",
      "number": 4,
      "text": "They are like a breath;"
    },
    {
      "block_id": "ps-144-5",
      "type": "verse",
      "number": 5,
      "text": "Bow your heavens, O Lord, and come down;"
    },
    {
      "block_id": "ps-144-6",
      "type": "verse",
      "number": 6,
      "text": "Make the lightning flash and scatter them;"
    },
    {
      "block_id": "ps-144-7",
      "type": "verse",
      "number": 7,
      "text": "Stretch out your hand from on high;"
    },
    {
      "block_id": "ps-144-8",
      "type": "verse",
      "number": 8,
      "text": "whose mouths speak lies"
    },
    {
      "block_id": "ps-144-9",
      "type": "verse",
      "number": 9,
      "text": "I will sing a new song to you, O God;"
    },
    {
      "block_id": "ps-144-10",
      "type": "verse",
      "number": 10,
      "text": "the one who gives victory to kings,"
    },
    {
      "block_id": "ps-144-11",
      "type": "verse",
      "number": 11,
      "text": "Rescue me from the cruel sword,"
    },
    {
      "block_id": "ps-144-12",
      "type": "verse",
      "number": 12,
      "text": "May our sons in their youth"
    },
    {
      "block_id": "ps-144-13",
      "type": "verse",
      "number": 13,
      "text": "May our barns be filled"
    },
    {
      "block_id": "ps-144-14",
      "type": "verse",
      "number": 14,
      "text": "and may our cattle be heavy with young."
    },
    {
      "block_id": "ps-144-15",
      "type": "verse",
      "number": 15,
      "text": "Happy are the people to whom such blessings fall;"
    }
  ]
}