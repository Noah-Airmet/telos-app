{
  "document_id": "job-7",
  "title": "Job 7",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-7-1",
      "type": "verse",
      "number": 1,
      "text": "“Do not human beings have a hard service on earth,"
    },
    {
      "block_id": "job-7-2",
      "type": "verse",
      "number": 2,
      "text": "Like a slave who longs for the shadow,"
    },
    {
      "block_id": "job-7-3",
      "type": "verse",
      "number": 3,
      "text": "so I am allotted months of emptiness,"
    },
    {
      "block_id": "job-7-4",
      "type": "verse",
      "number": 4,
      "text": "When I lie down I say, ‘When shall I rise?’"
    },
    {
      "block_id": "job-7-5",
      "type": "verse",
      "number": 5,
      "text": "My flesh is clothed with worms and dirt;"
    },
    {
      "block_id": "job-7-6",
      "type": "verse",
      "number": 6,
      "text": "My days are swifter than a weaver’s shuttle"
    },
    {
      "block_id": "job-7-7",
      "type": "verse",
      "number": 7,
      "text": "“Remember that my life is a breath;"
    },
    {
      "block_id": "job-7-8",
      "type": "verse",
      "number": 8,
      "text": "The eye that beholds me will see me no more;"
    },
    {
      "block_id": "job-7-9",
      "type": "verse",
      "number": 9,
      "text": "As the cloud fades and vanishes,"
    },
    {
      "block_id": "job-7-10",
      "type": "verse",
      "number": 10,
      "text": "they return no more to their houses,"
    },
    {
      "block_id": "job-7-11",
      "type": "verse",
      "number": 11,
      "text": "“Therefore I will not restrain my mouth;"
    },
    {
      "block_id": "job-7-12",
      "type": "verse",
      "number": 12,
      "text": "Am I the Sea or the Dragon"
    },
    {
      "block_id": "job-7-13",
      "type": "verse",
      "number": 13,
      "text": "When I say, ‘My bed will comfort me,"
    },
    {
      "block_id": "job-7-14",
      "type": "verse",
      "number": 14,
      "text": "then you scare me with dreams"
    },
    {
      "block_id": "job-7-15",
      "type": "verse",
      "number": 15,
      "text": "so that I would choose strangling"
    },
    {
      "block_id": "job-7-16",
      "type": "verse",
      "number": 16,
      "text": "I loathe my life; I would not live forever."
    },
    {
      "block_id": "job-7-17",
      "type": "verse",
      "number": 17,
      "text": "What are humans, that you make so much of them,"
    },
    {
      "block_id": "job-7-18",
      "type": "verse",
      "number": 18,
      "text": "visit them every morning,"
    },
    {
      "block_id": "job-7-19",
      "type": "verse",
      "number": 19,
      "text": "Will you not look away from me for a while,"
    },
    {
      "block_id": "job-7-20",
      "type": "verse",
      "number": 20,
      "text": "If I sin, what do I do to you, you watcher of humanity?"
    },
    {
      "block_id": "job-7-21",
      "type": "verse",
      "number": 21,
      "text": "Why do you not pardon my transgression"
    }
  ]
}