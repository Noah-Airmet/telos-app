{
  "document_id": "amos-2",
  "title": "Amos 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "amos-2-1",
      "type": "verse",
      "number": 1,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "amos-2-2",
      "type": "verse",
      "number": 2,
      "text": "So I will send a fire on Moab,"
    },
    {
      "block_id": "amos-2-3",
      "type": "verse",
      "number": 3,
      "text": "I will cut off the ruler from its midst"
    },
    {
      "block_id": "amos-2-4",
      "type": "verse",
      "number": 4,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "amos-2-5",
      "type": "verse",
      "number": 5,
      "text": "So I will send a fire on Judah,"
    },
    {
      "block_id": "amos-2-6",
      "type": "verse",
      "number": 6,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "amos-2-7",
      "type": "verse",
      "number": 7,
      "text": "they who trample the head of the poor into the dust of the earth"
    },
    {
      "block_id": "amos-2-8",
      "type": "verse",
      "number": 8,
      "text": "they lay themselves down beside every altar"
    },
    {
      "block_id": "amos-2-9",
      "type": "verse",
      "number": 9,
      "text": "Yet I destroyed the Amorite before them,"
    },
    {
      "block_id": "amos-2-10",
      "type": "verse",
      "number": 10,
      "text": "Also I brought you up out of the land of Egypt"
    },
    {
      "block_id": "amos-2-11",
      "type": "verse",
      "number": 11,
      "text": "And I raised up some of your children to be prophets"
    },
    {
      "block_id": "amos-2-12",
      "type": "verse",
      "number": 12,
      "text": "But you made the nazirites drink wine"
    },
    {
      "block_id": "amos-2-13",
      "type": "verse",
      "number": 13,
      "text": "So, I will press you down in your place,"
    },
    {
      "block_id": "amos-2-14",
      "type": "verse",
      "number": 14,
      "text": "Flight shall perish from the swift,"
    },
    {
      "block_id": "amos-2-15",
      "type": "verse",
      "number": 15,
      "text": "those who handle the bow shall not stand,"
    },
    {
      "block_id": "amos-2-16",
      "type": "verse",
      "number": 16,
      "text": "and those who are stout of heart among the mighty"
    }
  ]
}