{
  "document_id": "ps-94",
  "title": "Psalms 94",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-94-1",
      "type": "verse",
      "number": 1,
      "text": "O Lord, you God of vengeance,"
    },
    {
      "block_id": "ps-94-2",
      "type": "verse",
      "number": 2,
      "text": "Rise up, O judge of the earth;"
    },
    {
      "block_id": "ps-94-3",
      "type": "verse",
      "number": 3,
      "text": "O Lord, how long shall the wicked,"
    },
    {
      "block_id": "ps-94-4",
      "type": "verse",
      "number": 4,
      "text": "They pour out their arrogant words;"
    },
    {
      "block_id": "ps-94-5",
      "type": "verse",
      "number": 5,
      "text": "They crush your people, O Lord,"
    },
    {
      "block_id": "ps-94-6",
      "type": "verse",
      "number": 6,
      "text": "They kill the widow and the stranger;"
    },
    {
      "block_id": "ps-94-7",
      "type": "verse",
      "number": 7,
      "text": "and they say, “The Lord does not see;"
    },
    {
      "block_id": "ps-94-8",
      "type": "verse",
      "number": 8,
      "text": "Understand, O dullest of the people;"
    },
    {
      "block_id": "ps-94-9",
      "type": "verse",
      "number": 9,
      "text": "He who planted the ear, does he not hear?"
    },
    {
      "block_id": "ps-94-10",
      "type": "verse",
      "number": 10,
      "text": "He who disciplines the nations,"
    },
    {
      "block_id": "ps-94-11",
      "type": "verse",
      "number": 11,
      "text": "The Lord knows our thoughts,"
    },
    {
      "block_id": "ps-94-12",
      "type": "verse",
      "number": 12,
      "text": "Happy are those whom you discipline, O Lord,"
    },
    {
      "block_id": "ps-94-13",
      "type": "verse",
      "number": 13,
      "text": "giving them respite from days of trouble,"
    },
    {
      "block_id": "ps-94-14",
      "type": "verse",
      "number": 14,
      "text": "For the Lord will not forsake his people;"
    },
    {
      "block_id": "ps-94-15",
      "type": "verse",
      "number": 15,
      "text": "for justice will return to the righteous,"
    },
    {
      "block_id": "ps-94-16",
      "type": "verse",
      "number": 16,
      "text": "Who rises up for me against the wicked?"
    },
    {
      "block_id": "ps-94-17",
      "type": "verse",
      "number": 17,
      "text": "If the Lord had not been my help,"
    },
    {
      "block_id": "ps-94-18",
      "type": "verse",
      "number": 18,
      "text": "When I thought, “My foot is slipping,”"
    },
    {
      "block_id": "ps-94-19",
      "type": "verse",
      "number": 19,
      "text": "When the cares of my heart are many,"
    },
    {
      "block_id": "ps-94-20",
      "type": "verse",
      "number": 20,
      "text": "Can wicked rulers be allied with you,"
    },
    {
      "block_id": "ps-94-21",
      "type": "verse",
      "number": 21,
      "text": "They band together against the life of the righteous"
    },
    {
      "block_id": "ps-94-22",
      "type": "verse",
      "number": 22,
      "text": "But the Lord has become my stronghold"
    },
    {
      "block_id": "ps-94-23",
      "type": "verse",
      "number": 23,
      "text": "He will repay them for their iniquity"
    }
  ]
}