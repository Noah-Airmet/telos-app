{
  "document_id": "ps-88",
  "title": "Psalms 88",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-88-1",
      "type": "verse",
      "number": 1,
      "text": "O Lord, God of my salvation,"
    },
    {
      "block_id": "ps-88-2",
      "type": "verse",
      "number": 2,
      "text": "let my prayer come before you;"
    },
    {
      "block_id": "ps-88-3",
      "type": "verse",
      "number": 3,
      "text": "For my soul is full of troubles,"
    },
    {
      "block_id": "ps-88-4",
      "type": "verse",
      "number": 4,
      "text": "I am counted among those who go down to the Pit;"
    },
    {
      "block_id": "ps-88-5",
      "type": "verse",
      "number": 5,
      "text": "like those forsaken among the dead,"
    },
    {
      "block_id": "ps-88-6",
      "type": "verse",
      "number": 6,
      "text": "You have put me in the depths of the Pit,"
    },
    {
      "block_id": "ps-88-7",
      "type": "verse",
      "number": 7,
      "text": "Your wrath lies heavy upon me,"
    },
    {
      "block_id": "ps-88-8",
      "type": "verse",
      "number": 8,
      "text": "You have caused my companions to shun me;"
    },
    {
      "block_id": "ps-88-9",
      "type": "verse",
      "number": 9,
      "text": "my eye grows dim through sorrow."
    },
    {
      "block_id": "ps-88-10",
      "type": "verse",
      "number": 10,
      "text": "Do you work wonders for the dead?"
    },
    {
      "block_id": "ps-88-11",
      "type": "verse",
      "number": 11,
      "text": "Is your steadfast love declared in the grave"
    },
    {
      "block_id": "ps-88-12",
      "type": "verse",
      "number": 12,
      "text": "Are your wonders known in the darkness"
    },
    {
      "block_id": "ps-88-13",
      "type": "verse",
      "number": 13,
      "text": "But I, O Lord, cry out to you;"
    },
    {
      "block_id": "ps-88-14",
      "type": "verse",
      "number": 14,
      "text": "O Lord, why do you cast me off?"
    },
    {
      "block_id": "ps-88-15",
      "type": "verse",
      "number": 15,
      "text": "Wretched and close to death from my youth up,"
    },
    {
      "block_id": "ps-88-16",
      "type": "verse",
      "number": 16,
      "text": "Your wrath has swept over me;"
    },
    {
      "block_id": "ps-88-17",
      "type": "verse",
      "number": 17,
      "text": "They surround me like a flood all day long;"
    },
    {
      "block_id": "ps-88-18",
      "type": "verse",
      "number": 18,
      "text": "You have caused friend and neighbor to shun me;"
    }
  ]
}