{
  "document_id": "mic-5",
  "title": "Micah 5",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "mic-5-1",
      "type": "verse",
      "number": 1,
      "text": "Now you are walled around with a wall;"
    },
    {
      "block_id": "mic-5-2",
      "type": "verse",
      "number": 2,
      "text": "But you, O Bethlehem of Ephrathah,"
    },
    {
      "block_id": "mic-5-3",
      "type": "verse",
      "number": 3,
      "text": "Therefore he shall give them up until the time"
    },
    {
      "block_id": "mic-5-4",
      "type": "verse",
      "number": 4,
      "text": "And he shall stand and feed his flock in the strength of the Lord,"
    },
    {
      "block_id": "mic-5-5",
      "type": "verse",
      "number": 5,
      "text": "and he shall be the one of peace."
    },
    {
      "block_id": "mic-5-6",
      "type": "verse",
      "number": 6,
      "text": "They shall rule the land of Assyria with the sword"
    },
    {
      "block_id": "mic-5-7",
      "type": "verse",
      "number": 7,
      "text": "Then the remnant of Jacob,"
    },
    {
      "block_id": "mic-5-8",
      "type": "verse",
      "number": 8,
      "text": "And among the nations the remnant of Jacob,"
    },
    {
      "block_id": "mic-5-9",
      "type": "verse",
      "number": 9,
      "text": "Your hand shall be lifted up over your adversaries,"
    },
    {
      "block_id": "mic-5-10",
      "type": "verse",
      "number": 10,
      "text": "On that day, says the Lord,"
    },
    {
      "block_id": "mic-5-11",
      "type": "verse",
      "number": 11,
      "text": "and I will cut off the cities of your land"
    },
    {
      "block_id": "mic-5-12",
      "type": "verse",
      "number": 12,
      "text": "and I will cut off sorceries from your hand,"
    },
    {
      "block_id": "mic-5-13",
      "type": "verse",
      "number": 13,
      "text": "and I will cut off your images"
    },
    {
      "block_id": "mic-5-14",
      "type": "verse",
      "number": 14,
      "text": "and I will uproot your sacred poles from among you"
    },
    {
      "block_id": "mic-5-15",
      "type": "verse",
      "number": 15,
      "text": "And in anger and wrath I will execute vengeance"
    }
  ]
}