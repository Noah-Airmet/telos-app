{
  "document_id": "isa-21",
  "title": "Isaiah 21",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-21-heading-oracles-concerning-b",
      "type": "heading",
      "text": "Oracles concerning Babylon, Edom, and Arabia"
    },
    {
      "block_id": "isa-21-1",
      "type": "verse",
      "number": 1,
      "text": "The oracle concerning the wilderness of the sea."
    },
    {
      "block_id": "isa-21-2",
      "type": "verse",
      "number": 2,
      "text": "A stern vision is told to me;"
    },
    {
      "block_id": "isa-21-3",
      "type": "verse",
      "number": 3,
      "text": "Therefore my loins are filled with anguish;"
    },
    {
      "block_id": "isa-21-4",
      "type": "verse",
      "number": 4,
      "text": "My mind reels; horror has appalled me;"
    },
    {
      "block_id": "isa-21-5",
      "type": "verse",
      "number": 5,
      "text": "They prepare the table;"
    },
    {
      "block_id": "isa-21-6",
      "type": "verse",
      "number": 6,
      "text": "For thus the Lord said to me:"
    },
    {
      "block_id": "isa-21-7",
      "type": "verse",
      "number": 7,
      "text": "When he sees riders, horsemen in pairs,"
    },
    {
      "block_id": "isa-21-8",
      "type": "verse",
      "number": 8,
      "text": "Then the watcher called out:"
    },
    {
      "block_id": "isa-21-9",
      "type": "verse",
      "number": 9,
      "text": "Look, there they come, riders,"
    },
    {
      "block_id": "isa-21-10",
      "type": "verse",
      "number": 10,
      "text": "O my threshed and winnowed one,"
    },
    {
      "block_id": "isa-21-11",
      "type": "verse",
      "number": 11,
      "text": "The oracle concerning Dumah."
    },
    {
      "block_id": "isa-21-12",
      "type": "verse",
      "number": 12,
      "text": "The sentinel says:"
    },
    {
      "block_id": "isa-21-13",
      "type": "verse",
      "number": 13,
      "text": "The oracle concerning the desert plain."
    },
    {
      "block_id": "isa-21-14",
      "type": "verse",
      "number": 14,
      "text": "Bring water to the thirsty,"
    },
    {
      "block_id": "isa-21-15",
      "type": "verse",
      "number": 15,
      "text": "For they have fled from the swords,"
    },
    {
      "block_id": "isa-21-16",
      "type": "verse",
      "number": 16,
      "text": "For thus the Lord said to me: “Within a year, according to the years of a hired worker, all the glory of Kedar will come to an end,"
    },
    {
      "block_id": "isa-21-17",
      "type": "verse",
      "number": 17,
      "text": "and the remaining bows of Kedar’s warriors will be few, for the Lord, the God of Israel, has spoken.”"
    }
  ]
}