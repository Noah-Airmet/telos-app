{
  "document_id": "sir-16",
  "title": "Sirach 16",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-16-1",
      "type": "verse",
      "number": 1,
      "text": "Do not desire a multitude of worthless children,"
    },
    {
      "block_id": "sir-16-2",
      "type": "verse",
      "number": 2,
      "text": "If they multiply, do not rejoice in them,"
    },
    {
      "block_id": "sir-16-3",
      "type": "verse",
      "number": 3,
      "text": "Do not trust in their survival"
    },
    {
      "block_id": "sir-16-4",
      "type": "verse",
      "number": 4,
      "text": "For through one intelligent person a city can be filled with people,"
    },
    {
      "block_id": "sir-16-5",
      "type": "verse",
      "number": 5,
      "text": "Many such things my eye has seen,"
    },
    {
      "block_id": "sir-16-6",
      "type": "verse",
      "number": 6,
      "text": "In an assembly of sinners a fire is kindled,"
    },
    {
      "block_id": "sir-16-7",
      "type": "verse",
      "number": 7,
      "text": "He did not forgive the ancient giants"
    },
    {
      "block_id": "sir-16-8",
      "type": "verse",
      "number": 8,
      "text": "He did not spare the neighbors of Lot,"
    },
    {
      "block_id": "sir-16-9",
      "type": "verse",
      "number": 9,
      "text": "He showed no pity on the doomed nation,"
    },
    {
      "block_id": "sir-16-10",
      "type": "verse",
      "number": 10,
      "text": "or on the six hundred thousand foot soldiers"
    },
    {
      "block_id": "sir-16-11",
      "type": "verse",
      "number": 11,
      "text": "Even if there were only one stiff-necked person,"
    },
    {
      "block_id": "sir-16-12",
      "type": "verse",
      "number": 12,
      "text": "Great as is his mercy, so also is his chastisement;"
    },
    {
      "block_id": "sir-16-13",
      "type": "verse",
      "number": 13,
      "text": "The sinner will not escape with plunder,"
    },
    {
      "block_id": "sir-16-14",
      "type": "verse",
      "number": 14,
      "text": "He makes room for every act of almsgiving;"
    },
    {
      "block_id": "sir-16-17",
      "type": "verse",
      "number": 17,
      "text": "Do not say, “I am hidden from the Lord,"
    },
    {
      "block_id": "sir-16-18",
      "type": "verse",
      "number": 18,
      "text": "Look, heaven and the highest heaven,"
    },
    {
      "block_id": "sir-16-19",
      "type": "verse",
      "number": 19,
      "text": "Together the mountains and the foundations of the earth"
    },
    {
      "block_id": "sir-16-20",
      "type": "verse",
      "number": 20,
      "text": "But no human mind can grasp this,"
    },
    {
      "block_id": "sir-16-21",
      "type": "verse",
      "number": 21,
      "text": "Like a tempest that no one can see,"
    },
    {
      "block_id": "sir-16-22",
      "type": "verse",
      "number": 22,
      "text": "Who is to announce his acts of justice?"
    },
    {
      "block_id": "sir-16-23",
      "type": "verse",
      "number": 23,
      "text": "Such are the thoughts of one devoid of understanding;"
    },
    {
      "block_id": "sir-16-24",
      "type": "verse",
      "number": 24,
      "text": "Listen to me, my child, and acquire knowledge,"
    },
    {
      "block_id": "sir-16-25",
      "type": "verse",
      "number": 25,
      "text": "I will impart discipline precisely"
    },
    {
      "block_id": "sir-16-26",
      "type": "verse",
      "number": 26,
      "text": "When the Lord created his works from the beginning"
    },
    {
      "block_id": "sir-16-27",
      "type": "verse",
      "number": 27,
      "text": "he arranged their works in an eternal order"
    },
    {
      "block_id": "sir-16-28",
      "type": "verse",
      "number": 28,
      "text": "They do not crowd one another,"
    },
    {
      "block_id": "sir-16-29",
      "type": "verse",
      "number": 29,
      "text": "Then the Lord looked upon the earth"
    },
    {
      "block_id": "sir-16-30",
      "type": "verse",
      "number": 30,
      "text": "With all kinds of living beings he covered its surface,"
    }
  ]
}