{
  "document_id": "job-41",
  "title": "Job 41",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-41-1",
      "type": "verse",
      "number": 1,
      "text": "“Can you draw out Leviathan with a fishhook"
    },
    {
      "block_id": "job-41-2",
      "type": "verse",
      "number": 2,
      "text": "Can you put a rope in its nose"
    },
    {
      "block_id": "job-41-3",
      "type": "verse",
      "number": 3,
      "text": "Will it make many supplications to you?"
    },
    {
      "block_id": "job-41-4",
      "type": "verse",
      "number": 4,
      "text": "Will it make a covenant with you"
    },
    {
      "block_id": "job-41-5",
      "type": "verse",
      "number": 5,
      "text": "Will you play with it as with a bird"
    },
    {
      "block_id": "job-41-6",
      "type": "verse",
      "number": 6,
      "text": "Will traders bargain over it?"
    },
    {
      "block_id": "job-41-7",
      "type": "verse",
      "number": 7,
      "text": "Can you fill its skin with harpoons"
    },
    {
      "block_id": "job-41-8",
      "type": "verse",
      "number": 8,
      "text": "Lay hands on it;"
    },
    {
      "block_id": "job-41-9",
      "type": "verse",
      "number": 9,
      "text": "Any hope of capturing it will be disappointed;"
    },
    {
      "block_id": "job-41-10",
      "type": "verse",
      "number": 10,
      "text": "No one is so fierce as to dare to stir it up."
    },
    {
      "block_id": "job-41-11",
      "type": "verse",
      "number": 11,
      "text": "Who can confront it and be safe?"
    },
    {
      "block_id": "job-41-12",
      "type": "verse",
      "number": 12,
      "text": "“I will not keep silent concerning its limbs"
    },
    {
      "block_id": "job-41-13",
      "type": "verse",
      "number": 13,
      "text": "Who can strip off its outer garment?"
    },
    {
      "block_id": "job-41-14",
      "type": "verse",
      "number": 14,
      "text": "Who can open the doors of its face?"
    },
    {
      "block_id": "job-41-15",
      "type": "verse",
      "number": 15,
      "text": "Its back is made of shields in rows,"
    },
    {
      "block_id": "job-41-16",
      "type": "verse",
      "number": 16,
      "text": "One is so near to another"
    },
    {
      "block_id": "job-41-17",
      "type": "verse",
      "number": 17,
      "text": "They are joined one to another;"
    },
    {
      "block_id": "job-41-18",
      "type": "verse",
      "number": 18,
      "text": "Its sneezes flash forth light,"
    },
    {
      "block_id": "job-41-19",
      "type": "verse",
      "number": 19,
      "text": "From its mouth go flaming torches;"
    },
    {
      "block_id": "job-41-20",
      "type": "verse",
      "number": 20,
      "text": "Out of its nostrils comes smoke,"
    },
    {
      "block_id": "job-41-21",
      "type": "verse",
      "number": 21,
      "text": "Its breath kindles coals,"
    },
    {
      "block_id": "job-41-22",
      "type": "verse",
      "number": 22,
      "text": "In its neck abides strength,"
    },
    {
      "block_id": "job-41-23",
      "type": "verse",
      "number": 23,
      "text": "The folds of its flesh cling together;"
    },
    {
      "block_id": "job-41-24",
      "type": "verse",
      "number": 24,
      "text": "Its heart is as hard as stone,"
    },
    {
      "block_id": "job-41-25",
      "type": "verse",
      "number": 25,
      "text": "When it raises itself up the gods are afraid;"
    },
    {
      "block_id": "job-41-26",
      "type": "verse",
      "number": 26,
      "text": "Though the sword reaches it, it does not avail,"
    },
    {
      "block_id": "job-41-27",
      "type": "verse",
      "number": 27,
      "text": "It counts iron as straw"
    },
    {
      "block_id": "job-41-28",
      "type": "verse",
      "number": 28,
      "text": "The arrow cannot make it flee;"
    },
    {
      "block_id": "job-41-29",
      "type": "verse",
      "number": 29,
      "text": "Clubs are counted as chaff;"
    },
    {
      "block_id": "job-41-30",
      "type": "verse",
      "number": 30,
      "text": "Its underparts are like sharp potsherds;"
    },
    {
      "block_id": "job-41-31",
      "type": "verse",
      "number": 31,
      "text": "It makes the deep boil like a pot;"
    },
    {
      "block_id": "job-41-32",
      "type": "verse",
      "number": 32,
      "text": "It leaves a shining wake behind it;"
    },
    {
      "block_id": "job-41-33",
      "type": "verse",
      "number": 33,
      "text": "On earth it has no equal,"
    },
    {
      "block_id": "job-41-34",
      "type": "verse",
      "number": 34,
      "text": "It surveys everything that is lofty;"
    }
  ]
}