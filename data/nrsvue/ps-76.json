{
  "document_id": "ps-76",
  "title": "Psalms 76",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-76-1",
      "type": "verse",
      "number": 1,
      "text": "In Judah God is known;"
    },
    {
      "block_id": "ps-76-2",
      "type": "verse",
      "number": 2,
      "text": "His abode has been established in Salem,"
    },
    {
      "block_id": "ps-76-3",
      "type": "verse",
      "number": 3,
      "text": "There he broke the flashing arrows,"
    },
    {
      "block_id": "ps-76-4",
      "type": "verse",
      "number": 4,
      "text": "Glorious are you, more majestic"
    },
    {
      "block_id": "ps-76-5",
      "type": "verse",
      "number": 5,
      "text": "The courageous were stripped of their spoil;"
    },
    {
      "block_id": "ps-76-6",
      "type": "verse",
      "number": 6,
      "text": "At your rebuke, O God of Jacob,"
    },
    {
      "block_id": "ps-76-7",
      "type": "verse",
      "number": 7,
      "text": "But you indeed are awesome!"
    },
    {
      "block_id": "ps-76-8",
      "type": "verse",
      "number": 8,
      "text": "From the heavens you uttered judgment;"
    },
    {
      "block_id": "ps-76-9",
      "type": "verse",
      "number": 9,
      "text": "when God rose up to establish judgment,"
    },
    {
      "block_id": "ps-76-10",
      "type": "verse",
      "number": 10,
      "text": "Human wrath serves only to praise you,"
    },
    {
      "block_id": "ps-76-11",
      "type": "verse",
      "number": 11,
      "text": "Make vows to the Lord your God and perform them;"
    },
    {
      "block_id": "ps-76-12",
      "type": "verse",
      "number": 12,
      "text": "who cuts off the spirit of princes,"
    }
  ]
}