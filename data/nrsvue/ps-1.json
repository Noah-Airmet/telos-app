{
  "document_id": "ps-1",
  "title": "Psalms 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-1-1",
      "type": "verse",
      "number": 1,
      "text": "Happy are those"
    },
    {
      "block_id": "ps-1-2",
      "type": "verse",
      "number": 2,
      "text": "but their delight is in the law of the Lord,"
    },
    {
      "block_id": "ps-1-3",
      "type": "verse",
      "number": 3,
      "text": "They are like trees"
    },
    {
      "block_id": "ps-1-4",
      "type": "verse",
      "number": 4,
      "text": "The wicked are not so"
    },
    {
      "block_id": "ps-1-5",
      "type": "verse",
      "number": 5,
      "text": "Therefore the wicked will not stand in the judgment"
    },
    {
      "block_id": "ps-1-6",
      "type": "verse",
      "number": 6,
      "text": "for the Lord watches over the way of the righteous,"
    }
  ]
}