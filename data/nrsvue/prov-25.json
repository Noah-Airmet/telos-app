{
  "document_id": "prov-25",
  "title": "Proverbs 25",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-25-heading-further-wise-sayings",
      "type": "heading",
      "text": "Further Wise Sayings of Solomon"
    },
    {
      "block_id": "prov-25-1",
      "type": "verse",
      "number": 1,
      "text": "These are other proverbs of Solomon that the officials of King Hezekiah of Judah copied."
    },
    {
      "block_id": "prov-25-2",
      "type": "verse",
      "number": 2,
      "text": "It is the glory of God to conceal things,"
    },
    {
      "block_id": "prov-25-3",
      "type": "verse",
      "number": 3,
      "text": "Like the heavens for height, like the earth for depth,"
    },
    {
      "block_id": "prov-25-4",
      "type": "verse",
      "number": 4,
      "text": "Take away the dross from the silver,"
    },
    {
      "block_id": "prov-25-5",
      "type": "verse",
      "number": 5,
      "text": "take away the wicked from the presence of the king,"
    },
    {
      "block_id": "prov-25-6",
      "type": "verse",
      "number": 6,
      "text": "Do not put yourself forward in the king’s presence"
    },
    {
      "block_id": "prov-25-7",
      "type": "verse",
      "number": 7,
      "text": "for it is better to be told, “Come up here,”"
    },
    {
      "block_id": "prov-25-8",
      "type": "verse",
      "number": 8,
      "text": "do not hastily bring into court,"
    },
    {
      "block_id": "prov-25-9",
      "type": "verse",
      "number": 9,
      "text": "Argue your case with your neighbor directly,"
    },
    {
      "block_id": "prov-25-10",
      "type": "verse",
      "number": 10,
      "text": "or else someone who hears you will bring shame upon you,"
    },
    {
      "block_id": "prov-25-11",
      "type": "verse",
      "number": 11,
      "text": "A word fitly spoken"
    },
    {
      "block_id": "prov-25-12",
      "type": "verse",
      "number": 12,
      "text": "Like a gold ring or an ornament of gold"
    },
    {
      "block_id": "prov-25-13",
      "type": "verse",
      "number": 13,
      "text": "Like the cold of snow in the time of harvest"
    },
    {
      "block_id": "prov-25-14",
      "type": "verse",
      "number": 14,
      "text": "Like clouds and wind without rain"
    },
    {
      "block_id": "prov-25-15",
      "type": "verse",
      "number": 15,
      "text": "With patience a ruler may be persuaded,"
    },
    {
      "block_id": "prov-25-16",
      "type": "verse",
      "number": 16,
      "text": "If you have found honey, eat only enough for you,"
    },
    {
      "block_id": "prov-25-17",
      "type": "verse",
      "number": 17,
      "text": "Let your foot be seldom in your neighbor’s house,"
    },
    {
      "block_id": "prov-25-18",
      "type": "verse",
      "number": 18,
      "text": "Like a war club, a sword, or a sharp arrow"
    },
    {
      "block_id": "prov-25-19",
      "type": "verse",
      "number": 19,
      "text": "Like a bad tooth or a lame foot"
    },
    {
      "block_id": "prov-25-20",
      "type": "verse",
      "number": 20,
      "text": "Like vinegar on a wound"
    },
    {
      "block_id": "prov-25-21",
      "type": "verse",
      "number": 21,
      "text": "If your enemies are hungry, give them bread to eat,"
    },
    {
      "block_id": "prov-25-22",
      "type": "verse",
      "number": 22,
      "text": "for you will heap coals of fire on their heads,"
    },
    {
      "block_id": "prov-25-23",
      "type": "verse",
      "number": 23,
      "text": "The north wind produces rain,"
    },
    {
      "block_id": "prov-25-24",
      "type": "verse",
      "number": 24,
      "text": "It is better to live in a corner of the housetop"
    },
    {
      "block_id": "prov-25-25",
      "type": "verse",
      "number": 25,
      "text": "Like cold water to a thirsty soul,"
    },
    {
      "block_id": "prov-25-26",
      "type": "verse",
      "number": 26,
      "text": "Like a muddied spring or a polluted fountain"
    },
    {
      "block_id": "prov-25-27",
      "type": "verse",
      "number": 27,
      "text": "It is not good to eat much honey"
    },
    {
      "block_id": "prov-25-28",
      "type": "verse",
      "number": 28,
      "text": "Like a city breached, without walls,"
    }
  ]
}