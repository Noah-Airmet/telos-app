{
  "document_id": "ps-50",
  "title": "Psalms 50",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-50-1",
      "type": "verse",
      "number": 1,
      "text": "The mighty one, God the Lord,"
    },
    {
      "block_id": "ps-50-2",
      "type": "verse",
      "number": 2,
      "text": "Out of Zion, the perfection of beauty,"
    },
    {
      "block_id": "ps-50-3",
      "type": "verse",
      "number": 3,
      "text": "Our God comes and does not keep silent;"
    },
    {
      "block_id": "ps-50-4",
      "type": "verse",
      "number": 4,
      "text": "He calls to the heavens above"
    },
    {
      "block_id": "ps-50-5",
      "type": "verse",
      "number": 5,
      "text": "“Gather to me my faithful ones,"
    },
    {
      "block_id": "ps-50-6",
      "type": "verse",
      "number": 6,
      "text": "The heavens declare his righteousness,"
    },
    {
      "block_id": "ps-50-7",
      "type": "verse",
      "number": 7,
      "text": "“Hear, O my people, and I will speak,"
    },
    {
      "block_id": "ps-50-8",
      "type": "verse",
      "number": 8,
      "text": "Not for your sacrifices do I rebuke you;"
    },
    {
      "block_id": "ps-50-9",
      "type": "verse",
      "number": 9,
      "text": "I will not accept a bull from your house"
    },
    {
      "block_id": "ps-50-10",
      "type": "verse",
      "number": 10,
      "text": "For every wild animal of the forest is mine,"
    },
    {
      "block_id": "ps-50-11",
      "type": "verse",
      "number": 11,
      "text": "I know all the birds of the air,"
    },
    {
      "block_id": "ps-50-12",
      "type": "verse",
      "number": 12,
      "text": "“If I were hungry, I would not tell you,"
    },
    {
      "block_id": "ps-50-13",
      "type": "verse",
      "number": 13,
      "text": "Do I eat the flesh of bulls"
    },
    {
      "block_id": "ps-50-14",
      "type": "verse",
      "number": 14,
      "text": "Offer to God a sacrifice of thanksgiving,"
    },
    {
      "block_id": "ps-50-15",
      "type": "verse",
      "number": 15,
      "text": "Call on me in the day of trouble;"
    },
    {
      "block_id": "ps-50-16",
      "type": "verse",
      "number": 16,
      "text": "But to the wicked God says,"
    },
    {
      "block_id": "ps-50-17",
      "type": "verse",
      "number": 17,
      "text": "For you hate discipline,"
    },
    {
      "block_id": "ps-50-18",
      "type": "verse",
      "number": 18,
      "text": "You make friends with a thief when you see one,"
    },
    {
      "block_id": "ps-50-19",
      "type": "verse",
      "number": 19,
      "text": "You give your mouth free rein for evil,"
    },
    {
      "block_id": "ps-50-20",
      "type": "verse",
      "number": 20,
      "text": "You sit and speak against your kin;"
    },
    {
      "block_id": "ps-50-21",
      "type": "verse",
      "number": 21,
      "text": "These things you have done, and I have been silent;"
    },
    {
      "block_id": "ps-50-22",
      "type": "verse",
      "number": 22,
      "text": "Mark this, then, you who forget God,"
    },
    {
      "block_id": "ps-50-23",
      "type": "verse",
      "number": 23,
      "text": "Those who bring thanksgiving as their sacrifice honor me;"
    }
  ]
}