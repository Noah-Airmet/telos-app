{
  "document_id": "isa-2",
  "title": "Isaiah 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-2-heading-the-future-house-of-",
      "type": "heading",
      "text": "The Future House of God"
    },
    {
      "block_id": "isa-2-1",
      "type": "verse",
      "number": 1,
      "text": "The word that Isaiah son of Amoz saw concerning Judah and Jerusalem."
    },
    {
      "block_id": "isa-2-2",
      "type": "verse",
      "number": 2,
      "text": "In days to come"
    },
    {
      "block_id": "isa-2-3",
      "type": "verse",
      "number": 3,
      "text": "Many peoples shall come and say,"
    },
    {
      "block_id": "isa-2-4",
      "type": "verse",
      "number": 4,
      "text": "He shall judge between the nations"
    },
    {
      "block_id": "isa-2-5",
      "type": "verse",
      "number": 5,
      "text": "O house of Jacob,"
    },
    {
      "block_id": "isa-2-6",
      "type": "verse",
      "number": 6,
      "text": "You have forsaken your people,"
    },
    {
      "block_id": "isa-2-7",
      "type": "verse",
      "number": 7,
      "text": "Their land is filled with silver and gold,"
    },
    {
      "block_id": "isa-2-8",
      "type": "verse",
      "number": 8,
      "text": "Their land is filled with idols;"
    },
    {
      "block_id": "isa-2-9",
      "type": "verse",
      "number": 9,
      "text": "And so people are humbled,"
    },
    {
      "block_id": "isa-2-10",
      "type": "verse",
      "number": 10,
      "text": "Enter into the rock,"
    },
    {
      "block_id": "isa-2-11",
      "type": "verse",
      "number": 11,
      "text": "The haughty eyes of people shall be brought low,"
    },
    {
      "block_id": "isa-2-12",
      "type": "verse",
      "number": 12,
      "text": "For the Lord of hosts has a day"
    },
    {
      "block_id": "isa-2-13",
      "type": "verse",
      "number": 13,
      "text": "against all the cedars of Lebanon,"
    },
    {
      "block_id": "isa-2-14",
      "type": "verse",
      "number": 14,
      "text": "against all the high mountains"
    },
    {
      "block_id": "isa-2-15",
      "type": "verse",
      "number": 15,
      "text": "against every high tower"
    },
    {
      "block_id": "isa-2-16",
      "type": "verse",
      "number": 16,
      "text": "against all the ships of Tarshish"
    },
    {
      "block_id": "isa-2-17",
      "type": "verse",
      "number": 17,
      "text": "The haughtiness of people shall be humbled,"
    },
    {
      "block_id": "isa-2-18",
      "type": "verse",
      "number": 18,
      "text": "The idols shall utterly pass away."
    },
    {
      "block_id": "isa-2-19",
      "type": "verse",
      "number": 19,
      "text": "Enter the caves of the rocks"
    },
    {
      "block_id": "isa-2-20",
      "type": "verse",
      "number": 20,
      "text": "On that day people will throw away"
    },
    {
      "block_id": "isa-2-21",
      "type": "verse",
      "number": 21,
      "text": "to enter the caverns of the rocks"
    },
    {
      "block_id": "isa-2-22",
      "type": "verse",
      "number": 22,
      "text": "[[Turn away from mortals,"
    }
  ]
}