{
  "document_id": "mic-4",
  "title": "Micah 4",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "mic-4-1",
      "type": "verse",
      "number": 1,
      "text": "In days to come"
    },
    {
      "block_id": "mic-4-2",
      "type": "verse",
      "number": 2,
      "text": "and many nations shall come and say:"
    },
    {
      "block_id": "mic-4-3",
      "type": "verse",
      "number": 3,
      "text": "He shall judge between many peoples"
    },
    {
      "block_id": "mic-4-4",
      "type": "verse",
      "number": 4,
      "text": "but they shall all sit under their own vines and under their own fig trees,"
    },
    {
      "block_id": "mic-4-5",
      "type": "verse",
      "number": 5,
      "text": "For all the peoples walk,"
    },
    {
      "block_id": "mic-4-6",
      "type": "verse",
      "number": 6,
      "text": "On that day, says the Lord,"
    },
    {
      "block_id": "mic-4-7",
      "type": "verse",
      "number": 7,
      "text": "The lame I will make the remnant,"
    },
    {
      "block_id": "mic-4-8",
      "type": "verse",
      "number": 8,
      "text": "And you, O tower of the flock,"
    },
    {
      "block_id": "mic-4-9",
      "type": "verse",
      "number": 9,
      "text": "Now why do you cry aloud?"
    },
    {
      "block_id": "mic-4-10",
      "type": "verse",
      "number": 10,
      "text": "Writhe and groan, O daughter Zion,"
    },
    {
      "block_id": "mic-4-11",
      "type": "verse",
      "number": 11,
      "text": "Now many nations"
    },
    {
      "block_id": "mic-4-12",
      "type": "verse",
      "number": 12,
      "text": "But they do not know"
    },
    {
      "block_id": "mic-4-13",
      "type": "verse",
      "number": 13,
      "text": "Arise and thresh,"
    }
  ]
}