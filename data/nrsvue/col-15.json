{
  "document_id": "col-15",
  "title": "Colossians 15",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-15-1",
      "type": "verse",
      "number": 1,
      "text": "Whoever fears the Lord will do this,"
    },
    {
      "block_id": "col-15-2",
      "type": "verse",
      "number": 2,
      "text": "She will come to meet him like a mother,"
    },
    {
      "block_id": "col-15-3",
      "type": "verse",
      "number": 3,
      "text": "She will feed him with the bread of understanding"
    },
    {
      "block_id": "col-15-4",
      "type": "verse",
      "number": 4,
      "text": "He will lean on her and not fall,"
    },
    {
      "block_id": "col-15-5",
      "type": "verse",
      "number": 5,
      "text": "She will exalt him above his neighbors"
    },
    {
      "block_id": "col-15-6",
      "type": "verse",
      "number": 6,
      "text": "Gladness and a crown of rejoicing"
    },
    {
      "block_id": "col-15-7",
      "type": "verse",
      "number": 7,
      "text": "The foolish will not obtain her,"
    },
    {
      "block_id": "col-15-8",
      "type": "verse",
      "number": 8,
      "text": "She is far from arrogance,"
    },
    {
      "block_id": "col-15-9",
      "type": "verse",
      "number": 9,
      "text": "Praise is unseemly on the lips of a sinner,"
    },
    {
      "block_id": "col-15-10",
      "type": "verse",
      "number": 10,
      "text": "For in wisdom must praise be uttered,"
    },
    {
      "block_id": "col-15-11",
      "type": "verse",
      "number": 11,
      "text": "Do not say, “It was the Lord’s doing that I fell away,”"
    },
    {
      "block_id": "col-15-12",
      "type": "verse",
      "number": 12,
      "text": "Do not say, “It was he who led me astray,”"
    },
    {
      "block_id": "col-15-13",
      "type": "verse",
      "number": 13,
      "text": "The Lord hates all abominations;"
    },
    {
      "block_id": "col-15-14",
      "type": "verse",
      "number": 14,
      "text": "It was he who created humans in the beginning,"
    },
    {
      "block_id": "col-15-15",
      "type": "verse",
      "number": 15,
      "text": "If you choose, you can keep the commandments,"
    },
    {
      "block_id": "col-15-16",
      "type": "verse",
      "number": 16,
      "text": "He has placed before you fire and water;"
    },
    {
      "block_id": "col-15-17",
      "type": "verse",
      "number": 17,
      "text": "Before each person are life and death,"
    },
    {
      "block_id": "col-15-18",
      "type": "verse",
      "number": 18,
      "text": "For great is the wisdom of the Lord;"
    },
    {
      "block_id": "col-15-19",
      "type": "verse",
      "number": 19,
      "text": "his eyes are on those who fear him,"
    },
    {
      "block_id": "col-15-20",
      "type": "verse",
      "number": 20,
      "text": "He has not commanded anyone to be ungodly,"
    }
  ]
}