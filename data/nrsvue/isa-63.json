{
  "document_id": "isa-63",
  "title": "Isaiah 63",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-63-1",
      "type": "verse",
      "number": 1,
      "text": "“Who is this coming from Edom,"
    },
    {
      "block_id": "isa-63-2",
      "type": "verse",
      "number": 2,
      "text": "“Why are your robes red"
    },
    {
      "block_id": "isa-63-3",
      "type": "verse",
      "number": 3,
      "text": "“I have trodden the winepress alone,"
    },
    {
      "block_id": "isa-63-4",
      "type": "verse",
      "number": 4,
      "text": "For the day of vengeance was in my mind,"
    },
    {
      "block_id": "isa-63-5",
      "type": "verse",
      "number": 5,
      "text": "I looked, but there was no helper;"
    },
    {
      "block_id": "isa-63-6",
      "type": "verse",
      "number": 6,
      "text": "I trampled down peoples in my anger;"
    },
    {
      "block_id": "isa-63-7",
      "type": "verse",
      "number": 7,
      "text": "I will recount the gracious deeds of the Lord,"
    },
    {
      "block_id": "isa-63-8",
      "type": "verse",
      "number": 8,
      "text": "For he said, “Surely they are my people,"
    },
    {
      "block_id": "isa-63-9",
      "type": "verse",
      "number": 9,
      "text": "in all their distress."
    },
    {
      "block_id": "isa-63-10",
      "type": "verse",
      "number": 10,
      "text": "But they rebelled"
    },
    {
      "block_id": "isa-63-11",
      "type": "verse",
      "number": 11,
      "text": "Then they remembered the days of old,"
    },
    {
      "block_id": "isa-63-12",
      "type": "verse",
      "number": 12,
      "text": "who caused his glorious arm"
    },
    {
      "block_id": "isa-63-13",
      "type": "verse",
      "number": 13,
      "text": "who led them through the depths?"
    },
    {
      "block_id": "isa-63-14",
      "type": "verse",
      "number": 14,
      "text": "Like cattle that go down into the valley,"
    },
    {
      "block_id": "isa-63-15",
      "type": "verse",
      "number": 15,
      "text": "Look down from heaven and see,"
    },
    {
      "block_id": "isa-63-16",
      "type": "verse",
      "number": 16,
      "text": "For you are our father,"
    },
    {
      "block_id": "isa-63-17",
      "type": "verse",
      "number": 17,
      "text": "Why, O Lord, do you let us stray from your ways"
    },
    {
      "block_id": "isa-63-18",
      "type": "verse",
      "number": 18,
      "text": "Your holy people took possession for a little while,"
    },
    {
      "block_id": "isa-63-19",
      "type": "verse",
      "number": 19,
      "text": "We have long been like those whom you do not rule,"
    }
  ]
}