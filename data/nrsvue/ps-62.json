{
  "document_id": "ps-62",
  "title": "Psalms 62",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-62-1",
      "type": "verse",
      "number": 1,
      "text": "For God alone my soul waits in silence;"
    },
    {
      "block_id": "ps-62-2",
      "type": "verse",
      "number": 2,
      "text": "He alone is my rock and my salvation,"
    },
    {
      "block_id": "ps-62-3",
      "type": "verse",
      "number": 3,
      "text": "How long will you assail a person,"
    },
    {
      "block_id": "ps-62-4",
      "type": "verse",
      "number": 4,
      "text": "Their only plan is to bring down a person of prominence."
    },
    {
      "block_id": "ps-62-5",
      "type": "verse",
      "number": 5,
      "text": "For God alone my soul waits in silence,"
    },
    {
      "block_id": "ps-62-6",
      "type": "verse",
      "number": 6,
      "text": "He alone is my rock and my salvation,"
    },
    {
      "block_id": "ps-62-7",
      "type": "verse",
      "number": 7,
      "text": "On God rests my deliverance and my honor;"
    },
    {
      "block_id": "ps-62-8",
      "type": "verse",
      "number": 8,
      "text": "Trust in him at all times, O people;"
    },
    {
      "block_id": "ps-62-9",
      "type": "verse",
      "number": 9,
      "text": "Those of low estate are but a breath;"
    },
    {
      "block_id": "ps-62-10",
      "type": "verse",
      "number": 10,
      "text": "Put no confidence in extortion,"
    },
    {
      "block_id": "ps-62-11",
      "type": "verse",
      "number": 11,
      "text": "Once God has spoken;"
    },
    {
      "block_id": "ps-62-12",
      "type": "verse",
      "number": 12,
      "text": "and steadfast love belongs to you, O Lord."
    }
  ]
}