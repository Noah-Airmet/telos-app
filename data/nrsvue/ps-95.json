{
  "document_id": "ps-95",
  "title": "Psalms 95",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-95-1",
      "type": "verse",
      "number": 1,
      "text": "O come, let us sing to the Lord;"
    },
    {
      "block_id": "ps-95-2",
      "type": "verse",
      "number": 2,
      "text": "Let us come into his presence with thanksgiving;"
    },
    {
      "block_id": "ps-95-3",
      "type": "verse",
      "number": 3,
      "text": "For the Lord is a great God"
    },
    {
      "block_id": "ps-95-4",
      "type": "verse",
      "number": 4,
      "text": "In his hand are the depths of the earth;"
    },
    {
      "block_id": "ps-95-5",
      "type": "verse",
      "number": 5,
      "text": "The sea is his, for he made it,"
    },
    {
      "block_id": "ps-95-6",
      "type": "verse",
      "number": 6,
      "text": "O come, let us worship and bow down;"
    },
    {
      "block_id": "ps-95-7",
      "type": "verse",
      "number": 7,
      "text": "For he is our God,"
    },
    {
      "block_id": "ps-95-8",
      "type": "verse",
      "number": 8,
      "text": "Do not harden your hearts, as at Meribah,"
    },
    {
      "block_id": "ps-95-9",
      "type": "verse",
      "number": 9,
      "text": "when your ancestors tested me"
    },
    {
      "block_id": "ps-95-10",
      "type": "verse",
      "number": 10,
      "text": "For forty years I loathed that generation"
    },
    {
      "block_id": "ps-95-11",
      "type": "verse",
      "number": 11,
      "text": "Therefore in my anger I swore,"
    }
  ]
}