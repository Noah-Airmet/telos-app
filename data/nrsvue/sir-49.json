{
  "document_id": "sir-49",
  "title": "Sirach 49",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-49-1",
      "type": "verse",
      "number": 1,
      "text": "The name of Josiah is like blended incense"
    },
    {
      "block_id": "sir-49-2",
      "type": "verse",
      "number": 2,
      "text": "He did what was right by reforming the people"
    },
    {
      "block_id": "sir-49-3",
      "type": "verse",
      "number": 3,
      "text": "He kept his heart fixed on the Lord;"
    },
    {
      "block_id": "sir-49-4",
      "type": "verse",
      "number": 4,
      "text": "Except for David and Hezekiah and Josiah,"
    },
    {
      "block_id": "sir-49-5",
      "type": "verse",
      "number": 5,
      "text": "They gave their power to others"
    },
    {
      "block_id": "sir-49-6",
      "type": "verse",
      "number": 6,
      "text": "who set fire to the chosen city of the sanctuary"
    },
    {
      "block_id": "sir-49-7",
      "type": "verse",
      "number": 7,
      "text": "For they had mistreated him,"
    },
    {
      "block_id": "sir-49-8",
      "type": "verse",
      "number": 8,
      "text": "It was Ezekiel who saw the vision of glory,"
    },
    {
      "block_id": "sir-49-9",
      "type": "verse",
      "number": 9,
      "text": "For he also mentioned Job,"
    },
    {
      "block_id": "sir-49-10",
      "type": "verse",
      "number": 10,
      "text": "May the bones of the Twelve Prophets"
    },
    {
      "block_id": "sir-49-11",
      "type": "verse",
      "number": 11,
      "text": "How shall we magnify Zerubbabel?"
    },
    {
      "block_id": "sir-49-12",
      "type": "verse",
      "number": 12,
      "text": "and so was Jeshua son of Jozadak;"
    },
    {
      "block_id": "sir-49-13",
      "type": "verse",
      "number": 13,
      "text": "The memory of Nehemiah also is lasting;"
    },
    {
      "block_id": "sir-49-14",
      "type": "verse",
      "number": 14,
      "text": "Few have ever been created on earth like Enoch,"
    },
    {
      "block_id": "sir-49-15",
      "type": "verse",
      "number": 15,
      "text": "Nor was anyone ever born like Joseph;"
    },
    {
      "block_id": "sir-49-16",
      "type": "verse",
      "number": 16,
      "text": "Shem and Seth and Enosh were honored,"
    }
  ]
}