{
  "document_id": "ps-124",
  "title": "Psalms 124",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-124-1",
      "type": "verse",
      "number": 1,
      "text": "If it had not been the Lord who was on our side"
    },
    {
      "block_id": "ps-124-2",
      "type": "verse",
      "number": 2,
      "text": "if it had not been the Lord who was on our side,"
    },
    {
      "block_id": "ps-124-3",
      "type": "verse",
      "number": 3,
      "text": "then they would have swallowed us up alive,"
    },
    {
      "block_id": "ps-124-4",
      "type": "verse",
      "number": 4,
      "text": "then the flood would have swept us away;"
    },
    {
      "block_id": "ps-124-5",
      "type": "verse",
      "number": 5,
      "text": "then over us would have gone"
    },
    {
      "block_id": "ps-124-6",
      "type": "verse",
      "number": 6,
      "text": "Blessed be the Lord,"
    },
    {
      "block_id": "ps-124-7",
      "type": "verse",
      "number": 7,
      "text": "We have escaped like a bird"
    },
    {
      "block_id": "ps-124-8",
      "type": "verse",
      "number": 8,
      "text": "Our help is in the name of the Lord,"
    }
  ]
}