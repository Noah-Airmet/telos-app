{
  "document_id": "hos-6",
  "title": "Hosea 6",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-6-1",
      "type": "verse",
      "number": 1,
      "text": "“Come, let us return to the Lord,"
    },
    {
      "block_id": "hos-6-2",
      "type": "verse",
      "number": 2,
      "text": "After two days he will revive us;"
    },
    {
      "block_id": "hos-6-3",
      "type": "verse",
      "number": 3,
      "text": "Let us know, let us press on to know the Lord;"
    },
    {
      "block_id": "hos-6-4",
      "type": "verse",
      "number": 4,
      "text": "What shall I do with you, O Ephraim?"
    },
    {
      "block_id": "hos-6-5",
      "type": "verse",
      "number": 5,
      "text": "Therefore I have hewn them by the prophets;"
    },
    {
      "block_id": "hos-6-6",
      "type": "verse",
      "number": 6,
      "text": "For I desire steadfast love and not sacrifice,"
    },
    {
      "block_id": "hos-6-7",
      "type": "verse",
      "number": 7,
      "text": "But at Adam they transgressed the covenant;"
    },
    {
      "block_id": "hos-6-8",
      "type": "verse",
      "number": 8,
      "text": "Gilead is a city of evildoers,"
    },
    {
      "block_id": "hos-6-9",
      "type": "verse",
      "number": 9,
      "text": "As robbers lie in wait for someone,"
    },
    {
      "block_id": "hos-6-10",
      "type": "verse",
      "number": 10,
      "text": "In the house of Israel I have seen a horrible thing;"
    },
    {
      "block_id": "hos-6-11",
      "type": "verse",
      "number": 11,
      "text": "For you also, O Judah, a harvest is appointed."
    }
  ]
}