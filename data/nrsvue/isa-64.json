{
  "document_id": "isa-64",
  "title": "Isaiah 64",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-64-1",
      "type": "verse",
      "number": 1,
      "text": "O that you would tear open the heavens and come down,"
    },
    {
      "block_id": "isa-64-2",
      "type": "verse",
      "number": 2,
      "text": "as when fire kindles brushwood"
    },
    {
      "block_id": "isa-64-3",
      "type": "verse",
      "number": 3,
      "text": "When you did awesome deeds that we did not expect,"
    },
    {
      "block_id": "isa-64-4",
      "type": "verse",
      "number": 4,
      "text": "From ages past no one has heard,"
    },
    {
      "block_id": "isa-64-5",
      "type": "verse",
      "number": 5,
      "text": "You meet those who gladly do right,"
    },
    {
      "block_id": "isa-64-6",
      "type": "verse",
      "number": 6,
      "text": "We have all become like one who is unclean,"
    },
    {
      "block_id": "isa-64-7",
      "type": "verse",
      "number": 7,
      "text": "There is no one who calls on your name"
    },
    {
      "block_id": "isa-64-8",
      "type": "verse",
      "number": 8,
      "text": "Yet, O Lord, you are our Father;"
    },
    {
      "block_id": "isa-64-9",
      "type": "verse",
      "number": 9,
      "text": "Do not be exceedingly angry, O Lord,"
    },
    {
      "block_id": "isa-64-10",
      "type": "verse",
      "number": 10,
      "text": "Your holy cities have become a wilderness;"
    },
    {
      "block_id": "isa-64-11",
      "type": "verse",
      "number": 11,
      "text": "Our holy and beautiful house,"
    },
    {
      "block_id": "isa-64-12",
      "type": "verse",
      "number": 12,
      "text": "After all this, will you restrain yourself, O Lord?"
    }
  ]
}