{
  "document_id": "ps-83",
  "title": "Psalms 83",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-83-1",
      "type": "verse",
      "number": 1,
      "text": "O God, do not keep silent;"
    },
    {
      "block_id": "ps-83-2",
      "type": "verse",
      "number": 2,
      "text": "Even now your enemies are in tumult;"
    },
    {
      "block_id": "ps-83-3",
      "type": "verse",
      "number": 3,
      "text": "They lay crafty plans against your people;"
    },
    {
      "block_id": "ps-83-4",
      "type": "verse",
      "number": 4,
      "text": "They say, “Come, let us wipe them out as a nation;"
    },
    {
      "block_id": "ps-83-5",
      "type": "verse",
      "number": 5,
      "text": "They conspire with one accord;"
    },
    {
      "block_id": "ps-83-6",
      "type": "verse",
      "number": 6,
      "text": "the tents of Edom and the Ishmaelites,"
    },
    {
      "block_id": "ps-83-7",
      "type": "verse",
      "number": 7,
      "text": "Gebal and Ammon and Amalek,"
    },
    {
      "block_id": "ps-83-8",
      "type": "verse",
      "number": 8,
      "text": "Assyria also has joined them;"
    },
    {
      "block_id": "ps-83-9",
      "type": "verse",
      "number": 9,
      "text": "Do to them as you did to Midian,"
    },
    {
      "block_id": "ps-83-10",
      "type": "verse",
      "number": 10,
      "text": "who were destroyed at En-dor,"
    },
    {
      "block_id": "ps-83-11",
      "type": "verse",
      "number": 11,
      "text": "Make their nobles like Oreb and Zeeb,"
    },
    {
      "block_id": "ps-83-12",
      "type": "verse",
      "number": 12,
      "text": "who said, “Let us take the pastures of God"
    },
    {
      "block_id": "ps-83-13",
      "type": "verse",
      "number": 13,
      "text": "O my God, make them like whirling dust,"
    },
    {
      "block_id": "ps-83-14",
      "type": "verse",
      "number": 14,
      "text": "As fire consumes the forest,"
    },
    {
      "block_id": "ps-83-15",
      "type": "verse",
      "number": 15,
      "text": "so pursue them with your tempest"
    },
    {
      "block_id": "ps-83-16",
      "type": "verse",
      "number": 16,
      "text": "Fill their faces with shame,"
    },
    {
      "block_id": "ps-83-17",
      "type": "verse",
      "number": 17,
      "text": "Let them be put to shame and dismayed forever;"
    },
    {
      "block_id": "ps-83-18",
      "type": "verse",
      "number": 18,
      "text": "Let them know that you alone,"
    }
  ]
}