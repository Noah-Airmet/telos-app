{
  "document_id": "zeph-3",
  "title": "Zephaniah 3",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "zeph-3-1",
      "type": "verse",
      "number": 1,
      "text": "Woe, soiled, defiled,"
    },
    {
      "block_id": "zeph-3-2",
      "type": "verse",
      "number": 2,
      "text": "It has listened to no voice;"
    },
    {
      "block_id": "zeph-3-3",
      "type": "verse",
      "number": 3,
      "text": "The officials within it"
    },
    {
      "block_id": "zeph-3-4",
      "type": "verse",
      "number": 4,
      "text": "Its prophets are reckless,"
    },
    {
      "block_id": "zeph-3-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord within it is righteous;"
    },
    {
      "block_id": "zeph-3-6",
      "type": "verse",
      "number": 6,
      "text": "I have cut off nations;"
    },
    {
      "block_id": "zeph-3-7",
      "type": "verse",
      "number": 7,
      "text": "I said, “Surely the city will fear me;"
    },
    {
      "block_id": "zeph-3-8",
      "type": "verse",
      "number": 8,
      "text": "Therefore wait for me, says the Lord,"
    },
    {
      "block_id": "zeph-3-9",
      "type": "verse",
      "number": 9,
      "text": "At that time I will change the speech of the peoples"
    },
    {
      "block_id": "zeph-3-10",
      "type": "verse",
      "number": 10,
      "text": "From beyond the rivers of Cush"
    },
    {
      "block_id": "zeph-3-11",
      "type": "verse",
      "number": 11,
      "text": "On that day you shall not be put to shame"
    },
    {
      "block_id": "zeph-3-12",
      "type": "verse",
      "number": 12,
      "text": "For I will leave in the midst of you"
    },
    {
      "block_id": "zeph-3-13",
      "type": "verse",
      "number": 13,
      "text": "the remnant of Israel;"
    },
    {
      "block_id": "zeph-3-14",
      "type": "verse",
      "number": 14,
      "text": "Sing aloud, O daughter Zion;"
    },
    {
      "block_id": "zeph-3-15",
      "type": "verse",
      "number": 15,
      "text": "The Lord has taken away the judgments against you;"
    },
    {
      "block_id": "zeph-3-16",
      "type": "verse",
      "number": 16,
      "text": "On that day it shall be said to Jerusalem:"
    },
    {
      "block_id": "zeph-3-17",
      "type": "verse",
      "number": 17,
      "text": "The Lord, your God, is in your midst,"
    },
    {
      "block_id": "zeph-3-18",
      "type": "verse",
      "number": 18,
      "text": "as on a day of festival.”"
    },
    {
      "block_id": "zeph-3-19",
      "type": "verse",
      "number": 19,
      "text": "I will deal with all your oppressors"
    },
    {
      "block_id": "zeph-3-20",
      "type": "verse",
      "number": 20,
      "text": "At that time I will bring you home,"
    }
  ]
}