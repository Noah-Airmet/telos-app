{
  "document_id": "song-2",
  "title": "Song of Songs 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "song-2-1",
      "type": "verse",
      "number": 1,
      "text": "I am a rose of Sharon,"
    },
    {
      "block_id": "song-2-2",
      "type": "verse",
      "number": 2,
      "text": "As a lily among brambles,"
    },
    {
      "block_id": "song-2-3",
      "type": "verse",
      "number": 3,
      "text": "As an apple tree among the trees of the wood,"
    },
    {
      "block_id": "song-2-4",
      "type": "verse",
      "number": 4,
      "text": "He brought me to the banqueting house,"
    },
    {
      "block_id": "song-2-5",
      "type": "verse",
      "number": 5,
      "text": "Sustain me with raisins,"
    },
    {
      "block_id": "song-2-6",
      "type": "verse",
      "number": 6,
      "text": "O that his left hand were under my head"
    },
    {
      "block_id": "song-2-7",
      "type": "verse",
      "number": 7,
      "text": "I charge you, O daughters of Jerusalem,"
    },
    {
      "block_id": "song-2-8",
      "type": "verse",
      "number": 8,
      "text": "The voice of my beloved!"
    },
    {
      "block_id": "song-2-9",
      "type": "verse",
      "number": 9,
      "text": "My beloved is like a gazelle"
    },
    {
      "block_id": "song-2-10",
      "type": "verse",
      "number": 10,
      "text": "My beloved speaks and says to me:"
    },
    {
      "block_id": "song-2-11",
      "type": "verse",
      "number": 11,
      "text": "for now the winter is past,"
    },
    {
      "block_id": "song-2-12",
      "type": "verse",
      "number": 12,
      "text": "The flowers appear on the earth;"
    },
    {
      "block_id": "song-2-13",
      "type": "verse",
      "number": 13,
      "text": "The fig tree puts forth its figs,"
    },
    {
      "block_id": "song-2-14",
      "type": "verse",
      "number": 14,
      "text": "O my dove, in the clefts of the rock,"
    },
    {
      "block_id": "song-2-15",
      "type": "verse",
      "number": 15,
      "text": "Catch us the foxes,"
    },
    {
      "block_id": "song-2-16",
      "type": "verse",
      "number": 16,
      "text": "My beloved is mine, and I am his;"
    },
    {
      "block_id": "song-2-17",
      "type": "verse",
      "number": 17,
      "text": "Until the day breathes"
    }
  ]
}