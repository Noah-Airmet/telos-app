{
  "document_id": "prov-19",
  "title": "Proverbs 19",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-19-1",
      "type": "verse",
      "number": 1,
      "text": "Better the poor walking in integrity"
    },
    {
      "block_id": "prov-19-2",
      "type": "verse",
      "number": 2,
      "text": "Desire without knowledge is not good,"
    },
    {
      "block_id": "prov-19-3",
      "type": "verse",
      "number": 3,
      "text": "One’s own folly leads to ruin,"
    },
    {
      "block_id": "prov-19-4",
      "type": "verse",
      "number": 4,
      "text": "Wealth brings many friends,"
    },
    {
      "block_id": "prov-19-5",
      "type": "verse",
      "number": 5,
      "text": "A false witness will not go unpunished,"
    },
    {
      "block_id": "prov-19-6",
      "type": "verse",
      "number": 6,
      "text": "Many seek the favor of the generous,"
    },
    {
      "block_id": "prov-19-7",
      "type": "verse",
      "number": 7,
      "text": "If the poor are hated even by their kin,"
    },
    {
      "block_id": "prov-19-8",
      "type": "verse",
      "number": 8,
      "text": "To get wisdom is to love oneself;"
    },
    {
      "block_id": "prov-19-9",
      "type": "verse",
      "number": 9,
      "text": "A false witness will not go unpunished,"
    },
    {
      "block_id": "prov-19-10",
      "type": "verse",
      "number": 10,
      "text": "It is not fitting for a fool to live in luxury,"
    },
    {
      "block_id": "prov-19-11",
      "type": "verse",
      "number": 11,
      "text": "Those with good sense are slow to anger,"
    },
    {
      "block_id": "prov-19-12",
      "type": "verse",
      "number": 12,
      "text": "A king’s anger is like the growling of a lion,"
    },
    {
      "block_id": "prov-19-13",
      "type": "verse",
      "number": 13,
      "text": "A stupid child is ruin to a father,"
    },
    {
      "block_id": "prov-19-14",
      "type": "verse",
      "number": 14,
      "text": "House and wealth are inherited from parents,"
    },
    {
      "block_id": "prov-19-15",
      "type": "verse",
      "number": 15,
      "text": "Laziness brings on deep sleep;"
    },
    {
      "block_id": "prov-19-16",
      "type": "verse",
      "number": 16,
      "text": "Those who keep the commandment will live;"
    },
    {
      "block_id": "prov-19-17",
      "type": "verse",
      "number": 17,
      "text": "Whoever is kind to the poor lends to the Lord"
    },
    {
      "block_id": "prov-19-18",
      "type": "verse",
      "number": 18,
      "text": "Discipline your children while there is hope;"
    },
    {
      "block_id": "prov-19-19",
      "type": "verse",
      "number": 19,
      "text": "A violent-tempered person will pay the penalty;"
    },
    {
      "block_id": "prov-19-20",
      "type": "verse",
      "number": 20,
      "text": "Listen to advice and accept instruction,"
    },
    {
      "block_id": "prov-19-21",
      "type": "verse",
      "number": 21,
      "text": "The human mind may devise many plans,"
    },
    {
      "block_id": "prov-19-22",
      "type": "verse",
      "number": 22,
      "text": "What is desirable in a person is loyalty,"
    },
    {
      "block_id": "prov-19-23",
      "type": "verse",
      "number": 23,
      "text": "The fear of the Lord is life indeed;"
    },
    {
      "block_id": "prov-19-24",
      "type": "verse",
      "number": 24,
      "text": "The lazy person buries a hand in the dish"
    },
    {
      "block_id": "prov-19-25",
      "type": "verse",
      "number": 25,
      "text": "Strike a scoffer, and the simple will learn prudence;"
    },
    {
      "block_id": "prov-19-26",
      "type": "verse",
      "number": 26,
      "text": "Those who do violence to their father and chase away their mother"
    },
    {
      "block_id": "prov-19-27",
      "type": "verse",
      "number": 27,
      "text": "My child, stop ignoring instruction,"
    },
    {
      "block_id": "prov-19-28",
      "type": "verse",
      "number": 28,
      "text": "A worthless witness mocks at justice,"
    },
    {
      "block_id": "prov-19-29",
      "type": "verse",
      "number": 29,
      "text": "Punishments are prepared for scoffers"
    }
  ]
}