{
  "document_id": "prov-5",
  "title": "Proverbs 5",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-5-1",
      "type": "verse",
      "number": 1,
      "text": "My child, be attentive to my wisdom;"
    },
    {
      "block_id": "prov-5-2",
      "type": "verse",
      "number": 2,
      "text": "so that you may hold on to prudence,"
    },
    {
      "block_id": "prov-5-3",
      "type": "verse",
      "number": 3,
      "text": "For the lips of a loose woman drip honey,"
    },
    {
      "block_id": "prov-5-4",
      "type": "verse",
      "number": 4,
      "text": "but in the end she is bitter as wormwood,"
    },
    {
      "block_id": "prov-5-5",
      "type": "verse",
      "number": 5,
      "text": "Her feet go down to death;"
    },
    {
      "block_id": "prov-5-6",
      "type": "verse",
      "number": 6,
      "text": "She does not keep straight to the path of life;"
    },
    {
      "block_id": "prov-5-7",
      "type": "verse",
      "number": 7,
      "text": "And now, my child, listen to me,"
    },
    {
      "block_id": "prov-5-8",
      "type": "verse",
      "number": 8,
      "text": "Keep your way far from her,"
    },
    {
      "block_id": "prov-5-9",
      "type": "verse",
      "number": 9,
      "text": "lest you give your honor to others"
    },
    {
      "block_id": "prov-5-10",
      "type": "verse",
      "number": 10,
      "text": "and strangers take their fill of your wealth,"
    },
    {
      "block_id": "prov-5-11",
      "type": "verse",
      "number": 11,
      "text": "and at the end of your life you groan,"
    },
    {
      "block_id": "prov-5-12",
      "type": "verse",
      "number": 12,
      "text": "and you say, “Oh, how I hated discipline,"
    },
    {
      "block_id": "prov-5-13",
      "type": "verse",
      "number": 13,
      "text": "I did not listen to the voice of my teachers"
    },
    {
      "block_id": "prov-5-14",
      "type": "verse",
      "number": 14,
      "text": "Now I am at the point of utter ruin"
    },
    {
      "block_id": "prov-5-15",
      "type": "verse",
      "number": 15,
      "text": "Drink water from your own cistern,"
    },
    {
      "block_id": "prov-5-16",
      "type": "verse",
      "number": 16,
      "text": "Should your springs be scattered abroad,"
    },
    {
      "block_id": "prov-5-17",
      "type": "verse",
      "number": 17,
      "text": "Let them be for yourself alone"
    },
    {
      "block_id": "prov-5-18",
      "type": "verse",
      "number": 18,
      "text": "Let your fountain be blessed,"
    },
    {
      "block_id": "prov-5-19",
      "type": "verse",
      "number": 19,
      "text": "a lovely deer, a graceful doe."
    },
    {
      "block_id": "prov-5-20",
      "type": "verse",
      "number": 20,
      "text": "Why should you be intoxicated, my son, by another woman"
    },
    {
      "block_id": "prov-5-21",
      "type": "verse",
      "number": 21,
      "text": "For human ways are under the eyes of the Lord,"
    },
    {
      "block_id": "prov-5-22",
      "type": "verse",
      "number": 22,
      "text": "The iniquities of the wicked ensnare them,"
    },
    {
      "block_id": "prov-5-23",
      "type": "verse",
      "number": 23,
      "text": "They die for lack of discipline,"
    }
  ]
}