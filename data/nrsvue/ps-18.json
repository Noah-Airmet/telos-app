{
  "document_id": "ps-18",
  "title": "Psalms 18",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-18-1",
      "type": "verse",
      "number": 1,
      "text": "I love you, O Lord, my strength."
    },
    {
      "block_id": "ps-18-2",
      "type": "verse",
      "number": 2,
      "text": "The Lord is my rock, my fortress, and my deliverer,"
    },
    {
      "block_id": "ps-18-3",
      "type": "verse",
      "number": 3,
      "text": "I call upon the Lord, who is worthy to be praised,"
    },
    {
      "block_id": "ps-18-4",
      "type": "verse",
      "number": 4,
      "text": "The cords of death encompassed me;"
    },
    {
      "block_id": "ps-18-5",
      "type": "verse",
      "number": 5,
      "text": "the cords of Sheol entangled me;"
    },
    {
      "block_id": "ps-18-6",
      "type": "verse",
      "number": 6,
      "text": "In my distress I called upon the Lord;"
    },
    {
      "block_id": "ps-18-7",
      "type": "verse",
      "number": 7,
      "text": "Then the earth reeled and rocked;"
    },
    {
      "block_id": "ps-18-8",
      "type": "verse",
      "number": 8,
      "text": "Smoke went up from his nostrils"
    },
    {
      "block_id": "ps-18-9",
      "type": "verse",
      "number": 9,
      "text": "He bowed the heavens and came down;"
    },
    {
      "block_id": "ps-18-10",
      "type": "verse",
      "number": 10,
      "text": "He rode on a cherub and flew;"
    },
    {
      "block_id": "ps-18-11",
      "type": "verse",
      "number": 11,
      "text": "He made darkness his covering around him,"
    },
    {
      "block_id": "ps-18-12",
      "type": "verse",
      "number": 12,
      "text": "Out of the brightness before him"
    },
    {
      "block_id": "ps-18-13",
      "type": "verse",
      "number": 13,
      "text": "The Lord also thundered in the heavens,"
    },
    {
      "block_id": "ps-18-14",
      "type": "verse",
      "number": 14,
      "text": "And he sent out his arrows and scattered them;"
    },
    {
      "block_id": "ps-18-15",
      "type": "verse",
      "number": 15,
      "text": "Then the channels of the sea were seen,"
    },
    {
      "block_id": "ps-18-16",
      "type": "verse",
      "number": 16,
      "text": "He reached down from on high; he took me;"
    },
    {
      "block_id": "ps-18-17",
      "type": "verse",
      "number": 17,
      "text": "He delivered me from my strong enemy"
    },
    {
      "block_id": "ps-18-18",
      "type": "verse",
      "number": 18,
      "text": "They confronted me in the day of my calamity,"
    },
    {
      "block_id": "ps-18-19",
      "type": "verse",
      "number": 19,
      "text": "He brought me out into a broad place;"
    },
    {
      "block_id": "ps-18-20",
      "type": "verse",
      "number": 20,
      "text": "The Lord rewarded me according to my righteousness;"
    },
    {
      "block_id": "ps-18-21",
      "type": "verse",
      "number": 21,
      "text": "For I have kept the ways of the Lord"
    },
    {
      "block_id": "ps-18-22",
      "type": "verse",
      "number": 22,
      "text": "For all his ordinances were before me,"
    },
    {
      "block_id": "ps-18-23",
      "type": "verse",
      "number": 23,
      "text": "I was blameless before him,"
    },
    {
      "block_id": "ps-18-24",
      "type": "verse",
      "number": 24,
      "text": "Therefore the Lord has recompensed me according to my righteousness,"
    },
    {
      "block_id": "ps-18-25",
      "type": "verse",
      "number": 25,
      "text": "With the loyal you show yourself loyal;"
    },
    {
      "block_id": "ps-18-26",
      "type": "verse",
      "number": 26,
      "text": "with the pure you show yourself pure;"
    },
    {
      "block_id": "ps-18-27",
      "type": "verse",
      "number": 27,
      "text": "For you deliver a humble people,"
    },
    {
      "block_id": "ps-18-28",
      "type": "verse",
      "number": 28,
      "text": "It is you who light my lamp;"
    },
    {
      "block_id": "ps-18-29",
      "type": "verse",
      "number": 29,
      "text": "By you I can outrun a troop,"
    },
    {
      "block_id": "ps-18-30",
      "type": "verse",
      "number": 30,
      "text": "This God—his way is perfect;"
    },
    {
      "block_id": "ps-18-31",
      "type": "verse",
      "number": 31,
      "text": "For who is God except the Lord?"
    },
    {
      "block_id": "ps-18-32",
      "type": "verse",
      "number": 32,
      "text": "The God who has girded me with strength"
    },
    {
      "block_id": "ps-18-33",
      "type": "verse",
      "number": 33,
      "text": "He made my feet like the feet of a deer"
    },
    {
      "block_id": "ps-18-34",
      "type": "verse",
      "number": 34,
      "text": "He trains my hands for war,"
    },
    {
      "block_id": "ps-18-35",
      "type": "verse",
      "number": 35,
      "text": "You have given me the shield of your salvation,"
    },
    {
      "block_id": "ps-18-36",
      "type": "verse",
      "number": 36,
      "text": "You gave me a wide place for my steps under me,"
    },
    {
      "block_id": "ps-18-37",
      "type": "verse",
      "number": 37,
      "text": "I pursued my enemies and overtook them"
    },
    {
      "block_id": "ps-18-38",
      "type": "verse",
      "number": 38,
      "text": "I struck them down so that they were unable to rise;"
    },
    {
      "block_id": "ps-18-39",
      "type": "verse",
      "number": 39,
      "text": "For you girded me with strength for the battle;"
    },
    {
      "block_id": "ps-18-40",
      "type": "verse",
      "number": 40,
      "text": "You made my enemies turn their backs to me,"
    },
    {
      "block_id": "ps-18-41",
      "type": "verse",
      "number": 41,
      "text": "They cried for help, but there was no one to save them;"
    },
    {
      "block_id": "ps-18-42",
      "type": "verse",
      "number": 42,
      "text": "I beat them fine, like dust before the wind;"
    },
    {
      "block_id": "ps-18-43",
      "type": "verse",
      "number": 43,
      "text": "You delivered me from strife with the peoples;"
    },
    {
      "block_id": "ps-18-44",
      "type": "verse",
      "number": 44,
      "text": "As soon as they heard of me, they obeyed me;"
    },
    {
      "block_id": "ps-18-45",
      "type": "verse",
      "number": 45,
      "text": "Foreigners lost heart"
    },
    {
      "block_id": "ps-18-46",
      "type": "verse",
      "number": 46,
      "text": "The Lord lives! Blessed be my rock,"
    },
    {
      "block_id": "ps-18-47",
      "type": "verse",
      "number": 47,
      "text": "the God who gave me vengeance"
    },
    {
      "block_id": "ps-18-48",
      "type": "verse",
      "number": 48,
      "text": "who delivered me from my enemies;"
    },
    {
      "block_id": "ps-18-49",
      "type": "verse",
      "number": 49,
      "text": "For this I will extol you, O Lord, among the nations"
    },
    {
      "block_id": "ps-18-50",
      "type": "verse",
      "number": 50,
      "text": "Great triumphs he gives to his king"
    }
  ]
}