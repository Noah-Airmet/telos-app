{
  "document_id": "pr-man-1",
  "title": "Prayer of Manasseh 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "pr-man-1-1",
      "type": "verse",
      "number": 1,
      "text": "O Lord Almighty,"
    },
    {
      "block_id": "pr-man-1-2",
      "type": "verse",
      "number": 2,
      "text": "you who made heaven and earth"
    },
    {
      "block_id": "pr-man-1-3",
      "type": "verse",
      "number": 3,
      "text": "who shackled the sea by your word of command,"
    },
    {
      "block_id": "pr-man-1-4",
      "type": "verse",
      "number": 4,
      "text": "at whom all things shudder"
    },
    {
      "block_id": "pr-man-1-5",
      "type": "verse",
      "number": 5,
      "text": "for your glorious splendor cannot be borne,"
    },
    {
      "block_id": "pr-man-1-6",
      "type": "verse",
      "number": 6,
      "text": "yet immeasurable and unsearchable"
    },
    {
      "block_id": "pr-man-1-7",
      "type": "verse",
      "number": 7,
      "text": "for you are the Lord Most High,"
    },
    {
      "block_id": "pr-man-1-8",
      "type": "verse",
      "number": 8,
      "text": "Therefore you, O Lord, God of the righteous,"
    },
    {
      "block_id": "pr-man-1-9",
      "type": "verse",
      "number": 9,
      "text": "For the sins I have committed are more in number than the sand of the sea;"
    },
    {
      "block_id": "pr-man-1-10",
      "type": "verse",
      "number": 10,
      "text": "I am weighted down with many an iron fetter,"
    },
    {
      "block_id": "pr-man-1-11",
      "type": "verse",
      "number": 11,
      "text": "And now I bend the knee of my heart,"
    },
    {
      "block_id": "pr-man-1-12",
      "type": "verse",
      "number": 12,
      "text": "I have sinned, O Lord, I have sinned,"
    },
    {
      "block_id": "pr-man-1-13",
      "type": "verse",
      "number": 13,
      "text": "I earnestly implore you,"
    },
    {
      "block_id": "pr-man-1-14",
      "type": "verse",
      "number": 14,
      "text": "and in me you will manifest your goodness,"
    },
    {
      "block_id": "pr-man-1-15",
      "type": "verse",
      "number": 15,
      "text": "and I will praise you continually all the days of my life."
    }
  ]
}