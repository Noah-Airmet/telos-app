{
  "document_id": "ps-135",
  "title": "Psalms 135",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-135-1",
      "type": "verse",
      "number": 1,
      "text": "Praise the Lord!"
    },
    {
      "block_id": "ps-135-2",
      "type": "verse",
      "number": 2,
      "text": "you who stand in the house of the Lord,"
    },
    {
      "block_id": "ps-135-3",
      "type": "verse",
      "number": 3,
      "text": "Praise the Lord, for the Lord is good;"
    },
    {
      "block_id": "ps-135-4",
      "type": "verse",
      "number": 4,
      "text": "For the Lord has chosen Jacob for himself,"
    },
    {
      "block_id": "ps-135-5",
      "type": "verse",
      "number": 5,
      "text": "For I know that the Lord is great;"
    },
    {
      "block_id": "ps-135-6",
      "type": "verse",
      "number": 6,
      "text": "Whatever the Lord pleases he does,"
    },
    {
      "block_id": "ps-135-7",
      "type": "verse",
      "number": 7,
      "text": "He it is who makes the clouds rise at the end of the earth;"
    },
    {
      "block_id": "ps-135-8",
      "type": "verse",
      "number": 8,
      "text": "He it was who struck down the firstborn of Egypt,"
    },
    {
      "block_id": "ps-135-9",
      "type": "verse",
      "number": 9,
      "text": "he sent signs and wonders"
    },
    {
      "block_id": "ps-135-10",
      "type": "verse",
      "number": 10,
      "text": "He struck down many nations"
    },
    {
      "block_id": "ps-135-11",
      "type": "verse",
      "number": 11,
      "text": "Sihon, king of the Amorites,"
    },
    {
      "block_id": "ps-135-12",
      "type": "verse",
      "number": 12,
      "text": "and gave their land as a heritage,"
    },
    {
      "block_id": "ps-135-13",
      "type": "verse",
      "number": 13,
      "text": "Your name, O Lord, endures forever,"
    },
    {
      "block_id": "ps-135-14",
      "type": "verse",
      "number": 14,
      "text": "For the Lord will vindicate his people"
    },
    {
      "block_id": "ps-135-15",
      "type": "verse",
      "number": 15,
      "text": "The idols of the nations are silver and gold,"
    },
    {
      "block_id": "ps-135-16",
      "type": "verse",
      "number": 16,
      "text": "They have mouths, but they do not speak;"
    },
    {
      "block_id": "ps-135-17",
      "type": "verse",
      "number": 17,
      "text": "they have ears, but they do not hear,"
    },
    {
      "block_id": "ps-135-18",
      "type": "verse",
      "number": 18,
      "text": "Those who make them"
    },
    {
      "block_id": "ps-135-19",
      "type": "verse",
      "number": 19,
      "text": "O house of Israel, bless the Lord!"
    },
    {
      "block_id": "ps-135-20",
      "type": "verse",
      "number": 20,
      "text": "O house of Levi, bless the Lord!"
    },
    {
      "block_id": "ps-135-21",
      "type": "verse",
      "number": 21,
      "text": "Blessed be the Lord from Zion,"
    }
  ]
}