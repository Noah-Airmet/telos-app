{
  "document_id": "prov-13",
  "title": "Proverbs 13",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-13-1",
      "type": "verse",
      "number": 1,
      "text": "A wise child loves discipline,"
    },
    {
      "block_id": "prov-13-2",
      "type": "verse",
      "number": 2,
      "text": "From the fruit of their words good persons eat good things,"
    },
    {
      "block_id": "prov-13-3",
      "type": "verse",
      "number": 3,
      "text": "Those who guard their mouths preserve their lives;"
    },
    {
      "block_id": "prov-13-4",
      "type": "verse",
      "number": 4,
      "text": "The appetite of the lazy craves and gets nothing,"
    },
    {
      "block_id": "prov-13-5",
      "type": "verse",
      "number": 5,
      "text": "The righteous hate falsehood,"
    },
    {
      "block_id": "prov-13-6",
      "type": "verse",
      "number": 6,
      "text": "Righteousness guards one whose way is upright,"
    },
    {
      "block_id": "prov-13-7",
      "type": "verse",
      "number": 7,
      "text": "Some pretend to be rich yet have nothing;"
    },
    {
      "block_id": "prov-13-8",
      "type": "verse",
      "number": 8,
      "text": "Wealth is a ransom for a person’s life,"
    },
    {
      "block_id": "prov-13-9",
      "type": "verse",
      "number": 9,
      "text": "The light of the righteous rejoices,"
    },
    {
      "block_id": "prov-13-10",
      "type": "verse",
      "number": 10,
      "text": "By insolence the empty-headed person makes strife,"
    },
    {
      "block_id": "prov-13-11",
      "type": "verse",
      "number": 11,
      "text": "Wealth hastily gotten will dwindle,"
    },
    {
      "block_id": "prov-13-12",
      "type": "verse",
      "number": 12,
      "text": "Hope deferred makes the heart sick,"
    },
    {
      "block_id": "prov-13-13",
      "type": "verse",
      "number": 13,
      "text": "Those who despise a word bring destruction on themselves,"
    },
    {
      "block_id": "prov-13-14",
      "type": "verse",
      "number": 14,
      "text": "The teaching of the wise is a fountain of life,"
    },
    {
      "block_id": "prov-13-15",
      "type": "verse",
      "number": 15,
      "text": "Good sense wins favor,"
    },
    {
      "block_id": "prov-13-16",
      "type": "verse",
      "number": 16,
      "text": "The clever do all things intelligently,"
    },
    {
      "block_id": "prov-13-17",
      "type": "verse",
      "number": 17,
      "text": "A bad messenger brings trouble,"
    },
    {
      "block_id": "prov-13-18",
      "type": "verse",
      "number": 18,
      "text": "Poverty and disgrace are for the one who ignores instruction,"
    },
    {
      "block_id": "prov-13-19",
      "type": "verse",
      "number": 19,
      "text": "A desire realized is sweet to the soul,"
    },
    {
      "block_id": "prov-13-20",
      "type": "verse",
      "number": 20,
      "text": "Whoever walks with the wise becomes wise,"
    },
    {
      "block_id": "prov-13-21",
      "type": "verse",
      "number": 21,
      "text": "Misfortune pursues sinners,"
    },
    {
      "block_id": "prov-13-22",
      "type": "verse",
      "number": 22,
      "text": "The good leave an inheritance to their children’s children,"
    },
    {
      "block_id": "prov-13-23",
      "type": "verse",
      "number": 23,
      "text": "The field of the poor may yield much food,"
    },
    {
      "block_id": "prov-13-24",
      "type": "verse",
      "number": 24,
      "text": "Those who spare the rod hate their children,"
    },
    {
      "block_id": "prov-13-25",
      "type": "verse",
      "number": 25,
      "text": "The righteous have enough to satisfy their appetite,"
    }
  ]
}