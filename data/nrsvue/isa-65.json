{
  "document_id": "isa-65",
  "title": "Isaiah 65",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-65-1",
      "type": "verse",
      "number": 1,
      "text": "I was ready to be sought out by those who did not ask,"
    },
    {
      "block_id": "isa-65-2",
      "type": "verse",
      "number": 2,
      "text": "I held out my hands all day long"
    },
    {
      "block_id": "isa-65-3",
      "type": "verse",
      "number": 3,
      "text": "a people who provoke me"
    },
    {
      "block_id": "isa-65-4",
      "type": "verse",
      "number": 4,
      "text": "who sit inside tombs"
    },
    {
      "block_id": "isa-65-5",
      "type": "verse",
      "number": 5,
      "text": "who say, “Keep to yourself;"
    },
    {
      "block_id": "isa-65-6",
      "type": "verse",
      "number": 6,
      "text": "See, it is written before me:"
    },
    {
      "block_id": "isa-65-7",
      "type": "verse",
      "number": 7,
      "text": "their iniquities and their ancestors’ iniquities together,"
    },
    {
      "block_id": "isa-65-8",
      "type": "verse",
      "number": 8,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "isa-65-9",
      "type": "verse",
      "number": 9,
      "text": "I will bring forth descendants from Jacob"
    },
    {
      "block_id": "isa-65-10",
      "type": "verse",
      "number": 10,
      "text": "Sharon shall become a pasture for flocks"
    },
    {
      "block_id": "isa-65-11",
      "type": "verse",
      "number": 11,
      "text": "But you who forsake the Lord,"
    },
    {
      "block_id": "isa-65-12",
      "type": "verse",
      "number": 12,
      "text": "I will destine you to the sword,"
    },
    {
      "block_id": "isa-65-13",
      "type": "verse",
      "number": 13,
      "text": "Therefore thus says the Lord God:"
    },
    {
      "block_id": "isa-65-14",
      "type": "verse",
      "number": 14,
      "text": "my servants shall sing with gladness of heart,"
    },
    {
      "block_id": "isa-65-15",
      "type": "verse",
      "number": 15,
      "text": "You shall leave your name to my chosen to use as a curse,"
    },
    {
      "block_id": "isa-65-16",
      "type": "verse",
      "number": 16,
      "text": "Then whoever invokes a blessing in the land"
    },
    {
      "block_id": "isa-65-17",
      "type": "verse",
      "number": 17,
      "text": "For I am about to create new heavens"
    },
    {
      "block_id": "isa-65-18",
      "type": "verse",
      "number": 18,
      "text": "But be glad and rejoice forever"
    },
    {
      "block_id": "isa-65-19",
      "type": "verse",
      "number": 19,
      "text": "I will rejoice in Jerusalem"
    },
    {
      "block_id": "isa-65-20",
      "type": "verse",
      "number": 20,
      "text": "No more shall there be in it"
    },
    {
      "block_id": "isa-65-21",
      "type": "verse",
      "number": 21,
      "text": "They shall build houses and inhabit them;"
    },
    {
      "block_id": "isa-65-22",
      "type": "verse",
      "number": 22,
      "text": "They shall not build and another inhabit;"
    },
    {
      "block_id": "isa-65-23",
      "type": "verse",
      "number": 23,
      "text": "They shall not labor in vain"
    },
    {
      "block_id": "isa-65-24",
      "type": "verse",
      "number": 24,
      "text": "Before they call I will answer,"
    },
    {
      "block_id": "isa-65-25",
      "type": "verse",
      "number": 25,
      "text": "The wolf and the lamb shall feed together;"
    }
  ]
}