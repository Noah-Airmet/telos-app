{
  "document_id": "isa-40",
  "title": "Isaiah 40",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-40-1",
      "type": "verse",
      "number": 1,
      "text": "Comfort, O comfort my people,"
    },
    {
      "block_id": "isa-40-2",
      "type": "verse",
      "number": 2,
      "text": "Speak tenderly to Jerusalem,"
    },
    {
      "block_id": "isa-40-3",
      "type": "verse",
      "number": 3,
      "text": "A voice cries out:"
    },
    {
      "block_id": "isa-40-4",
      "type": "verse",
      "number": 4,
      "text": "Every valley shall be lifted up,"
    },
    {
      "block_id": "isa-40-5",
      "type": "verse",
      "number": 5,
      "text": "Then the glory of the Lord shall be revealed,"
    },
    {
      "block_id": "isa-40-6",
      "type": "verse",
      "number": 6,
      "text": "A voice says, “Cry out!”"
    },
    {
      "block_id": "isa-40-7",
      "type": "verse",
      "number": 7,
      "text": "The grass withers; the flower fades,"
    },
    {
      "block_id": "isa-40-8",
      "type": "verse",
      "number": 8,
      "text": "The grass withers; the flower fades,]]"
    },
    {
      "block_id": "isa-40-9",
      "type": "verse",
      "number": 9,
      "text": "Get you up to a high mountain,"
    },
    {
      "block_id": "isa-40-10",
      "type": "verse",
      "number": 10,
      "text": "See, the Lord God comes with might,"
    },
    {
      "block_id": "isa-40-11",
      "type": "verse",
      "number": 11,
      "text": "He will feed his flock like a shepherd;"
    },
    {
      "block_id": "isa-40-12",
      "type": "verse",
      "number": 12,
      "text": "Who has measured the waters of the sea in the hollow of his hand"
    },
    {
      "block_id": "isa-40-13",
      "type": "verse",
      "number": 13,
      "text": "Who has directed the spirit of the Lord"
    },
    {
      "block_id": "isa-40-14",
      "type": "verse",
      "number": 14,
      "text": "Whom did he consult for his enlightenment,"
    },
    {
      "block_id": "isa-40-15",
      "type": "verse",
      "number": 15,
      "text": "Even the nations are like a drop from a bucket"
    },
    {
      "block_id": "isa-40-16",
      "type": "verse",
      "number": 16,
      "text": "Lebanon would not provide fuel enough,"
    },
    {
      "block_id": "isa-40-17",
      "type": "verse",
      "number": 17,
      "text": "All the nations are as nothing before him;"
    },
    {
      "block_id": "isa-40-18",
      "type": "verse",
      "number": 18,
      "text": "To whom, then, will you liken God,"
    },
    {
      "block_id": "isa-40-19",
      "type": "verse",
      "number": 19,
      "text": "An idol? A workman casts it,"
    },
    {
      "block_id": "isa-40-20",
      "type": "verse",
      "number": 20,
      "text": "As a gift one chooses mulberry wood"
    },
    {
      "block_id": "isa-40-21",
      "type": "verse",
      "number": 21,
      "text": "Have you not known? Have you not heard?"
    },
    {
      "block_id": "isa-40-22",
      "type": "verse",
      "number": 22,
      "text": "It is he who sits above the circle of the earth,"
    },
    {
      "block_id": "isa-40-23",
      "type": "verse",
      "number": 23,
      "text": "who brings princes to naught"
    },
    {
      "block_id": "isa-40-24",
      "type": "verse",
      "number": 24,
      "text": "Scarcely are they planted, scarcely sown,"
    },
    {
      "block_id": "isa-40-25",
      "type": "verse",
      "number": 25,
      "text": "To whom, then, will you compare me,"
    },
    {
      "block_id": "isa-40-26",
      "type": "verse",
      "number": 26,
      "text": "Lift up your eyes on high and see:"
    },
    {
      "block_id": "isa-40-27",
      "type": "verse",
      "number": 27,
      "text": "Why do you say, O Jacob,"
    },
    {
      "block_id": "isa-40-28",
      "type": "verse",
      "number": 28,
      "text": "Have you not known? Have you not heard?"
    },
    {
      "block_id": "isa-40-29",
      "type": "verse",
      "number": 29,
      "text": "He gives power to the faint"
    },
    {
      "block_id": "isa-40-30",
      "type": "verse",
      "number": 30,
      "text": "Even youths will faint and be weary,"
    },
    {
      "block_id": "isa-40-31",
      "type": "verse",
      "number": 31,
      "text": "but those who wait for the Lord shall renew their strength;"
    }
  ]
}