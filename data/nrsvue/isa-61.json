{
  "document_id": "isa-61",
  "title": "Isaiah 61",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-61-1",
      "type": "verse",
      "number": 1,
      "text": "The spirit of the Lord God is upon me"
    },
    {
      "block_id": "isa-61-2",
      "type": "verse",
      "number": 2,
      "text": "to proclaim the year of the Lord’s favor"
    },
    {
      "block_id": "isa-61-3",
      "type": "verse",
      "number": 3,
      "text": "to provide for those who mourn in Zion—"
    },
    {
      "block_id": "isa-61-4",
      "type": "verse",
      "number": 4,
      "text": "They shall build up the ancient ruins;"
    },
    {
      "block_id": "isa-61-5",
      "type": "verse",
      "number": 5,
      "text": "Strangers shall stand and feed your flocks;"
    },
    {
      "block_id": "isa-61-6",
      "type": "verse",
      "number": 6,
      "text": "but you shall be called priests of the Lord;"
    },
    {
      "block_id": "isa-61-7",
      "type": "verse",
      "number": 7,
      "text": "Because their shame was double"
    },
    {
      "block_id": "isa-61-8",
      "type": "verse",
      "number": 8,
      "text": "For I, the Lord, love justice,"
    },
    {
      "block_id": "isa-61-9",
      "type": "verse",
      "number": 9,
      "text": "Their descendants shall be known among the nations"
    },
    {
      "block_id": "isa-61-10",
      "type": "verse",
      "number": 10,
      "text": "I will greatly rejoice in the Lord;"
    },
    {
      "block_id": "isa-61-11",
      "type": "verse",
      "number": 11,
      "text": "For as the earth brings forth its shoots"
    }
  ]
}