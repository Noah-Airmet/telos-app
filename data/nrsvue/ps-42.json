{
  "document_id": "ps-42",
  "title": "Psalms 42",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-42-1",
      "type": "verse",
      "number": 1,
      "text": "As a deer longs for flowing streams,"
    },
    {
      "block_id": "ps-42-2",
      "type": "verse",
      "number": 2,
      "text": "My soul thirsts for God,"
    },
    {
      "block_id": "ps-42-3",
      "type": "verse",
      "number": 3,
      "text": "My tears have been my food"
    },
    {
      "block_id": "ps-42-4",
      "type": "verse",
      "number": 4,
      "text": "These things I remember,"
    },
    {
      "block_id": "ps-42-5",
      "type": "verse",
      "number": 5,
      "text": "Why are you cast down, O my soul,"
    },
    {
      "block_id": "ps-42-6",
      "type": "verse",
      "number": 6,
      "text": "and my God."
    },
    {
      "block_id": "ps-42-7",
      "type": "verse",
      "number": 7,
      "text": "Deep calls to deep"
    },
    {
      "block_id": "ps-42-8",
      "type": "verse",
      "number": 8,
      "text": "By day the Lord commands his steadfast love,"
    },
    {
      "block_id": "ps-42-9",
      "type": "verse",
      "number": 9,
      "text": "I say to God, my rock,"
    },
    {
      "block_id": "ps-42-10",
      "type": "verse",
      "number": 10,
      "text": "As with a deadly wound in my body,"
    },
    {
      "block_id": "ps-42-11",
      "type": "verse",
      "number": 11,
      "text": "Why are you cast down, O my soul,"
    }
  ]
}