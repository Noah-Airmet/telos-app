{
  "document_id": "col-17",
  "title": "Colossians 17",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-17-1",
      "type": "verse",
      "number": 1,
      "text": "The Lord created humans out of earth"
    },
    {
      "block_id": "col-17-2",
      "type": "verse",
      "number": 2,
      "text": "He gave them a fixed number of days"
    },
    {
      "block_id": "col-17-3",
      "type": "verse",
      "number": 3,
      "text": "He endowed them with strength like his own"
    },
    {
      "block_id": "col-17-4",
      "type": "verse",
      "number": 4,
      "text": "He put the fear of them in all living beings"
    },
    {
      "block_id": "col-17-6",
      "type": "verse",
      "number": 6,
      "text": "Discretion and tongue and eyes,"
    },
    {
      "block_id": "col-17-7",
      "type": "verse",
      "number": 7,
      "text": "He filled them with knowledge and understanding"
    },
    {
      "block_id": "col-17-8",
      "type": "verse",
      "number": 8,
      "text": "He put the fear of him into their hearts"
    },
    {
      "block_id": "col-17-9",
      "type": "verse",
      "number": 9,
      "text": "to proclaim the grandeur of his works."
    },
    {
      "block_id": "col-17-10",
      "type": "verse",
      "number": 10,
      "text": "And they will praise his holy name,"
    },
    {
      "block_id": "col-17-11",
      "type": "verse",
      "number": 11,
      "text": "He bestowed knowledge upon them"
    },
    {
      "block_id": "col-17-12",
      "type": "verse",
      "number": 12,
      "text": "He established with them an eternal covenant"
    },
    {
      "block_id": "col-17-13",
      "type": "verse",
      "number": 13,
      "text": "Their eyes saw his glorious majesty,"
    },
    {
      "block_id": "col-17-14",
      "type": "verse",
      "number": 14,
      "text": "He said to them, “Beware of all iniquity.”"
    },
    {
      "block_id": "col-17-15",
      "type": "verse",
      "number": 15,
      "text": "Their ways are always before him;"
    },
    {
      "block_id": "col-17-17",
      "type": "verse",
      "number": 17,
      "text": "He appointed a ruler for every nation,"
    },
    {
      "block_id": "col-17-19",
      "type": "verse",
      "number": 19,
      "text": "All their works are as the sun before him,"
    },
    {
      "block_id": "col-17-20",
      "type": "verse",
      "number": 20,
      "text": "Their iniquities are not hidden from him,"
    },
    {
      "block_id": "col-17-22",
      "type": "verse",
      "number": 22,
      "text": "One’s almsgiving is like a signet ring with the Lord,"
    },
    {
      "block_id": "col-17-23",
      "type": "verse",
      "number": 23,
      "text": "Afterward he will rise up and repay them,"
    },
    {
      "block_id": "col-17-24",
      "type": "verse",
      "number": 24,
      "text": "Yet to those who repent he grants a return,"
    },
    {
      "block_id": "col-17-25",
      "type": "verse",
      "number": 25,
      "text": "Turn back to the Lord and forsake your sins;"
    },
    {
      "block_id": "col-17-26",
      "type": "verse",
      "number": 26,
      "text": "Return to the Most High and turn away from iniquity"
    },
    {
      "block_id": "col-17-27",
      "type": "verse",
      "number": 27,
      "text": "Who will sing praises to the Most High in Hades"
    },
    {
      "block_id": "col-17-28",
      "type": "verse",
      "number": 28,
      "text": "From the dead, as from one who does not exist, thanksgiving has ceased;"
    },
    {
      "block_id": "col-17-29",
      "type": "verse",
      "number": 29,
      "text": "How great is the mercy of the Lord"
    },
    {
      "block_id": "col-17-30",
      "type": "verse",
      "number": 30,
      "text": "For not everything is within human capability,"
    },
    {
      "block_id": "col-17-31",
      "type": "verse",
      "number": 31,
      "text": "What is brighter than the sun? Yet it can be eclipsed."
    },
    {
      "block_id": "col-17-32",
      "type": "verse",
      "number": 32,
      "text": "He marshals the host of the height of heaven,"
    }
  ]
}