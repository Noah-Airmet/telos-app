{
  "document_id": "zech-9",
  "title": "Zechariah 9",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "zech-9-heading-judgment-on-israel’s",
      "type": "heading",
      "text": "Judgment on Israel’s Enemies"
    },
    {
      "block_id": "zech-9-1",
      "type": "verse",
      "number": 1,
      "text": "An Oracle."
    },
    {
      "block_id": "zech-9-2",
      "type": "verse",
      "number": 2,
      "text": "Hamath also, which borders on it,"
    },
    {
      "block_id": "zech-9-3",
      "type": "verse",
      "number": 3,
      "text": "Tyre has built itself a rampart"
    },
    {
      "block_id": "zech-9-4",
      "type": "verse",
      "number": 4,
      "text": "But now, the Lord will strip it of its possessions"
    },
    {
      "block_id": "zech-9-5",
      "type": "verse",
      "number": 5,
      "text": "Ashkelon shall see it and be afraid;"
    },
    {
      "block_id": "zech-9-6",
      "type": "verse",
      "number": 6,
      "text": "a mongrel people shall settle in Ashdod,"
    },
    {
      "block_id": "zech-9-7",
      "type": "verse",
      "number": 7,
      "text": "I will take away its blood from its mouth"
    },
    {
      "block_id": "zech-9-8",
      "type": "verse",
      "number": 8,
      "text": "Then I will encamp at my house as a guard,"
    },
    {
      "block_id": "zech-9-9",
      "type": "verse",
      "number": 9,
      "text": "Rejoice greatly, O daughter Zion!"
    },
    {
      "block_id": "zech-9-10",
      "type": "verse",
      "number": 10,
      "text": "He will cut off the chariot from Ephraim"
    },
    {
      "block_id": "zech-9-11",
      "type": "verse",
      "number": 11,
      "text": "As for you also, because of the blood of my covenant with you,"
    },
    {
      "block_id": "zech-9-12",
      "type": "verse",
      "number": 12,
      "text": "Return to your stronghold, O prisoners of hope;"
    },
    {
      "block_id": "zech-9-13",
      "type": "verse",
      "number": 13,
      "text": "For I have bent Judah as my bow;"
    },
    {
      "block_id": "zech-9-14",
      "type": "verse",
      "number": 14,
      "text": "Then the Lord will appear over them,"
    },
    {
      "block_id": "zech-9-15",
      "type": "verse",
      "number": 15,
      "text": "The Lord of hosts will protect them,"
    },
    {
      "block_id": "zech-9-16",
      "type": "verse",
      "number": 16,
      "text": "On that day the Lord their God will save them,"
    },
    {
      "block_id": "zech-9-17",
      "type": "verse",
      "number": 17,
      "text": "For what goodness and beauty are his!"
    }
  ]
}