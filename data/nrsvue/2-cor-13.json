{
  "document_id": "2-cor-13",
  "title": "2 Corinthians 13",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "2-cor-13-heading-tobit’s-thanksgiving",
      "type": "heading",
      "text": "Tobit’s Thanksgiving to God"
    },
    {
      "block_id": "2-cor-13-1",
      "type": "verse",
      "number": 1,
      "text": "Then Tobit said:"
    },
    {
      "block_id": "2-cor-13-2",
      "type": "verse",
      "number": 2,
      "text": "For he afflicts, and he shows mercy;"
    },
    {
      "block_id": "2-cor-13-3",
      "type": "verse",
      "number": 3,
      "text": "Acknowledge him before the nations, O children of Israel,"
    },
    {
      "block_id": "2-cor-13-4",
      "type": "verse",
      "number": 4,
      "text": "He has shown you his greatness even there."
    },
    {
      "block_id": "2-cor-13-5",
      "type": "verse",
      "number": 5,
      "text": "He will afflict you for your iniquities,"
    },
    {
      "block_id": "2-cor-13-6",
      "type": "verse",
      "number": 6,
      "text": "If you turn to him with all your heart and with all your soul,"
    },
    {
      "block_id": "2-cor-13-7",
      "type": "verse",
      "number": 7,
      "text": "As for me, I exalt my God,"
    },
    {
      "block_id": "2-cor-13-8",
      "type": "verse",
      "number": 8,
      "text": "Let all people speak of his majesty"
    },
    {
      "block_id": "2-cor-13-9",
      "type": "verse",
      "number": 9,
      "text": "O Jerusalem, the holy city,"
    },
    {
      "block_id": "2-cor-13-10",
      "type": "verse",
      "number": 10,
      "text": "Acknowledge the Lord worthily,"
    },
    {
      "block_id": "2-cor-13-11",
      "type": "verse",
      "number": 11,
      "text": "A bright light will shine to all the remotest parts of the earth;"
    },
    {
      "block_id": "2-cor-13-12",
      "type": "verse",
      "number": 12,
      "text": "Cursed are all who reject you"
    },
    {
      "block_id": "2-cor-13-13",
      "type": "verse",
      "number": 13,
      "text": "Rejoice, then, and exult over the children of the righteous,"
    },
    {
      "block_id": "2-cor-13-14",
      "type": "verse",
      "number": 14,
      "text": "Happy will be those who love you,"
    },
    {
      "block_id": "2-cor-13-15",
      "type": "verse",
      "number": 15,
      "text": "My soul blesses the Lord, the great King,"
    },
    {
      "block_id": "2-cor-13-16",
      "type": "verse",
      "number": 16,
      "text": "for Jerusalem will be rebuilt as his house for all ages."
    },
    {
      "block_id": "2-cor-13-17",
      "type": "verse",
      "number": 17,
      "text": "The streets of Jerusalem will be paved"
    },
    {
      "block_id": "2-cor-13-18",
      "type": "verse",
      "number": 18,
      "text": "The gates of Jerusalem will sing hymns of joy,"
    }
  ]
}