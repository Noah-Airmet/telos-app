{
  "document_id": "song-4",
  "title": "Song of Songs 4",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "song-4-1",
      "type": "verse",
      "number": 1,
      "text": "How beautiful you are, my love,"
    },
    {
      "block_id": "song-4-2",
      "type": "verse",
      "number": 2,
      "text": "Your teeth are like a flock of shorn ewes"
    },
    {
      "block_id": "song-4-3",
      "type": "verse",
      "number": 3,
      "text": "Your lips are like a crimson thread,"
    },
    {
      "block_id": "song-4-4",
      "type": "verse",
      "number": 4,
      "text": "Your neck is like the tower of David,"
    },
    {
      "block_id": "song-4-5",
      "type": "verse",
      "number": 5,
      "text": "Your two breasts are like two fawns,"
    },
    {
      "block_id": "song-4-6",
      "type": "verse",
      "number": 6,
      "text": "Until the day breathes"
    },
    {
      "block_id": "song-4-7",
      "type": "verse",
      "number": 7,
      "text": "You are altogether beautiful, my love;"
    },
    {
      "block_id": "song-4-8",
      "type": "verse",
      "number": 8,
      "text": "Come with me from Lebanon, my bride;"
    },
    {
      "block_id": "song-4-9",
      "type": "verse",
      "number": 9,
      "text": "You have ravished my heart, my sister, my bride;"
    },
    {
      "block_id": "song-4-10",
      "type": "verse",
      "number": 10,
      "text": "How sweet is your love, my sister, my bride!"
    },
    {
      "block_id": "song-4-11",
      "type": "verse",
      "number": 11,
      "text": "Your lips distill nectar, my bride;"
    },
    {
      "block_id": "song-4-12",
      "type": "verse",
      "number": 12,
      "text": "A garden locked is my sister, my bride,"
    },
    {
      "block_id": "song-4-13",
      "type": "verse",
      "number": 13,
      "text": "Your channel is an orchard of pomegranates"
    },
    {
      "block_id": "song-4-14",
      "type": "verse",
      "number": 14,
      "text": "nard and saffron, calamus and cinnamon,"
    },
    {
      "block_id": "song-4-15",
      "type": "verse",
      "number": 15,
      "text": "a garden fountain, a well of living water,"
    },
    {
      "block_id": "song-4-16",
      "type": "verse",
      "number": 16,
      "text": "Awake, O north wind,"
    }
  ]
}