{
  "document_id": "prov-17",
  "title": "Proverbs 17",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-17-1",
      "type": "verse",
      "number": 1,
      "text": "Better is a dry morsel with quiet"
    },
    {
      "block_id": "prov-17-2",
      "type": "verse",
      "number": 2,
      "text": "A slave who deals wisely will rule over a child who acts shamefully"
    },
    {
      "block_id": "prov-17-3",
      "type": "verse",
      "number": 3,
      "text": "The crucible is for silver and the furnace for gold,"
    },
    {
      "block_id": "prov-17-4",
      "type": "verse",
      "number": 4,
      "text": "An evildoer listens to wicked lips,"
    },
    {
      "block_id": "prov-17-5",
      "type": "verse",
      "number": 5,
      "text": "Those who mock the poor insult their Maker;"
    },
    {
      "block_id": "prov-17-6",
      "type": "verse",
      "number": 6,
      "text": "Grandchildren are the crown of the aged,"
    },
    {
      "block_id": "prov-17-7",
      "type": "verse",
      "number": 7,
      "text": "Excess speech is not becoming to a fool;"
    },
    {
      "block_id": "prov-17-8",
      "type": "verse",
      "number": 8,
      "text": "A bribe is like a magic stone in the eyes of those who give it;"
    },
    {
      "block_id": "prov-17-9",
      "type": "verse",
      "number": 9,
      "text": "One who forgives an affront fosters friendship,"
    },
    {
      "block_id": "prov-17-10",
      "type": "verse",
      "number": 10,
      "text": "A rebuke strikes deeper into a discerning person"
    },
    {
      "block_id": "prov-17-11",
      "type": "verse",
      "number": 11,
      "text": "Evil people seek only rebellion,"
    },
    {
      "block_id": "prov-17-12",
      "type": "verse",
      "number": 12,
      "text": "Better to meet a she-bear robbed of its cubs"
    },
    {
      "block_id": "prov-17-13",
      "type": "verse",
      "number": 13,
      "text": "Evil will not depart from the house"
    },
    {
      "block_id": "prov-17-14",
      "type": "verse",
      "number": 14,
      "text": "The beginning of strife is like letting out water,"
    },
    {
      "block_id": "prov-17-15",
      "type": "verse",
      "number": 15,
      "text": "One who justifies the wicked and one who condemns the righteous"
    },
    {
      "block_id": "prov-17-16",
      "type": "verse",
      "number": 16,
      "text": "Why should fools have a price in hand"
    },
    {
      "block_id": "prov-17-17",
      "type": "verse",
      "number": 17,
      "text": "A friend loves at all times,"
    },
    {
      "block_id": "prov-17-18",
      "type": "verse",
      "number": 18,
      "text": "It is senseless to give a pledge,"
    },
    {
      "block_id": "prov-17-19",
      "type": "verse",
      "number": 19,
      "text": "One who loves transgression loves strife;"
    },
    {
      "block_id": "prov-17-20",
      "type": "verse",
      "number": 20,
      "text": "The crooked of mind do not prosper,"
    },
    {
      "block_id": "prov-17-21",
      "type": "verse",
      "number": 21,
      "text": "The one who fathers a fool gets trouble;"
    },
    {
      "block_id": "prov-17-22",
      "type": "verse",
      "number": 22,
      "text": "A cheerful heart is a good medicine,"
    },
    {
      "block_id": "prov-17-23",
      "type": "verse",
      "number": 23,
      "text": "The wicked accept a concealed bribe"
    },
    {
      "block_id": "prov-17-24",
      "type": "verse",
      "number": 24,
      "text": "The discerning person looks to wisdom,"
    },
    {
      "block_id": "prov-17-25",
      "type": "verse",
      "number": 25,
      "text": "Foolish children are a grief to their father"
    },
    {
      "block_id": "prov-17-26",
      "type": "verse",
      "number": 26,
      "text": "To impose a fine on the innocent is not right"
    },
    {
      "block_id": "prov-17-27",
      "type": "verse",
      "number": 27,
      "text": "One who spares words is knowledgeable;"
    },
    {
      "block_id": "prov-17-28",
      "type": "verse",
      "number": 28,
      "text": "Even fools who keep silent are considered wise;"
    }
  ]
}