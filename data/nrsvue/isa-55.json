{
  "document_id": "isa-55",
  "title": "Isaiah 55",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-55-1",
      "type": "verse",
      "number": 1,
      "text": "Hear, everyone who thirsts;"
    },
    {
      "block_id": "isa-55-2",
      "type": "verse",
      "number": 2,
      "text": "Why do you spend your money for that which is not bread"
    },
    {
      "block_id": "isa-55-3",
      "type": "verse",
      "number": 3,
      "text": "Incline your ear, and come to me;"
    },
    {
      "block_id": "isa-55-4",
      "type": "verse",
      "number": 4,
      "text": "See, I made him a witness to the peoples,"
    },
    {
      "block_id": "isa-55-5",
      "type": "verse",
      "number": 5,
      "text": "Now you shall call nations that you do not know,"
    },
    {
      "block_id": "isa-55-6",
      "type": "verse",
      "number": 6,
      "text": "Seek the Lord while he may be found;"
    },
    {
      "block_id": "isa-55-7",
      "type": "verse",
      "number": 7,
      "text": "let the wicked forsake their way"
    },
    {
      "block_id": "isa-55-8",
      "type": "verse",
      "number": 8,
      "text": "For my thoughts are not your thoughts,"
    },
    {
      "block_id": "isa-55-9",
      "type": "verse",
      "number": 9,
      "text": "For as the heavens are higher than the earth,"
    },
    {
      "block_id": "isa-55-10",
      "type": "verse",
      "number": 10,
      "text": "For as the rain and the snow come down from heaven"
    },
    {
      "block_id": "isa-55-11",
      "type": "verse",
      "number": 11,
      "text": "so shall my word be that goes out from my mouth;"
    },
    {
      "block_id": "isa-55-12",
      "type": "verse",
      "number": 12,
      "text": "For you shall go out in joy"
    },
    {
      "block_id": "isa-55-13",
      "type": "verse",
      "number": 13,
      "text": "Instead of the thorn shall come up the cypress;"
    }
  ]
}