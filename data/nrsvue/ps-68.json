{
  "document_id": "ps-68",
  "title": "Psalms 68",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-68-1",
      "type": "verse",
      "number": 1,
      "text": "Let God rise up; let his enemies be scattered;"
    },
    {
      "block_id": "ps-68-2",
      "type": "verse",
      "number": 2,
      "text": "As smoke is driven away, so drive them away;"
    },
    {
      "block_id": "ps-68-3",
      "type": "verse",
      "number": 3,
      "text": "But let the righteous be joyful;"
    },
    {
      "block_id": "ps-68-4",
      "type": "verse",
      "number": 4,
      "text": "Sing to God; sing praises to his name;"
    },
    {
      "block_id": "ps-68-5",
      "type": "verse",
      "number": 5,
      "text": "Father of orphans and protector of widows"
    },
    {
      "block_id": "ps-68-6",
      "type": "verse",
      "number": 6,
      "text": "God gives the desolate a home to live in;"
    },
    {
      "block_id": "ps-68-7",
      "type": "verse",
      "number": 7,
      "text": "O God, when you went out before your people,"
    },
    {
      "block_id": "ps-68-8",
      "type": "verse",
      "number": 8,
      "text": "the earth quaked, the heavens poured down rain"
    },
    {
      "block_id": "ps-68-9",
      "type": "verse",
      "number": 9,
      "text": "Rain in abundance, O God, you showered abroad;"
    },
    {
      "block_id": "ps-68-10",
      "type": "verse",
      "number": 10,
      "text": "your flock found a dwelling in it;"
    },
    {
      "block_id": "ps-68-11",
      "type": "verse",
      "number": 11,
      "text": "The Lord gives the command;"
    },
    {
      "block_id": "ps-68-12",
      "type": "verse",
      "number": 12,
      "text": "“The kings of the armies, they flee, they flee!”"
    },
    {
      "block_id": "ps-68-13",
      "type": "verse",
      "number": 13,
      "text": "though they stay among the sheepfolds—"
    },
    {
      "block_id": "ps-68-14",
      "type": "verse",
      "number": 14,
      "text": "When the Almighty scattered kings there,"
    },
    {
      "block_id": "ps-68-15",
      "type": "verse",
      "number": 15,
      "text": "O mighty mountain, mountain of Bashan;"
    },
    {
      "block_id": "ps-68-16",
      "type": "verse",
      "number": 16,
      "text": "Why do you look with envy, O many-peaked mountain,"
    },
    {
      "block_id": "ps-68-17",
      "type": "verse",
      "number": 17,
      "text": "With mighty chariotry, twice ten thousand,"
    },
    {
      "block_id": "ps-68-18",
      "type": "verse",
      "number": 18,
      "text": "You ascended the high mount,"
    },
    {
      "block_id": "ps-68-19",
      "type": "verse",
      "number": 19,
      "text": "Blessed be the Lord,"
    },
    {
      "block_id": "ps-68-20",
      "type": "verse",
      "number": 20,
      "text": "Our God is a God of salvation,"
    },
    {
      "block_id": "ps-68-21",
      "type": "verse",
      "number": 21,
      "text": "But God will shatter the heads of his enemies,"
    },
    {
      "block_id": "ps-68-22",
      "type": "verse",
      "number": 22,
      "text": "The Lord said,"
    },
    {
      "block_id": "ps-68-23",
      "type": "verse",
      "number": 23,
      "text": "so that you may bathe your feet in blood,"
    },
    {
      "block_id": "ps-68-24",
      "type": "verse",
      "number": 24,
      "text": "Your solemn processions are seen, O God,"
    },
    {
      "block_id": "ps-68-25",
      "type": "verse",
      "number": 25,
      "text": "the singers in front, the musicians last,"
    },
    {
      "block_id": "ps-68-26",
      "type": "verse",
      "number": 26,
      "text": "“Bless God in the great congregation,"
    },
    {
      "block_id": "ps-68-27",
      "type": "verse",
      "number": 27,
      "text": "There is Benjamin, the least of them, in the lead,"
    },
    {
      "block_id": "ps-68-28",
      "type": "verse",
      "number": 28,
      "text": "Summon your might, O God;"
    },
    {
      "block_id": "ps-68-29",
      "type": "verse",
      "number": 29,
      "text": "Because of your temple at Jerusalem,"
    },
    {
      "block_id": "ps-68-30",
      "type": "verse",
      "number": 30,
      "text": "Rebuke the wild animals that live among the reeds,"
    },
    {
      "block_id": "ps-68-31",
      "type": "verse",
      "number": 31,
      "text": "Let bronze be brought from Egypt;"
    },
    {
      "block_id": "ps-68-32",
      "type": "verse",
      "number": 32,
      "text": "Sing to God, O kingdoms of the earth;"
    },
    {
      "block_id": "ps-68-33",
      "type": "verse",
      "number": 33,
      "text": "O rider in the heavens, the ancient heavens;"
    },
    {
      "block_id": "ps-68-34",
      "type": "verse",
      "number": 34,
      "text": "Ascribe power to God,"
    },
    {
      "block_id": "ps-68-35",
      "type": "verse",
      "number": 35,
      "text": "Awesome is God in his sanctuary,"
    }
  ]
}