{
  "document_id": "ps-19",
  "title": "Psalms 19",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-19-1",
      "type": "verse",
      "number": 1,
      "text": "The heavens are telling the glory of God,"
    },
    {
      "block_id": "ps-19-2",
      "type": "verse",
      "number": 2,
      "text": "Day to day pours forth speech,"
    },
    {
      "block_id": "ps-19-3",
      "type": "verse",
      "number": 3,
      "text": "There is no speech, nor are there words;"
    },
    {
      "block_id": "ps-19-4",
      "type": "verse",
      "number": 4,
      "text": "yet their voice goes out through all the earth"
    },
    {
      "block_id": "ps-19-5",
      "type": "verse",
      "number": 5,
      "text": "which comes out like a bridegroom from his wedding canopy,"
    },
    {
      "block_id": "ps-19-6",
      "type": "verse",
      "number": 6,
      "text": "Its rising is from the end of the heavens"
    },
    {
      "block_id": "ps-19-7",
      "type": "verse",
      "number": 7,
      "text": "The law of the Lord is perfect,"
    },
    {
      "block_id": "ps-19-8",
      "type": "verse",
      "number": 8,
      "text": "the precepts of the Lord are right,"
    },
    {
      "block_id": "ps-19-9",
      "type": "verse",
      "number": 9,
      "text": "the fear of the Lord is pure,"
    },
    {
      "block_id": "ps-19-10",
      "type": "verse",
      "number": 10,
      "text": "More to be desired are they than gold,"
    },
    {
      "block_id": "ps-19-11",
      "type": "verse",
      "number": 11,
      "text": "Moreover, by them is your servant warned;"
    },
    {
      "block_id": "ps-19-12",
      "type": "verse",
      "number": 12,
      "text": "But who can detect one’s own errors?"
    },
    {
      "block_id": "ps-19-13",
      "type": "verse",
      "number": 13,
      "text": "Keep back your servant also from the insolent;"
    },
    {
      "block_id": "ps-19-14",
      "type": "verse",
      "number": 14,
      "text": "Let the words of my mouth and the meditation of my heart"
    }
  ]
}