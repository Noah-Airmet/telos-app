  "blocks": [
    {
      "block_id": "isa-15-heading-an-oracle-concerning",
      "type": "heading",
      "text": "An Oracle concerning Moab"
    },
    {
      "block_id": "isa-15-1",
      "type": "verse",
      "number": 1,
      "text": "An oracle concerning Moab."
    },
    {
      "block_id": "isa-15-2",
      "type": "verse",
      "number": 2,
      "text": "Daughter Dibon has gone up"
    },
    {
      "block_id": "isa-15-3",
      "type": "verse",
      "number": 3,
      "text": "in the streets they bind on sackcloth;"
    },
    {
      "block_id": "isa-15-4",
      "type": "verse",
      "number": 4,
      "text": "Heshbon and Elealeh cry out;"
    },
    {
      "block_id": "isa-15-5",
      "type": "verse",
      "number": 5,
      "text": "My heart cries out for Moab;"
    },
    {
      "block_id": "isa-15-6",
      "type": "verse",
      "number": 6,
      "text": "the waters of Nimrim"
    },
    {
      "block_id": "isa-15-7",
      "type": "verse",
      "number": 7,
      "text": "Therefore the abundance they have gained"
    },
    {
      "block_id": "isa-15-8",
      "type": "verse",
      "number": 8,
      "text": "For a cry has gone"
    },
    {
      "block_id": "isa-15-9",
      "type": "verse",
      "number": 9,
      "text": "For the waters of Dibon are full of blood,"
    }
  ]
}