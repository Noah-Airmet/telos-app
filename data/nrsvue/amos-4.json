{
  "document_id": "amos-4",
  "title": "Amos 4",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "amos-4-1",
      "type": "verse",
      "number": 1,
      "text": "Hear this word, you cows of Bashan"
    },
    {
      "block_id": "amos-4-2",
      "type": "verse",
      "number": 2,
      "text": "The Lord God has sworn by his holiness:"
    },
    {
      "block_id": "amos-4-3",
      "type": "verse",
      "number": 3,
      "text": "Through breaches in the wall you shall leave,"
    },
    {
      "block_id": "amos-4-4",
      "type": "verse",
      "number": 4,
      "text": "Come to Bethel—and transgress;"
    },
    {
      "block_id": "amos-4-5",
      "type": "verse",
      "number": 5,
      "text": "bring a thank offering of leavened bread"
    },
    {
      "block_id": "amos-4-6",
      "type": "verse",
      "number": 6,
      "text": "I gave you cleanness of teeth in all your cities"
    },
    {
      "block_id": "amos-4-7",
      "type": "verse",
      "number": 7,
      "text": "And I also withheld the rain from you"
    },
    {
      "block_id": "amos-4-8",
      "type": "verse",
      "number": 8,
      "text": "so two or three towns wandered to one town"
    },
    {
      "block_id": "amos-4-9",
      "type": "verse",
      "number": 9,
      "text": "I struck you with blight and mildew;"
    },
    {
      "block_id": "amos-4-10",
      "type": "verse",
      "number": 10,
      "text": "I sent among you a pestilence after the manner of Egypt;"
    },
    {
      "block_id": "amos-4-11",
      "type": "verse",
      "number": 11,
      "text": "I overthrew some of you"
    },
    {
      "block_id": "amos-4-12",
      "type": "verse",
      "number": 12,
      "text": "Therefore thus I will do to you, O Israel;"
    },
    {
      "block_id": "amos-4-13",
      "type": "verse",
      "number": 13,
      "text": "For the one who forms the mountains, creates the wind,"
    }
  ]
}