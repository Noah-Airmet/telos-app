{
  "document_id": "ps-4",
  "title": "Psalms 4",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-4-1",
      "type": "verse",
      "number": 1,
      "text": "Answer me when I call, O God of my right!"
    },
    {
      "block_id": "ps-4-2",
      "type": "verse",
      "number": 2,
      "text": "How long, you people, shall my honor suffer shame?"
    },
    {
      "block_id": "ps-4-3",
      "type": "verse",
      "number": 3,
      "text": "But know that the Lord has set apart the faithful for himself;"
    },
    {
      "block_id": "ps-4-4",
      "type": "verse",
      "number": 4,
      "text": "When you are disturbed, do not sin;"
    },
    {
      "block_id": "ps-4-5",
      "type": "verse",
      "number": 5,
      "text": "Offer right sacrifices,"
    },
    {
      "block_id": "ps-4-6",
      "type": "verse",
      "number": 6,
      "text": "There are many who say, “O that we might see some good!"
    },
    {
      "block_id": "ps-4-7",
      "type": "verse",
      "number": 7,
      "text": "You have put gladness in my heart"
    },
    {
      "block_id": "ps-4-8",
      "type": "verse",
      "number": 8,
      "text": "I will both lie down and sleep in peace,"
    }
  ]
}