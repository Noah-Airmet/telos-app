{
  "document_id": "prov-6",
  "title": "Proverbs 6",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-6-1",
      "type": "verse",
      "number": 1,
      "text": "My child, if you have given your pledge to your neighbor,"
    },
    {
      "block_id": "prov-6-2",
      "type": "verse",
      "number": 2,
      "text": "you are snared by the utterance of your lips,"
    },
    {
      "block_id": "prov-6-3",
      "type": "verse",
      "number": 3,
      "text": "So do this, my child, and save yourself,"
    },
    {
      "block_id": "prov-6-4",
      "type": "verse",
      "number": 4,
      "text": "Give your eyes no sleep"
    },
    {
      "block_id": "prov-6-5",
      "type": "verse",
      "number": 5,
      "text": "save yourself like a gazelle from the hunter,"
    },
    {
      "block_id": "prov-6-6",
      "type": "verse",
      "number": 6,
      "text": "Go to the ant, you lazybones;"
    },
    {
      "block_id": "prov-6-7",
      "type": "verse",
      "number": 7,
      "text": "Without having any chief"
    },
    {
      "block_id": "prov-6-8",
      "type": "verse",
      "number": 8,
      "text": "it prepares its food in summer"
    },
    {
      "block_id": "prov-6-9",
      "type": "verse",
      "number": 9,
      "text": "How long will you lie there, O lazybones?"
    },
    {
      "block_id": "prov-6-10",
      "type": "verse",
      "number": 10,
      "text": "A little sleep, a little slumber,"
    },
    {
      "block_id": "prov-6-11",
      "type": "verse",
      "number": 11,
      "text": "and poverty will come upon you like a robber,"
    },
    {
      "block_id": "prov-6-12",
      "type": "verse",
      "number": 12,
      "text": "A scoundrel and a villain"
    },
    {
      "block_id": "prov-6-13",
      "type": "verse",
      "number": 13,
      "text": "winking the eyes, shuffling the feet,"
    },
    {
      "block_id": "prov-6-14",
      "type": "verse",
      "number": 14,
      "text": "with perverted mind devising evil,"
    },
    {
      "block_id": "prov-6-15",
      "type": "verse",
      "number": 15,
      "text": "on such a one calamity will descend suddenly,"
    },
    {
      "block_id": "prov-6-16",
      "type": "verse",
      "number": 16,
      "text": "There are six things that the Lord hates,"
    },
    {
      "block_id": "prov-6-17",
      "type": "verse",
      "number": 17,
      "text": "haughty eyes, a lying tongue,"
    },
    {
      "block_id": "prov-6-18",
      "type": "verse",
      "number": 18,
      "text": "a heart that devises wicked plans,"
    },
    {
      "block_id": "prov-6-19",
      "type": "verse",
      "number": 19,
      "text": "a lying witness who testifies falsely,"
    },
    {
      "block_id": "prov-6-20",
      "type": "verse",
      "number": 20,
      "text": "My child, keep your father’s commandment,"
    },
    {
      "block_id": "prov-6-21",
      "type": "verse",
      "number": 21,
      "text": "Bind them upon your heart always;"
    },
    {
      "block_id": "prov-6-22",
      "type": "verse",
      "number": 22,
      "text": "When you walk, they will lead you;"
    },
    {
      "block_id": "prov-6-23",
      "type": "verse",
      "number": 23,
      "text": "For the commandment is a lamp and the teaching a light,"
    },
    {
      "block_id": "prov-6-24",
      "type": "verse",
      "number": 24,
      "text": "to preserve you from the wife of another,"
    },
    {
      "block_id": "prov-6-25",
      "type": "verse",
      "number": 25,
      "text": "Do not desire her beauty in your heart,"
    },
    {
      "block_id": "prov-6-26",
      "type": "verse",
      "number": 26,
      "text": "for a prostitute’s fee is only a loaf of bread,"
    },
    {
      "block_id": "prov-6-27",
      "type": "verse",
      "number": 27,
      "text": "Can fire be carried in the bosom"
    },
    {
      "block_id": "prov-6-28",
      "type": "verse",
      "number": 28,
      "text": "Or can one walk on hot coals"
    },
    {
      "block_id": "prov-6-29",
      "type": "verse",
      "number": 29,
      "text": "So is he who sleeps with his neighbor’s wife;"
    },
    {
      "block_id": "prov-6-30",
      "type": "verse",
      "number": 30,
      "text": "Thieves are not despised who steal only"
    },
    {
      "block_id": "prov-6-31",
      "type": "verse",
      "number": 31,
      "text": "Yet if they are caught, they will pay sevenfold;"
    },
    {
      "block_id": "prov-6-32",
      "type": "verse",
      "number": 32,
      "text": "But he who commits adultery has no sense;"
    },
    {
      "block_id": "prov-6-33",
      "type": "verse",
      "number": 33,
      "text": "He will get wounds and dishonor,"
    },
    {
      "block_id": "prov-6-34",
      "type": "verse",
      "number": 34,
      "text": "For jealousy arouses a husband’s fury,"
    },
    {
      "block_id": "prov-6-35",
      "type": "verse",
      "number": 35,
      "text": "He will accept no compensation"
    }
  ]
}