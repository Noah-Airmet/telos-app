{
  "document_id": "jer-47",
  "title": "Jeremiah 47",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "jer-47-heading-judgment-on-the-phil",
      "type": "heading",
      "text": "Judgment on the Philistines"
    },
    {
      "block_id": "jer-47-1",
      "type": "verse",
      "number": 1,
      "text": "The word of the Lord that came to the prophet Jeremiah concerning the Philistines, before Pharaoh attacked Gaza:"
    },
    {
      "block_id": "jer-47-2",
      "type": "verse",
      "number": 2,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "jer-47-3",
      "type": "verse",
      "number": 3,
      "text": "At the noise of the stamping of the hoofs of his stallions,"
    },
    {
      "block_id": "jer-47-4",
      "type": "verse",
      "number": 4,
      "text": "because of the day that is coming"
    },
    {
      "block_id": "jer-47-5",
      "type": "verse",
      "number": 5,
      "text": "Baldness has come upon Gaza;"
    },
    {
      "block_id": "jer-47-6",
      "type": "verse",
      "number": 6,
      "text": "Ah, sword of the Lord!"
    },
    {
      "block_id": "jer-47-7",
      "type": "verse",
      "number": 7,
      "text": "How can it be quiet,"
    }
  ]
}