{
  "document_id": "job-5",
  "title": "Job 5",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-5-1",
      "type": "verse",
      "number": 1,
      "text": "“Call now; is there anyone who will answer you?"
    },
    {
      "block_id": "job-5-2",
      "type": "verse",
      "number": 2,
      "text": "Surely vexation kills the fool,"
    },
    {
      "block_id": "job-5-3",
      "type": "verse",
      "number": 3,
      "text": "I have seen fools taking root,"
    },
    {
      "block_id": "job-5-4",
      "type": "verse",
      "number": 4,
      "text": "Their children are far from safety,"
    },
    {
      "block_id": "job-5-5",
      "type": "verse",
      "number": 5,
      "text": "The hungry eat their harvest,"
    },
    {
      "block_id": "job-5-6",
      "type": "verse",
      "number": 6,
      "text": "For misery does not come from the earth,"
    },
    {
      "block_id": "job-5-7",
      "type": "verse",
      "number": 7,
      "text": "but humans are born to trouble"
    },
    {
      "block_id": "job-5-8",
      "type": "verse",
      "number": 8,
      "text": "“As for me, I would seek God,"
    },
    {
      "block_id": "job-5-9",
      "type": "verse",
      "number": 9,
      "text": "He does great things and unsearchable,"
    },
    {
      "block_id": "job-5-10",
      "type": "verse",
      "number": 10,
      "text": "He gives rain on the earth"
    },
    {
      "block_id": "job-5-11",
      "type": "verse",
      "number": 11,
      "text": "he sets on high those who are lowly,"
    },
    {
      "block_id": "job-5-12",
      "type": "verse",
      "number": 12,
      "text": "He frustrates the devices of the crafty,"
    },
    {
      "block_id": "job-5-13",
      "type": "verse",
      "number": 13,
      "text": "He takes the wise in their own craftiness,"
    },
    {
      "block_id": "job-5-14",
      "type": "verse",
      "number": 14,
      "text": "They meet with darkness in the daytime"
    },
    {
      "block_id": "job-5-15",
      "type": "verse",
      "number": 15,
      "text": "But he saves the needy from the sword of their mouth,"
    },
    {
      "block_id": "job-5-16",
      "type": "verse",
      "number": 16,
      "text": "So the poor have hope,"
    },
    {
      "block_id": "job-5-17",
      "type": "verse",
      "number": 17,
      "text": "“How happy is the one whom God reproves;"
    },
    {
      "block_id": "job-5-18",
      "type": "verse",
      "number": 18,
      "text": "For he wounds, but he binds up;"
    },
    {
      "block_id": "job-5-19",
      "type": "verse",
      "number": 19,
      "text": "He will deliver you from six troubles;"
    },
    {
      "block_id": "job-5-20",
      "type": "verse",
      "number": 20,
      "text": "In famine he will redeem you from death"
    },
    {
      "block_id": "job-5-21",
      "type": "verse",
      "number": 21,
      "text": "You shall be hidden from the scourge of the tongue"
    },
    {
      "block_id": "job-5-22",
      "type": "verse",
      "number": 22,
      "text": "At destruction and famine you shall laugh"
    },
    {
      "block_id": "job-5-23",
      "type": "verse",
      "number": 23,
      "text": "For you shall be in league with the stones of the field,"
    },
    {
      "block_id": "job-5-24",
      "type": "verse",
      "number": 24,
      "text": "You shall know that your tent is safe;"
    },
    {
      "block_id": "job-5-25",
      "type": "verse",
      "number": 25,
      "text": "You shall know that your descendants will be many"
    },
    {
      "block_id": "job-5-26",
      "type": "verse",
      "number": 26,
      "text": "You shall come to your grave in ripe old age,"
    },
    {
      "block_id": "job-5-27",
      "type": "verse",
      "number": 27,
      "text": "See, we have searched this out; it is true."
    }
  ]
}