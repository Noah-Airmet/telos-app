{
  "document_id": "prov-23",
  "title": "Proverbs 23",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-23-1",
      "type": "verse",
      "number": 1,
      "text": "When you sit down to eat with an official,"
    },
    {
      "block_id": "prov-23-2",
      "type": "verse",
      "number": 2,
      "text": "and put a knife to your throat"
    },
    {
      "block_id": "prov-23-3",
      "type": "verse",
      "number": 3,
      "text": "Do not desire an official’s delicacies,"
    },
    {
      "block_id": "prov-23-4",
      "type": "verse",
      "number": 4,
      "text": "Do not wear yourself out to get rich;"
    },
    {
      "block_id": "prov-23-5",
      "type": "verse",
      "number": 5,
      "text": "When your eyes light upon it, it is gone,"
    },
    {
      "block_id": "prov-23-6",
      "type": "verse",
      "number": 6,
      "text": "Do not eat the bread of the stingy;"
    },
    {
      "block_id": "prov-23-7",
      "type": "verse",
      "number": 7,
      "text": "for like a hair in the throat, so are they."
    },
    {
      "block_id": "prov-23-8",
      "type": "verse",
      "number": 8,
      "text": "You will vomit up the little you have eaten,"
    },
    {
      "block_id": "prov-23-9",
      "type": "verse",
      "number": 9,
      "text": "Do not speak in the hearing of a fool,"
    },
    {
      "block_id": "prov-23-10",
      "type": "verse",
      "number": 10,
      "text": "Do not remove an ancient landmark"
    },
    {
      "block_id": "prov-23-11",
      "type": "verse",
      "number": 11,
      "text": "for their vindicator is strong;"
    },
    {
      "block_id": "prov-23-12",
      "type": "verse",
      "number": 12,
      "text": "Apply your mind to instruction"
    },
    {
      "block_id": "prov-23-13",
      "type": "verse",
      "number": 13,
      "text": "Do not withhold discipline from your children;"
    },
    {
      "block_id": "prov-23-14",
      "type": "verse",
      "number": 14,
      "text": "If you beat them with the rod,"
    },
    {
      "block_id": "prov-23-15",
      "type": "verse",
      "number": 15,
      "text": "My child, if your heart is wise,"
    },
    {
      "block_id": "prov-23-16",
      "type": "verse",
      "number": 16,
      "text": "My soul will rejoice"
    },
    {
      "block_id": "prov-23-17",
      "type": "verse",
      "number": 17,
      "text": "Do not let your heart envy sinners,"
    },
    {
      "block_id": "prov-23-18",
      "type": "verse",
      "number": 18,
      "text": "Surely there is a future,"
    },
    {
      "block_id": "prov-23-19",
      "type": "verse",
      "number": 19,
      "text": "Hear, my child, and be wise,"
    },
    {
      "block_id": "prov-23-20",
      "type": "verse",
      "number": 20,
      "text": "Do not be among winebibbers"
    },
    {
      "block_id": "prov-23-21",
      "type": "verse",
      "number": 21,
      "text": "for the drunkard and the glutton will come to poverty,"
    },
    {
      "block_id": "prov-23-22",
      "type": "verse",
      "number": 22,
      "text": "Listen to your father who begot you,"
    },
    {
      "block_id": "prov-23-23",
      "type": "verse",
      "number": 23,
      "text": "Buy truth, and do not sell it;"
    },
    {
      "block_id": "prov-23-24",
      "type": "verse",
      "number": 24,
      "text": "The father of the righteous will greatly rejoice;"
    },
    {
      "block_id": "prov-23-25",
      "type": "verse",
      "number": 25,
      "text": "Let your father and mother be glad;"
    },
    {
      "block_id": "prov-23-26",
      "type": "verse",
      "number": 26,
      "text": "My child, give me your heart,"
    },
    {
      "block_id": "prov-23-27",
      "type": "verse",
      "number": 27,
      "text": "For a prostitute is a deep pit;"
    },
    {
      "block_id": "prov-23-28",
      "type": "verse",
      "number": 28,
      "text": "She lies in wait like a robber"
    },
    {
      "block_id": "prov-23-29",
      "type": "verse",
      "number": 29,
      "text": "Who has woe? Who has sorrow?"
    },
    {
      "block_id": "prov-23-30",
      "type": "verse",
      "number": 30,
      "text": "Those who linger late over wine,"
    },
    {
      "block_id": "prov-23-31",
      "type": "verse",
      "number": 31,
      "text": "Do not look at wine when it is red,"
    },
    {
      "block_id": "prov-23-32",
      "type": "verse",
      "number": 32,
      "text": "At the last it bites like a serpent"
    },
    {
      "block_id": "prov-23-33",
      "type": "verse",
      "number": 33,
      "text": "Your eyes will see strange things,"
    },
    {
      "block_id": "prov-23-34",
      "type": "verse",
      "number": 34,
      "text": "You will be like one who lies down in the midst of the sea,"
    },
    {
      "block_id": "prov-23-35",
      "type": "verse",
      "number": 35,
      "text": "“They struck me,” you will say, “but I was not hurt;"
    }
  ]
}