{
  "document_id": "jonah-2",
  "title": "Jonah 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "jonah-2-heading-a-psalm-of-thanksgiv",
      "type": "heading",
      "text": "A Psalm of Thanksgiving"
    },
    {
      "block_id": "jonah-2-1",
      "type": "verse",
      "number": 1,
      "text": "Then Jonah prayed to the Lord his God from the belly of the fish,"
    },
    {
      "block_id": "jonah-2-2",
      "type": "verse",
      "number": 2,
      "text": "saying,"
    },
    {
      "block_id": "jonah-2-3",
      "type": "verse",
      "number": 3,
      "text": "You cast me into the deep,"
    },
    {
      "block_id": "jonah-2-4",
      "type": "verse",
      "number": 4,
      "text": "Then I said, ‘I am driven away"
    },
    {
      "block_id": "jonah-2-5",
      "type": "verse",
      "number": 5,
      "text": "The waters closed in over me;"
    },
    {
      "block_id": "jonah-2-6",
      "type": "verse",
      "number": 6,
      "text": "at the roots of the mountains."
    },
    {
      "block_id": "jonah-2-7",
      "type": "verse",
      "number": 7,
      "text": "As my life was ebbing away,"
    },
    {
      "block_id": "jonah-2-8",
      "type": "verse",
      "number": 8,
      "text": "Those who worship vain idols"
    },
    {
      "block_id": "jonah-2-9",
      "type": "verse",
      "number": 9,
      "text": "But I with the voice of thanksgiving"
    },
    {
      "block_id": "jonah-2-10",
      "type": "verse",
      "number": 10,
      "text": "Then the Lord spoke to the fish, and it vomited Jonah out onto the dry land."
    }
  ]
}