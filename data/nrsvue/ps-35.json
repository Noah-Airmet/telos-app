{
  "document_id": "ps-35",
  "title": "Psalms 35",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-35-1",
      "type": "verse",
      "number": 1,
      "text": "Contend, O Lord, with those who contend with me;"
    },
    {
      "block_id": "ps-35-2",
      "type": "verse",
      "number": 2,
      "text": "Take hold of shield and buckler,"
    },
    {
      "block_id": "ps-35-3",
      "type": "verse",
      "number": 3,
      "text": "Draw the spear and javelin"
    },
    {
      "block_id": "ps-35-4",
      "type": "verse",
      "number": 4,
      "text": "Let them be put to shame and dishonor"
    },
    {
      "block_id": "ps-35-5",
      "type": "verse",
      "number": 5,
      "text": "Let them be like chaff before the wind,"
    },
    {
      "block_id": "ps-35-6",
      "type": "verse",
      "number": 6,
      "text": "Let their way be dark and slippery,"
    },
    {
      "block_id": "ps-35-7",
      "type": "verse",
      "number": 7,
      "text": "For without cause they hid their net for me;"
    },
    {
      "block_id": "ps-35-8",
      "type": "verse",
      "number": 8,
      "text": "Let ruin come on them unawares,"
    },
    {
      "block_id": "ps-35-9",
      "type": "verse",
      "number": 9,
      "text": "Then my soul shall rejoice in the Lord,"
    },
    {
      "block_id": "ps-35-10",
      "type": "verse",
      "number": 10,
      "text": "All my bones shall say,"
    },
    {
      "block_id": "ps-35-11",
      "type": "verse",
      "number": 11,
      "text": "Malicious witnesses rise up;"
    },
    {
      "block_id": "ps-35-12",
      "type": "verse",
      "number": 12,
      "text": "They repay me evil for good;"
    },
    {
      "block_id": "ps-35-13",
      "type": "verse",
      "number": 13,
      "text": "But as for me, when they were sick,"
    },
    {
      "block_id": "ps-35-14",
      "type": "verse",
      "number": 14,
      "text": "as though I grieved for a friend or a brother;"
    },
    {
      "block_id": "ps-35-15",
      "type": "verse",
      "number": 15,
      "text": "But at my stumbling they gathered in glee;"
    },
    {
      "block_id": "ps-35-16",
      "type": "verse",
      "number": 16,
      "text": "they impiously mocked more and more,"
    },
    {
      "block_id": "ps-35-17",
      "type": "verse",
      "number": 17,
      "text": "How long, O Lord, will you look on?"
    },
    {
      "block_id": "ps-35-18",
      "type": "verse",
      "number": 18,
      "text": "Then I will thank you in the great congregation;"
    },
    {
      "block_id": "ps-35-19",
      "type": "verse",
      "number": 19,
      "text": "Do not let my treacherous enemies rejoice over me"
    },
    {
      "block_id": "ps-35-20",
      "type": "verse",
      "number": 20,
      "text": "For they do not speak peace,"
    },
    {
      "block_id": "ps-35-21",
      "type": "verse",
      "number": 21,
      "text": "They open wide their mouths against me;"
    },
    {
      "block_id": "ps-35-22",
      "type": "verse",
      "number": 22,
      "text": "You have seen, O Lord; do not be silent!"
    },
    {
      "block_id": "ps-35-23",
      "type": "verse",
      "number": 23,
      "text": "Wake up! Rouse yourself for my defense,"
    },
    {
      "block_id": "ps-35-24",
      "type": "verse",
      "number": 24,
      "text": "Vindicate me, O Lord, my God,"
    },
    {
      "block_id": "ps-35-25",
      "type": "verse",
      "number": 25,
      "text": "Do not let them say to themselves,"
    },
    {
      "block_id": "ps-35-26",
      "type": "verse",
      "number": 26,
      "text": "Let all those who rejoice at my calamity"
    },
    {
      "block_id": "ps-35-27",
      "type": "verse",
      "number": 27,
      "text": "Let those who desire my vindication"
    },
    {
      "block_id": "ps-35-28",
      "type": "verse",
      "number": 28,
      "text": "Then my tongue shall tell of your righteousness"
    }
  ]
}