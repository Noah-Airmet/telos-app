{
  "document_id": "isa-56",
  "title": "Isaiah 56",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-56-1",
      "type": "verse",
      "number": 1,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "isa-56-2",
      "type": "verse",
      "number": 2,
      "text": "Happy is the mortal who does this,"
    },
    {
      "block_id": "isa-56-3",
      "type": "verse",
      "number": 3,
      "text": "Do not let the foreigner joined to the Lord say,"
    },
    {
      "block_id": "isa-56-4",
      "type": "verse",
      "number": 4,
      "text": "For thus says the Lord:"
    },
    {
      "block_id": "isa-56-5",
      "type": "verse",
      "number": 5,
      "text": "I will give, in my house and within my walls,"
    },
    {
      "block_id": "isa-56-6",
      "type": "verse",
      "number": 6,
      "text": "And the foreigners who join themselves to the Lord,"
    },
    {
      "block_id": "isa-56-7",
      "type": "verse",
      "number": 7,
      "text": "these I will bring to my holy mountain"
    },
    {
      "block_id": "isa-56-8",
      "type": "verse",
      "number": 8,
      "text": "Thus says the Lord God,"
    },
    {
      "block_id": "isa-56-9",
      "type": "verse",
      "number": 9,
      "text": "All you wild animals,"
    },
    {
      "block_id": "isa-56-10",
      "type": "verse",
      "number": 10,
      "text": "Israel’s sentinels are blind;"
    },
    {
      "block_id": "isa-56-11",
      "type": "verse",
      "number": 11,
      "text": "The dogs have a mighty appetite;"
    },
    {
      "block_id": "isa-56-12",
      "type": "verse",
      "number": 12,
      "text": "“Come,” they say, “let us get wine;"
    }
  ]
}