{
  "document_id": "prov-2",
  "title": "Proverbs 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-2-1",
      "type": "verse",
      "number": 1,
      "text": "My child, if you accept my words"
    },
    {
      "block_id": "prov-2-2",
      "type": "verse",
      "number": 2,
      "text": "making your ear attentive to wisdom"
    },
    {
      "block_id": "prov-2-3",
      "type": "verse",
      "number": 3,
      "text": "if you indeed cry out for insight"
    },
    {
      "block_id": "prov-2-4",
      "type": "verse",
      "number": 4,
      "text": "if you seek it like silver"
    },
    {
      "block_id": "prov-2-5",
      "type": "verse",
      "number": 5,
      "text": "then you will understand the fear of the Lord"
    },
    {
      "block_id": "prov-2-6",
      "type": "verse",
      "number": 6,
      "text": "For the Lord gives wisdom;"
    },
    {
      "block_id": "prov-2-7",
      "type": "verse",
      "number": 7,
      "text": "he stores up sound wisdom for the upright;"
    },
    {
      "block_id": "prov-2-8",
      "type": "verse",
      "number": 8,
      "text": "guarding the paths of justice"
    },
    {
      "block_id": "prov-2-9",
      "type": "verse",
      "number": 9,
      "text": "Then you will understand righteousness and justice"
    },
    {
      "block_id": "prov-2-10",
      "type": "verse",
      "number": 10,
      "text": "for wisdom will come into your heart,"
    },
    {
      "block_id": "prov-2-11",
      "type": "verse",
      "number": 11,
      "text": "prudence will watch over you,"
    },
    {
      "block_id": "prov-2-12",
      "type": "verse",
      "number": 12,
      "text": "It will save you from the way of evil,"
    },
    {
      "block_id": "prov-2-13",
      "type": "verse",
      "number": 13,
      "text": "who forsake the paths of uprightness"
    },
    {
      "block_id": "prov-2-14",
      "type": "verse",
      "number": 14,
      "text": "who rejoice in doing evil"
    },
    {
      "block_id": "prov-2-15",
      "type": "verse",
      "number": 15,
      "text": "those whose paths are crooked"
    },
    {
      "block_id": "prov-2-16",
      "type": "verse",
      "number": 16,
      "text": "You will be saved from the loose woman,"
    },
    {
      "block_id": "prov-2-17",
      "type": "verse",
      "number": 17,
      "text": "who forsakes the partner of her youth"
    },
    {
      "block_id": "prov-2-18",
      "type": "verse",
      "number": 18,
      "text": "for her way leads down to death"
    },
    {
      "block_id": "prov-2-19",
      "type": "verse",
      "number": 19,
      "text": "those who go to her never come back,"
    },
    {
      "block_id": "prov-2-20",
      "type": "verse",
      "number": 20,
      "text": "Therefore walk in the way of the good,"
    },
    {
      "block_id": "prov-2-21",
      "type": "verse",
      "number": 21,
      "text": "For the upright will abide in the land,"
    },
    {
      "block_id": "prov-2-22",
      "type": "verse",
      "number": 22,
      "text": "but the wicked will be cut off from the earth,"
    }
  ]
}