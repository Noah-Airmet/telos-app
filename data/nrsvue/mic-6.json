{
  "document_id": "mic-6",
  "title": "Micah 6",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "mic-6-1",
      "type": "verse",
      "number": 1,
      "text": "Hear what the Lord says:"
    },
    {
      "block_id": "mic-6-2",
      "type": "verse",
      "number": 2,
      "text": "Hear, you mountains, the case of the Lord,"
    },
    {
      "block_id": "mic-6-3",
      "type": "verse",
      "number": 3,
      "text": "“O my people, what have I done to you?"
    },
    {
      "block_id": "mic-6-4",
      "type": "verse",
      "number": 4,
      "text": "For I brought you up from the land of Egypt"
    },
    {
      "block_id": "mic-6-5",
      "type": "verse",
      "number": 5,
      "text": "O my people, remember now what King Balak of Moab devised,"
    },
    {
      "block_id": "mic-6-6",
      "type": "verse",
      "number": 6,
      "text": "“With what shall I come before the Lord"
    },
    {
      "block_id": "mic-6-7",
      "type": "verse",
      "number": 7,
      "text": "Will the Lord be pleased with thousands of rams,"
    },
    {
      "block_id": "mic-6-8",
      "type": "verse",
      "number": 8,
      "text": "He has told you, O mortal, what is good,"
    },
    {
      "block_id": "mic-6-9",
      "type": "verse",
      "number": 9,
      "text": "The voice of the Lord cries to the city"
    },
    {
      "block_id": "mic-6-10",
      "type": "verse",
      "number": 10,
      "text": "Can I forget the treasures of wickedness in the house of the wicked"
    },
    {
      "block_id": "mic-6-11",
      "type": "verse",
      "number": 11,
      "text": "Can I tolerate wicked scales"
    },
    {
      "block_id": "mic-6-12",
      "type": "verse",
      "number": 12,
      "text": "Your wealthy are full of violence;"
    },
    {
      "block_id": "mic-6-13",
      "type": "verse",
      "number": 13,
      "text": "Therefore I have begun to strike you down,"
    },
    {
      "block_id": "mic-6-14",
      "type": "verse",
      "number": 14,
      "text": "You shall eat but not be satisfied,"
    },
    {
      "block_id": "mic-6-15",
      "type": "verse",
      "number": 15,
      "text": "You shall sow but not reap;"
    },
    {
      "block_id": "mic-6-16",
      "type": "verse",
      "number": 16,
      "text": "For you have kept the statutes of Omri"
    }
  ]
}