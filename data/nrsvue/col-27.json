{
  "document_id": "col-27",
  "title": "Colossians 27",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-27-1",
      "type": "verse",
      "number": 1,
      "text": "Many have committed sin for gain,"
    },
    {
      "block_id": "col-27-2",
      "type": "verse",
      "number": 2,
      "text": "As a stake is driven firmly into a fissure between stones,"
    },
    {
      "block_id": "col-27-3",
      "type": "verse",
      "number": 3,
      "text": "If a person is not steadfast in the fear of the Lord,"
    },
    {
      "block_id": "col-27-4",
      "type": "verse",
      "number": 4,
      "text": "When a sieve is shaken, the refuse appears;"
    },
    {
      "block_id": "col-27-5",
      "type": "verse",
      "number": 5,
      "text": "The kiln tests the potter’s vessels,"
    },
    {
      "block_id": "col-27-6",
      "type": "verse",
      "number": 6,
      "text": "Its fruit discloses the cultivation of a tree;"
    },
    {
      "block_id": "col-27-7",
      "type": "verse",
      "number": 7,
      "text": "Do not praise anyone before he speaks,"
    },
    {
      "block_id": "col-27-8",
      "type": "verse",
      "number": 8,
      "text": "If you pursue justice, you will attain it"
    },
    {
      "block_id": "col-27-9",
      "type": "verse",
      "number": 9,
      "text": "Birds roost with their own kind,"
    },
    {
      "block_id": "col-27-10",
      "type": "verse",
      "number": 10,
      "text": "A lion lies in wait for prey;"
    },
    {
      "block_id": "col-27-11",
      "type": "verse",
      "number": 11,
      "text": "The conversation of the godly is always wise,"
    },
    {
      "block_id": "col-27-12",
      "type": "verse",
      "number": 12,
      "text": "Among stupid people limit your time,"
    },
    {
      "block_id": "col-27-13",
      "type": "verse",
      "number": 13,
      "text": "The talk of fools is offensive,"
    },
    {
      "block_id": "col-27-14",
      "type": "verse",
      "number": 14,
      "text": "Their cursing and swearing make one’s hair stand on end,"
    },
    {
      "block_id": "col-27-15",
      "type": "verse",
      "number": 15,
      "text": "The strife of the proud leads to bloodshed,"
    },
    {
      "block_id": "col-27-16",
      "type": "verse",
      "number": 16,
      "text": "Whoever betrays secrets destroys confidence"
    },
    {
      "block_id": "col-27-17",
      "type": "verse",
      "number": 17,
      "text": "Love your friends and keep faith with them,"
    },
    {
      "block_id": "col-27-18",
      "type": "verse",
      "number": 18,
      "text": "For as a person destroys an enemy,"
    },
    {
      "block_id": "col-27-19",
      "type": "verse",
      "number": 19,
      "text": "And as you allow a bird to escape from your hand,"
    },
    {
      "block_id": "col-27-20",
      "type": "verse",
      "number": 20,
      "text": "Do not go after him, for he is too far off"
    },
    {
      "block_id": "col-27-21",
      "type": "verse",
      "number": 21,
      "text": "For a wound may be bandaged,"
    },
    {
      "block_id": "col-27-22",
      "type": "verse",
      "number": 22,
      "text": "Whoever winks the eye plots harm,"
    },
    {
      "block_id": "col-27-23",
      "type": "verse",
      "number": 23,
      "text": "In your presence their mouths are all sweetness,"
    },
    {
      "block_id": "col-27-24",
      "type": "verse",
      "number": 24,
      "text": "I have hated many things but them above all;"
    },
    {
      "block_id": "col-27-25",
      "type": "verse",
      "number": 25,
      "text": "Those who throw a stone straight up throw it on their own heads,"
    },
    {
      "block_id": "col-27-26",
      "type": "verse",
      "number": 26,
      "text": "Whoever digs a pit will fall into it,"
    },
    {
      "block_id": "col-27-27",
      "type": "verse",
      "number": 27,
      "text": "If people do evil, it will roll back upon them,"
    },
    {
      "block_id": "col-27-28",
      "type": "verse",
      "number": 28,
      "text": "Mockery and abuse issue from the proud,"
    },
    {
      "block_id": "col-27-29",
      "type": "verse",
      "number": 29,
      "text": "Those who rejoice in the fall of the godly will be caught in a snare,"
    },
    {
      "block_id": "col-27-30",
      "type": "verse",
      "number": 30,
      "text": "Anger and wrath, these also are abominations,"
    }
  ]
}