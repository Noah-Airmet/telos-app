{
  "document_id": "nahum-2",
  "title": "Nahum 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "nahum-2-heading-the-destruction-of-t",
      "type": "heading",
      "text": "The Destruction of the Wicked City"
    },
    {
      "block_id": "nahum-2-1",
      "type": "verse",
      "number": 1,
      "text": "A scatterer has come up against you."
    },
    {
      "block_id": "nahum-2-2",
      "type": "verse",
      "number": 2,
      "text": "(For the Lord is restoring the majesty of Jacob,"
    },
    {
      "block_id": "nahum-2-3",
      "type": "verse",
      "number": 3,
      "text": "The shields of his warriors are red;"
    },
    {
      "block_id": "nahum-2-4",
      "type": "verse",
      "number": 4,
      "text": "The chariots race madly through the streets;"
    },
    {
      "block_id": "nahum-2-5",
      "type": "verse",
      "number": 5,
      "text": "He calls his officers;"
    },
    {
      "block_id": "nahum-2-6",
      "type": "verse",
      "number": 6,
      "text": "The river gates are opened;"
    },
    {
      "block_id": "nahum-2-7",
      "type": "verse",
      "number": 7,
      "text": "It is decreed that the city be exiled,"
    },
    {
      "block_id": "nahum-2-8",
      "type": "verse",
      "number": 8,
      "text": "Nineveh is like a pool"
    },
    {
      "block_id": "nahum-2-9",
      "type": "verse",
      "number": 9,
      "text": "“Plunder the silver;"
    },
    {
      "block_id": "nahum-2-10",
      "type": "verse",
      "number": 10,
      "text": "Devastation, desolation, and destruction!"
    },
    {
      "block_id": "nahum-2-11",
      "type": "verse",
      "number": 11,
      "text": "What became of the lions’ den,"
    },
    {
      "block_id": "nahum-2-12",
      "type": "verse",
      "number": 12,
      "text": "The lion has torn enough for his whelps"
    },
    {
      "block_id": "nahum-2-13",
      "type": "verse",
      "number": 13,
      "text": "See, I am against you, says the Lord of hosts, and I will burn your chariots in smoke, and the sword shall devour your young lions; I will cut off your prey from the earth, and the voice of your messengers shall be heard no more."
    }
  ]
}