{
  "document_id": "ps-72",
  "title": "Psalms 72",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-72-1",
      "type": "verse",
      "number": 1,
      "text": "Give the king your justice, O God,"
    },
    {
      "block_id": "ps-72-2",
      "type": "verse",
      "number": 2,
      "text": "May he judge your people with righteousness"
    },
    {
      "block_id": "ps-72-3",
      "type": "verse",
      "number": 3,
      "text": "May the mountains yield prosperity for the people,"
    },
    {
      "block_id": "ps-72-4",
      "type": "verse",
      "number": 4,
      "text": "May he defend the cause of the poor of the people,"
    },
    {
      "block_id": "ps-72-5",
      "type": "verse",
      "number": 5,
      "text": "May he live while the sun endures"
    },
    {
      "block_id": "ps-72-6",
      "type": "verse",
      "number": 6,
      "text": "May he be like rain that falls on the mown grass,"
    },
    {
      "block_id": "ps-72-7",
      "type": "verse",
      "number": 7,
      "text": "In his days may righteousness flourish"
    },
    {
      "block_id": "ps-72-8",
      "type": "verse",
      "number": 8,
      "text": "May he have dominion from sea to sea"
    },
    {
      "block_id": "ps-72-9",
      "type": "verse",
      "number": 9,
      "text": "May his foes bow down before him,"
    },
    {
      "block_id": "ps-72-10",
      "type": "verse",
      "number": 10,
      "text": "May the kings of Tarshish and of the isles"
    },
    {
      "block_id": "ps-72-11",
      "type": "verse",
      "number": 11,
      "text": "May all kings fall down before him,"
    },
    {
      "block_id": "ps-72-12",
      "type": "verse",
      "number": 12,
      "text": "For he delivers the needy when they call,"
    },
    {
      "block_id": "ps-72-13",
      "type": "verse",
      "number": 13,
      "text": "He has pity on the weak and the needy"
    },
    {
      "block_id": "ps-72-14",
      "type": "verse",
      "number": 14,
      "text": "From oppression and violence he redeems their life,"
    },
    {
      "block_id": "ps-72-15",
      "type": "verse",
      "number": 15,
      "text": "Long may he live!"
    },
    {
      "block_id": "ps-72-16",
      "type": "verse",
      "number": 16,
      "text": "May there be abundance of grain in the land;"
    },
    {
      "block_id": "ps-72-17",
      "type": "verse",
      "number": 17,
      "text": "May his name endure forever,"
    },
    {
      "block_id": "ps-72-18",
      "type": "verse",
      "number": 18,
      "text": "Blessed be the Lord, the God of Israel,"
    },
    {
      "block_id": "ps-72-19",
      "type": "verse",
      "number": 19,
      "text": "Blessed be his glorious name forever;"
    },
    {
      "block_id": "ps-72-20",
      "type": "verse",
      "number": 20,
      "text": "The prayers of David son of Jesse are ended."
    }
  ]
}