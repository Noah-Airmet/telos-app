{
  "document_id": "ps-136",
  "title": "Psalms 136",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-136-1",
      "type": "verse",
      "number": 1,
      "text": "O give thanks to the Lord, for he is good,"
    },
    {
      "block_id": "ps-136-2",
      "type": "verse",
      "number": 2,
      "text": "O give thanks to the God of gods,"
    },
    {
      "block_id": "ps-136-3",
      "type": "verse",
      "number": 3,
      "text": "O give thanks to the Lord of lords,"
    },
    {
      "block_id": "ps-136-4",
      "type": "verse",
      "number": 4,
      "text": "who alone does great wonders,"
    },
    {
      "block_id": "ps-136-5",
      "type": "verse",
      "number": 5,
      "text": "who by understanding made the heavens,"
    },
    {
      "block_id": "ps-136-6",
      "type": "verse",
      "number": 6,
      "text": "who spread out the earth on the waters,"
    },
    {
      "block_id": "ps-136-7",
      "type": "verse",
      "number": 7,
      "text": "who made the great lights,"
    },
    {
      "block_id": "ps-136-8",
      "type": "verse",
      "number": 8,
      "text": "the sun to rule over the day,"
    },
    {
      "block_id": "ps-136-9",
      "type": "verse",
      "number": 9,
      "text": "the moon and stars to rule over the night,"
    },
    {
      "block_id": "ps-136-10",
      "type": "verse",
      "number": 10,
      "text": "who struck Egypt through their firstborn,"
    },
    {
      "block_id": "ps-136-11",
      "type": "verse",
      "number": 11,
      "text": "and brought Israel out from among them,"
    },
    {
      "block_id": "ps-136-12",
      "type": "verse",
      "number": 12,
      "text": "with a strong hand and an outstretched arm,"
    },
    {
      "block_id": "ps-136-13",
      "type": "verse",
      "number": 13,
      "text": "who divided the Red Sea in two,"
    },
    {
      "block_id": "ps-136-14",
      "type": "verse",
      "number": 14,
      "text": "and made Israel pass through the midst of it,"
    },
    {
      "block_id": "ps-136-15",
      "type": "verse",
      "number": 15,
      "text": "but overthrew Pharaoh and his army in the Red Sea,"
    },
    {
      "block_id": "ps-136-16",
      "type": "verse",
      "number": 16,
      "text": "who led his people through the wilderness,"
    },
    {
      "block_id": "ps-136-17",
      "type": "verse",
      "number": 17,
      "text": "who struck down great kings,"
    },
    {
      "block_id": "ps-136-18",
      "type": "verse",
      "number": 18,
      "text": "and killed famous kings,"
    },
    {
      "block_id": "ps-136-19",
      "type": "verse",
      "number": 19,
      "text": "Sihon, king of the Amorites,"
    },
    {
      "block_id": "ps-136-20",
      "type": "verse",
      "number": 20,
      "text": "and Og, king of Bashan,"
    },
    {
      "block_id": "ps-136-21",
      "type": "verse",
      "number": 21,
      "text": "and gave their land as a heritage,"
    },
    {
      "block_id": "ps-136-22",
      "type": "verse",
      "number": 22,
      "text": "a heritage to his servant Israel,"
    },
    {
      "block_id": "ps-136-23",
      "type": "verse",
      "number": 23,
      "text": "It is he who remembered us in our low estate,"
    },
    {
      "block_id": "ps-136-24",
      "type": "verse",
      "number": 24,
      "text": "and rescued us from our foes,"
    },
    {
      "block_id": "ps-136-25",
      "type": "verse",
      "number": 25,
      "text": "who gives food to all flesh,"
    },
    {
      "block_id": "ps-136-26",
      "type": "verse",
      "number": 26,
      "text": "O give thanks to the God of heaven,"
    }
  ]
}