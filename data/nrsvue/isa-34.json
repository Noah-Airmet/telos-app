{
  "document_id": "isa-34",
  "title": "Isaiah 34",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-34-1",
      "type": "verse",
      "number": 1,
      "text": "Draw near, O nations, to hear;"
    },
    {
      "block_id": "isa-34-2",
      "type": "verse",
      "number": 2,
      "text": "For the Lord is enraged against all the nations"
    },
    {
      "block_id": "isa-34-3",
      "type": "verse",
      "number": 3,
      "text": "Their slain shall be cast out,"
    },
    {
      "block_id": "isa-34-4",
      "type": "verse",
      "number": 4,
      "text": "All the host of heaven shall rot away,"
    },
    {
      "block_id": "isa-34-5",
      "type": "verse",
      "number": 5,
      "text": "When my sword has drunk its fill in the heavens,"
    },
    {
      "block_id": "isa-34-6",
      "type": "verse",
      "number": 6,
      "text": "The Lord has a sword; it is sated with blood;"
    },
    {
      "block_id": "isa-34-7",
      "type": "verse",
      "number": 7,
      "text": "Wild oxen shall fall with them"
    },
    {
      "block_id": "isa-34-8",
      "type": "verse",
      "number": 8,
      "text": "For the Lord has a day of vengeance,"
    },
    {
      "block_id": "isa-34-9",
      "type": "verse",
      "number": 9,
      "text": "And the streams of Edom shall be turned into pitch"
    },
    {
      "block_id": "isa-34-10",
      "type": "verse",
      "number": 10,
      "text": "Night and day it shall not be quenched;"
    },
    {
      "block_id": "isa-34-11",
      "type": "verse",
      "number": 11,
      "text": "But the desert owl and the screech owl shall possess it;"
    },
    {
      "block_id": "isa-34-12",
      "type": "verse",
      "number": 12,
      "text": "They shall call its nobles No Kingdom There,"
    },
    {
      "block_id": "isa-34-13",
      "type": "verse",
      "number": 13,
      "text": "Thorns shall grow over its strongholds,"
    },
    {
      "block_id": "isa-34-14",
      "type": "verse",
      "number": 14,
      "text": "Wildcats shall meet with hyenas;"
    },
    {
      "block_id": "isa-34-15",
      "type": "verse",
      "number": 15,
      "text": "There shall the owl nest"
    },
    {
      "block_id": "isa-34-16",
      "type": "verse",
      "number": 16,
      "text": "Seek and read from the book of the Lord:"
    },
    {
      "block_id": "isa-34-17",
      "type": "verse",
      "number": 17,
      "text": "He has cast the lot for them;"
    }
  ]
}