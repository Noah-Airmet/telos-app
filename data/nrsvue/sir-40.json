{
  "document_id": "sir-40",
  "title": "Sirach 40",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-40-1",
      "type": "verse",
      "number": 1,
      "text": "Hard work was created for everyone,"
    },
    {
      "block_id": "sir-40-2",
      "type": "verse",
      "number": 2,
      "text": "Perplexities and fear of heart are theirs"
    },
    {
      "block_id": "sir-40-3",
      "type": "verse",
      "number": 3,
      "text": "From the one who sits on a splendid throne"
    },
    {
      "block_id": "sir-40-4",
      "type": "verse",
      "number": 4,
      "text": "from the one who wears purple and a crown"
    },
    {
      "block_id": "sir-40-5",
      "type": "verse",
      "number": 5,
      "text": "there is anger and envy and trouble and unrest"
    },
    {
      "block_id": "sir-40-6",
      "type": "verse",
      "number": 6,
      "text": "He gets little or no rest;"
    },
    {
      "block_id": "sir-40-7",
      "type": "verse",
      "number": 7,
      "text": "At the moment he reaches safety he wakes up,"
    },
    {
      "block_id": "sir-40-8",
      "type": "verse",
      "number": 8,
      "text": "To all creatures, human and animal,"
    },
    {
      "block_id": "sir-40-9",
      "type": "verse",
      "number": 9,
      "text": "come death and bloodshed and strife and sword,"
    },
    {
      "block_id": "sir-40-10",
      "type": "verse",
      "number": 10,
      "text": "All these were created for the lawless,"
    },
    {
      "block_id": "sir-40-11",
      "type": "verse",
      "number": 11,
      "text": "All that is of earth returns to earth,"
    },
    {
      "block_id": "sir-40-12",
      "type": "verse",
      "number": 12,
      "text": "All bribery and injustice will be blotted out,"
    },
    {
      "block_id": "sir-40-13",
      "type": "verse",
      "number": 13,
      "text": "The wealth of the unjust will dry up like a river"
    },
    {
      "block_id": "sir-40-14",
      "type": "verse",
      "number": 14,
      "text": "As a generous person has cause to rejoice,"
    },
    {
      "block_id": "sir-40-15",
      "type": "verse",
      "number": 15,
      "text": "The children of the ungodly put out few branches;"
    },
    {
      "block_id": "sir-40-16",
      "type": "verse",
      "number": 16,
      "text": "The reeds by any water or river bank"
    },
    {
      "block_id": "sir-40-17",
      "type": "verse",
      "number": 17,
      "text": "but kindness is like a garden of blessings,"
    },
    {
      "block_id": "sir-40-18",
      "type": "verse",
      "number": 18,
      "text": "A life of abundance and wages make life sweet,"
    },
    {
      "block_id": "sir-40-19",
      "type": "verse",
      "number": 19,
      "text": "Children and the building of a city establish one’s name,"
    },
    {
      "block_id": "sir-40-20",
      "type": "verse",
      "number": 20,
      "text": "Wine and music gladden the heart,"
    },
    {
      "block_id": "sir-40-21",
      "type": "verse",
      "number": 21,
      "text": "The flute and the harp make sweet melody,"
    },
    {
      "block_id": "sir-40-22",
      "type": "verse",
      "number": 22,
      "text": "The eye desires grace and beauty,"
    },
    {
      "block_id": "sir-40-23",
      "type": "verse",
      "number": 23,
      "text": "A friend or companion is always welcome,"
    },
    {
      "block_id": "sir-40-24",
      "type": "verse",
      "number": 24,
      "text": "Kindred and helpers are for a time of trouble,"
    },
    {
      "block_id": "sir-40-25",
      "type": "verse",
      "number": 25,
      "text": "Gold and silver make one stand firm,"
    },
    {
      "block_id": "sir-40-26",
      "type": "verse",
      "number": 26,
      "text": "Riches and strength build up confidence,"
    },
    {
      "block_id": "sir-40-27",
      "type": "verse",
      "number": 27,
      "text": "The fear of the Lord is like a garden of blessing"
    },
    {
      "block_id": "sir-40-28",
      "type": "verse",
      "number": 28,
      "text": "My child, do not lead the life of a beggar;"
    },
    {
      "block_id": "sir-40-29",
      "type": "verse",
      "number": 29,
      "text": "When one looks to the table of another,"
    },
    {
      "block_id": "sir-40-30",
      "type": "verse",
      "number": 30,
      "text": "In the mouth of the shameless begging is sweet,"
    }
  ]
}