{
  "document_id": "ps-17",
  "title": "Psalms 17",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-17-1",
      "type": "verse",
      "number": 1,
      "text": "Hear a just cause, O Lord; attend to my cry;"
    },
    {
      "block_id": "ps-17-2",
      "type": "verse",
      "number": 2,
      "text": "From you let my vindication come;"
    },
    {
      "block_id": "ps-17-3",
      "type": "verse",
      "number": 3,
      "text": "If you try my heart, if you visit me by night,"
    },
    {
      "block_id": "ps-17-4",
      "type": "verse",
      "number": 4,
      "text": "As for what others do, by the word of your lips"
    },
    {
      "block_id": "ps-17-5",
      "type": "verse",
      "number": 5,
      "text": "My steps have held fast to your paths;"
    },
    {
      "block_id": "ps-17-6",
      "type": "verse",
      "number": 6,
      "text": "I call upon you, for you will answer me, O God;"
    },
    {
      "block_id": "ps-17-7",
      "type": "verse",
      "number": 7,
      "text": "Wondrously show your steadfast love,"
    },
    {
      "block_id": "ps-17-8",
      "type": "verse",
      "number": 8,
      "text": "Guard me as the apple of the eye;"
    },
    {
      "block_id": "ps-17-9",
      "type": "verse",
      "number": 9,
      "text": "from the wicked who despoil me,"
    },
    {
      "block_id": "ps-17-10",
      "type": "verse",
      "number": 10,
      "text": "They close their hearts to pity;"
    },
    {
      "block_id": "ps-17-11",
      "type": "verse",
      "number": 11,
      "text": "They flush me out; now they surround me;"
    },
    {
      "block_id": "ps-17-12",
      "type": "verse",
      "number": 12,
      "text": "They are like a lion eager to tear,"
    },
    {
      "block_id": "ps-17-13",
      "type": "verse",
      "number": 13,
      "text": "Rise up, O Lord, confront them, overthrow them!"
    },
    {
      "block_id": "ps-17-14",
      "type": "verse",
      "number": 14,
      "text": "from mortals—by your hand, O Lord—"
    },
    {
      "block_id": "ps-17-15",
      "type": "verse",
      "number": 15,
      "text": "As for me, I shall behold your face in righteousness;"
    }
  ]
}