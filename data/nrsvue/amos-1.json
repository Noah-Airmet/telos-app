{
  "document_id": "amos-1",
  "title": "Amos 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "amos-1-heading-judgment-on-israel’s",
      "type": "heading",
      "text": "Judgment on Israel’s Neighbors"
    },
    {
      "block_id": "amos-1-1",
      "type": "verse",
      "number": 1,
      "text": "The words of Amos, who was among the shepherds of Tekoa, which he saw concerning Israel in the days of King Uzziah of Judah and in the days of King Jeroboam son of Joash of Israel, two years before the earthquake."
    },
    {
      "block_id": "amos-1-2",
      "type": "verse",
      "number": 2,
      "text": "And he said:"
    },
    {
      "block_id": "amos-1-3",
      "type": "verse",
      "number": 3,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "amos-1-4",
      "type": "verse",
      "number": 4,
      "text": "So I will send a fire on the house of Hazael,"
    },
    {
      "block_id": "amos-1-5",
      "type": "verse",
      "number": 5,
      "text": "I will break the gate bars of Damascus"
    },
    {
      "block_id": "amos-1-6",
      "type": "verse",
      "number": 6,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "amos-1-7",
      "type": "verse",
      "number": 7,
      "text": "So I will send a fire on the wall of Gaza,"
    },
    {
      "block_id": "amos-1-8",
      "type": "verse",
      "number": 8,
      "text": "I will cut off the inhabitants from Ashdod"
    },
    {
      "block_id": "amos-1-9",
      "type": "verse",
      "number": 9,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "amos-1-10",
      "type": "verse",
      "number": 10,
      "text": "So I will send a fire on the wall of Tyre,"
    },
    {
      "block_id": "amos-1-11",
      "type": "verse",
      "number": 11,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "amos-1-12",
      "type": "verse",
      "number": 12,
      "text": "So I will send a fire on Teman,"
    },
    {
      "block_id": "amos-1-13",
      "type": "verse",
      "number": 13,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "amos-1-14",
      "type": "verse",
      "number": 14,
      "text": "So I will kindle a fire against the wall of Rabbah,"
    },
    {
      "block_id": "amos-1-15",
      "type": "verse",
      "number": 15,
      "text": "then their king shall go into exile,"
    }
  ]
}