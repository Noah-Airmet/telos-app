{
  "document_id": "ps-31",
  "title": "Psalms 31",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-31-1",
      "type": "verse",
      "number": 1,
      "text": "In you, O Lord, I seek refuge;"
    },
    {
      "block_id": "ps-31-2",
      "type": "verse",
      "number": 2,
      "text": "Incline your ear to me;"
    },
    {
      "block_id": "ps-31-3",
      "type": "verse",
      "number": 3,
      "text": "You are indeed my rock and my fortress;"
    },
    {
      "block_id": "ps-31-4",
      "type": "verse",
      "number": 4,
      "text": "take me out of the net that is hidden for me,"
    },
    {
      "block_id": "ps-31-5",
      "type": "verse",
      "number": 5,
      "text": "Into your hand I commit my spirit;"
    },
    {
      "block_id": "ps-31-6",
      "type": "verse",
      "number": 6,
      "text": "You hate those who pay regard to worthless idols,"
    },
    {
      "block_id": "ps-31-7",
      "type": "verse",
      "number": 7,
      "text": "I will exult and rejoice in your steadfast love,"
    },
    {
      "block_id": "ps-31-8",
      "type": "verse",
      "number": 8,
      "text": "and have not delivered me into the hand of the enemy;"
    },
    {
      "block_id": "ps-31-9",
      "type": "verse",
      "number": 9,
      "text": "Be gracious to me, O Lord, for I am in distress;"
    },
    {
      "block_id": "ps-31-10",
      "type": "verse",
      "number": 10,
      "text": "For my life is spent with sorrow"
    },
    {
      "block_id": "ps-31-11",
      "type": "verse",
      "number": 11,
      "text": "I am the scorn of all my adversaries,"
    },
    {
      "block_id": "ps-31-12",
      "type": "verse",
      "number": 12,
      "text": "I have passed out of mind like one who is dead;"
    },
    {
      "block_id": "ps-31-13",
      "type": "verse",
      "number": 13,
      "text": "For I hear the whispering of many—"
    },
    {
      "block_id": "ps-31-14",
      "type": "verse",
      "number": 14,
      "text": "But I trust in you, O Lord;"
    },
    {
      "block_id": "ps-31-15",
      "type": "verse",
      "number": 15,
      "text": "My times are in your hand;"
    },
    {
      "block_id": "ps-31-16",
      "type": "verse",
      "number": 16,
      "text": "Let your face shine upon your servant;"
    },
    {
      "block_id": "ps-31-17",
      "type": "verse",
      "number": 17,
      "text": "Do not let me be put to shame, O Lord,"
    },
    {
      "block_id": "ps-31-18",
      "type": "verse",
      "number": 18,
      "text": "Let the lying lips be stilled"
    },
    {
      "block_id": "ps-31-19",
      "type": "verse",
      "number": 19,
      "text": "O how abundant is your goodness"
    },
    {
      "block_id": "ps-31-20",
      "type": "verse",
      "number": 20,
      "text": "In the shelter of your presence you hide them"
    },
    {
      "block_id": "ps-31-21",
      "type": "verse",
      "number": 21,
      "text": "Blessed be the Lord,"
    },
    {
      "block_id": "ps-31-22",
      "type": "verse",
      "number": 22,
      "text": "I had said in my alarm,"
    },
    {
      "block_id": "ps-31-23",
      "type": "verse",
      "number": 23,
      "text": "Love the Lord, all you his saints."
    },
    {
      "block_id": "ps-31-24",
      "type": "verse",
      "number": 24,
      "text": "Be strong, and let your heart take courage,"
    }
  ]
}