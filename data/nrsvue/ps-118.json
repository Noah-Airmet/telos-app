{
  "document_id": "ps-118",
  "title": "Psalms 118",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-118-1",
      "type": "verse",
      "number": 1,
      "text": "O give thanks to the Lord, for he is good;"
    },
    {
      "block_id": "ps-118-2",
      "type": "verse",
      "number": 2,
      "text": "Let Israel say,"
    },
    {
      "block_id": "ps-118-3",
      "type": "verse",
      "number": 3,
      "text": "Let the house of Aaron say,"
    },
    {
      "block_id": "ps-118-4",
      "type": "verse",
      "number": 4,
      "text": "Let those who fear the Lord say,"
    },
    {
      "block_id": "ps-118-5",
      "type": "verse",
      "number": 5,
      "text": "Out of my distress I called on the Lord;"
    },
    {
      "block_id": "ps-118-6",
      "type": "verse",
      "number": 6,
      "text": "With the Lord on my side I do not fear."
    },
    {
      "block_id": "ps-118-7",
      "type": "verse",
      "number": 7,
      "text": "The Lord is on my side to help me;"
    },
    {
      "block_id": "ps-118-8",
      "type": "verse",
      "number": 8,
      "text": "It is better to take refuge in the Lord"
    },
    {
      "block_id": "ps-118-9",
      "type": "verse",
      "number": 9,
      "text": "It is better to take refuge in the Lord"
    },
    {
      "block_id": "ps-118-10",
      "type": "verse",
      "number": 10,
      "text": "All nations surrounded me;"
    },
    {
      "block_id": "ps-118-11",
      "type": "verse",
      "number": 11,
      "text": "They surrounded me, surrounded me on every side;"
    },
    {
      "block_id": "ps-118-12",
      "type": "verse",
      "number": 12,
      "text": "They surrounded me like bees;"
    },
    {
      "block_id": "ps-118-13",
      "type": "verse",
      "number": 13,
      "text": "I was pushed hard, so that I was falling,"
    },
    {
      "block_id": "ps-118-14",
      "type": "verse",
      "number": 14,
      "text": "The Lord is my strength and my might;"
    },
    {
      "block_id": "ps-118-15",
      "type": "verse",
      "number": 15,
      "text": "There are glad songs of victory in the tents of the righteous:"
    },
    {
      "block_id": "ps-118-16",
      "type": "verse",
      "number": 16,
      "text": "the right hand of the Lord is exalted;"
    },
    {
      "block_id": "ps-118-17",
      "type": "verse",
      "number": 17,
      "text": "I shall not die, but I shall live"
    },
    {
      "block_id": "ps-118-18",
      "type": "verse",
      "number": 18,
      "text": "The Lord has punished me severely,"
    },
    {
      "block_id": "ps-118-19",
      "type": "verse",
      "number": 19,
      "text": "Open to me the gates of righteousness,"
    },
    {
      "block_id": "ps-118-20",
      "type": "verse",
      "number": 20,
      "text": "This is the gate of the Lord;"
    },
    {
      "block_id": "ps-118-21",
      "type": "verse",
      "number": 21,
      "text": "I thank you that you have answered me"
    },
    {
      "block_id": "ps-118-22",
      "type": "verse",
      "number": 22,
      "text": "The stone that the builders rejected"
    },
    {
      "block_id": "ps-118-23",
      "type": "verse",
      "number": 23,
      "text": "This is the Lord’s doing;"
    },
    {
      "block_id": "ps-118-24",
      "type": "verse",
      "number": 24,
      "text": "This is the day that the Lord has made;"
    },
    {
      "block_id": "ps-118-25",
      "type": "verse",
      "number": 25,
      "text": "Save us, we beseech you, O Lord!"
    },
    {
      "block_id": "ps-118-26",
      "type": "verse",
      "number": 26,
      "text": "Blessed is the one who comes in the name of the Lord."
    },
    {
      "block_id": "ps-118-27",
      "type": "verse",
      "number": 27,
      "text": "The Lord is God,"
    },
    {
      "block_id": "ps-118-28",
      "type": "verse",
      "number": 28,
      "text": "You are my God, and I will give thanks to you;"
    },
    {
      "block_id": "ps-118-29",
      "type": "verse",
      "number": 29,
      "text": "O give thanks to the Lord, for he is good,"
    }
  ]
}