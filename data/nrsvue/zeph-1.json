{
  "document_id": "zeph-1",
  "title": "Zephaniah 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "zeph-1-1",
      "type": "verse",
      "number": 1,
      "text": "The word of the Lord that came to Zephaniah son of Cushi son of Gedaliah son of Amariah son of Hezekiah, in the days of King Josiah son of Amon of Judah."
    },
    {
      "block_id": "zeph-1-2",
      "type": "verse",
      "number": 2,
      "text": "I will utterly sweep away everything"
    },
    {
      "block_id": "zeph-1-3",
      "type": "verse",
      "number": 3,
      "text": "I will sweep away humans and animals;"
    },
    {
      "block_id": "zeph-1-4",
      "type": "verse",
      "number": 4,
      "text": "I will stretch out my hand against Judah"
    },
    {
      "block_id": "zeph-1-5",
      "type": "verse",
      "number": 5,
      "text": "those who bow down on the roofs"
    },
    {
      "block_id": "zeph-1-6",
      "type": "verse",
      "number": 6,
      "text": "those who have turned back from following the Lord,"
    },
    {
      "block_id": "zeph-1-7",
      "type": "verse",
      "number": 7,
      "text": "Be silent before the Lord God,"
    },
    {
      "block_id": "zeph-1-8",
      "type": "verse",
      "number": 8,
      "text": "And on the day of the Lord’s sacrifice"
    },
    {
      "block_id": "zeph-1-9",
      "type": "verse",
      "number": 9,
      "text": "On that day I will punish"
    },
    {
      "block_id": "zeph-1-10",
      "type": "verse",
      "number": 10,
      "text": "On that day, says the Lord,"
    },
    {
      "block_id": "zeph-1-11",
      "type": "verse",
      "number": 11,
      "text": "The inhabitants of the Mortar wail,"
    },
    {
      "block_id": "zeph-1-12",
      "type": "verse",
      "number": 12,
      "text": "At that time I will search Jerusalem with lamps,"
    },
    {
      "block_id": "zeph-1-13",
      "type": "verse",
      "number": 13,
      "text": "Their wealth shall be plundered"
    },
    {
      "block_id": "zeph-1-14",
      "type": "verse",
      "number": 14,
      "text": "The great day of the Lord is near,"
    },
    {
      "block_id": "zeph-1-15",
      "type": "verse",
      "number": 15,
      "text": "That day will be a day of wrath,"
    },
    {
      "block_id": "zeph-1-16",
      "type": "verse",
      "number": 16,
      "text": "a day of trumpet blast and battle cry"
    },
    {
      "block_id": "zeph-1-17",
      "type": "verse",
      "number": 17,
      "text": "I will bring such distress upon people"
    },
    {
      "block_id": "zeph-1-18",
      "type": "verse",
      "number": 18,
      "text": "Neither their silver nor their gold"
    }
  ]
}