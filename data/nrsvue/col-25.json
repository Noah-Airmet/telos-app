{
  "document_id": "col-25",
  "title": "Colossians 25",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-25-1",
      "type": "verse",
      "number": 1,
      "text": "I take pleasure in three things,"
    },
    {
      "block_id": "col-25-2",
      "type": "verse",
      "number": 2,
      "text": "I hate three kinds of people,"
    },
    {
      "block_id": "col-25-3",
      "type": "verse",
      "number": 3,
      "text": "If you gathered nothing in your youth,"
    },
    {
      "block_id": "col-25-4",
      "type": "verse",
      "number": 4,
      "text": "How attractive is sound judgment in gray-haired women"
    },
    {
      "block_id": "col-25-5",
      "type": "verse",
      "number": 5,
      "text": "How attractive is wisdom in the aged"
    },
    {
      "block_id": "col-25-6",
      "type": "verse",
      "number": 6,
      "text": "Rich experience is the crown of the aged,"
    },
    {
      "block_id": "col-25-7",
      "type": "verse",
      "number": 7,
      "text": "I can think of nine whom I would call happy,"
    },
    {
      "block_id": "col-25-8",
      "type": "verse",
      "number": 8,
      "text": "Happy the man who lives with a sensible wife"
    },
    {
      "block_id": "col-25-9",
      "type": "verse",
      "number": 9,
      "text": "Happy is the one who finds good sense"
    },
    {
      "block_id": "col-25-10",
      "type": "verse",
      "number": 10,
      "text": "How great is the one who finds wisdom!"
    },
    {
      "block_id": "col-25-11",
      "type": "verse",
      "number": 11,
      "text": "Fear of the Lord surpasses everything;"
    },
    {
      "block_id": "col-25-13",
      "type": "verse",
      "number": 13,
      "text": "Any wound, but not a wound of the heart!"
    },
    {
      "block_id": "col-25-14",
      "type": "verse",
      "number": 14,
      "text": "Any suffering, but not suffering from those who hate!"
    },
    {
      "block_id": "col-25-15",
      "type": "verse",
      "number": 15,
      "text": "There is no venom worse than a snake’s venom"
    },
    {
      "block_id": "col-25-16",
      "type": "verse",
      "number": 16,
      "text": "I would rather live with a lion and a dragon"
    },
    {
      "block_id": "col-25-17",
      "type": "verse",
      "number": 17,
      "text": "A woman’s wickedness changes her appearance"
    },
    {
      "block_id": "col-25-18",
      "type": "verse",
      "number": 18,
      "text": "Her husband sits among the neighbors,"
    },
    {
      "block_id": "col-25-19",
      "type": "verse",
      "number": 19,
      "text": "Any iniquity is small compared to a woman’s iniquity;"
    },
    {
      "block_id": "col-25-20",
      "type": "verse",
      "number": 20,
      "text": "A sandy ascent for the feet of the aged—"
    },
    {
      "block_id": "col-25-21",
      "type": "verse",
      "number": 21,
      "text": "Do not be ensnared by a woman’s beauty,"
    },
    {
      "block_id": "col-25-22",
      "type": "verse",
      "number": 22,
      "text": "There is wrath and impudence and great disgrace"
    },
    {
      "block_id": "col-25-23",
      "type": "verse",
      "number": 23,
      "text": "Dejected mind, gloomy face,"
    },
    {
      "block_id": "col-25-24",
      "type": "verse",
      "number": 24,
      "text": "From a woman sin had its beginning,"
    },
    {
      "block_id": "col-25-25",
      "type": "verse",
      "number": 25,
      "text": "Allow no outlet to water"
    },
    {
      "block_id": "col-25-26",
      "type": "verse",
      "number": 26,
      "text": "If she does not go as you direct,"
    }
  ]
}