{
  "document_id": "sir-44",
  "title": "Sirach 44",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-44-1",
      "type": "verse",
      "number": 1,
      "text": "Let us now sing the praises of famous men,"
    },
    {
      "block_id": "sir-44-2",
      "type": "verse",
      "number": 2,
      "text": "The Lord apportioned to them great glory,"
    },
    {
      "block_id": "sir-44-3",
      "type": "verse",
      "number": 3,
      "text": "There were those who ruled in their kingdoms"
    },
    {
      "block_id": "sir-44-4",
      "type": "verse",
      "number": 4,
      "text": "those who led the people by their counsels"
    },
    {
      "block_id": "sir-44-5",
      "type": "verse",
      "number": 5,
      "text": "those who composed musical tunes"
    },
    {
      "block_id": "sir-44-6",
      "type": "verse",
      "number": 6,
      "text": "rich men endowed with resources,"
    },
    {
      "block_id": "sir-44-7",
      "type": "verse",
      "number": 7,
      "text": "all these were honored in their generations"
    },
    {
      "block_id": "sir-44-8",
      "type": "verse",
      "number": 8,
      "text": "Some of them have left behind a name,"
    },
    {
      "block_id": "sir-44-9",
      "type": "verse",
      "number": 9,
      "text": "But of others there is no memory;"
    },
    {
      "block_id": "sir-44-10",
      "type": "verse",
      "number": 10,
      "text": "But these also were men of compassion"
    },
    {
      "block_id": "sir-44-11",
      "type": "verse",
      "number": 11,
      "text": "their wealth will remain with their descendants"
    },
    {
      "block_id": "sir-44-12",
      "type": "verse",
      "number": 12,
      "text": "Their descendants stand by the covenants;"
    },
    {
      "block_id": "sir-44-13",
      "type": "verse",
      "number": 13,
      "text": "Their offspring will continue forever,"
    },
    {
      "block_id": "sir-44-14",
      "type": "verse",
      "number": 14,
      "text": "Their bodies are buried in peace,"
    },
    {
      "block_id": "sir-44-15",
      "type": "verse",
      "number": 15,
      "text": "The assembly declares their wisdom,"
    },
    {
      "block_id": "sir-44-16",
      "type": "verse",
      "number": 16,
      "text": "Enoch pleased the Lord and was taken up,"
    },
    {
      "block_id": "sir-44-17",
      "type": "verse",
      "number": 17,
      "text": "Noah was found perfect and righteous;"
    },
    {
      "block_id": "sir-44-18",
      "type": "verse",
      "number": 18,
      "text": "Everlasting covenants were made with him"
    },
    {
      "block_id": "sir-44-19",
      "type": "verse",
      "number": 19,
      "text": "Abraham was the great father of a multitude of nations,"
    },
    {
      "block_id": "sir-44-20",
      "type": "verse",
      "number": 20,
      "text": "He kept the law of the Most High"
    },
    {
      "block_id": "sir-44-21",
      "type": "verse",
      "number": 21,
      "text": "Therefore the Lord assured him with an oath"
    },
    {
      "block_id": "sir-44-22",
      "type": "verse",
      "number": 22,
      "text": "To Isaac also he gave the same assurance"
    },
    {
      "block_id": "sir-44-23",
      "type": "verse",
      "number": 23,
      "text": "he made to rest on the head of Jacob;"
    }
  ]
}