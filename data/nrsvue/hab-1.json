{
  "document_id": "hab-1",
  "title": "Habakkuk 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hab-1-1",
      "type": "verse",
      "number": 1,
      "text": "The oracle that the prophet Habakkuk saw."
    },
    {
      "block_id": "hab-1-2",
      "type": "verse",
      "number": 2,
      "text": "O Lord, how long shall I cry for help,"
    },
    {
      "block_id": "hab-1-3",
      "type": "verse",
      "number": 3,
      "text": "Why do you make me see wrongdoing"
    },
    {
      "block_id": "hab-1-4",
      "type": "verse",
      "number": 4,
      "text": "So the law becomes slack,"
    },
    {
      "block_id": "hab-1-5",
      "type": "verse",
      "number": 5,
      "text": "Look at the nations and see!"
    },
    {
      "block_id": "hab-1-6",
      "type": "verse",
      "number": 6,
      "text": "For I am rousing the Chaldeans,"
    },
    {
      "block_id": "hab-1-7",
      "type": "verse",
      "number": 7,
      "text": "Dread and fearsome are they;"
    },
    {
      "block_id": "hab-1-8",
      "type": "verse",
      "number": 8,
      "text": "Their horses are swifter than leopards,"
    },
    {
      "block_id": "hab-1-9",
      "type": "verse",
      "number": 9,
      "text": "They all come for violence,"
    },
    {
      "block_id": "hab-1-10",
      "type": "verse",
      "number": 10,
      "text": "At kings they scoff,"
    },
    {
      "block_id": "hab-1-11",
      "type": "verse",
      "number": 11,
      "text": "Then they sweep by like the wind;"
    },
    {
      "block_id": "hab-1-12",
      "type": "verse",
      "number": 12,
      "text": "Are you not from of old,"
    },
    {
      "block_id": "hab-1-13",
      "type": "verse",
      "number": 13,
      "text": "Your eyes are too pure to behold evil,"
    },
    {
      "block_id": "hab-1-14",
      "type": "verse",
      "number": 14,
      "text": "You have made people like the fish of the sea,"
    },
    {
      "block_id": "hab-1-15",
      "type": "verse",
      "number": 15,
      "text": "He brings all of them up with a hook;"
    },
    {
      "block_id": "hab-1-16",
      "type": "verse",
      "number": 16,
      "text": "Therefore he sacrifices to his net"
    },
    {
      "block_id": "hab-1-17",
      "type": "verse",
      "number": 17,
      "text": "Is he then to keep on emptying his net"
    }
  ]
}