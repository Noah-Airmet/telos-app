{
  "document_id": "ps-38",
  "title": "Psalms 38",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-38-1",
      "type": "verse",
      "number": 1,
      "text": "O Lord, do not rebuke me in your anger"
    },
    {
      "block_id": "ps-38-2",
      "type": "verse",
      "number": 2,
      "text": "For your arrows have sunk into me,"
    },
    {
      "block_id": "ps-38-3",
      "type": "verse",
      "number": 3,
      "text": "There is no soundness in my flesh"
    },
    {
      "block_id": "ps-38-4",
      "type": "verse",
      "number": 4,
      "text": "For my iniquities have gone over my head;"
    },
    {
      "block_id": "ps-38-5",
      "type": "verse",
      "number": 5,
      "text": "My wounds grow foul and fester"
    },
    {
      "block_id": "ps-38-6",
      "type": "verse",
      "number": 6,
      "text": "I am utterly bowed down and prostrate;"
    },
    {
      "block_id": "ps-38-7",
      "type": "verse",
      "number": 7,
      "text": "For my loins are filled with burning,"
    },
    {
      "block_id": "ps-38-8",
      "type": "verse",
      "number": 8,
      "text": "I am utterly spent and crushed;"
    },
    {
      "block_id": "ps-38-9",
      "type": "verse",
      "number": 9,
      "text": "O Lord, all my longing is known to you;"
    },
    {
      "block_id": "ps-38-10",
      "type": "verse",
      "number": 10,
      "text": "My heart throbs; my strength fails me;"
    },
    {
      "block_id": "ps-38-11",
      "type": "verse",
      "number": 11,
      "text": "My friends and companions stand aloof from my affliction,"
    },
    {
      "block_id": "ps-38-12",
      "type": "verse",
      "number": 12,
      "text": "Those who seek my life lay their snares;"
    },
    {
      "block_id": "ps-38-13",
      "type": "verse",
      "number": 13,
      "text": "But I am like the deaf; I do not hear;"
    },
    {
      "block_id": "ps-38-14",
      "type": "verse",
      "number": 14,
      "text": "Truly, I am like one who does not hear"
    },
    {
      "block_id": "ps-38-15",
      "type": "verse",
      "number": 15,
      "text": "But it is for you, O Lord, that I wait;"
    },
    {
      "block_id": "ps-38-16",
      "type": "verse",
      "number": 16,
      "text": "For I pray, “Only do not let them rejoice over me,"
    },
    {
      "block_id": "ps-38-17",
      "type": "verse",
      "number": 17,
      "text": "For I am ready to fall,"
    },
    {
      "block_id": "ps-38-18",
      "type": "verse",
      "number": 18,
      "text": "I confess my iniquity;"
    },
    {
      "block_id": "ps-38-19",
      "type": "verse",
      "number": 19,
      "text": "Those who are my foes without cause are mighty,"
    },
    {
      "block_id": "ps-38-20",
      "type": "verse",
      "number": 20,
      "text": "Those who render me evil for good"
    },
    {
      "block_id": "ps-38-21",
      "type": "verse",
      "number": 21,
      "text": "Do not forsake me, O Lord;"
    },
    {
      "block_id": "ps-38-22",
      "type": "verse",
      "number": 22,
      "text": "make haste to help me,"
    }
  ]
}