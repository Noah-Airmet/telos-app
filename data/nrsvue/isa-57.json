{
  "document_id": "isa-57",
  "title": "Isaiah 57",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-57-1",
      "type": "verse",
      "number": 1,
      "text": "The righteous perish,"
    },
    {
      "block_id": "isa-57-2",
      "type": "verse",
      "number": 2,
      "text": "Those who walk uprightly enter into peace"
    },
    {
      "block_id": "isa-57-3",
      "type": "verse",
      "number": 3,
      "text": "But as for you, come here,"
    },
    {
      "block_id": "isa-57-4",
      "type": "verse",
      "number": 4,
      "text": "Whom are you mocking?"
    },
    {
      "block_id": "isa-57-5",
      "type": "verse",
      "number": 5,
      "text": "you who burn with lust among the oaks,"
    },
    {
      "block_id": "isa-57-6",
      "type": "verse",
      "number": 6,
      "text": "Among the smooth stones of the valley is your portion;"
    },
    {
      "block_id": "isa-57-7",
      "type": "verse",
      "number": 7,
      "text": "Upon a high and lofty mountain"
    },
    {
      "block_id": "isa-57-8",
      "type": "verse",
      "number": 8,
      "text": "Behind the door and the doorpost"
    },
    {
      "block_id": "isa-57-9",
      "type": "verse",
      "number": 9,
      "text": "You journeyed to Molech with oil"
    },
    {
      "block_id": "isa-57-10",
      "type": "verse",
      "number": 10,
      "text": "You grew weary from your many wanderings,"
    },
    {
      "block_id": "isa-57-11",
      "type": "verse",
      "number": 11,
      "text": "Whom did you dread and fear"
    },
    {
      "block_id": "isa-57-12",
      "type": "verse",
      "number": 12,
      "text": "I will announce your verdict,"
    },
    {
      "block_id": "isa-57-13",
      "type": "verse",
      "number": 13,
      "text": "When you cry out, let your collection of idols deliver you!"
    },
    {
      "block_id": "isa-57-14",
      "type": "verse",
      "number": 14,
      "text": "It shall be said,"
    },
    {
      "block_id": "isa-57-15",
      "type": "verse",
      "number": 15,
      "text": "For thus says the high and lofty one"
    },
    {
      "block_id": "isa-57-16",
      "type": "verse",
      "number": 16,
      "text": "For I will not continually accuse,"
    },
    {
      "block_id": "isa-57-17",
      "type": "verse",
      "number": 17,
      "text": "Because of their wicked covetousness I was angry;"
    },
    {
      "block_id": "isa-57-18",
      "type": "verse",
      "number": 18,
      "text": "I have seen their ways, but I will heal them;"
    },
    {
      "block_id": "isa-57-19",
      "type": "verse",
      "number": 19,
      "text": "creating for their mourners the fruit of the lips."
    },
    {
      "block_id": "isa-57-20",
      "type": "verse",
      "number": 20,
      "text": "But the wicked are like the tossing sea"
    },
    {
      "block_id": "isa-57-21",
      "type": "verse",
      "number": 21,
      "text": "There is no peace, says my God, for the wicked."
    }
  ]
}