{
  "document_id": "ps-93",
  "title": "Psalms 93",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-93-1",
      "type": "verse",
      "number": 1,
      "text": "The Lord is king; he is robed in majesty;"
    },
    {
      "block_id": "ps-93-2",
      "type": "verse",
      "number": 2,
      "text": "your throne is established from of old;"
    },
    {
      "block_id": "ps-93-3",
      "type": "verse",
      "number": 3,
      "text": "The floods have lifted up, O Lord,"
    },
    {
      "block_id": "ps-93-4",
      "type": "verse",
      "number": 4,
      "text": "More majestic than the thunders of mighty waters,"
    },
    {
      "block_id": "ps-93-5",
      "type": "verse",
      "number": 5,
      "text": "Your decrees are very sure;"
    }
  ]
}