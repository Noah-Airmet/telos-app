{
  "document_id": "prov-1",
  "title": "Proverbs 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-1-1",
      "type": "verse",
      "number": 1,
      "text": "The proverbs of Solomon son of David, king of Israel:"
    },
    {
      "block_id": "prov-1-2",
      "type": "verse",
      "number": 2,
      "text": "For learning about wisdom and instruction,"
    },
    {
      "block_id": "prov-1-3",
      "type": "verse",
      "number": 3,
      "text": "for gaining instruction in wise dealing,"
    },
    {
      "block_id": "prov-1-4",
      "type": "verse",
      "number": 4,
      "text": "to teach shrewdness to the simple,"
    },
    {
      "block_id": "prov-1-5",
      "type": "verse",
      "number": 5,
      "text": "let the wise, too, hear and gain in learning"
    },
    {
      "block_id": "prov-1-6",
      "type": "verse",
      "number": 6,
      "text": "to understand a proverb and a figure,"
    },
    {
      "block_id": "prov-1-7",
      "type": "verse",
      "number": 7,
      "text": "The fear of the Lord is the beginning of knowledge;"
    },
    {
      "block_id": "prov-1-8",
      "type": "verse",
      "number": 8,
      "text": "Hear, my child, your father’s instruction,"
    },
    {
      "block_id": "prov-1-9",
      "type": "verse",
      "number": 9,
      "text": "for they are a fair garland for your head"
    },
    {
      "block_id": "prov-1-10",
      "type": "verse",
      "number": 10,
      "text": "My child, if sinners entice you,"
    },
    {
      "block_id": "prov-1-11",
      "type": "verse",
      "number": 11,
      "text": "If they say, “Come with us, let us lie in wait for blood;"
    },
    {
      "block_id": "prov-1-12",
      "type": "verse",
      "number": 12,
      "text": "like Sheol let us swallow them alive"
    },
    {
      "block_id": "prov-1-13",
      "type": "verse",
      "number": 13,
      "text": "We shall find all kinds of costly things;"
    },
    {
      "block_id": "prov-1-14",
      "type": "verse",
      "number": 14,
      "text": "Throw in your lot among us;"
    },
    {
      "block_id": "prov-1-15",
      "type": "verse",
      "number": 15,
      "text": "my child, do not walk in their way;"
    },
    {
      "block_id": "prov-1-16",
      "type": "verse",
      "number": 16,
      "text": "for their feet run to evil,"
    },
    {
      "block_id": "prov-1-17",
      "type": "verse",
      "number": 17,
      "text": "For in vain is the net baited"
    },
    {
      "block_id": "prov-1-18",
      "type": "verse",
      "number": 18,
      "text": "yet they lie in wait—to kill themselves!"
    },
    {
      "block_id": "prov-1-19",
      "type": "verse",
      "number": 19,
      "text": "Such is the end of all who are greedy for gain;"
    },
    {
      "block_id": "prov-1-20",
      "type": "verse",
      "number": 20,
      "text": "Wisdom cries out in the street;"
    },
    {
      "block_id": "prov-1-21",
      "type": "verse",
      "number": 21,
      "text": "At the busiest corner she cries out;"
    },
    {
      "block_id": "prov-1-22",
      "type": "verse",
      "number": 22,
      "text": "“How long, O simple ones, will you love being simple?"
    },
    {
      "block_id": "prov-1-23",
      "type": "verse",
      "number": 23,
      "text": "Give heed to my reproof;"
    },
    {
      "block_id": "prov-1-24",
      "type": "verse",
      "number": 24,
      "text": "Because I have called and you refused,"
    },
    {
      "block_id": "prov-1-25",
      "type": "verse",
      "number": 25,
      "text": "and because you have ignored all my counsel"
    },
    {
      "block_id": "prov-1-26",
      "type": "verse",
      "number": 26,
      "text": "I also will laugh at your calamity;"
    },
    {
      "block_id": "prov-1-27",
      "type": "verse",
      "number": 27,
      "text": "when panic strikes you like a storm"
    },
    {
      "block_id": "prov-1-28",
      "type": "verse",
      "number": 28,
      "text": "Then they will call upon me, but I will not answer;"
    },
    {
      "block_id": "prov-1-29",
      "type": "verse",
      "number": 29,
      "text": "Because they hated knowledge"
    },
    {
      "block_id": "prov-1-30",
      "type": "verse",
      "number": 30,
      "text": "would have none of my counsel"
    },
    {
      "block_id": "prov-1-31",
      "type": "verse",
      "number": 31,
      "text": "therefore they shall eat the fruit of their way"
    },
    {
      "block_id": "prov-1-32",
      "type": "verse",
      "number": 32,
      "text": "For waywardness kills the simple,"
    },
    {
      "block_id": "prov-1-33",
      "type": "verse",
      "number": 33,
      "text": "but those who listen to me will be secure"
    }
  ]
}