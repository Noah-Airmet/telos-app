{
  "document_id": "col-11",
  "title": "Colossians 11",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-11-1",
      "type": "verse",
      "number": 1,
      "text": "The wisdom of the humble lifts their heads high"
    },
    {
      "block_id": "col-11-2",
      "type": "verse",
      "number": 2,
      "text": "Do not praise individuals for their good looks"
    },
    {
      "block_id": "col-11-3",
      "type": "verse",
      "number": 3,
      "text": "The bee is small among flying creatures,"
    },
    {
      "block_id": "col-11-4",
      "type": "verse",
      "number": 4,
      "text": "Do not mock those wearing only a loincloth"
    },
    {
      "block_id": "col-11-5",
      "type": "verse",
      "number": 5,
      "text": "Many oppressed have sat upon a throne,"
    },
    {
      "block_id": "col-11-6",
      "type": "verse",
      "number": 6,
      "text": "Many rulers have been utterly disgraced,"
    },
    {
      "block_id": "col-11-7",
      "type": "verse",
      "number": 7,
      "text": "Do not find fault before you investigate;"
    },
    {
      "block_id": "col-11-8",
      "type": "verse",
      "number": 8,
      "text": "Do not answer before you listen,"
    },
    {
      "block_id": "col-11-9",
      "type": "verse",
      "number": 9,
      "text": "Do not argue about a matter that does not concern you,"
    },
    {
      "block_id": "col-11-10",
      "type": "verse",
      "number": 10,
      "text": "My child, do not busy yourself with many matters;"
    },
    {
      "block_id": "col-11-11",
      "type": "verse",
      "number": 11,
      "text": "There are those who work and struggle and hurry"
    },
    {
      "block_id": "col-11-12",
      "type": "verse",
      "number": 12,
      "text": "There are others who are slow and need help,"
    },
    {
      "block_id": "col-11-13",
      "type": "verse",
      "number": 13,
      "text": "and raises up their heads"
    },
    {
      "block_id": "col-11-14",
      "type": "verse",
      "number": 14,
      "text": "Good things and bad, life and death,"
    },
    {
      "block_id": "col-11-17",
      "type": "verse",
      "number": 17,
      "text": "The Lord’s gift remains with the devout,"
    },
    {
      "block_id": "col-11-18",
      "type": "verse",
      "number": 18,
      "text": "A person becomes rich through diligence and self-denial,"
    },
    {
      "block_id": "col-11-19",
      "type": "verse",
      "number": 19,
      "text": "when he says, “I have found rest,"
    },
    {
      "block_id": "col-11-20",
      "type": "verse",
      "number": 20,
      "text": "Stand by your agreement and attend to it,"
    },
    {
      "block_id": "col-11-21",
      "type": "verse",
      "number": 21,
      "text": "Do not wonder at the works of a sinner,"
    },
    {
      "block_id": "col-11-22",
      "type": "verse",
      "number": 22,
      "text": "The blessing of the Lord is the reward of the pious,"
    },
    {
      "block_id": "col-11-23",
      "type": "verse",
      "number": 23,
      "text": "Do not say, “What do I need,"
    },
    {
      "block_id": "col-11-24",
      "type": "verse",
      "number": 24,
      "text": "Do not say, “I have enough,"
    },
    {
      "block_id": "col-11-25",
      "type": "verse",
      "number": 25,
      "text": "In the day of prosperity, adversity is forgotten,"
    },
    {
      "block_id": "col-11-26",
      "type": "verse",
      "number": 26,
      "text": "For it is easy for the Lord on the day of death"
    },
    {
      "block_id": "col-11-27",
      "type": "verse",
      "number": 27,
      "text": "An hour’s misery makes one forget delights,"
    },
    {
      "block_id": "col-11-28",
      "type": "verse",
      "number": 28,
      "text": "Call no one happy before his death;"
    },
    {
      "block_id": "col-11-29",
      "type": "verse",
      "number": 29,
      "text": "Do not invite everyone into your home,"
    },
    {
      "block_id": "col-11-30",
      "type": "verse",
      "number": 30,
      "text": "Like a decoy partridge in a cage, so is the mind of the proud,"
    },
    {
      "block_id": "col-11-31",
      "type": "verse",
      "number": 31,
      "text": "for they lie in wait, turning good into evil,"
    },
    {
      "block_id": "col-11-32",
      "type": "verse",
      "number": 32,
      "text": "From a spark many coals are kindled,"
    },
    {
      "block_id": "col-11-33",
      "type": "verse",
      "number": 33,
      "text": "Beware of scoundrels, for they devise evil,"
    },
    {
      "block_id": "col-11-34",
      "type": "verse",
      "number": 34,
      "text": "Receive strangers into your home, and they will stir up trouble for you"
    }
  ]
}