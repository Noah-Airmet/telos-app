{
  "document_id": "sir-32",
  "title": "Sirach 32",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-32-1",
      "type": "verse",
      "number": 1,
      "text": "If they make you master of the feast, do not exalt yourself;"
    },
    {
      "block_id": "sir-32-2",
      "type": "verse",
      "number": 2,
      "text": "when you have fulfilled all your duties, take your place,"
    },
    {
      "block_id": "sir-32-3",
      "type": "verse",
      "number": 3,
      "text": "Speak, you who are older, for it is your right,"
    },
    {
      "block_id": "sir-32-4",
      "type": "verse",
      "number": 4,
      "text": "Where there is entertainment, do not pour out talk;"
    },
    {
      "block_id": "sir-32-5",
      "type": "verse",
      "number": 5,
      "text": "A ruby seal in a setting of gold"
    },
    {
      "block_id": "sir-32-6",
      "type": "verse",
      "number": 6,
      "text": "A seal of emerald in a rich setting of gold"
    },
    {
      "block_id": "sir-32-7",
      "type": "verse",
      "number": 7,
      "text": "Speak, you who are young, if you are obliged to,"
    },
    {
      "block_id": "sir-32-8",
      "type": "verse",
      "number": 8,
      "text": "Be brief; say much in few words;"
    },
    {
      "block_id": "sir-32-9",
      "type": "verse",
      "number": 9,
      "text": "Among the great do not act as their equal;"
    },
    {
      "block_id": "sir-32-10",
      "type": "verse",
      "number": 10,
      "text": "Lightning travels ahead of the thunder,"
    },
    {
      "block_id": "sir-32-11",
      "type": "verse",
      "number": 11,
      "text": "Leave in good time and do not be the last;"
    },
    {
      "block_id": "sir-32-12",
      "type": "verse",
      "number": 12,
      "text": "Amuse yourself there to your heart’s content,"
    },
    {
      "block_id": "sir-32-13",
      "type": "verse",
      "number": 13,
      "text": "But above all bless your Maker,"
    },
    {
      "block_id": "sir-32-14",
      "type": "verse",
      "number": 14,
      "text": "The one who seeks God will accept his discipline,"
    },
    {
      "block_id": "sir-32-15",
      "type": "verse",
      "number": 15,
      "text": "The one who seeks the law will be filled with it,"
    },
    {
      "block_id": "sir-32-16",
      "type": "verse",
      "number": 16,
      "text": "Those who fear the Lord will form true judgments,"
    },
    {
      "block_id": "sir-32-17",
      "type": "verse",
      "number": 17,
      "text": "Sinners will shun reproof"
    },
    {
      "block_id": "sir-32-18",
      "type": "verse",
      "number": 18,
      "text": "A sensible person will not overlook a thoughtful suggestion;"
    },
    {
      "block_id": "sir-32-19",
      "type": "verse",
      "number": 19,
      "text": "Do nothing without deliberation,"
    },
    {
      "block_id": "sir-32-20",
      "type": "verse",
      "number": 20,
      "text": "Do not go on a path full of hazards,"
    },
    {
      "block_id": "sir-32-21",
      "type": "verse",
      "number": 21,
      "text": "Do not be overconfident on a smooth road,"
    },
    {
      "block_id": "sir-32-22",
      "type": "verse",
      "number": 22,
      "text": "and give good heed to your paths."
    },
    {
      "block_id": "sir-32-23",
      "type": "verse",
      "number": 23,
      "text": "Guard yourself in every act,"
    },
    {
      "block_id": "sir-32-24",
      "type": "verse",
      "number": 24,
      "text": "The one who keeps the law preserves himself,"
    }
  ]
}