{
  "document_id": "ps-36",
  "title": "Psalms 36",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-36-1",
      "type": "verse",
      "number": 1,
      "text": "Transgression speaks to the wicked"
    },
    {
      "block_id": "ps-36-2",
      "type": "verse",
      "number": 2,
      "text": "For they flatter themselves in their own eyes"
    },
    {
      "block_id": "ps-36-3",
      "type": "verse",
      "number": 3,
      "text": "The words of their mouths are mischief and deceit;"
    },
    {
      "block_id": "ps-36-4",
      "type": "verse",
      "number": 4,
      "text": "They plot mischief while on their beds;"
    },
    {
      "block_id": "ps-36-5",
      "type": "verse",
      "number": 5,
      "text": "Your steadfast love, O Lord, extends to the heavens,"
    },
    {
      "block_id": "ps-36-6",
      "type": "verse",
      "number": 6,
      "text": "Your righteousness is like the mighty mountains;"
    },
    {
      "block_id": "ps-36-7",
      "type": "verse",
      "number": 7,
      "text": "How precious is your steadfast love, O God!"
    },
    {
      "block_id": "ps-36-8",
      "type": "verse",
      "number": 8,
      "text": "They feast on the abundance of your house,"
    },
    {
      "block_id": "ps-36-9",
      "type": "verse",
      "number": 9,
      "text": "For with you is the fountain of life;"
    },
    {
      "block_id": "ps-36-10",
      "type": "verse",
      "number": 10,
      "text": "O continue your steadfast love to those who know you"
    },
    {
      "block_id": "ps-36-11",
      "type": "verse",
      "number": 11,
      "text": "Do not let the foot of the arrogant tread on me"
    },
    {
      "block_id": "ps-36-12",
      "type": "verse",
      "number": 12,
      "text": "There the evildoers lie prostrate;"
    }
  ]
}