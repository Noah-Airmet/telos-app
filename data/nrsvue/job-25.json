{
  "document_id": "job-25",
  "title": "Job 25",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-25-heading-bildad-speaks:-how-c",
      "type": "heading",
      "text": "Bildad Speaks: How Can a Mortal Be Righteous Before God?"
    },
    {
      "block_id": "job-25-1",
      "type": "verse",
      "number": 1,
      "text": "Then Bildad the Shuhite answered:"
    },
    {
      "block_id": "job-25-2",
      "type": "verse",
      "number": 2,
      "text": "“Dominion and fear are with God;"
    },
    {
      "block_id": "job-25-3",
      "type": "verse",
      "number": 3,
      "text": "Is there any number to his armies?"
    },
    {
      "block_id": "job-25-4",
      "type": "verse",
      "number": 4,
      "text": "How then can a mortal be righteous before God?"
    },
    {
      "block_id": "job-25-5",
      "type": "verse",
      "number": 5,
      "text": "If even the moon is not bright"
    },
    {
      "block_id": "job-25-6",
      "type": "verse",
      "number": 6,
      "text": "how much less a mortal, who is a maggot,"
    }
  ]
}