{
  "document_id": "ps-2",
  "title": "Psalms 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-2-1",
      "type": "verse",
      "number": 1,
      "text": "Why do the nations conspire"
    },
    {
      "block_id": "ps-2-2",
      "type": "verse",
      "number": 2,
      "text": "The kings of the earth set themselves,"
    },
    {
      "block_id": "ps-2-3",
      "type": "verse",
      "number": 3,
      "text": "“Let us burst their bonds apart"
    },
    {
      "block_id": "ps-2-4",
      "type": "verse",
      "number": 4,
      "text": "He who sits in the heavens laughs;"
    },
    {
      "block_id": "ps-2-5",
      "type": "verse",
      "number": 5,
      "text": "Then he will speak to them in his wrath"
    },
    {
      "block_id": "ps-2-6",
      "type": "verse",
      "number": 6,
      "text": "“I have set my king on Zion, my holy hill.”"
    },
    {
      "block_id": "ps-2-7",
      "type": "verse",
      "number": 7,
      "text": "I will tell of the decree of the Lord:"
    },
    {
      "block_id": "ps-2-8",
      "type": "verse",
      "number": 8,
      "text": "Ask of me, and I will make the nations your heritage"
    },
    {
      "block_id": "ps-2-9",
      "type": "verse",
      "number": 9,
      "text": "You shall break them with a rod of iron"
    },
    {
      "block_id": "ps-2-10",
      "type": "verse",
      "number": 10,
      "text": "Now therefore, O kings, be wise;"
    },
    {
      "block_id": "ps-2-11",
      "type": "verse",
      "number": 11,
      "text": "Serve the Lord with fear;"
    },
    {
      "block_id": "ps-2-12",
      "type": "verse",
      "number": 12,
      "text": "kiss his feet,"
    }
  ]
}