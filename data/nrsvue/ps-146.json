{
  "document_id": "ps-146",
  "title": "Psalms 146",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-146-1",
      "type": "verse",
      "number": 1,
      "text": "Praise the Lord!"
    },
    {
      "block_id": "ps-146-2",
      "type": "verse",
      "number": 2,
      "text": "I will praise the Lord as long as I live;"
    },
    {
      "block_id": "ps-146-3",
      "type": "verse",
      "number": 3,
      "text": "Do not put your trust in princes,"
    },
    {
      "block_id": "ps-146-4",
      "type": "verse",
      "number": 4,
      "text": "When their breath departs, they return to the earth;"
    },
    {
      "block_id": "ps-146-5",
      "type": "verse",
      "number": 5,
      "text": "Happy are those whose help is the God of Jacob,"
    },
    {
      "block_id": "ps-146-6",
      "type": "verse",
      "number": 6,
      "text": "who made heaven and earth,"
    },
    {
      "block_id": "ps-146-7",
      "type": "verse",
      "number": 7,
      "text": "who executes justice for the oppressed;"
    },
    {
      "block_id": "ps-146-8",
      "type": "verse",
      "number": 8,
      "text": "the Lord opens the eyes of the blind."
    },
    {
      "block_id": "ps-146-9",
      "type": "verse",
      "number": 9,
      "text": "The Lord watches over the strangers;"
    },
    {
      "block_id": "ps-146-10",
      "type": "verse",
      "number": 10,
      "text": "The Lord will reign forever,"
    }
  ]
}