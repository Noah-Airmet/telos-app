{
  "document_id": "isa-49",
  "title": "Isaiah 49",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-49-1",
      "type": "verse",
      "number": 1,
      "text": "Listen to me, O coastlands;"
    },
    {
      "block_id": "isa-49-2",
      "type": "verse",
      "number": 2,
      "text": "He made my mouth like a sharp sword;"
    },
    {
      "block_id": "isa-49-3",
      "type": "verse",
      "number": 3,
      "text": "And he said to me, “You are my servant,"
    },
    {
      "block_id": "isa-49-4",
      "type": "verse",
      "number": 4,
      "text": "But I said, “I have labored in vain;"
    },
    {
      "block_id": "isa-49-5",
      "type": "verse",
      "number": 5,
      "text": "And now the Lord says,"
    },
    {
      "block_id": "isa-49-6",
      "type": "verse",
      "number": 6,
      "text": "he says,"
    },
    {
      "block_id": "isa-49-7",
      "type": "verse",
      "number": 7,
      "text": "Thus says the Lord,"
    },
    {
      "block_id": "isa-49-8",
      "type": "verse",
      "number": 8,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "isa-49-9",
      "type": "verse",
      "number": 9,
      "text": "saying to the prisoners, “Come out,”"
    },
    {
      "block_id": "isa-49-10",
      "type": "verse",
      "number": 10,
      "text": "they shall not hunger or thirst,"
    },
    {
      "block_id": "isa-49-11",
      "type": "verse",
      "number": 11,
      "text": "And I will turn all my mountains into a road,"
    },
    {
      "block_id": "isa-49-12",
      "type": "verse",
      "number": 12,
      "text": "Look, some shall come from far away,"
    },
    {
      "block_id": "isa-49-13",
      "type": "verse",
      "number": 13,
      "text": "Sing for joy, O heavens, and exult, O earth;"
    },
    {
      "block_id": "isa-49-14",
      "type": "verse",
      "number": 14,
      "text": "But Zion said, “The Lord has forsaken me;"
    },
    {
      "block_id": "isa-49-15",
      "type": "verse",
      "number": 15,
      "text": "Can a woman forget her nursing child"
    },
    {
      "block_id": "isa-49-16",
      "type": "verse",
      "number": 16,
      "text": "See, I have inscribed you on the palms of my hands;"
    },
    {
      "block_id": "isa-49-17",
      "type": "verse",
      "number": 17,
      "text": "Your builders outdo your destroyers,"
    },
    {
      "block_id": "isa-49-18",
      "type": "verse",
      "number": 18,
      "text": "Lift up your eyes all around and see;"
    },
    {
      "block_id": "isa-49-19",
      "type": "verse",
      "number": 19,
      "text": "For your wastelands, your desolate places,"
    },
    {
      "block_id": "isa-49-20",
      "type": "verse",
      "number": 20,
      "text": "The children born in the time of your bereavement"
    },
    {
      "block_id": "isa-49-21",
      "type": "verse",
      "number": 21,
      "text": "Then you will say in your heart,"
    },
    {
      "block_id": "isa-49-22",
      "type": "verse",
      "number": 22,
      "text": "Thus says the Lord God:"
    },
    {
      "block_id": "isa-49-23",
      "type": "verse",
      "number": 23,
      "text": "Kings shall be your foster fathers"
    },
    {
      "block_id": "isa-49-24",
      "type": "verse",
      "number": 24,
      "text": "Can the prey be taken from the mighty"
    },
    {
      "block_id": "isa-49-25",
      "type": "verse",
      "number": 25,
      "text": "But thus says the Lord:"
    },
    {
      "block_id": "isa-49-26",
      "type": "verse",
      "number": 26,
      "text": "I will make your oppressors eat their own flesh,"
    }
  ]
}