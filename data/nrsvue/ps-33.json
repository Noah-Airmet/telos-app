{
  "document_id": "ps-33",
  "title": "Psalms 33",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-33-1",
      "type": "verse",
      "number": 1,
      "text": "Rejoice in the Lord, O you righteous."
    },
    {
      "block_id": "ps-33-2",
      "type": "verse",
      "number": 2,
      "text": "Praise the Lord with the lyre;"
    },
    {
      "block_id": "ps-33-3",
      "type": "verse",
      "number": 3,
      "text": "Sing to him a new song;"
    },
    {
      "block_id": "ps-33-4",
      "type": "verse",
      "number": 4,
      "text": "For the word of the Lord is upright,"
    },
    {
      "block_id": "ps-33-5",
      "type": "verse",
      "number": 5,
      "text": "He loves righteousness and justice;"
    },
    {
      "block_id": "ps-33-6",
      "type": "verse",
      "number": 6,
      "text": "By the word of the Lord the heavens were made"
    },
    {
      "block_id": "ps-33-7",
      "type": "verse",
      "number": 7,
      "text": "He gathered the waters of the sea as in a bottle;"
    },
    {
      "block_id": "ps-33-8",
      "type": "verse",
      "number": 8,
      "text": "Let all the earth fear the Lord;"
    },
    {
      "block_id": "ps-33-9",
      "type": "verse",
      "number": 9,
      "text": "for he spoke, and it came to be;"
    },
    {
      "block_id": "ps-33-10",
      "type": "verse",
      "number": 10,
      "text": "The Lord brings the counsel of the nations to nothing;"
    },
    {
      "block_id": "ps-33-11",
      "type": "verse",
      "number": 11,
      "text": "The counsel of the Lord stands forever,"
    },
    {
      "block_id": "ps-33-12",
      "type": "verse",
      "number": 12,
      "text": "Happy is the nation whose God is the Lord,"
    },
    {
      "block_id": "ps-33-13",
      "type": "verse",
      "number": 13,
      "text": "The Lord looks down from heaven;"
    },
    {
      "block_id": "ps-33-14",
      "type": "verse",
      "number": 14,
      "text": "From where he sits enthroned he watches"
    },
    {
      "block_id": "ps-33-15",
      "type": "verse",
      "number": 15,
      "text": "he who fashions the hearts of them all"
    },
    {
      "block_id": "ps-33-16",
      "type": "verse",
      "number": 16,
      "text": "A king is not saved by his great army;"
    },
    {
      "block_id": "ps-33-17",
      "type": "verse",
      "number": 17,
      "text": "The war horse is a vain hope for victory,"
    },
    {
      "block_id": "ps-33-18",
      "type": "verse",
      "number": 18,
      "text": "Truly the eye of the Lord is on those who fear him,"
    },
    {
      "block_id": "ps-33-19",
      "type": "verse",
      "number": 19,
      "text": "to deliver their soul from death"
    },
    {
      "block_id": "ps-33-20",
      "type": "verse",
      "number": 20,
      "text": "Our soul waits for the Lord;"
    },
    {
      "block_id": "ps-33-21",
      "type": "verse",
      "number": 21,
      "text": "Our heart is glad in him"
    },
    {
      "block_id": "ps-33-22",
      "type": "verse",
      "number": 22,
      "text": "Let your steadfast love, O Lord, be upon us,"
    }
  ]
}