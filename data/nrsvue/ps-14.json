{
  "document_id": "ps-14",
  "title": "Psalms 14",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-14-1",
      "type": "verse",
      "number": 1,
      "text": "Fools say in their hearts, “There is no God.”"
    },
    {
      "block_id": "ps-14-2",
      "type": "verse",
      "number": 2,
      "text": "The Lord looks down from heaven on humankind"
    },
    {
      "block_id": "ps-14-3",
      "type": "verse",
      "number": 3,
      "text": "They have all gone astray; they are all alike perverse;"
    },
    {
      "block_id": "ps-14-4",
      "type": "verse",
      "number": 4,
      "text": "Have they no knowledge, all the evildoers"
    },
    {
      "block_id": "ps-14-5",
      "type": "verse",
      "number": 5,
      "text": "There they shall be in great terror,"
    },
    {
      "block_id": "ps-14-6",
      "type": "verse",
      "number": 6,
      "text": "You would confound the plans of the poor,"
    },
    {
      "block_id": "ps-14-7",
      "type": "verse",
      "number": 7,
      "text": "O that deliverance for Israel would come from Zion!"
    }
  ]
}