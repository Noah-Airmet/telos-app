{
  "document_id": "isa-54",
  "title": "Isaiah 54",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-54-1",
      "type": "verse",
      "number": 1,
      "text": "Shout for joy, O barren one who has borne no children;"
    },
    {
      "block_id": "isa-54-2",
      "type": "verse",
      "number": 2,
      "text": "Enlarge the site of your tent,"
    },
    {
      "block_id": "isa-54-3",
      "type": "verse",
      "number": 3,
      "text": "For you will spread out to the right and to the left,"
    },
    {
      "block_id": "isa-54-4",
      "type": "verse",
      "number": 4,
      "text": "Do not fear, for you will not be ashamed;"
    },
    {
      "block_id": "isa-54-5",
      "type": "verse",
      "number": 5,
      "text": "For your Maker is your husband;"
    },
    {
      "block_id": "isa-54-6",
      "type": "verse",
      "number": 6,
      "text": "For the Lord has called you"
    },
    {
      "block_id": "isa-54-7",
      "type": "verse",
      "number": 7,
      "text": "For a brief moment I abandoned you,"
    },
    {
      "block_id": "isa-54-8",
      "type": "verse",
      "number": 8,
      "text": "In overflowing wrath for a moment"
    },
    {
      "block_id": "isa-54-9",
      "type": "verse",
      "number": 9,
      "text": "This is like the days of Noah to me:"
    },
    {
      "block_id": "isa-54-10",
      "type": "verse",
      "number": 10,
      "text": "For the mountains may depart"
    },
    {
      "block_id": "isa-54-11",
      "type": "verse",
      "number": 11,
      "text": "O afflicted one, storm-tossed and not comforted,"
    },
    {
      "block_id": "isa-54-12",
      "type": "verse",
      "number": 12,
      "text": "I will make your pinnacles of rubies,"
    },
    {
      "block_id": "isa-54-13",
      "type": "verse",
      "number": 13,
      "text": "All your children shall be taught by the Lord,"
    },
    {
      "block_id": "isa-54-14",
      "type": "verse",
      "number": 14,
      "text": "In righteousness you shall be established;"
    },
    {
      "block_id": "isa-54-15",
      "type": "verse",
      "number": 15,
      "text": "If anyone stirs up strife,"
    },
    {
      "block_id": "isa-54-16",
      "type": "verse",
      "number": 16,
      "text": "See, it is I who have created the smith"
    },
    {
      "block_id": "isa-54-17",
      "type": "verse",
      "number": 17,
      "text": "No weapon that is fashioned against you shall prosper,"
    }
  ]
}