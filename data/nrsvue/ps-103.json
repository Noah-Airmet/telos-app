{
  "document_id": "ps-103",
  "title": "Psalms 103",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-103-1",
      "type": "verse",
      "number": 1,
      "text": "Bless the Lord, O my soul,"
    },
    {
      "block_id": "ps-103-2",
      "type": "verse",
      "number": 2,
      "text": "Bless the Lord, O my soul,"
    },
    {
      "block_id": "ps-103-3",
      "type": "verse",
      "number": 3,
      "text": "who forgives all your iniquity,"
    },
    {
      "block_id": "ps-103-4",
      "type": "verse",
      "number": 4,
      "text": "who redeems your life from the Pit,"
    },
    {
      "block_id": "ps-103-5",
      "type": "verse",
      "number": 5,
      "text": "who satisfies you with good as long as you live"
    },
    {
      "block_id": "ps-103-6",
      "type": "verse",
      "number": 6,
      "text": "The Lord works vindication"
    },
    {
      "block_id": "ps-103-7",
      "type": "verse",
      "number": 7,
      "text": "He made known his ways to Moses,"
    },
    {
      "block_id": "ps-103-8",
      "type": "verse",
      "number": 8,
      "text": "The Lord is merciful and gracious,"
    },
    {
      "block_id": "ps-103-9",
      "type": "verse",
      "number": 9,
      "text": "He will not always accuse,"
    },
    {
      "block_id": "ps-103-10",
      "type": "verse",
      "number": 10,
      "text": "He does not deal with us according to our sins"
    },
    {
      "block_id": "ps-103-11",
      "type": "verse",
      "number": 11,
      "text": "For as the heavens are high above the earth,"
    },
    {
      "block_id": "ps-103-12",
      "type": "verse",
      "number": 12,
      "text": "as far as the east is from the west,"
    },
    {
      "block_id": "ps-103-13",
      "type": "verse",
      "number": 13,
      "text": "As a father has compassion for his children,"
    },
    {
      "block_id": "ps-103-14",
      "type": "verse",
      "number": 14,
      "text": "For he knows how we were made;"
    },
    {
      "block_id": "ps-103-15",
      "type": "verse",
      "number": 15,
      "text": "As for mortals, their days are like grass;"
    },
    {
      "block_id": "ps-103-16",
      "type": "verse",
      "number": 16,
      "text": "for the wind passes over it, and it is gone,"
    },
    {
      "block_id": "ps-103-17",
      "type": "verse",
      "number": 17,
      "text": "But the steadfast love of the Lord is from everlasting to everlasting"
    },
    {
      "block_id": "ps-103-18",
      "type": "verse",
      "number": 18,
      "text": "to those who keep his covenant"
    },
    {
      "block_id": "ps-103-19",
      "type": "verse",
      "number": 19,
      "text": "The Lord has established his throne in the heavens,"
    },
    {
      "block_id": "ps-103-20",
      "type": "verse",
      "number": 20,
      "text": "Bless the Lord, O you his angels,"
    },
    {
      "block_id": "ps-103-21",
      "type": "verse",
      "number": 21,
      "text": "Bless the Lord, all his hosts,"
    },
    {
      "block_id": "ps-103-22",
      "type": "verse",
      "number": 22,
      "text": "Bless the Lord, all his works,"
    }
  ]
}