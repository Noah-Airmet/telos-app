{
  "document_id": "ps-43",
  "title": "Psalms 43",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-43-1",
      "type": "verse",
      "number": 1,
      "text": "Vindicate me, O God, and defend my cause"
    },
    {
      "block_id": "ps-43-2",
      "type": "verse",
      "number": 2,
      "text": "For you are the God in whom I take refuge;"
    },
    {
      "block_id": "ps-43-3",
      "type": "verse",
      "number": 3,
      "text": "O send out your light and your truth;"
    },
    {
      "block_id": "ps-43-4",
      "type": "verse",
      "number": 4,
      "text": "Then I will go to the altar of God,"
    },
    {
      "block_id": "ps-43-5",
      "type": "verse",
      "number": 5,
      "text": "Why are you cast down, O my soul,"
    }
  ]
}