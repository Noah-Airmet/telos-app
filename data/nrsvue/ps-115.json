{
  "document_id": "ps-115",
  "title": "Psalms 115",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-115-1",
      "type": "verse",
      "number": 1,
      "text": "Not to us, O Lord, not to us, but to your name give glory,"
    },
    {
      "block_id": "ps-115-2",
      "type": "verse",
      "number": 2,
      "text": "Why should the nations say,"
    },
    {
      "block_id": "ps-115-3",
      "type": "verse",
      "number": 3,
      "text": "Our God is in the heavens;"
    },
    {
      "block_id": "ps-115-4",
      "type": "verse",
      "number": 4,
      "text": "Their idols are silver and gold,"
    },
    {
      "block_id": "ps-115-5",
      "type": "verse",
      "number": 5,
      "text": "They have mouths, but they do not speak;"
    },
    {
      "block_id": "ps-115-6",
      "type": "verse",
      "number": 6,
      "text": "They have ears, but they do not hear;"
    },
    {
      "block_id": "ps-115-7",
      "type": "verse",
      "number": 7,
      "text": "They have hands, but they do not feel;"
    },
    {
      "block_id": "ps-115-8",
      "type": "verse",
      "number": 8,
      "text": "Those who make them are like them;"
    },
    {
      "block_id": "ps-115-9",
      "type": "verse",
      "number": 9,
      "text": "O Israel, trust in the Lord!"
    },
    {
      "block_id": "ps-115-10",
      "type": "verse",
      "number": 10,
      "text": "O house of Aaron, trust in the Lord!"
    },
    {
      "block_id": "ps-115-11",
      "type": "verse",
      "number": 11,
      "text": "You who fear the Lord, trust in the Lord!"
    },
    {
      "block_id": "ps-115-12",
      "type": "verse",
      "number": 12,
      "text": "The Lord has been mindful of us; he will bless us;"
    },
    {
      "block_id": "ps-115-13",
      "type": "verse",
      "number": 13,
      "text": "he will bless those who fear the Lord,"
    },
    {
      "block_id": "ps-115-14",
      "type": "verse",
      "number": 14,
      "text": "May the Lord give you increase,"
    },
    {
      "block_id": "ps-115-15",
      "type": "verse",
      "number": 15,
      "text": "May you be blessed by the Lord,"
    },
    {
      "block_id": "ps-115-16",
      "type": "verse",
      "number": 16,
      "text": "The heavens are the Lord’s heavens,"
    },
    {
      "block_id": "ps-115-17",
      "type": "verse",
      "number": 17,
      "text": "The dead do not praise the Lord,"
    },
    {
      "block_id": "ps-115-18",
      "type": "verse",
      "number": 18,
      "text": "But we will bless the Lord"
    }
  ]
}