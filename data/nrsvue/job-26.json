{
  "document_id": "job-26",
  "title": "Job 26",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-26-heading-job-replies:-god’s-m",
      "type": "heading",
      "text": "Job Replies: God’s Majesty Is Unsearchable"
    },
    {
      "block_id": "job-26-1",
      "type": "verse",
      "number": 1,
      "text": "Then Job answered:"
    },
    {
      "block_id": "job-26-2",
      "type": "verse",
      "number": 2,
      "text": "“How you have helped one who has no power!"
    },
    {
      "block_id": "job-26-3",
      "type": "verse",
      "number": 3,
      "text": "How you have counseled one who has no wisdom"
    },
    {
      "block_id": "job-26-4",
      "type": "verse",
      "number": 4,
      "text": "With whose help have you uttered words,"
    },
    {
      "block_id": "job-26-5",
      "type": "verse",
      "number": 5,
      "text": "The shades below tremble,"
    },
    {
      "block_id": "job-26-6",
      "type": "verse",
      "number": 6,
      "text": "Sheol is naked before God,"
    },
    {
      "block_id": "job-26-7",
      "type": "verse",
      "number": 7,
      "text": "He stretches out Zaphon over the void"
    },
    {
      "block_id": "job-26-8",
      "type": "verse",
      "number": 8,
      "text": "He binds up the waters in his thick clouds,"
    },
    {
      "block_id": "job-26-9",
      "type": "verse",
      "number": 9,
      "text": "He covers the face of the full moon"
    },
    {
      "block_id": "job-26-10",
      "type": "verse",
      "number": 10,
      "text": "He has described a circle on the face of the waters,"
    },
    {
      "block_id": "job-26-11",
      "type": "verse",
      "number": 11,
      "text": "The pillars of heaven tremble"
    },
    {
      "block_id": "job-26-12",
      "type": "verse",
      "number": 12,
      "text": "By his power he stilled the Sea;"
    },
    {
      "block_id": "job-26-13",
      "type": "verse",
      "number": 13,
      "text": "By his wind the heavens were made fair;"
    },
    {
      "block_id": "job-26-14",
      "type": "verse",
      "number": 14,
      "text": "These are indeed but the outskirts of his ways,"
    }
  ]
}