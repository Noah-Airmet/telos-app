{
  "document_id": "isa-43",
  "title": "Isaiah 43",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-43-1",
      "type": "verse",
      "number": 1,
      "text": "But now thus says the Lord,"
    },
    {
      "block_id": "isa-43-2",
      "type": "verse",
      "number": 2,
      "text": "When you pass through the waters, I will be with you,"
    },
    {
      "block_id": "isa-43-3",
      "type": "verse",
      "number": 3,
      "text": "For I am the Lord your God,"
    },
    {
      "block_id": "isa-43-4",
      "type": "verse",
      "number": 4,
      "text": "Because you are precious in my sight"
    },
    {
      "block_id": "isa-43-5",
      "type": "verse",
      "number": 5,
      "text": "Do not fear, for I am with you;"
    },
    {
      "block_id": "isa-43-6",
      "type": "verse",
      "number": 6,
      "text": "I will say to the north, “Give them up,”"
    },
    {
      "block_id": "isa-43-7",
      "type": "verse",
      "number": 7,
      "text": "everyone who is called by my name,"
    },
    {
      "block_id": "isa-43-8",
      "type": "verse",
      "number": 8,
      "text": "Bring forth the people who are blind yet have eyes,"
    },
    {
      "block_id": "isa-43-9",
      "type": "verse",
      "number": 9,
      "text": "Let all the nations gather together,"
    },
    {
      "block_id": "isa-43-10",
      "type": "verse",
      "number": 10,
      "text": "You are my witnesses, says the Lord,"
    },
    {
      "block_id": "isa-43-11",
      "type": "verse",
      "number": 11,
      "text": "I, I am the Lord,"
    },
    {
      "block_id": "isa-43-12",
      "type": "verse",
      "number": 12,
      "text": "I am the one who declared and saved and proclaimed,"
    },
    {
      "block_id": "isa-43-13",
      "type": "verse",
      "number": 13,
      "text": "Indeed, since that day I am he;"
    },
    {
      "block_id": "isa-43-14",
      "type": "verse",
      "number": 14,
      "text": "Thus says the Lord,"
    },
    {
      "block_id": "isa-43-15",
      "type": "verse",
      "number": 15,
      "text": "I am the Lord, your Holy One,"
    },
    {
      "block_id": "isa-43-16",
      "type": "verse",
      "number": 16,
      "text": "Thus says the Lord,"
    },
    {
      "block_id": "isa-43-17",
      "type": "verse",
      "number": 17,
      "text": "who brings out chariot and horse,"
    },
    {
      "block_id": "isa-43-18",
      "type": "verse",
      "number": 18,
      "text": "Do not remember the former things"
    },
    {
      "block_id": "isa-43-19",
      "type": "verse",
      "number": 19,
      "text": "I am about to do a new thing;"
    },
    {
      "block_id": "isa-43-20",
      "type": "verse",
      "number": 20,
      "text": "The wild animals will honor me,"
    },
    {
      "block_id": "isa-43-21",
      "type": "verse",
      "number": 21,
      "text": "the people whom I formed for myself"
    },
    {
      "block_id": "isa-43-22",
      "type": "verse",
      "number": 22,
      "text": "Yet you did not call upon me, O Jacob;"
    },
    {
      "block_id": "isa-43-23",
      "type": "verse",
      "number": 23,
      "text": "You have not brought me your sheep for burnt offerings"
    },
    {
      "block_id": "isa-43-24",
      "type": "verse",
      "number": 24,
      "text": "You have not bought me sweet cane with money"
    },
    {
      "block_id": "isa-43-25",
      "type": "verse",
      "number": 25,
      "text": "I alone am the one"
    },
    {
      "block_id": "isa-43-26",
      "type": "verse",
      "number": 26,
      "text": "Accuse me; let us go to trial;"
    },
    {
      "block_id": "isa-43-27",
      "type": "verse",
      "number": 27,
      "text": "Your first ancestor sinned,"
    },
    {
      "block_id": "isa-43-28",
      "type": "verse",
      "number": 28,
      "text": "Therefore I profaned the princes of the sanctuary;"
    }
  ]
}