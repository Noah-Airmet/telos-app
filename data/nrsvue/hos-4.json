{
  "document_id": "hos-4",
  "title": "Hosea 4",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-4-1",
      "type": "verse",
      "number": 1,
      "text": "Hear the word of the Lord, O people of Israel,"
    },
    {
      "block_id": "hos-4-2",
      "type": "verse",
      "number": 2,
      "text": "Swearing, lying, and murder,"
    },
    {
      "block_id": "hos-4-3",
      "type": "verse",
      "number": 3,
      "text": "Therefore the land mourns,"
    },
    {
      "block_id": "hos-4-4",
      "type": "verse",
      "number": 4,
      "text": "Yet let no one contend,"
    },
    {
      "block_id": "hos-4-5",
      "type": "verse",
      "number": 5,
      "text": "You shall stumble by day;"
    },
    {
      "block_id": "hos-4-6",
      "type": "verse",
      "number": 6,
      "text": "My people are destroyed for lack of knowledge!"
    },
    {
      "block_id": "hos-4-7",
      "type": "verse",
      "number": 7,
      "text": "The more they increased,"
    },
    {
      "block_id": "hos-4-8",
      "type": "verse",
      "number": 8,
      "text": "They feed on the sin of my people;"
    },
    {
      "block_id": "hos-4-9",
      "type": "verse",
      "number": 9,
      "text": "And it shall be like people, like priest;"
    },
    {
      "block_id": "hos-4-10",
      "type": "verse",
      "number": 10,
      "text": "They shall eat but not be satisfied;"
    },
    {
      "block_id": "hos-4-11",
      "type": "verse",
      "number": 11,
      "text": "prostitution."
    },
    {
      "block_id": "hos-4-12",
      "type": "verse",
      "number": 12,
      "text": "My people consult a piece of wood,"
    },
    {
      "block_id": "hos-4-13",
      "type": "verse",
      "number": 13,
      "text": "They sacrifice on the tops of the mountains"
    },
    {
      "block_id": "hos-4-14",
      "type": "verse",
      "number": 14,
      "text": "I will not punish your daughters when they prostitute themselves"
    },
    {
      "block_id": "hos-4-15",
      "type": "verse",
      "number": 15,
      "text": "Though you prostitute yourself, O Israel,"
    },
    {
      "block_id": "hos-4-16",
      "type": "verse",
      "number": 16,
      "text": "Like a stubborn heifer,"
    },
    {
      "block_id": "hos-4-17",
      "type": "verse",
      "number": 17,
      "text": "Ephraim is joined to idols—"
    },
    {
      "block_id": "hos-4-18",
      "type": "verse",
      "number": 18,
      "text": "When their drinking is ended, they indulge in sexual orgies;"
    },
    {
      "block_id": "hos-4-19",
      "type": "verse",
      "number": 19,
      "text": "A wind has wrapped them in its wings,"
    }
  ]
}