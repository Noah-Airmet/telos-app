{
  "document_id": "sir-6",
  "title": "Sirach 6",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-6-1",
      "type": "verse",
      "number": 1,
      "text": "and do not become an enemy instead of a friend,"
    },
    {
      "block_id": "sir-6-2",
      "type": "verse",
      "number": 2,
      "text": "Do not fall into the grip of passion,"
    },
    {
      "block_id": "sir-6-3",
      "type": "verse",
      "number": 3,
      "text": "Your leaves will be devoured and your fruit destroyed,"
    },
    {
      "block_id": "sir-6-4",
      "type": "verse",
      "number": 4,
      "text": "Strong passion destroys those who have it"
    },
    {
      "block_id": "sir-6-5",
      "type": "verse",
      "number": 5,
      "text": "Pleasant speech multiplies friends,"
    },
    {
      "block_id": "sir-6-6",
      "type": "verse",
      "number": 6,
      "text": "Let those who are at peace with you be many,"
    },
    {
      "block_id": "sir-6-7",
      "type": "verse",
      "number": 7,
      "text": "When you gain friends, gain them through testing,"
    },
    {
      "block_id": "sir-6-8",
      "type": "verse",
      "number": 8,
      "text": "For there are friends who are such when it suits them,"
    },
    {
      "block_id": "sir-6-9",
      "type": "verse",
      "number": 9,
      "text": "And there are friends who turn to enmity"
    },
    {
      "block_id": "sir-6-10",
      "type": "verse",
      "number": 10,
      "text": "And there are friends who are companions at the table,"
    },
    {
      "block_id": "sir-6-11",
      "type": "verse",
      "number": 11,
      "text": "When you are prosperous, they become your second self"
    },
    {
      "block_id": "sir-6-12",
      "type": "verse",
      "number": 12,
      "text": "but if you are brought low, they turn against you"
    },
    {
      "block_id": "sir-6-13",
      "type": "verse",
      "number": 13,
      "text": "Keep away from your enemies,"
    },
    {
      "block_id": "sir-6-14",
      "type": "verse",
      "number": 14,
      "text": "Faithful friends are a sturdy shelter;"
    },
    {
      "block_id": "sir-6-15",
      "type": "verse",
      "number": 15,
      "text": "Faithful friends are beyond price;"
    },
    {
      "block_id": "sir-6-16",
      "type": "verse",
      "number": 16,
      "text": "Faithful friends are life-saving medicine,"
    },
    {
      "block_id": "sir-6-17",
      "type": "verse",
      "number": 17,
      "text": "Those who fear the Lord direct their friendship aright,"
    },
    {
      "block_id": "sir-6-18",
      "type": "verse",
      "number": 18,
      "text": "My child, from your youth choose discipline,"
    },
    {
      "block_id": "sir-6-19",
      "type": "verse",
      "number": 19,
      "text": "Come to her like one who plows and sows,"
    },
    {
      "block_id": "sir-6-20",
      "type": "verse",
      "number": 20,
      "text": "She seems very harsh to the undisciplined;"
    },
    {
      "block_id": "sir-6-21",
      "type": "verse",
      "number": 21,
      "text": "She will be like a heavy stone to test them,"
    },
    {
      "block_id": "sir-6-22",
      "type": "verse",
      "number": 22,
      "text": "For wisdom is like her name;"
    },
    {
      "block_id": "sir-6-23",
      "type": "verse",
      "number": 23,
      "text": "Listen, my child, and accept my judgment;"
    },
    {
      "block_id": "sir-6-24",
      "type": "verse",
      "number": 24,
      "text": "Put your feet into her fetters"
    },
    {
      "block_id": "sir-6-25",
      "type": "verse",
      "number": 25,
      "text": "Bend your shoulder and carry her,"
    },
    {
      "block_id": "sir-6-26",
      "type": "verse",
      "number": 26,
      "text": "Come to her with all your soul,"
    },
    {
      "block_id": "sir-6-27",
      "type": "verse",
      "number": 27,
      "text": "Search out and seek, and she will become known to you,"
    },
    {
      "block_id": "sir-6-28",
      "type": "verse",
      "number": 28,
      "text": "For at last you will find her rest,"
    },
    {
      "block_id": "sir-6-29",
      "type": "verse",
      "number": 29,
      "text": "Then her fetters will become for you a strong defense,"
    },
    {
      "block_id": "sir-6-30",
      "type": "verse",
      "number": 30,
      "text": "Her yoke is a golden ornament"
    },
    {
      "block_id": "sir-6-31",
      "type": "verse",
      "number": 31,
      "text": "You will wear her like a glorious robe"
    },
    {
      "block_id": "sir-6-32",
      "type": "verse",
      "number": 32,
      "text": "If you are willing, my child, you can be disciplined,"
    },
    {
      "block_id": "sir-6-33",
      "type": "verse",
      "number": 33,
      "text": "If you love to listen you will accept discipline,"
    },
    {
      "block_id": "sir-6-34",
      "type": "verse",
      "number": 34,
      "text": "Stand in the company of the elders."
    },
    {
      "block_id": "sir-6-35",
      "type": "verse",
      "number": 35,
      "text": "Be ready to listen to every godly discourse,"
    },
    {
      "block_id": "sir-6-36",
      "type": "verse",
      "number": 36,
      "text": "If you see an intelligent person, rise early to visit him;"
    },
    {
      "block_id": "sir-6-37",
      "type": "verse",
      "number": 37,
      "text": "Reflect on the statutes of the Lord,"
    }
  ]
}