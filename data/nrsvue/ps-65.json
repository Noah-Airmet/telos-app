{
  "document_id": "ps-65",
  "title": "Psalms 65",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-65-1",
      "type": "verse",
      "number": 1,
      "text": "Praise is due to you,"
    },
    {
      "block_id": "ps-65-2",
      "type": "verse",
      "number": 2,
      "text": "O you who answer prayer!"
    },
    {
      "block_id": "ps-65-3",
      "type": "verse",
      "number": 3,
      "text": "When deeds of iniquity overwhelm us,"
    },
    {
      "block_id": "ps-65-4",
      "type": "verse",
      "number": 4,
      "text": "Happy are those whom you choose and bring near"
    },
    {
      "block_id": "ps-65-5",
      "type": "verse",
      "number": 5,
      "text": "By awesome deeds you answer us with deliverance,"
    },
    {
      "block_id": "ps-65-6",
      "type": "verse",
      "number": 6,
      "text": "By your strength you established the mountains;"
    },
    {
      "block_id": "ps-65-7",
      "type": "verse",
      "number": 7,
      "text": "You silence the roaring of the seas,"
    },
    {
      "block_id": "ps-65-8",
      "type": "verse",
      "number": 8,
      "text": "Those who live at earth’s farthest bounds are awed by your signs;"
    },
    {
      "block_id": "ps-65-9",
      "type": "verse",
      "number": 9,
      "text": "You visit the earth and water it;"
    },
    {
      "block_id": "ps-65-10",
      "type": "verse",
      "number": 10,
      "text": "You water its furrows abundantly,"
    },
    {
      "block_id": "ps-65-11",
      "type": "verse",
      "number": 11,
      "text": "You crown the year with your bounty;"
    },
    {
      "block_id": "ps-65-12",
      "type": "verse",
      "number": 12,
      "text": "The pastures of the wilderness overflow;"
    },
    {
      "block_id": "ps-65-13",
      "type": "verse",
      "number": 13,
      "text": "the meadows clothe themselves with flocks;"
    }
  ]
}