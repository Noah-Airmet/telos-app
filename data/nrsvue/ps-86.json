{
  "document_id": "ps-86",
  "title": "Psalms 86",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-86-1",
      "type": "verse",
      "number": 1,
      "text": "Incline your ear, O Lord, and answer me,"
    },
    {
      "block_id": "ps-86-2",
      "type": "verse",
      "number": 2,
      "text": "Preserve my life, for I am devoted to you;"
    },
    {
      "block_id": "ps-86-3",
      "type": "verse",
      "number": 3,
      "text": "be gracious to me, O Lord,"
    },
    {
      "block_id": "ps-86-4",
      "type": "verse",
      "number": 4,
      "text": "Gladden the soul of your servant,"
    },
    {
      "block_id": "ps-86-5",
      "type": "verse",
      "number": 5,
      "text": "For you, O Lord, are good and forgiving,"
    },
    {
      "block_id": "ps-86-6",
      "type": "verse",
      "number": 6,
      "text": "Give ear, O Lord, to my prayer;"
    },
    {
      "block_id": "ps-86-7",
      "type": "verse",
      "number": 7,
      "text": "In the day of my trouble I call on you,"
    },
    {
      "block_id": "ps-86-8",
      "type": "verse",
      "number": 8,
      "text": "There is none like you among the gods, O Lord,"
    },
    {
      "block_id": "ps-86-9",
      "type": "verse",
      "number": 9,
      "text": "All the nations you have made shall come"
    },
    {
      "block_id": "ps-86-10",
      "type": "verse",
      "number": 10,
      "text": "For you are great and do wondrous things;"
    },
    {
      "block_id": "ps-86-11",
      "type": "verse",
      "number": 11,
      "text": "Teach me your way, O Lord,"
    },
    {
      "block_id": "ps-86-12",
      "type": "verse",
      "number": 12,
      "text": "I give thanks to you, O Lord my God, with my whole heart,"
    },
    {
      "block_id": "ps-86-13",
      "type": "verse",
      "number": 13,
      "text": "For great is your steadfast love toward me;"
    },
    {
      "block_id": "ps-86-14",
      "type": "verse",
      "number": 14,
      "text": "O God, the insolent rise up against me;"
    },
    {
      "block_id": "ps-86-15",
      "type": "verse",
      "number": 15,
      "text": "But you, O Lord, are a God merciful and gracious,"
    },
    {
      "block_id": "ps-86-16",
      "type": "verse",
      "number": 16,
      "text": "Turn to me and be gracious to me;"
    },
    {
      "block_id": "ps-86-17",
      "type": "verse",
      "number": 17,
      "text": "Show me a sign of your favor,"
    }
  ]
}