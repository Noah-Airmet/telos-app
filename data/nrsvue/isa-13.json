{
  "document_id": "isa-13",
  "title": "Isaiah 13",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-13-heading-proclamation-against",
      "type": "heading",
      "text": "Proclamation against Babylon"
    },
    {
      "block_id": "isa-13-1",
      "type": "verse",
      "number": 1,
      "text": "The oracle concerning Babylon that Isaiah son of Amoz saw."
    },
    {
      "block_id": "isa-13-2",
      "type": "verse",
      "number": 2,
      "text": "On a bare hill raise a signal;"
    },
    {
      "block_id": "isa-13-3",
      "type": "verse",
      "number": 3,
      "text": "I myself have commanded my consecrated ones,"
    },
    {
      "block_id": "isa-13-4",
      "type": "verse",
      "number": 4,
      "text": "Listen, a tumult on the mountains"
    },
    {
      "block_id": "isa-13-5",
      "type": "verse",
      "number": 5,
      "text": "They come from a distant land,"
    },
    {
      "block_id": "isa-13-6",
      "type": "verse",
      "number": 6,
      "text": "Wail, for the day of the Lord is near;"
    },
    {
      "block_id": "isa-13-7",
      "type": "verse",
      "number": 7,
      "text": "Therefore all hands will be feeble,"
    },
    {
      "block_id": "isa-13-8",
      "type": "verse",
      "number": 8,
      "text": "and they will be terrified."
    },
    {
      "block_id": "isa-13-9",
      "type": "verse",
      "number": 9,
      "text": "See, the day of the Lord is coming,"
    },
    {
      "block_id": "isa-13-10",
      "type": "verse",
      "number": 10,
      "text": "For the stars of the heavens and their constellations"
    },
    {
      "block_id": "isa-13-11",
      "type": "verse",
      "number": 11,
      "text": "I will punish the world for its evil"
    },
    {
      "block_id": "isa-13-12",
      "type": "verse",
      "number": 12,
      "text": "I will make mortals more rare than fine gold"
    },
    {
      "block_id": "isa-13-13",
      "type": "verse",
      "number": 13,
      "text": "Therefore I will make the heavens tremble,"
    },
    {
      "block_id": "isa-13-14",
      "type": "verse",
      "number": 14,
      "text": "Like a gazelle on the run"
    },
    {
      "block_id": "isa-13-15",
      "type": "verse",
      "number": 15,
      "text": "Whoever is found will be thrust through,"
    },
    {
      "block_id": "isa-13-16",
      "type": "verse",
      "number": 16,
      "text": "Their infants will be dashed to pieces"
    },
    {
      "block_id": "isa-13-17",
      "type": "verse",
      "number": 17,
      "text": "See, I am stirring up the Medes against them,"
    },
    {
      "block_id": "isa-13-18",
      "type": "verse",
      "number": 18,
      "text": "Their bows will slaughter the young men;"
    },
    {
      "block_id": "isa-13-19",
      "type": "verse",
      "number": 19,
      "text": "And Babylon, the glory of kingdoms,"
    },
    {
      "block_id": "isa-13-20",
      "type": "verse",
      "number": 20,
      "text": "It will never be inhabited"
    },
    {
      "block_id": "isa-13-21",
      "type": "verse",
      "number": 21,
      "text": "But wild animals will lie down there,"
    },
    {
      "block_id": "isa-13-22",
      "type": "verse",
      "number": 22,
      "text": "Hyenas will cry in its towers"
    }
  ]
}