{
  "document_id": "col-19",
  "title": "Colossians 19",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-19-1",
      "type": "verse",
      "number": 1,
      "text": "The one who does this will not become rich;"
    },
    {
      "block_id": "col-19-2",
      "type": "verse",
      "number": 2,
      "text": "Wine and women lead intelligent men astray,"
    },
    {
      "block_id": "col-19-3",
      "type": "verse",
      "number": 3,
      "text": "Decay and worms will take possession of him,"
    },
    {
      "block_id": "col-19-4",
      "type": "verse",
      "number": 4,
      "text": "One who trusts quickly has a shallow mind,"
    },
    {
      "block_id": "col-19-5",
      "type": "verse",
      "number": 5,
      "text": "One who rejoices in wickedness will be condemned,"
    },
    {
      "block_id": "col-19-6",
      "type": "verse",
      "number": 6,
      "text": "but one who hates discussion lacks understanding."
    },
    {
      "block_id": "col-19-7",
      "type": "verse",
      "number": 7,
      "text": "Never repeat a conversation,"
    },
    {
      "block_id": "col-19-8",
      "type": "verse",
      "number": 8,
      "text": "With friend or foe do not report it,"
    },
    {
      "block_id": "col-19-9",
      "type": "verse",
      "number": 9,
      "text": "for someone may have heard you and watched you"
    },
    {
      "block_id": "col-19-10",
      "type": "verse",
      "number": 10,
      "text": "Have you heard something? Let it die with you."
    },
    {
      "block_id": "col-19-11",
      "type": "verse",
      "number": 11,
      "text": "Having heard something, the fool suffers birth pangs"
    },
    {
      "block_id": "col-19-12",
      "type": "verse",
      "number": 12,
      "text": "Like an arrow stuck in a person’s thigh,"
    },
    {
      "block_id": "col-19-13",
      "type": "verse",
      "number": 13,
      "text": "Question a friend; perhaps he did not do it;"
    },
    {
      "block_id": "col-19-14",
      "type": "verse",
      "number": 14,
      "text": "Question a neighbor; perhaps he did not say it;"
    },
    {
      "block_id": "col-19-15",
      "type": "verse",
      "number": 15,
      "text": "Question a friend, for often it is slander;"
    },
    {
      "block_id": "col-19-16",
      "type": "verse",
      "number": 16,
      "text": "A person may make a slip without intending it."
    },
    {
      "block_id": "col-19-17",
      "type": "verse",
      "number": 17,
      "text": "Question your neighbor before you threaten him,"
    },
    {
      "block_id": "col-19-20",
      "type": "verse",
      "number": 20,
      "text": "The whole of wisdom is fear of the Lord,"
    },
    {
      "block_id": "col-19-22",
      "type": "verse",
      "number": 22,
      "text": "The knowledge of wickedness is not wisdom,"
    },
    {
      "block_id": "col-19-23",
      "type": "verse",
      "number": 23,
      "text": "There is a cleverness that is detestable,"
    },
    {
      "block_id": "col-19-24",
      "type": "verse",
      "number": 24,
      "text": "Better are the God-fearing who lack understanding"
    },
    {
      "block_id": "col-19-25",
      "type": "verse",
      "number": 25,
      "text": "There is a cleverness that is exact but unjust,"
    },
    {
      "block_id": "col-19-26",
      "type": "verse",
      "number": 26,
      "text": "There are villains bowed down in mourning,"
    },
    {
      "block_id": "col-19-27",
      "type": "verse",
      "number": 27,
      "text": "They hide their faces and pretend not to hear,"
    },
    {
      "block_id": "col-19-28",
      "type": "verse",
      "number": 28,
      "text": "Even if lack of strength keeps them from sinning,"
    },
    {
      "block_id": "col-19-29",
      "type": "verse",
      "number": 29,
      "text": "People will be known by their appearances,"
    },
    {
      "block_id": "col-19-30",
      "type": "verse",
      "number": 30,
      "text": "People’s attire and hearty laughter"
    }
  ]
}