{
  "document_id": "1-thess-4",
  "title": "1 Thessalonians 4",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "1-thess-4-1",
      "type": "verse",
      "number": 1,
      "text": "She is the book of the commandments of God,"
    },
    {
      "block_id": "1-thess-4-2",
      "type": "verse",
      "number": 2,
      "text": "Turn, O Jacob, and take her;"
    },
    {
      "block_id": "1-thess-4-3",
      "type": "verse",
      "number": 3,
      "text": "Do not give your glory to another"
    },
    {
      "block_id": "1-thess-4-4",
      "type": "verse",
      "number": 4,
      "text": "Happy are we, O Israel,"
    },
    {
      "block_id": "1-thess-4-5",
      "type": "verse",
      "number": 5,
      "text": "Take courage, my people,"
    },
    {
      "block_id": "1-thess-4-6",
      "type": "verse",
      "number": 6,
      "text": "It was not for destruction"
    },
    {
      "block_id": "1-thess-4-7",
      "type": "verse",
      "number": 7,
      "text": "For you provoked the one who made you"
    },
    {
      "block_id": "1-thess-4-8",
      "type": "verse",
      "number": 8,
      "text": "You forgot the everlasting God, who brought you up,"
    },
    {
      "block_id": "1-thess-4-9",
      "type": "verse",
      "number": 9,
      "text": "For she saw the wrath that came upon you from God,"
    },
    {
      "block_id": "1-thess-4-10",
      "type": "verse",
      "number": 10,
      "text": "for I have seen the exile of my sons and daughters,"
    },
    {
      "block_id": "1-thess-4-11",
      "type": "verse",
      "number": 11,
      "text": "With joy I nurtured them,"
    },
    {
      "block_id": "1-thess-4-12",
      "type": "verse",
      "number": 12,
      "text": "Let no one rejoice over me, a widow"
    },
    {
      "block_id": "1-thess-4-13",
      "type": "verse",
      "number": 13,
      "text": "They had no regard for his statutes;"
    },
    {
      "block_id": "1-thess-4-14",
      "type": "verse",
      "number": 14,
      "text": "Let the neighbors of Zion come;"
    },
    {
      "block_id": "1-thess-4-15",
      "type": "verse",
      "number": 15,
      "text": "For he brought a distant nation against them,"
    },
    {
      "block_id": "1-thess-4-16",
      "type": "verse",
      "number": 16,
      "text": "They led away the widow’s beloved sons"
    },
    {
      "block_id": "1-thess-4-17",
      "type": "verse",
      "number": 17,
      "text": "“But I, how can I help you?"
    },
    {
      "block_id": "1-thess-4-18",
      "type": "verse",
      "number": 18,
      "text": "For he who brought these calamities"
    },
    {
      "block_id": "1-thess-4-19",
      "type": "verse",
      "number": 19,
      "text": "Go, my children, go,"
    },
    {
      "block_id": "1-thess-4-20",
      "type": "verse",
      "number": 20,
      "text": "I have taken off the robe of peace"
    },
    {
      "block_id": "1-thess-4-21",
      "type": "verse",
      "number": 21,
      "text": "“Take courage, my children, cry to God,"
    },
    {
      "block_id": "1-thess-4-22",
      "type": "verse",
      "number": 22,
      "text": "For I have put my hope in the Everlasting to save you,"
    },
    {
      "block_id": "1-thess-4-23",
      "type": "verse",
      "number": 23,
      "text": "For I sent you out with sorrow and weeping,"
    },
    {
      "block_id": "1-thess-4-24",
      "type": "verse",
      "number": 24,
      "text": "For as the neighbors of Zion have now seen your capture,"
    },
    {
      "block_id": "1-thess-4-25",
      "type": "verse",
      "number": 25,
      "text": "My children, endure with patience the wrath that has come upon you from God."
    },
    {
      "block_id": "1-thess-4-26",
      "type": "verse",
      "number": 26,
      "text": "My pampered children have traveled rough roads;"
    },
    {
      "block_id": "1-thess-4-27",
      "type": "verse",
      "number": 27,
      "text": "“Take courage, my children, and cry to God,"
    },
    {
      "block_id": "1-thess-4-28",
      "type": "verse",
      "number": 28,
      "text": "For just as you were disposed to go astray from God,"
    },
    {
      "block_id": "1-thess-4-29",
      "type": "verse",
      "number": 29,
      "text": "For the one who brought these calamities upon you"
    },
    {
      "block_id": "1-thess-4-30",
      "type": "verse",
      "number": 30,
      "text": "Take courage, O Jerusalem,"
    },
    {
      "block_id": "1-thess-4-31",
      "type": "verse",
      "number": 31,
      "text": "Wretched will be those who mistreated you"
    },
    {
      "block_id": "1-thess-4-32",
      "type": "verse",
      "number": 32,
      "text": "Wretched will be the cities that your children served as slaves;"
    },
    {
      "block_id": "1-thess-4-33",
      "type": "verse",
      "number": 33,
      "text": "For just as she rejoiced at your fall"
    },
    {
      "block_id": "1-thess-4-34",
      "type": "verse",
      "number": 34,
      "text": "I will take away her pride in her great population,"
    },
    {
      "block_id": "1-thess-4-35",
      "type": "verse",
      "number": 35,
      "text": "For fire will come upon her from the Everlasting for many days,"
    },
    {
      "block_id": "1-thess-4-36",
      "type": "verse",
      "number": 36,
      "text": "Look toward the east, O Jerusalem,"
    },
    {
      "block_id": "1-thess-4-37",
      "type": "verse",
      "number": 37,
      "text": "Look, your children are coming, whom you sent away;"
    }
  ]
}