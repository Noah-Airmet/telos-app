{
  "document_id": "col-8",
  "title": "Colossians 8",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-8-1",
      "type": "verse",
      "number": 1,
      "text": "Do not contend with the powerful,"
    },
    {
      "block_id": "col-8-2",
      "type": "verse",
      "number": 2,
      "text": "Do not quarrel with the rich,"
    },
    {
      "block_id": "col-8-3",
      "type": "verse",
      "number": 3,
      "text": "Do not argue with the loud of mouth,"
    },
    {
      "block_id": "col-8-4",
      "type": "verse",
      "number": 4,
      "text": "Do not make fun of one who is uneducated,"
    },
    {
      "block_id": "col-8-5",
      "type": "verse",
      "number": 5,
      "text": "Do not reproach one who is turning away from sin;"
    },
    {
      "block_id": "col-8-6",
      "type": "verse",
      "number": 6,
      "text": "Do not disdain one who is old,"
    },
    {
      "block_id": "col-8-7",
      "type": "verse",
      "number": 7,
      "text": "Do not rejoice over anyone’s death;"
    },
    {
      "block_id": "col-8-8",
      "type": "verse",
      "number": 8,
      "text": "Do not slight the discourse of the sages,"
    },
    {
      "block_id": "col-8-9",
      "type": "verse",
      "number": 9,
      "text": "Do not ignore the discourse of the aged,"
    },
    {
      "block_id": "col-8-10",
      "type": "verse",
      "number": 10,
      "text": "Do not kindle the coals of sinners,"
    },
    {
      "block_id": "col-8-11",
      "type": "verse",
      "number": 11,
      "text": "Do not let the insolent bring you to your feet,"
    },
    {
      "block_id": "col-8-12",
      "type": "verse",
      "number": 12,
      "text": "Do not lend to one who is stronger than you,"
    },
    {
      "block_id": "col-8-13",
      "type": "verse",
      "number": 13,
      "text": "Do not give surety beyond your means,"
    },
    {
      "block_id": "col-8-14",
      "type": "verse",
      "number": 14,
      "text": "Do not go to law against a judge,"
    },
    {
      "block_id": "col-8-15",
      "type": "verse",
      "number": 15,
      "text": "Do not travel on the road with the reckless,"
    },
    {
      "block_id": "col-8-16",
      "type": "verse",
      "number": 16,
      "text": "Do not pick a fight with the quick-tempered,"
    },
    {
      "block_id": "col-8-17",
      "type": "verse",
      "number": 17,
      "text": "Do not consult with fools,"
    },
    {
      "block_id": "col-8-18",
      "type": "verse",
      "number": 18,
      "text": "In the presence of strangers do nothing that is to be kept secret,"
    },
    {
      "block_id": "col-8-19",
      "type": "verse",
      "number": 19,
      "text": "Do not reveal your thoughts to anyone,"
    }
  ]
}