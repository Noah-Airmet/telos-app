{
  "document_id": "ps-52",
  "title": "Psalms 52",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-52-1",
      "type": "verse",
      "number": 1,
      "text": "Why do you boast, O mighty one,"
    },
    {
      "block_id": "ps-52-2",
      "type": "verse",
      "number": 2,
      "text": "you are plotting destruction."
    },
    {
      "block_id": "ps-52-3",
      "type": "verse",
      "number": 3,
      "text": "You love evil more than good"
    },
    {
      "block_id": "ps-52-4",
      "type": "verse",
      "number": 4,
      "text": "You love all words that devour,"
    },
    {
      "block_id": "ps-52-5",
      "type": "verse",
      "number": 5,
      "text": "But God will break you down forever;"
    },
    {
      "block_id": "ps-52-6",
      "type": "verse",
      "number": 6,
      "text": "The righteous will see and fear"
    },
    {
      "block_id": "ps-52-7",
      "type": "verse",
      "number": 7,
      "text": "“See the one who would not take"
    },
    {
      "block_id": "ps-52-8",
      "type": "verse",
      "number": 8,
      "text": "But I am like a green olive tree"
    },
    {
      "block_id": "ps-52-9",
      "type": "verse",
      "number": 9,
      "text": "I will thank you forever"
    }
  ]
}