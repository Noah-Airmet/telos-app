{
  "document_id": "ps-22",
  "title": "Psalms 22",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-22-1",
      "type": "verse",
      "number": 1,
      "text": "My God, my God, why have you forsaken me?"
    },
    {
      "block_id": "ps-22-2",
      "type": "verse",
      "number": 2,
      "text": "O my God, I cry by day, but you do not answer;"
    },
    {
      "block_id": "ps-22-3",
      "type": "verse",
      "number": 3,
      "text": "Yet you are holy,"
    },
    {
      "block_id": "ps-22-4",
      "type": "verse",
      "number": 4,
      "text": "In you our ancestors trusted;"
    },
    {
      "block_id": "ps-22-5",
      "type": "verse",
      "number": 5,
      "text": "To you they cried and were saved;"
    },
    {
      "block_id": "ps-22-6",
      "type": "verse",
      "number": 6,
      "text": "But I am a worm and not human,"
    },
    {
      "block_id": "ps-22-7",
      "type": "verse",
      "number": 7,
      "text": "All who see me mock me;"
    },
    {
      "block_id": "ps-22-8",
      "type": "verse",
      "number": 8,
      "text": "“Commit your cause to the Lord; let him deliver—"
    },
    {
      "block_id": "ps-22-9",
      "type": "verse",
      "number": 9,
      "text": "Yet it was you who took me from the womb;"
    },
    {
      "block_id": "ps-22-10",
      "type": "verse",
      "number": 10,
      "text": "On you I was cast from my birth,"
    },
    {
      "block_id": "ps-22-11",
      "type": "verse",
      "number": 11,
      "text": "Do not be far from me,"
    },
    {
      "block_id": "ps-22-12",
      "type": "verse",
      "number": 12,
      "text": "Many bulls encircle me;"
    },
    {
      "block_id": "ps-22-13",
      "type": "verse",
      "number": 13,
      "text": "they open wide their mouths at me,"
    },
    {
      "block_id": "ps-22-14",
      "type": "verse",
      "number": 14,
      "text": "I am poured out like water,"
    },
    {
      "block_id": "ps-22-15",
      "type": "verse",
      "number": 15,
      "text": "my mouth is dried up like a potsherd,"
    },
    {
      "block_id": "ps-22-16",
      "type": "verse",
      "number": 16,
      "text": "For dogs are all around me;"
    },
    {
      "block_id": "ps-22-17",
      "type": "verse",
      "number": 17,
      "text": "I can count all my bones."
    },
    {
      "block_id": "ps-22-18",
      "type": "verse",
      "number": 18,
      "text": "they divide my clothes among themselves,"
    },
    {
      "block_id": "ps-22-19",
      "type": "verse",
      "number": 19,
      "text": "But you, O Lord, do not be far away!"
    },
    {
      "block_id": "ps-22-20",
      "type": "verse",
      "number": 20,
      "text": "Deliver my soul from the sword,"
    },
    {
      "block_id": "ps-22-21",
      "type": "verse",
      "number": 21,
      "text": "Save me from the mouth of the lion!"
    },
    {
      "block_id": "ps-22-22",
      "type": "verse",
      "number": 22,
      "text": "I will tell of your name to my brothers and sisters;"
    },
    {
      "block_id": "ps-22-23",
      "type": "verse",
      "number": 23,
      "text": "You who fear the Lord, praise him!"
    },
    {
      "block_id": "ps-22-24",
      "type": "verse",
      "number": 24,
      "text": "For he did not despise or abhor"
    },
    {
      "block_id": "ps-22-25",
      "type": "verse",
      "number": 25,
      "text": "From you comes my praise in the great congregation;"
    },
    {
      "block_id": "ps-22-26",
      "type": "verse",
      "number": 26,
      "text": "The poor shall eat and be satisfied;"
    },
    {
      "block_id": "ps-22-27",
      "type": "verse",
      "number": 27,
      "text": "All the ends of the earth shall remember"
    },
    {
      "block_id": "ps-22-28",
      "type": "verse",
      "number": 28,
      "text": "For dominion belongs to the Lord,"
    },
    {
      "block_id": "ps-22-29",
      "type": "verse",
      "number": 29,
      "text": "To him, indeed, shall all who sleep in the earth bow down;"
    },
    {
      "block_id": "ps-22-30",
      "type": "verse",
      "number": 30,
      "text": "Posterity will serve him;"
    },
    {
      "block_id": "ps-22-31",
      "type": "verse",
      "number": 31,
      "text": "and proclaim his deliverance to a people yet unborn,"
    }
  ]
}