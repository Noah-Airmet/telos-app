{
  "document_id": "joel-1",
  "title": "Joel 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "joel-1-1",
      "type": "verse",
      "number": 1,
      "text": "The word of the Lord that came to Joel son of Pethuel:"
    },
    {
      "block_id": "joel-1-2",
      "type": "verse",
      "number": 2,
      "text": "Hear this, O elders;"
    },
    {
      "block_id": "joel-1-3",
      "type": "verse",
      "number": 3,
      "text": "Tell your children of it,"
    },
    {
      "block_id": "joel-1-4",
      "type": "verse",
      "number": 4,
      "text": "What the cutting locust left,"
    },
    {
      "block_id": "joel-1-5",
      "type": "verse",
      "number": 5,
      "text": "Wake up, you drunkards, and weep,"
    },
    {
      "block_id": "joel-1-6",
      "type": "verse",
      "number": 6,
      "text": "For a nation has invaded my land,"
    },
    {
      "block_id": "joel-1-7",
      "type": "verse",
      "number": 7,
      "text": "It has laid waste my vines"
    },
    {
      "block_id": "joel-1-8",
      "type": "verse",
      "number": 8,
      "text": "Lament like a virgin dressed in sackcloth"
    },
    {
      "block_id": "joel-1-9",
      "type": "verse",
      "number": 9,
      "text": "The grain offering and the drink offering are cut off"
    },
    {
      "block_id": "joel-1-10",
      "type": "verse",
      "number": 10,
      "text": "The fields are devastated,"
    },
    {
      "block_id": "joel-1-11",
      "type": "verse",
      "number": 11,
      "text": "Be dismayed, you farmers;"
    },
    {
      "block_id": "joel-1-12",
      "type": "verse",
      "number": 12,
      "text": "The vine withers;"
    },
    {
      "block_id": "joel-1-13",
      "type": "verse",
      "number": 13,
      "text": "Put on sackcloth and lament, you priests;"
    },
    {
      "block_id": "joel-1-14",
      "type": "verse",
      "number": 14,
      "text": "Consecrate a fast;"
    },
    {
      "block_id": "joel-1-15",
      "type": "verse",
      "number": 15,
      "text": "Alas for the day!"
    },
    {
      "block_id": "joel-1-16",
      "type": "verse",
      "number": 16,
      "text": "Is not the food cut off"
    },
    {
      "block_id": "joel-1-17",
      "type": "verse",
      "number": 17,
      "text": "The seed shrivels under the clods;"
    },
    {
      "block_id": "joel-1-18",
      "type": "verse",
      "number": 18,
      "text": "How the animals groan!"
    },
    {
      "block_id": "joel-1-19",
      "type": "verse",
      "number": 19,
      "text": "To you, O Lord, I cry,"
    },
    {
      "block_id": "joel-1-20",
      "type": "verse",
      "number": 20,
      "text": "Even the wild animals cry to you"
    }
  ]
}