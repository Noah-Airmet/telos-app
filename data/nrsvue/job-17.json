{
  "document_id": "job-17",
  "title": "Job 17",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-17-1",
      "type": "verse",
      "number": 1,
      "text": "“My spirit is broken; my days are extinct;"
    },
    {
      "block_id": "job-17-2",
      "type": "verse",
      "number": 2,
      "text": "Surely there are mockers around me,"
    },
    {
      "block_id": "job-17-3",
      "type": "verse",
      "number": 3,
      "text": "“Lay down a pledge for me with yourself;"
    },
    {
      "block_id": "job-17-4",
      "type": "verse",
      "number": 4,
      "text": "Since you have closed their minds to understanding,"
    },
    {
      "block_id": "job-17-5",
      "type": "verse",
      "number": 5,
      "text": "Those who denounce friends for reward—"
    },
    {
      "block_id": "job-17-6",
      "type": "verse",
      "number": 6,
      "text": "“He has made me a byword of the peoples,"
    },
    {
      "block_id": "job-17-7",
      "type": "verse",
      "number": 7,
      "text": "My eye has grown dim from grief,"
    },
    {
      "block_id": "job-17-8",
      "type": "verse",
      "number": 8,
      "text": "The upright are appalled at this,"
    },
    {
      "block_id": "job-17-9",
      "type": "verse",
      "number": 9,
      "text": "Yet the righteous hold to their way,"
    },
    {
      "block_id": "job-17-10",
      "type": "verse",
      "number": 10,
      "text": "But you, come back now, all of you,"
    },
    {
      "block_id": "job-17-11",
      "type": "verse",
      "number": 11,
      "text": "My days are past; my plans are broken off,"
    },
    {
      "block_id": "job-17-12",
      "type": "verse",
      "number": 12,
      "text": "They make night into day;"
    },
    {
      "block_id": "job-17-13",
      "type": "verse",
      "number": 13,
      "text": "If I look for Sheol as my house,"
    },
    {
      "block_id": "job-17-14",
      "type": "verse",
      "number": 14,
      "text": "if I say to the Pit, ‘You are my father,’"
    },
    {
      "block_id": "job-17-15",
      "type": "verse",
      "number": 15,
      "text": "where then is my hope?"
    },
    {
      "block_id": "job-17-16",
      "type": "verse",
      "number": 16,
      "text": "Will it go down to the bars of Sheol?"
    }
  ]
}