{
  "document_id": "ps-46",
  "title": "Psalms 46",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-46-1",
      "type": "verse",
      "number": 1,
      "text": "God is our refuge and strength,"
    },
    {
      "block_id": "ps-46-2",
      "type": "verse",
      "number": 2,
      "text": "Therefore we will not fear, though the earth should change,"
    },
    {
      "block_id": "ps-46-3",
      "type": "verse",
      "number": 3,
      "text": "though its waters roar and foam,"
    },
    {
      "block_id": "ps-46-4",
      "type": "verse",
      "number": 4,
      "text": "There is a river whose streams make glad the city of God,"
    },
    {
      "block_id": "ps-46-5",
      "type": "verse",
      "number": 5,
      "text": "God is in the midst of the city; it shall not be moved;"
    },
    {
      "block_id": "ps-46-6",
      "type": "verse",
      "number": 6,
      "text": "The nations are in an uproar; the kingdoms totter;"
    },
    {
      "block_id": "ps-46-7",
      "type": "verse",
      "number": 7,
      "text": "The Lord of hosts is with us;"
    },
    {
      "block_id": "ps-46-8",
      "type": "verse",
      "number": 8,
      "text": "Come, behold the works of the Lord;"
    },
    {
      "block_id": "ps-46-9",
      "type": "verse",
      "number": 9,
      "text": "He makes wars cease to the end of the earth;"
    },
    {
      "block_id": "ps-46-10",
      "type": "verse",
      "number": 10,
      "text": "“Be still, and know that I am God!"
    },
    {
      "block_id": "ps-46-11",
      "type": "verse",
      "number": 11,
      "text": "The Lord of hosts is with us;"
    }
  ]
}