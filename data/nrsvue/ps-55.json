{
  "document_id": "ps-55",
  "title": "Psalms 55",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-55-1",
      "type": "verse",
      "number": 1,
      "text": "Give ear to my prayer, O God;"
    },
    {
      "block_id": "ps-55-2",
      "type": "verse",
      "number": 2,
      "text": "Attend to me and answer me;"
    },
    {
      "block_id": "ps-55-3",
      "type": "verse",
      "number": 3,
      "text": "by the noise of the enemy,"
    },
    {
      "block_id": "ps-55-4",
      "type": "verse",
      "number": 4,
      "text": "My heart is in anguish within me;"
    },
    {
      "block_id": "ps-55-5",
      "type": "verse",
      "number": 5,
      "text": "Fear and trembling come upon me,"
    },
    {
      "block_id": "ps-55-6",
      "type": "verse",
      "number": 6,
      "text": "And I say, “O that I had wings like a dove!"
    },
    {
      "block_id": "ps-55-7",
      "type": "verse",
      "number": 7,
      "text": "truly, I would flee far away;"
    },
    {
      "block_id": "ps-55-8",
      "type": "verse",
      "number": 8,
      "text": "I would hurry to find a shelter for myself"
    },
    {
      "block_id": "ps-55-9",
      "type": "verse",
      "number": 9,
      "text": "Confuse, O Lord, confound their speech,"
    },
    {
      "block_id": "ps-55-10",
      "type": "verse",
      "number": 10,
      "text": "Day and night they go around it"
    },
    {
      "block_id": "ps-55-11",
      "type": "verse",
      "number": 11,
      "text": "ruin is in its midst;"
    },
    {
      "block_id": "ps-55-12",
      "type": "verse",
      "number": 12,
      "text": "It is not enemies who taunt me—"
    },
    {
      "block_id": "ps-55-13",
      "type": "verse",
      "number": 13,
      "text": "But it is you, my equal,"
    },
    {
      "block_id": "ps-55-14",
      "type": "verse",
      "number": 14,
      "text": "with whom I kept pleasant company;"
    },
    {
      "block_id": "ps-55-15",
      "type": "verse",
      "number": 15,
      "text": "Let death come upon them;"
    },
    {
      "block_id": "ps-55-16",
      "type": "verse",
      "number": 16,
      "text": "But I call upon God,"
    },
    {
      "block_id": "ps-55-17",
      "type": "verse",
      "number": 17,
      "text": "Evening and morning and at noon"
    },
    {
      "block_id": "ps-55-18",
      "type": "verse",
      "number": 18,
      "text": "He will redeem me unharmed"
    },
    {
      "block_id": "ps-55-19",
      "type": "verse",
      "number": 19,
      "text": "God, who is enthroned from of old, Selah"
    },
    {
      "block_id": "ps-55-20",
      "type": "verse",
      "number": 20,
      "text": "My companion laid hands on a friend"
    },
    {
      "block_id": "ps-55-21",
      "type": "verse",
      "number": 21,
      "text": "with speech smoother than butter"
    },
    {
      "block_id": "ps-55-22",
      "type": "verse",
      "number": 22,
      "text": "Cast your burden on the Lord,"
    },
    {
      "block_id": "ps-55-23",
      "type": "verse",
      "number": 23,
      "text": "But you, O God, will cast them down"
    }
  ]
}