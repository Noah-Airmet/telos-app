{
  "document_id": "amos-8",
  "title": "Amos 8",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "amos-8-heading-the-basket-of-fruit",
      "type": "heading",
      "text": "The Basket of Fruit"
    },
    {
      "block_id": "amos-8-1",
      "type": "verse",
      "number": 1,
      "text": "This is what the Lord God showed me: a basket of summer fruit."
    },
    {
      "block_id": "amos-8-2",
      "type": "verse",
      "number": 2,
      "text": "He said, “Amos, what do you see?” And I said, “A basket of summer fruit.” Then the Lord said to me,"
    },
    {
      "block_id": "amos-8-3",
      "type": "verse",
      "number": 3,
      "text": "The songs of the temple shall become wailings on that day,”"
    },
    {
      "block_id": "amos-8-4",
      "type": "verse",
      "number": 4,
      "text": "Hear this, you who trample on the needy,"
    },
    {
      "block_id": "amos-8-5",
      "type": "verse",
      "number": 5,
      "text": "saying, “When will the new moon be over"
    },
    {
      "block_id": "amos-8-6",
      "type": "verse",
      "number": 6,
      "text": "buying the poor for silver"
    },
    {
      "block_id": "amos-8-7",
      "type": "verse",
      "number": 7,
      "text": "The Lord has sworn by the pride of Jacob:"
    },
    {
      "block_id": "amos-8-8",
      "type": "verse",
      "number": 8,
      "text": "Shall not the land tremble on this account,"
    },
    {
      "block_id": "amos-8-9",
      "type": "verse",
      "number": 9,
      "text": "On that day, says the Lord God,"
    },
    {
      "block_id": "amos-8-10",
      "type": "verse",
      "number": 10,
      "text": "I will turn your feasts into mourning"
    },
    {
      "block_id": "amos-8-11",
      "type": "verse",
      "number": 11,
      "text": "The time is surely coming, says the Lord God,"
    },
    {
      "block_id": "amos-8-12",
      "type": "verse",
      "number": 12,
      "text": "They shall wander from sea to sea"
    },
    {
      "block_id": "amos-8-13",
      "type": "verse",
      "number": 13,
      "text": "On that day the beautiful young women and the young men"
    },
    {
      "block_id": "amos-8-14",
      "type": "verse",
      "number": 14,
      "text": "Those who swear by Ashimah of Samaria"
    }
  ]
}