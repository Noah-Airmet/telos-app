{
  "document_id": "phil-9",
  "title": "Philippians 9",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "phil-9-1",
      "type": "verse",
      "number": 1,
      "text": "“O God of my ancestors and Lord of mercy,"
    },
    {
      "block_id": "phil-9-2",
      "type": "verse",
      "number": 2,
      "text": "and by your wisdom have formed humankind"
    },
    {
      "block_id": "phil-9-3",
      "type": "verse",
      "number": 3,
      "text": "and rule the world in holiness and righteousness"
    },
    {
      "block_id": "phil-9-4",
      "type": "verse",
      "number": 4,
      "text": "give me the wisdom that sits by your throne,"
    },
    {
      "block_id": "phil-9-5",
      "type": "verse",
      "number": 5,
      "text": "For I am your servant, the son of your female servant,"
    },
    {
      "block_id": "phil-9-6",
      "type": "verse",
      "number": 6,
      "text": "for even one who is perfect among humans"
    },
    {
      "block_id": "phil-9-7",
      "type": "verse",
      "number": 7,
      "text": "You have chosen me to be king of your people"
    },
    {
      "block_id": "phil-9-8",
      "type": "verse",
      "number": 8,
      "text": "You have given command to build a temple on your holy mountain"
    },
    {
      "block_id": "phil-9-9",
      "type": "verse",
      "number": 9,
      "text": "With you is wisdom, she who knows your works"
    },
    {
      "block_id": "phil-9-10",
      "type": "verse",
      "number": 10,
      "text": "Send her forth from the holy heavens,"
    },
    {
      "block_id": "phil-9-11",
      "type": "verse",
      "number": 11,
      "text": "For she knows and understands all things,"
    },
    {
      "block_id": "phil-9-12",
      "type": "verse",
      "number": 12,
      "text": "Then my works will be acceptable,"
    },
    {
      "block_id": "phil-9-13",
      "type": "verse",
      "number": 13,
      "text": "For who can learn the counsel of God?"
    },
    {
      "block_id": "phil-9-14",
      "type": "verse",
      "number": 14,
      "text": "For the reasoning of mortals is worthless,"
    },
    {
      "block_id": "phil-9-15",
      "type": "verse",
      "number": 15,
      "text": "for a perishable body weighs down the soul,"
    },
    {
      "block_id": "phil-9-16",
      "type": "verse",
      "number": 16,
      "text": "We can hardly guess at what is on earth,"
    },
    {
      "block_id": "phil-9-17",
      "type": "verse",
      "number": 17,
      "text": "Who has learned your counsel"
    },
    {
      "block_id": "phil-9-18",
      "type": "verse",
      "number": 18,
      "text": "And thus the paths of those on earth were set right,"
    }
  ]
}