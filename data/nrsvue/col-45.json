{
  "document_id": "col-45",
  "title": "Colossians 45",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-45-1",
      "type": "verse",
      "number": 1,
      "text": "and was beloved by God and people,"
    },
    {
      "block_id": "col-45-2",
      "type": "verse",
      "number": 2,
      "text": "He made him equal in glory to the holy ones"
    },
    {
      "block_id": "col-45-3",
      "type": "verse",
      "number": 3,
      "text": "By his words he performed swift miracles;"
    },
    {
      "block_id": "col-45-4",
      "type": "verse",
      "number": 4,
      "text": "For his faithfulness and meekness he consecrated him,"
    },
    {
      "block_id": "col-45-5",
      "type": "verse",
      "number": 5,
      "text": "He allowed him to hear his voice"
    },
    {
      "block_id": "col-45-6",
      "type": "verse",
      "number": 6,
      "text": "He exalted Aaron, a holy man like Moses,"
    },
    {
      "block_id": "col-45-7",
      "type": "verse",
      "number": 7,
      "text": "He made an everlasting covenant with him"
    },
    {
      "block_id": "col-45-8",
      "type": "verse",
      "number": 8,
      "text": "He clothed him in perfect splendor"
    },
    {
      "block_id": "col-45-9",
      "type": "verse",
      "number": 9,
      "text": "And he encircled him with pomegranates,"
    },
    {
      "block_id": "col-45-10",
      "type": "verse",
      "number": 10,
      "text": "with the sacred vestment, of gold and violet"
    },
    {
      "block_id": "col-45-11",
      "type": "verse",
      "number": 11,
      "text": "with twisted crimson, the work of an artisan;"
    },
    {
      "block_id": "col-45-12",
      "type": "verse",
      "number": 12,
      "text": "with a gold crown upon his turban,"
    },
    {
      "block_id": "col-45-13",
      "type": "verse",
      "number": 13,
      "text": "Before him such beautiful things did not exist."
    },
    {
      "block_id": "col-45-14",
      "type": "verse",
      "number": 14,
      "text": "His sacrifices shall be wholly burned"
    },
    {
      "block_id": "col-45-15",
      "type": "verse",
      "number": 15,
      "text": "Moses ordained him"
    },
    {
      "block_id": "col-45-16",
      "type": "verse",
      "number": 16,
      "text": "He chose him out of all the living"
    },
    {
      "block_id": "col-45-17",
      "type": "verse",
      "number": 17,
      "text": "In his commandments he gave him"
    },
    {
      "block_id": "col-45-18",
      "type": "verse",
      "number": 18,
      "text": "Outsiders conspired against him"
    },
    {
      "block_id": "col-45-19",
      "type": "verse",
      "number": 19,
      "text": "The Lord saw it and was not pleased,"
    },
    {
      "block_id": "col-45-20",
      "type": "verse",
      "number": 20,
      "text": "He added glory to Aaron"
    },
    {
      "block_id": "col-45-21",
      "type": "verse",
      "number": 21,
      "text": "for they eat the sacrifices of the Lord,"
    },
    {
      "block_id": "col-45-22",
      "type": "verse",
      "number": 22,
      "text": "But in the land of the people he has no inheritance,"
    },
    {
      "block_id": "col-45-23",
      "type": "verse",
      "number": 23,
      "text": "Phinehas son of Eleazar ranks third in glory"
    },
    {
      "block_id": "col-45-24",
      "type": "verse",
      "number": 24,
      "text": "Therefore a covenant of peace was established with him,"
    },
    {
      "block_id": "col-45-25",
      "type": "verse",
      "number": 25,
      "text": "Just as a covenant was established with David"
    },
    {
      "block_id": "col-45-26",
      "type": "verse",
      "number": 26,
      "text": "And now bless the Lord"
    }
  ]
}