{
  "document_id": "nahum-1",
  "title": "Nahum 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "nahum-1-1",
      "type": "verse",
      "number": 1,
      "text": "An oracle concerning Nineveh. The book of the vision of Nahum of Elkosh."
    },
    {
      "block_id": "nahum-1-2",
      "type": "verse",
      "number": 2,
      "text": "A jealous and avenging God is the Lord;"
    },
    {
      "block_id": "nahum-1-3",
      "type": "verse",
      "number": 3,
      "text": "The Lord is slow to anger but great in power,"
    },
    {
      "block_id": "nahum-1-4",
      "type": "verse",
      "number": 4,
      "text": "He rebukes the sea and makes it dry,"
    },
    {
      "block_id": "nahum-1-5",
      "type": "verse",
      "number": 5,
      "text": "The mountains quake before him,"
    },
    {
      "block_id": "nahum-1-6",
      "type": "verse",
      "number": 6,
      "text": "Who can stand before his indignation?"
    },
    {
      "block_id": "nahum-1-7",
      "type": "verse",
      "number": 7,
      "text": "The Lord is good,"
    },
    {
      "block_id": "nahum-1-8",
      "type": "verse",
      "number": 8,
      "text": "even in a rushing flood."
    },
    {
      "block_id": "nahum-1-9",
      "type": "verse",
      "number": 9,
      "text": "Why do you plot against the Lord?"
    },
    {
      "block_id": "nahum-1-10",
      "type": "verse",
      "number": 10,
      "text": "Like thorns they are entangled;"
    },
    {
      "block_id": "nahum-1-11",
      "type": "verse",
      "number": 11,
      "text": "From you one has gone out"
    },
    {
      "block_id": "nahum-1-12",
      "type": "verse",
      "number": 12,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "nahum-1-13",
      "type": "verse",
      "number": 13,
      "text": "And now I will break off his yoke from you"
    },
    {
      "block_id": "nahum-1-14",
      "type": "verse",
      "number": 14,
      "text": "The Lord has commanded concerning you:"
    },
    {
      "block_id": "nahum-1-15",
      "type": "verse",
      "number": 15,
      "text": "Look! On the mountains the feet of one"
    }
  ]
}