{
  "document_id": "prov-31",
  "title": "Proverbs 31",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-31-heading-the-teaching-of-king",
      "type": "heading",
      "text": "The Teaching of King Lemuel’s Mother"
    },
    {
      "block_id": "prov-31-1",
      "type": "verse",
      "number": 1,
      "text": "The words of King Lemuel. An oracle that his mother taught him:"
    },
    {
      "block_id": "prov-31-2",
      "type": "verse",
      "number": 2,
      "text": "No, my son! No, son of my womb!"
    },
    {
      "block_id": "prov-31-3",
      "type": "verse",
      "number": 3,
      "text": "Do not give your strength to women,"
    },
    {
      "block_id": "prov-31-4",
      "type": "verse",
      "number": 4,
      "text": "It is not for kings, O Lemuel,"
    },
    {
      "block_id": "prov-31-5",
      "type": "verse",
      "number": 5,
      "text": "lest they drink and forget what has been decreed"
    },
    {
      "block_id": "prov-31-6",
      "type": "verse",
      "number": 6,
      "text": "Give strong drink to one who is perishing"
    },
    {
      "block_id": "prov-31-7",
      "type": "verse",
      "number": 7,
      "text": "let them drink and forget their poverty"
    },
    {
      "block_id": "prov-31-8",
      "type": "verse",
      "number": 8,
      "text": "Speak out for those who cannot speak,"
    },
    {
      "block_id": "prov-31-9",
      "type": "verse",
      "number": 9,
      "text": "Speak out; judge righteously;"
    },
    {
      "block_id": "prov-31-10",
      "type": "verse",
      "number": 10,
      "text": "A woman of strength who can find?"
    },
    {
      "block_id": "prov-31-11",
      "type": "verse",
      "number": 11,
      "text": "The heart of her husband trusts in her,"
    },
    {
      "block_id": "prov-31-12",
      "type": "verse",
      "number": 12,
      "text": "She does him good and not harm"
    },
    {
      "block_id": "prov-31-13",
      "type": "verse",
      "number": 13,
      "text": "She seeks wool and flax"
    },
    {
      "block_id": "prov-31-14",
      "type": "verse",
      "number": 14,
      "text": "She is like the ships of the merchant;"
    },
    {
      "block_id": "prov-31-15",
      "type": "verse",
      "number": 15,
      "text": "She rises while it is still night"
    },
    {
      "block_id": "prov-31-16",
      "type": "verse",
      "number": 16,
      "text": "She considers a field and buys it;"
    },
    {
      "block_id": "prov-31-17",
      "type": "verse",
      "number": 17,
      "text": "She girds herself with strength"
    },
    {
      "block_id": "prov-31-18",
      "type": "verse",
      "number": 18,
      "text": "She perceives that her merchandise is profitable."
    },
    {
      "block_id": "prov-31-19",
      "type": "verse",
      "number": 19,
      "text": "She puts her hands to the distaff,"
    },
    {
      "block_id": "prov-31-20",
      "type": "verse",
      "number": 20,
      "text": "She opens her hand to the poor"
    },
    {
      "block_id": "prov-31-21",
      "type": "verse",
      "number": 21,
      "text": "She is not afraid for her household when it snows,"
    },
    {
      "block_id": "prov-31-22",
      "type": "verse",
      "number": 22,
      "text": "She makes herself coverings;"
    },
    {
      "block_id": "prov-31-23",
      "type": "verse",
      "number": 23,
      "text": "Her husband is known in the city gates,"
    },
    {
      "block_id": "prov-31-24",
      "type": "verse",
      "number": 24,
      "text": "She makes linen garments and sells them;"
    },
    {
      "block_id": "prov-31-25",
      "type": "verse",
      "number": 25,
      "text": "Strength and dignity are her clothing,"
    },
    {
      "block_id": "prov-31-26",
      "type": "verse",
      "number": 26,
      "text": "She opens her mouth with wisdom,"
    },
    {
      "block_id": "prov-31-27",
      "type": "verse",
      "number": 27,
      "text": "She looks well to the ways of her household"
    },
    {
      "block_id": "prov-31-28",
      "type": "verse",
      "number": 28,
      "text": "Her children rise up and call her happy;"
    },
    {
      "block_id": "prov-31-29",
      "type": "verse",
      "number": 29,
      "text": "“Many women have done excellently,"
    },
    {
      "block_id": "prov-31-30",
      "type": "verse",
      "number": 30,
      "text": "Charm is deceitful and beauty is vain,"
    },
    {
      "block_id": "prov-31-31",
      "type": "verse",
      "number": 31,
      "text": "Give her a share in the fruit of her hands,"
    }
  ]
}