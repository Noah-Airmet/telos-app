{
  "document_id": "sir-7",
  "title": "Sirach 7",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-7-1",
      "type": "verse",
      "number": 1,
      "text": "Do no evil, and evil will never overtake you."
    },
    {
      "block_id": "sir-7-2",
      "type": "verse",
      "number": 2,
      "text": "Stay away from wrong, and it will turn away from you."
    },
    {
      "block_id": "sir-7-3",
      "type": "verse",
      "number": 3,
      "text": "Do not sow in the furrows of injustice,"
    },
    {
      "block_id": "sir-7-4",
      "type": "verse",
      "number": 4,
      "text": "Do not seek from the Lord high office"
    },
    {
      "block_id": "sir-7-5",
      "type": "verse",
      "number": 5,
      "text": "Do not assert your righteousness before the Lord"
    },
    {
      "block_id": "sir-7-6",
      "type": "verse",
      "number": 6,
      "text": "Do not seek to become a judge,"
    },
    {
      "block_id": "sir-7-7",
      "type": "verse",
      "number": 7,
      "text": "Commit no offense against the public,"
    },
    {
      "block_id": "sir-7-8",
      "type": "verse",
      "number": 8,
      "text": "Do not commit a sin twice;"
    },
    {
      "block_id": "sir-7-9",
      "type": "verse",
      "number": 9,
      "text": "Do not say, “He will consider the great number of my gifts,"
    },
    {
      "block_id": "sir-7-10",
      "type": "verse",
      "number": 10,
      "text": "Do not grow weary when you pray;"
    },
    {
      "block_id": "sir-7-11",
      "type": "verse",
      "number": 11,
      "text": "Do not ridicule a person who is embittered in spirit,"
    },
    {
      "block_id": "sir-7-12",
      "type": "verse",
      "number": 12,
      "text": "Do not devise a lie against your brother"
    },
    {
      "block_id": "sir-7-13",
      "type": "verse",
      "number": 13,
      "text": "Refuse to utter any lie,"
    },
    {
      "block_id": "sir-7-14",
      "type": "verse",
      "number": 14,
      "text": "Do not babble in the company of the elders,"
    },
    {
      "block_id": "sir-7-15",
      "type": "verse",
      "number": 15,
      "text": "Do not hate hard labor"
    },
    {
      "block_id": "sir-7-16",
      "type": "verse",
      "number": 16,
      "text": "Do not enroll in the ranks of sinners;"
    },
    {
      "block_id": "sir-7-17",
      "type": "verse",
      "number": 17,
      "text": "Humble yourself to the utmost,"
    },
    {
      "block_id": "sir-7-18",
      "type": "verse",
      "number": 18,
      "text": "Do not exchange a friend for money"
    },
    {
      "block_id": "sir-7-19",
      "type": "verse",
      "number": 19,
      "text": "Do not dismiss a wise and good wife,"
    },
    {
      "block_id": "sir-7-20",
      "type": "verse",
      "number": 20,
      "text": "Do not abuse slaves who work faithfully"
    },
    {
      "block_id": "sir-7-21",
      "type": "verse",
      "number": 21,
      "text": "Let your soul love intelligent slaves;"
    },
    {
      "block_id": "sir-7-22",
      "type": "verse",
      "number": 22,
      "text": "Do you have cattle? Look after them;"
    },
    {
      "block_id": "sir-7-23",
      "type": "verse",
      "number": 23,
      "text": "Do you have children? Discipline them,"
    },
    {
      "block_id": "sir-7-24",
      "type": "verse",
      "number": 24,
      "text": "Do you have daughters? Be concerned for their chastity,"
    },
    {
      "block_id": "sir-7-25",
      "type": "verse",
      "number": 25,
      "text": "Give a daughter in marriage, and you complete a great task,"
    },
    {
      "block_id": "sir-7-26",
      "type": "verse",
      "number": 26,
      "text": "Do you have a wife who pleases you? Do not divorce her,"
    },
    {
      "block_id": "sir-7-27",
      "type": "verse",
      "number": 27,
      "text": "With all your heart honor your father,"
    },
    {
      "block_id": "sir-7-28",
      "type": "verse",
      "number": 28,
      "text": "Remember that it was of your parents you were born;"
    },
    {
      "block_id": "sir-7-29",
      "type": "verse",
      "number": 29,
      "text": "With all your soul fear the Lord"
    },
    {
      "block_id": "sir-7-30",
      "type": "verse",
      "number": 30,
      "text": "With all your might love your Maker,"
    },
    {
      "block_id": "sir-7-31",
      "type": "verse",
      "number": 31,
      "text": "Fear the Lord and honor the priest,"
    },
    {
      "block_id": "sir-7-32",
      "type": "verse",
      "number": 32,
      "text": "Stretch out your hand to the poor,"
    },
    {
      "block_id": "sir-7-33",
      "type": "verse",
      "number": 33,
      "text": "Give graciously to all the living;"
    },
    {
      "block_id": "sir-7-34",
      "type": "verse",
      "number": 34,
      "text": "Do not lag behind those who weep,"
    },
    {
      "block_id": "sir-7-35",
      "type": "verse",
      "number": 35,
      "text": "Do not hesitate to visit the sick,"
    },
    {
      "block_id": "sir-7-36",
      "type": "verse",
      "number": 36,
      "text": "In all you do, remember the end of your life,"
    }
  ]
}