{
  "document_id": "job-10",
  "title": "Job 10",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-10-1",
      "type": "verse",
      "number": 1,
      "text": "“I loathe my life;"
    },
    {
      "block_id": "job-10-2",
      "type": "verse",
      "number": 2,
      "text": "I will say to God, ‘Do not condemn me;"
    },
    {
      "block_id": "job-10-3",
      "type": "verse",
      "number": 3,
      "text": "Does it seem good to you to oppress,"
    },
    {
      "block_id": "job-10-4",
      "type": "verse",
      "number": 4,
      "text": "Do you have eyes of flesh?"
    },
    {
      "block_id": "job-10-5",
      "type": "verse",
      "number": 5,
      "text": "Are your days like the days of mortals"
    },
    {
      "block_id": "job-10-6",
      "type": "verse",
      "number": 6,
      "text": "that you seek out my iniquity"
    },
    {
      "block_id": "job-10-7",
      "type": "verse",
      "number": 7,
      "text": "although you know that I am not guilty,"
    },
    {
      "block_id": "job-10-8",
      "type": "verse",
      "number": 8,
      "text": "Your hands fashioned and made me,"
    },
    {
      "block_id": "job-10-9",
      "type": "verse",
      "number": 9,
      "text": "Remember that you fashioned me like clay,"
    },
    {
      "block_id": "job-10-10",
      "type": "verse",
      "number": 10,
      "text": "Did you not pour me out like milk"
    },
    {
      "block_id": "job-10-11",
      "type": "verse",
      "number": 11,
      "text": "You clothed me with skin and flesh"
    },
    {
      "block_id": "job-10-12",
      "type": "verse",
      "number": 12,
      "text": "You have granted me life and steadfast love,"
    },
    {
      "block_id": "job-10-13",
      "type": "verse",
      "number": 13,
      "text": "Yet these things you hid in your heart;"
    },
    {
      "block_id": "job-10-14",
      "type": "verse",
      "number": 14,
      "text": "If I sin, you watch me"
    },
    {
      "block_id": "job-10-15",
      "type": "verse",
      "number": 15,
      "text": "If I am wicked, woe to me!"
    },
    {
      "block_id": "job-10-16",
      "type": "verse",
      "number": 16,
      "text": "Bold as a lion you hunt me;"
    },
    {
      "block_id": "job-10-17",
      "type": "verse",
      "number": 17,
      "text": "You renew your witnesses against me"
    },
    {
      "block_id": "job-10-18",
      "type": "verse",
      "number": 18,
      "text": "“ ‘Why did you bring me forth from the womb?"
    },
    {
      "block_id": "job-10-19",
      "type": "verse",
      "number": 19,
      "text": "and were as though I had not been,"
    },
    {
      "block_id": "job-10-20",
      "type": "verse",
      "number": 20,
      "text": "Are not the days of my life few?"
    },
    {
      "block_id": "job-10-21",
      "type": "verse",
      "number": 21,
      "text": "before I go, never to return,"
    },
    {
      "block_id": "job-10-22",
      "type": "verse",
      "number": 22,
      "text": "the land of gloom and chaos,"
    }
  ]
}