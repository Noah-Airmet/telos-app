{
  "document_id": "ps-104",
  "title": "Psalms 104",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-104-1",
      "type": "verse",
      "number": 1,
      "text": "Bless the Lord, O my soul."
    },
    {
      "block_id": "ps-104-2",
      "type": "verse",
      "number": 2,
      "text": "wrapped in light as with a garment."
    },
    {
      "block_id": "ps-104-3",
      "type": "verse",
      "number": 3,
      "text": "you set the beams of your chambers on the waters;"
    },
    {
      "block_id": "ps-104-4",
      "type": "verse",
      "number": 4,
      "text": "you make the winds your messengers,"
    },
    {
      "block_id": "ps-104-5",
      "type": "verse",
      "number": 5,
      "text": "You set the earth on its foundations,"
    },
    {
      "block_id": "ps-104-6",
      "type": "verse",
      "number": 6,
      "text": "You cover it with the deep as with a garment;"
    },
    {
      "block_id": "ps-104-7",
      "type": "verse",
      "number": 7,
      "text": "At your rebuke they flee;"
    },
    {
      "block_id": "ps-104-8",
      "type": "verse",
      "number": 8,
      "text": "They rose up to the mountains, ran down to the valleys,"
    },
    {
      "block_id": "ps-104-9",
      "type": "verse",
      "number": 9,
      "text": "You set a boundary that they may not pass,"
    },
    {
      "block_id": "ps-104-10",
      "type": "verse",
      "number": 10,
      "text": "You make springs gush forth in the valleys;"
    },
    {
      "block_id": "ps-104-11",
      "type": "verse",
      "number": 11,
      "text": "giving drink to every wild animal;"
    },
    {
      "block_id": "ps-104-12",
      "type": "verse",
      "number": 12,
      "text": "By the streams the birds of the air have their habitation;"
    },
    {
      "block_id": "ps-104-13",
      "type": "verse",
      "number": 13,
      "text": "From your lofty abode you water the mountains;"
    },
    {
      "block_id": "ps-104-14",
      "type": "verse",
      "number": 14,
      "text": "You cause the grass to grow for the cattle"
    },
    {
      "block_id": "ps-104-15",
      "type": "verse",
      "number": 15,
      "text": "and wine to gladden the human heart,"
    },
    {
      "block_id": "ps-104-16",
      "type": "verse",
      "number": 16,
      "text": "The trees of the field are watered abundantly,"
    },
    {
      "block_id": "ps-104-17",
      "type": "verse",
      "number": 17,
      "text": "In them the birds build their nests;"
    },
    {
      "block_id": "ps-104-18",
      "type": "verse",
      "number": 18,
      "text": "The high mountains are for the wild goats;"
    },
    {
      "block_id": "ps-104-19",
      "type": "verse",
      "number": 19,
      "text": "You have made the moon to mark the seasons;"
    },
    {
      "block_id": "ps-104-20",
      "type": "verse",
      "number": 20,
      "text": "You make darkness, and it is night,"
    },
    {
      "block_id": "ps-104-21",
      "type": "verse",
      "number": 21,
      "text": "The young lions roar for their prey,"
    },
    {
      "block_id": "ps-104-22",
      "type": "verse",
      "number": 22,
      "text": "When the sun rises, they withdraw"
    },
    {
      "block_id": "ps-104-23",
      "type": "verse",
      "number": 23,
      "text": "People go out to their work"
    },
    {
      "block_id": "ps-104-24",
      "type": "verse",
      "number": 24,
      "text": "O Lord, how manifold are your works!"
    },
    {
      "block_id": "ps-104-25",
      "type": "verse",
      "number": 25,
      "text": "There is the sea, great and wide;"
    },
    {
      "block_id": "ps-104-26",
      "type": "verse",
      "number": 26,
      "text": "There go the ships"
    },
    {
      "block_id": "ps-104-27",
      "type": "verse",
      "number": 27,
      "text": "These all look to you"
    },
    {
      "block_id": "ps-104-28",
      "type": "verse",
      "number": 28,
      "text": "when you give to them, they gather it up;"
    },
    {
      "block_id": "ps-104-29",
      "type": "verse",
      "number": 29,
      "text": "When you hide your face, they are dismayed;"
    },
    {
      "block_id": "ps-104-30",
      "type": "verse",
      "number": 30,
      "text": "When you send forth your spirit, they are created,"
    },
    {
      "block_id": "ps-104-31",
      "type": "verse",
      "number": 31,
      "text": "May the glory of the Lord endure forever;"
    },
    {
      "block_id": "ps-104-32",
      "type": "verse",
      "number": 32,
      "text": "who looks on the earth and it trembles,"
    },
    {
      "block_id": "ps-104-33",
      "type": "verse",
      "number": 33,
      "text": "I will sing to the Lord as long as I live;"
    },
    {
      "block_id": "ps-104-34",
      "type": "verse",
      "number": 34,
      "text": "May my meditation be pleasing to him,"
    },
    {
      "block_id": "ps-104-35",
      "type": "verse",
      "number": 35,
      "text": "Let sinners be consumed from the earth,"
    }
  ]
}