{
  "document_id": "ps-82",
  "title": "Psalms 82",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-82-1",
      "type": "verse",
      "number": 1,
      "text": "God has taken his place in the divine council;"
    },
    {
      "block_id": "ps-82-2",
      "type": "verse",
      "number": 2,
      "text": "“How long will you judge unjustly"
    },
    {
      "block_id": "ps-82-3",
      "type": "verse",
      "number": 3,
      "text": "Give justice to the weak and the orphan;"
    },
    {
      "block_id": "ps-82-4",
      "type": "verse",
      "number": 4,
      "text": "Rescue the weak and the needy;"
    },
    {
      "block_id": "ps-82-5",
      "type": "verse",
      "number": 5,
      "text": "They have neither knowledge nor understanding;"
    },
    {
      "block_id": "ps-82-6",
      "type": "verse",
      "number": 6,
      "text": "I say, “You are gods,"
    },
    {
      "block_id": "ps-82-7",
      "type": "verse",
      "number": 7,
      "text": "nevertheless, you shall die like mortals"
    },
    {
      "block_id": "ps-82-8",
      "type": "verse",
      "number": 8,
      "text": "Rise up, O God, judge the earth,"
    }
  ]
}