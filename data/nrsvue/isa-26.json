{
  "document_id": "isa-26",
  "title": "Isaiah 26",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-26-heading-judah’s-song-of-vict",
      "type": "heading",
      "text": "Judah’s Song of Victory"
    },
    {
      "block_id": "isa-26-1",
      "type": "verse",
      "number": 1,
      "text": "On that day this song will be sung in the land of Judah:"
    },
    {
      "block_id": "isa-26-2",
      "type": "verse",
      "number": 2,
      "text": "Open the gates,"
    },
    {
      "block_id": "isa-26-3",
      "type": "verse",
      "number": 3,
      "text": "Those of steadfast mind you keep in peace,"
    },
    {
      "block_id": "isa-26-4",
      "type": "verse",
      "number": 4,
      "text": "Trust in the Lord forever,"
    },
    {
      "block_id": "isa-26-5",
      "type": "verse",
      "number": 5,
      "text": "For he has brought low"
    },
    {
      "block_id": "isa-26-6",
      "type": "verse",
      "number": 6,
      "text": "The foot tramples it,"
    },
    {
      "block_id": "isa-26-7",
      "type": "verse",
      "number": 7,
      "text": "The way of the righteous is level;"
    },
    {
      "block_id": "isa-26-8",
      "type": "verse",
      "number": 8,
      "text": "In the path of your judgments,"
    },
    {
      "block_id": "isa-26-9",
      "type": "verse",
      "number": 9,
      "text": "My soul yearns for you in the night;"
    },
    {
      "block_id": "isa-26-10",
      "type": "verse",
      "number": 10,
      "text": "If favor is shown to the wicked,"
    },
    {
      "block_id": "isa-26-11",
      "type": "verse",
      "number": 11,
      "text": "O Lord, your hand is lifted up,"
    },
    {
      "block_id": "isa-26-12",
      "type": "verse",
      "number": 12,
      "text": "O Lord, may you ordain peace for us,"
    },
    {
      "block_id": "isa-26-13",
      "type": "verse",
      "number": 13,
      "text": "O Lord our God,"
    },
    {
      "block_id": "isa-26-14",
      "type": "verse",
      "number": 14,
      "text": "The dead do not live;"
    },
    {
      "block_id": "isa-26-15",
      "type": "verse",
      "number": 15,
      "text": "But you have increased the nation, O Lord;"
    },
    {
      "block_id": "isa-26-16",
      "type": "verse",
      "number": 16,
      "text": "O Lord, in distress they sought you;"
    },
    {
      "block_id": "isa-26-17",
      "type": "verse",
      "number": 17,
      "text": "Like a woman with child"
    },
    {
      "block_id": "isa-26-18",
      "type": "verse",
      "number": 18,
      "text": "we were with child; we writhed,"
    },
    {
      "block_id": "isa-26-19",
      "type": "verse",
      "number": 19,
      "text": "Your dead shall live; their corpses shall rise."
    },
    {
      "block_id": "isa-26-20",
      "type": "verse",
      "number": 20,
      "text": "Come, my people, enter your chambers,"
    },
    {
      "block_id": "isa-26-21",
      "type": "verse",
      "number": 21,
      "text": "For the Lord comes out from his place"
    }
  ]
}