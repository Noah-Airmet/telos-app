{
  "document_id": "ps-7",
  "title": "Psalms 7",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-7-1",
      "type": "verse",
      "number": 1,
      "text": "O Lord my God, in you I take refuge;"
    },
    {
      "block_id": "ps-7-2",
      "type": "verse",
      "number": 2,
      "text": "or like a lion they will tear me apart;"
    },
    {
      "block_id": "ps-7-3",
      "type": "verse",
      "number": 3,
      "text": "O Lord my God, if I have done this,"
    },
    {
      "block_id": "ps-7-4",
      "type": "verse",
      "number": 4,
      "text": "if I have repaid my ally with harm"
    },
    {
      "block_id": "ps-7-5",
      "type": "verse",
      "number": 5,
      "text": "then let the enemy pursue and overtake me,"
    },
    {
      "block_id": "ps-7-6",
      "type": "verse",
      "number": 6,
      "text": "Rise up, O Lord, in your anger;"
    },
    {
      "block_id": "ps-7-7",
      "type": "verse",
      "number": 7,
      "text": "Let the assembly of the peoples be gathered around you,"
    },
    {
      "block_id": "ps-7-8",
      "type": "verse",
      "number": 8,
      "text": "The Lord judges the peoples;"
    },
    {
      "block_id": "ps-7-9",
      "type": "verse",
      "number": 9,
      "text": "O let the evil of the wicked come to an end,"
    },
    {
      "block_id": "ps-7-10",
      "type": "verse",
      "number": 10,
      "text": "God is my shield,"
    },
    {
      "block_id": "ps-7-11",
      "type": "verse",
      "number": 11,
      "text": "God is a righteous judge"
    },
    {
      "block_id": "ps-7-12",
      "type": "verse",
      "number": 12,
      "text": "If one does not repent, God will whet his sword;"
    },
    {
      "block_id": "ps-7-13",
      "type": "verse",
      "number": 13,
      "text": "he has prepared his deadly weapons,"
    },
    {
      "block_id": "ps-7-14",
      "type": "verse",
      "number": 14,
      "text": "See how they conceive evil"
    },
    {
      "block_id": "ps-7-15",
      "type": "verse",
      "number": 15,
      "text": "They make a pit, digging it out,"
    },
    {
      "block_id": "ps-7-16",
      "type": "verse",
      "number": 16,
      "text": "Their mischief returns upon their own heads,"
    },
    {
      "block_id": "ps-7-17",
      "type": "verse",
      "number": 17,
      "text": "I will give to the Lord the thanks due to his righteousness"
    }
  ]
}