{
  "document_id": "ps-75",
  "title": "Psalms 75",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-75-1",
      "type": "verse",
      "number": 1,
      "text": "We give thanks to you, O God;"
    },
    {
      "block_id": "ps-75-2",
      "type": "verse",
      "number": 2,
      "text": "At the set time that I appoint,"
    },
    {
      "block_id": "ps-75-3",
      "type": "verse",
      "number": 3,
      "text": "When the earth totters, with all its inhabitants,"
    },
    {
      "block_id": "ps-75-4",
      "type": "verse",
      "number": 4,
      "text": "I say to the boastful, “Do not boast,”"
    },
    {
      "block_id": "ps-75-5",
      "type": "verse",
      "number": 5,
      "text": "do not lift up your horn on high"
    },
    {
      "block_id": "ps-75-6",
      "type": "verse",
      "number": 6,
      "text": "For not from the east or from the west"
    },
    {
      "block_id": "ps-75-7",
      "type": "verse",
      "number": 7,
      "text": "but it is God who executes judgment,"
    },
    {
      "block_id": "ps-75-8",
      "type": "verse",
      "number": 8,
      "text": "For in the hand of the Lord there is a cup"
    },
    {
      "block_id": "ps-75-9",
      "type": "verse",
      "number": 9,
      "text": "But I will rejoice forever;"
    },
    {
      "block_id": "ps-75-10",
      "type": "verse",
      "number": 10,
      "text": "All the horns of the wicked I will cut off,"
    }
  ]
}