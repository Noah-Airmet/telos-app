{
  "document_id": "ps-151-1",
  "title": "Psalm 151 1",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-151-1-1",
      "type": "verse",
      "number": 1,
      "text": "I was small among my brothers"
    },
    {
      "block_id": "ps-151-1-2",
      "type": "verse",
      "number": 2,
      "text": "My hands made a harp;"
    },
    {
      "block_id": "ps-151-1-3",
      "type": "verse",
      "number": 3,
      "text": "And who will tell my Lord?"
    },
    {
      "block_id": "ps-151-1-4",
      "type": "verse",
      "number": 4,
      "text": "It was he who sent his messenger"
    },
    {
      "block_id": "ps-151-1-5",
      "type": "verse",
      "number": 5,
      "text": "My brothers were handsome and tall,"
    },
    {
      "block_id": "ps-151-1-6",
      "type": "verse",
      "number": 6,
      "text": "I went out to meet the foreigner,"
    },
    {
      "block_id": "ps-151-1-7",
      "type": "verse",
      "number": 7,
      "text": "But I drew his own sword;"
    }
  ]
}