{
  "document_id": "sir-2",
  "title": "Sirach 2",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-2-1",
      "type": "verse",
      "number": 1,
      "text": "My child, when you come to serve the Lord,"
    },
    {
      "block_id": "sir-2-2",
      "type": "verse",
      "number": 2,
      "text": "Set your heart right and be steadfast,"
    },
    {
      "block_id": "sir-2-3",
      "type": "verse",
      "number": 3,
      "text": "Cling to him and do not depart,"
    },
    {
      "block_id": "sir-2-4",
      "type": "verse",
      "number": 4,
      "text": "Accept whatever befalls you,"
    },
    {
      "block_id": "sir-2-5",
      "type": "verse",
      "number": 5,
      "text": "For gold is tested in the fire,"
    },
    {
      "block_id": "sir-2-6",
      "type": "verse",
      "number": 6,
      "text": "Trust in him, and he will help you;"
    },
    {
      "block_id": "sir-2-7",
      "type": "verse",
      "number": 7,
      "text": "You who fear the Lord, wait for his mercy;"
    },
    {
      "block_id": "sir-2-8",
      "type": "verse",
      "number": 8,
      "text": "You who fear the Lord, trust in him,"
    },
    {
      "block_id": "sir-2-9",
      "type": "verse",
      "number": 9,
      "text": "You who fear the Lord, hope for good things,"
    },
    {
      "block_id": "sir-2-10",
      "type": "verse",
      "number": 10,
      "text": "Consider the generations of old and see:"
    },
    {
      "block_id": "sir-2-11",
      "type": "verse",
      "number": 11,
      "text": "For the Lord is compassionate and merciful;"
    },
    {
      "block_id": "sir-2-12",
      "type": "verse",
      "number": 12,
      "text": "Woe to timid hearts and to slack hands"
    },
    {
      "block_id": "sir-2-13",
      "type": "verse",
      "number": 13,
      "text": "Woe to the fainthearted who have no trust!"
    },
    {
      "block_id": "sir-2-14",
      "type": "verse",
      "number": 14,
      "text": "Woe to you who have lost patience!"
    },
    {
      "block_id": "sir-2-15",
      "type": "verse",
      "number": 15,
      "text": "Those who fear the Lord will not disobey his words,"
    },
    {
      "block_id": "sir-2-16",
      "type": "verse",
      "number": 16,
      "text": "Those who fear the Lord will seek his favor,"
    },
    {
      "block_id": "sir-2-17",
      "type": "verse",
      "number": 17,
      "text": "Those who fear the Lord will prepare their hearts"
    },
    {
      "block_id": "sir-2-18",
      "type": "verse",
      "number": 18,
      "text": "Let us fall into the hands of the Lord"
    }
  ]
}