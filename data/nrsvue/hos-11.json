{
  "document_id": "hos-11",
  "title": "Hosea 11",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-11-1",
      "type": "verse",
      "number": 1,
      "text": "When Israel was a child, I loved him,"
    },
    {
      "block_id": "hos-11-2",
      "type": "verse",
      "number": 2,
      "text": "The more I called them,"
    },
    {
      "block_id": "hos-11-3",
      "type": "verse",
      "number": 3,
      "text": "Yet it was I who taught Ephraim to walk;"
    },
    {
      "block_id": "hos-11-4",
      "type": "verse",
      "number": 4,
      "text": "I led them with cords of human kindness,"
    },
    {
      "block_id": "hos-11-5",
      "type": "verse",
      "number": 5,
      "text": "They shall return to the land of Egypt,"
    },
    {
      "block_id": "hos-11-6",
      "type": "verse",
      "number": 6,
      "text": "The sword rages in their cities;"
    },
    {
      "block_id": "hos-11-7",
      "type": "verse",
      "number": 7,
      "text": "My people are bent on turning away from me."
    },
    {
      "block_id": "hos-11-8",
      "type": "verse",
      "number": 8,
      "text": "How can I give you up, Ephraim?"
    },
    {
      "block_id": "hos-11-9",
      "type": "verse",
      "number": 9,
      "text": "I will not execute my fierce anger;"
    },
    {
      "block_id": "hos-11-10",
      "type": "verse",
      "number": 10,
      "text": "They shall go after the Lord,"
    },
    {
      "block_id": "hos-11-11",
      "type": "verse",
      "number": 11,
      "text": "They shall come trembling like birds from Egypt"
    },
    {
      "block_id": "hos-11-12",
      "type": "verse",
      "number": 12,
      "text": "Ephraim has surrounded me with lies"
    }
  ]
}