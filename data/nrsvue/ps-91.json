{
  "document_id": "ps-91",
  "title": "Psalms 91",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-91-1",
      "type": "verse",
      "number": 1,
      "text": "You who live in the shelter of the Most High,"
    },
    {
      "block_id": "ps-91-2",
      "type": "verse",
      "number": 2,
      "text": "will say to the Lord, “My refuge and my fortress;"
    },
    {
      "block_id": "ps-91-3",
      "type": "verse",
      "number": 3,
      "text": "For he will deliver you from the snare of the hunter"
    },
    {
      "block_id": "ps-91-4",
      "type": "verse",
      "number": 4,
      "text": "he will cover you with his pinions,"
    },
    {
      "block_id": "ps-91-5",
      "type": "verse",
      "number": 5,
      "text": "You will not fear the terror of the night"
    },
    {
      "block_id": "ps-91-6",
      "type": "verse",
      "number": 6,
      "text": "or the pestilence that stalks in darkness"
    },
    {
      "block_id": "ps-91-7",
      "type": "verse",
      "number": 7,
      "text": "A thousand may fall at your side,"
    },
    {
      "block_id": "ps-91-8",
      "type": "verse",
      "number": 8,
      "text": "You will only look with your eyes"
    },
    {
      "block_id": "ps-91-9",
      "type": "verse",
      "number": 9,
      "text": "Because you have made the Lord your refuge,"
    },
    {
      "block_id": "ps-91-10",
      "type": "verse",
      "number": 10,
      "text": "no evil shall befall you,"
    },
    {
      "block_id": "ps-91-11",
      "type": "verse",
      "number": 11,
      "text": "For he will command his angels concerning you"
    },
    {
      "block_id": "ps-91-12",
      "type": "verse",
      "number": 12,
      "text": "On their hands they will bear you up,"
    },
    {
      "block_id": "ps-91-13",
      "type": "verse",
      "number": 13,
      "text": "You will tread on the lion and the adder;"
    },
    {
      "block_id": "ps-91-14",
      "type": "verse",
      "number": 14,
      "text": "Those who love me, I will deliver;"
    },
    {
      "block_id": "ps-91-15",
      "type": "verse",
      "number": 15,
      "text": "When they call to me, I will answer them;"
    },
    {
      "block_id": "ps-91-16",
      "type": "verse",
      "number": 16,
      "text": "With long life I will satisfy them"
    }
  ]
}