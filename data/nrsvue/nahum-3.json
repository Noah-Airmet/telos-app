{
  "document_id": "nahum-3",
  "title": "Nahum 3",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "nahum-3-1",
      "type": "verse",
      "number": 1,
      "text": "Woe, city of bloodshed,"
    },
    {
      "block_id": "nahum-3-2",
      "type": "verse",
      "number": 2,
      "text": "The crack of whip and rumble of wheel,"
    },
    {
      "block_id": "nahum-3-3",
      "type": "verse",
      "number": 3,
      "text": "Horsemen charging,"
    },
    {
      "block_id": "nahum-3-4",
      "type": "verse",
      "number": 4,
      "text": "Because of the countless debaucheries of the prostitute,"
    },
    {
      "block_id": "nahum-3-5",
      "type": "verse",
      "number": 5,
      "text": "I am against you,"
    },
    {
      "block_id": "nahum-3-6",
      "type": "verse",
      "number": 6,
      "text": "I will throw filth at you"
    },
    {
      "block_id": "nahum-3-7",
      "type": "verse",
      "number": 7,
      "text": "Then all who see you will shrink from you and say,"
    },
    {
      "block_id": "nahum-3-8",
      "type": "verse",
      "number": 8,
      "text": "Are you better than Thebes"
    },
    {
      "block_id": "nahum-3-9",
      "type": "verse",
      "number": 9,
      "text": "Cush was her strength,"
    },
    {
      "block_id": "nahum-3-10",
      "type": "verse",
      "number": 10,
      "text": "Yet she became an exile;"
    },
    {
      "block_id": "nahum-3-11",
      "type": "verse",
      "number": 11,
      "text": "You also will be drunken;"
    },
    {
      "block_id": "nahum-3-12",
      "type": "verse",
      "number": 12,
      "text": "All your fortresses are like fig trees"
    },
    {
      "block_id": "nahum-3-13",
      "type": "verse",
      "number": 13,
      "text": "Look at your troops:"
    },
    {
      "block_id": "nahum-3-14",
      "type": "verse",
      "number": 14,
      "text": "Draw water for the siege;"
    },
    {
      "block_id": "nahum-3-15",
      "type": "verse",
      "number": 15,
      "text": "There the fire will devour you;"
    },
    {
      "block_id": "nahum-3-16",
      "type": "verse",
      "number": 16,
      "text": "You increased your merchants"
    },
    {
      "block_id": "nahum-3-17",
      "type": "verse",
      "number": 17,
      "text": "Your guards are like grasshoppers,"
    },
    {
      "block_id": "nahum-3-18",
      "type": "verse",
      "number": 18,
      "text": "Your shepherds are asleep,"
    },
    {
      "block_id": "nahum-3-19",
      "type": "verse",
      "number": 19,
      "text": "There is no assuaging your hurt;"
    }
  ]
}