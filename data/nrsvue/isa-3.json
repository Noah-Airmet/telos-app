{
  "document_id": "isa-3",
  "title": "Isaiah 3",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-3-1",
      "type": "verse",
      "number": 1,
      "text": "For now the Sovereign, the Lord of hosts,"
    },
    {
      "block_id": "isa-3-2",
      "type": "verse",
      "number": 2,
      "text": "warrior and soldier,"
    },
    {
      "block_id": "isa-3-3",
      "type": "verse",
      "number": 3,
      "text": "captain of fifty"
    },
    {
      "block_id": "isa-3-4",
      "type": "verse",
      "number": 4,
      "text": "And I will make youths their princes,"
    },
    {
      "block_id": "isa-3-5",
      "type": "verse",
      "number": 5,
      "text": "The people will be oppressed,"
    },
    {
      "block_id": "isa-3-6",
      "type": "verse",
      "number": 6,
      "text": "Someone will seize a relative,"
    },
    {
      "block_id": "isa-3-7",
      "type": "verse",
      "number": 7,
      "text": "But the other will cry out on that day, saying,"
    },
    {
      "block_id": "isa-3-8",
      "type": "verse",
      "number": 8,
      "text": "For Jerusalem has stumbled,"
    },
    {
      "block_id": "isa-3-9",
      "type": "verse",
      "number": 9,
      "text": "The look on their faces bears witness against them;"
    },
    {
      "block_id": "isa-3-10",
      "type": "verse",
      "number": 10,
      "text": "Tell the innocent how fortunate they are,"
    },
    {
      "block_id": "isa-3-11",
      "type": "verse",
      "number": 11,
      "text": "Woe to the guilty! How unfortunate they are,"
    },
    {
      "block_id": "isa-3-12",
      "type": "verse",
      "number": 12,
      "text": "My people—their oppressors extort them,"
    },
    {
      "block_id": "isa-3-13",
      "type": "verse",
      "number": 13,
      "text": "The Lord rises to argue his case;"
    },
    {
      "block_id": "isa-3-14",
      "type": "verse",
      "number": 14,
      "text": "The Lord enters into judgment"
    },
    {
      "block_id": "isa-3-15",
      "type": "verse",
      "number": 15,
      "text": "What do you mean by crushing my people,"
    },
    {
      "block_id": "isa-3-16",
      "type": "verse",
      "number": 16,
      "text": "The Lord said:"
    },
    {
      "block_id": "isa-3-17",
      "type": "verse",
      "number": 17,
      "text": "the Lord will afflict with scabs"
    },
    {
      "block_id": "isa-3-18",
      "type": "verse",
      "number": 18,
      "text": "On that day the Lord will take away the finery of the anklets, the headbands, and the crescents;"
    },
    {
      "block_id": "isa-3-19",
      "type": "verse",
      "number": 19,
      "text": "the pendants, the bracelets, and the scarfs;"
    },
    {
      "block_id": "isa-3-20",
      "type": "verse",
      "number": 20,
      "text": "the headdresses, the armlets, the sashes, the perfume boxes, and the amulets;"
    },
    {
      "block_id": "isa-3-21",
      "type": "verse",
      "number": 21,
      "text": "the signet rings and nose rings;"
    },
    {
      "block_id": "isa-3-22",
      "type": "verse",
      "number": 22,
      "text": "the festal robes, the mantles, the cloaks, and the handbags;"
    },
    {
      "block_id": "isa-3-23",
      "type": "verse",
      "number": 23,
      "text": "the garments of gauze, the linen garments, the turbans, and the veils."
    },
    {
      "block_id": "isa-3-24",
      "type": "verse",
      "number": 24,
      "text": "Instead of perfume there will be a stench;"
    },
    {
      "block_id": "isa-3-25",
      "type": "verse",
      "number": 25,
      "text": "Your men shall fall by the sword"
    },
    {
      "block_id": "isa-3-26",
      "type": "verse",
      "number": 26,
      "text": "And her gates shall lament and mourn;"
    }
  ]
}