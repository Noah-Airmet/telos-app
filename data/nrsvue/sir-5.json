{
  "document_id": "sir-5",
  "title": "Sirach 5",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-5-1",
      "type": "verse",
      "number": 1,
      "text": "Do not rely on your wealth"
    },
    {
      "block_id": "sir-5-2",
      "type": "verse",
      "number": 2,
      "text": "Do not follow your inclination and strength"
    },
    {
      "block_id": "sir-5-3",
      "type": "verse",
      "number": 3,
      "text": "Do not say, “Who can have power over me?”"
    },
    {
      "block_id": "sir-5-4",
      "type": "verse",
      "number": 4,
      "text": "Do not say, “I sinned, yet what has happened to me?”"
    },
    {
      "block_id": "sir-5-5",
      "type": "verse",
      "number": 5,
      "text": "Do not be so confident of forgiveness"
    },
    {
      "block_id": "sir-5-6",
      "type": "verse",
      "number": 6,
      "text": "Do not say, “His mercy is great;"
    },
    {
      "block_id": "sir-5-7",
      "type": "verse",
      "number": 7,
      "text": "Do not delay to turn back to the Lord,"
    },
    {
      "block_id": "sir-5-8",
      "type": "verse",
      "number": 8,
      "text": "Do not rely on dishonest wealth,"
    },
    {
      "block_id": "sir-5-9",
      "type": "verse",
      "number": 9,
      "text": "Do not winnow in every wind"
    },
    {
      "block_id": "sir-5-10",
      "type": "verse",
      "number": 10,
      "text": "Stand firm in what you know,"
    },
    {
      "block_id": "sir-5-11",
      "type": "verse",
      "number": 11,
      "text": "Be quick to hear,"
    },
    {
      "block_id": "sir-5-12",
      "type": "verse",
      "number": 12,
      "text": "If you understand, answer your neighbor,"
    },
    {
      "block_id": "sir-5-13",
      "type": "verse",
      "number": 13,
      "text": "Honor and dishonor come from speaking,"
    },
    {
      "block_id": "sir-5-14",
      "type": "verse",
      "number": 14,
      "text": "Do not be called double-tongued"
    },
    {
      "block_id": "sir-5-15",
      "type": "verse",
      "number": 15,
      "text": "In great and small matters cause no harm,"
    }
  ]
}