{
  "document_id": "ps-137",
  "title": "Psalms 137",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-137-1",
      "type": "verse",
      "number": 1,
      "text": "By the rivers of Babylon—"
    },
    {
      "block_id": "ps-137-2",
      "type": "verse",
      "number": 2,
      "text": "On the willows there"
    },
    {
      "block_id": "ps-137-3",
      "type": "verse",
      "number": 3,
      "text": "For there our captors"
    },
    {
      "block_id": "ps-137-4",
      "type": "verse",
      "number": 4,
      "text": "How could we sing the Lord’s song"
    },
    {
      "block_id": "ps-137-5",
      "type": "verse",
      "number": 5,
      "text": "If I forget you, O Jerusalem,"
    },
    {
      "block_id": "ps-137-6",
      "type": "verse",
      "number": 6,
      "text": "Let my tongue cling to the roof of my mouth,"
    },
    {
      "block_id": "ps-137-7",
      "type": "verse",
      "number": 7,
      "text": "Remember, O Lord, against the Edomites"
    },
    {
      "block_id": "ps-137-8",
      "type": "verse",
      "number": 8,
      "text": "O daughter Babylon, you devastator!"
    },
    {
      "block_id": "ps-137-9",
      "type": "verse",
      "number": 9,
      "text": "Happy shall they be who take your little ones"
    }
  ]
}