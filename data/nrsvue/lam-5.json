{
  "document_id": "lam-5",
  "title": "Lamentations 5",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "lam-5-1",
      "type": "verse",
      "number": 1,
      "text": "Remember, O Lord, what has befallen us;"
    },
    {
      "block_id": "lam-5-2",
      "type": "verse",
      "number": 2,
      "text": "Our inheritance has been turned over to strangers,"
    },
    {
      "block_id": "lam-5-3",
      "type": "verse",
      "number": 3,
      "text": "We have become orphans, fatherless;"
    },
    {
      "block_id": "lam-5-4",
      "type": "verse",
      "number": 4,
      "text": "We must pay for the water we drink;"
    },
    {
      "block_id": "lam-5-5",
      "type": "verse",
      "number": 5,
      "text": "With a yoke on our necks we are hard driven;"
    },
    {
      "block_id": "lam-5-6",
      "type": "verse",
      "number": 6,
      "text": "We have made a pact with Egypt and Assyria"
    },
    {
      "block_id": "lam-5-7",
      "type": "verse",
      "number": 7,
      "text": "Our ancestors sinned; they are no more,"
    },
    {
      "block_id": "lam-5-8",
      "type": "verse",
      "number": 8,
      "text": "Slaves rule over us;"
    },
    {
      "block_id": "lam-5-9",
      "type": "verse",
      "number": 9,
      "text": "We get our bread at the peril of our lives,"
    },
    {
      "block_id": "lam-5-10",
      "type": "verse",
      "number": 10,
      "text": "Our skin is black as an oven"
    },
    {
      "block_id": "lam-5-11",
      "type": "verse",
      "number": 11,
      "text": "Women are raped in Zion,"
    },
    {
      "block_id": "lam-5-12",
      "type": "verse",
      "number": 12,
      "text": "Princes are hung up by their hands;"
    },
    {
      "block_id": "lam-5-13",
      "type": "verse",
      "number": 13,
      "text": "Young men are compelled to grind,"
    },
    {
      "block_id": "lam-5-14",
      "type": "verse",
      "number": 14,
      "text": "The old men have left the city gate,"
    },
    {
      "block_id": "lam-5-15",
      "type": "verse",
      "number": 15,
      "text": "The joy of our hearts has ceased;"
    },
    {
      "block_id": "lam-5-16",
      "type": "verse",
      "number": 16,
      "text": "The crown has fallen from our head;"
    },
    {
      "block_id": "lam-5-17",
      "type": "verse",
      "number": 17,
      "text": "Because of this our hearts are sick;"
    },
    {
      "block_id": "lam-5-18",
      "type": "verse",
      "number": 18,
      "text": "because of Mount Zion, which lies desolate;"
    },
    {
      "block_id": "lam-5-19",
      "type": "verse",
      "number": 19,
      "text": "But you, O Lord, reign forever;"
    },
    {
      "block_id": "lam-5-20",
      "type": "verse",
      "number": 20,
      "text": "Why have you forgotten us completely?"
    },
    {
      "block_id": "lam-5-21",
      "type": "verse",
      "number": 21,
      "text": "Restore us to yourself, O Lord, that we may be restored;"
    },
    {
      "block_id": "lam-5-22",
      "type": "verse",
      "number": 22,
      "text": "unless you have utterly rejected us"
    }
  ]
}