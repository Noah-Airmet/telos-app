{
  "document_id": "col-46",
  "title": "Colossians 46",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-46-1",
      "type": "verse",
      "number": 1,
      "text": "Joshua son of Nun was mighty in war"
    },
    {
      "block_id": "col-46-2",
      "type": "verse",
      "number": 2,
      "text": "How glorious he was when he lifted his hands"
    },
    {
      "block_id": "col-46-3",
      "type": "verse",
      "number": 3,
      "text": "Who before him ever stood so firm?"
    },
    {
      "block_id": "col-46-4",
      "type": "verse",
      "number": 4,
      "text": "Was it not through him that the sun stood still"
    },
    {
      "block_id": "col-46-5",
      "type": "verse",
      "number": 5,
      "text": "He called upon the Most High, the Mighty One,"
    },
    {
      "block_id": "col-46-6",
      "type": "verse",
      "number": 6,
      "text": "He overwhelmed that nation in battle,"
    },
    {
      "block_id": "col-46-7",
      "type": "verse",
      "number": 7,
      "text": "And in the days of Moses he showed compassion,"
    },
    {
      "block_id": "col-46-8",
      "type": "verse",
      "number": 8,
      "text": "And these two alone were spared"
    },
    {
      "block_id": "col-46-9",
      "type": "verse",
      "number": 9,
      "text": "The Lord gave Caleb strength,"
    },
    {
      "block_id": "col-46-10",
      "type": "verse",
      "number": 10,
      "text": "so that all the Israelites might see"
    },
    {
      "block_id": "col-46-11",
      "type": "verse",
      "number": 11,
      "text": "The judges also, with their respective names,"
    },
    {
      "block_id": "col-46-12",
      "type": "verse",
      "number": 12,
      "text": "May their bones send forth new life from where they lie,"
    },
    {
      "block_id": "col-46-13",
      "type": "verse",
      "number": 13,
      "text": "Samuel was beloved by his Lord;"
    },
    {
      "block_id": "col-46-14",
      "type": "verse",
      "number": 14,
      "text": "By the law of the Lord he judged the congregation,"
    },
    {
      "block_id": "col-46-15",
      "type": "verse",
      "number": 15,
      "text": "By his faithfulness he was proved to be a prophet,"
    },
    {
      "block_id": "col-46-16",
      "type": "verse",
      "number": 16,
      "text": "He called upon the Lord, the Mighty One,"
    },
    {
      "block_id": "col-46-17",
      "type": "verse",
      "number": 17,
      "text": "Then the Lord thundered from heaven"
    },
    {
      "block_id": "col-46-18",
      "type": "verse",
      "number": 18,
      "text": "he subdued the leaders of the enemy"
    },
    {
      "block_id": "col-46-19",
      "type": "verse",
      "number": 19,
      "text": "Before the time of his eternal sleep,"
    },
    {
      "block_id": "col-46-20",
      "type": "verse",
      "number": 20,
      "text": "Even after he had fallen asleep, he prophesied"
    }
  ]
}