{
  "document_id": "sir-47",
  "title": "Sirach 47",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-47-1",
      "type": "verse",
      "number": 1,
      "text": "After him Nathan rose up"
    },
    {
      "block_id": "sir-47-2",
      "type": "verse",
      "number": 2,
      "text": "As the fat is set apart from the offering of well-being,"
    },
    {
      "block_id": "sir-47-3",
      "type": "verse",
      "number": 3,
      "text": "He played with lions as though they were young goats"
    },
    {
      "block_id": "sir-47-4",
      "type": "verse",
      "number": 4,
      "text": "In his youth did he not kill a giant"
    },
    {
      "block_id": "sir-47-5",
      "type": "verse",
      "number": 5,
      "text": "For he called on the Lord, the Most High,"
    },
    {
      "block_id": "sir-47-6",
      "type": "verse",
      "number": 6,
      "text": "So they glorified him for the tens of thousands"
    },
    {
      "block_id": "sir-47-7",
      "type": "verse",
      "number": 7,
      "text": "For he wiped out his enemies on every side"
    },
    {
      "block_id": "sir-47-8",
      "type": "verse",
      "number": 8,
      "text": "In all that he did he gave thanks"
    },
    {
      "block_id": "sir-47-9",
      "type": "verse",
      "number": 9,
      "text": "He placed singers before the altar,"
    },
    {
      "block_id": "sir-47-10",
      "type": "verse",
      "number": 10,
      "text": "He gave beauty to the festivals"
    },
    {
      "block_id": "sir-47-11",
      "type": "verse",
      "number": 11,
      "text": "The Lord took away his sins"
    },
    {
      "block_id": "sir-47-12",
      "type": "verse",
      "number": 12,
      "text": "After him a wise son rose up"
    },
    {
      "block_id": "sir-47-13",
      "type": "verse",
      "number": 13,
      "text": "Solomon reigned in an age of peace,"
    },
    {
      "block_id": "sir-47-14",
      "type": "verse",
      "number": 14,
      "text": "How wise you were when you were young!"
    },
    {
      "block_id": "sir-47-15",
      "type": "verse",
      "number": 15,
      "text": "Your influence spread throughout the earth,"
    },
    {
      "block_id": "sir-47-16",
      "type": "verse",
      "number": 16,
      "text": "Your fame reached to far-off islands,"
    },
    {
      "block_id": "sir-47-17",
      "type": "verse",
      "number": 17,
      "text": "For your songs, proverbs, parables,"
    },
    {
      "block_id": "sir-47-18",
      "type": "verse",
      "number": 18,
      "text": "In the name of the Lord God,"
    },
    {
      "block_id": "sir-47-19",
      "type": "verse",
      "number": 19,
      "text": "But you brought in women to lie at your side,"
    },
    {
      "block_id": "sir-47-20",
      "type": "verse",
      "number": 20,
      "text": "You stained your honor"
    },
    {
      "block_id": "sir-47-21",
      "type": "verse",
      "number": 21,
      "text": "because the sovereignty was divided"
    },
    {
      "block_id": "sir-47-22",
      "type": "verse",
      "number": 22,
      "text": "But the Lord will never give up his mercy"
    },
    {
      "block_id": "sir-47-23",
      "type": "verse",
      "number": 23,
      "text": "Solomon rested with his ancestors"
    },
    {
      "block_id": "sir-47-24",
      "type": "verse",
      "number": 24,
      "text": "Their sins increased more and more"
    },
    {
      "block_id": "sir-47-25",
      "type": "verse",
      "number": 25,
      "text": "For they sought out every kind of wickedness"
    }
  ]
}