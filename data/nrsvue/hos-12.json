{
  "document_id": "hos-12",
  "title": "Hosea 12",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-12-1",
      "type": "verse",
      "number": 1,
      "text": "Ephraim herds the wind"
    },
    {
      "block_id": "hos-12-2",
      "type": "verse",
      "number": 2,
      "text": "The Lord has an indictment against Judah"
    },
    {
      "block_id": "hos-12-3",
      "type": "verse",
      "number": 3,
      "text": "In the womb he tried to supplant his brother,"
    },
    {
      "block_id": "hos-12-4",
      "type": "verse",
      "number": 4,
      "text": "He strove with the angel and prevailed;"
    },
    {
      "block_id": "hos-12-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord the God of hosts,"
    },
    {
      "block_id": "hos-12-6",
      "type": "verse",
      "number": 6,
      "text": "But as for you, return to your God;"
    },
    {
      "block_id": "hos-12-7",
      "type": "verse",
      "number": 7,
      "text": "A trader in whose hands are false balances,"
    },
    {
      "block_id": "hos-12-8",
      "type": "verse",
      "number": 8,
      "text": "Ephraim has said, “Ah, I am rich;"
    },
    {
      "block_id": "hos-12-9",
      "type": "verse",
      "number": 9,
      "text": "I am the Lord your God"
    },
    {
      "block_id": "hos-12-10",
      "type": "verse",
      "number": 10,
      "text": "I spoke to the prophets;"
    },
    {
      "block_id": "hos-12-11",
      "type": "verse",
      "number": 11,
      "text": "In Gilead there is iniquity;"
    },
    {
      "block_id": "hos-12-12",
      "type": "verse",
      "number": 12,
      "text": "Jacob fled to the land of Aram;"
    },
    {
      "block_id": "hos-12-13",
      "type": "verse",
      "number": 13,
      "text": "By a prophet the Lord brought Israel up from Egypt,"
    },
    {
      "block_id": "hos-12-14",
      "type": "verse",
      "number": 14,
      "text": "Ephraim has given bitter offense,"
    }
  ]
}