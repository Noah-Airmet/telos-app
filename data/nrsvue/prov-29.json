{
  "document_id": "prov-29",
  "title": "Proverbs 29",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-29-1",
      "type": "verse",
      "number": 1,
      "text": "One who is often reproved, yet remains stubborn,"
    },
    {
      "block_id": "prov-29-2",
      "type": "verse",
      "number": 2,
      "text": "When the righteous are in authority, the people rejoice,"
    },
    {
      "block_id": "prov-29-3",
      "type": "verse",
      "number": 3,
      "text": "A child who loves wisdom makes a parent glad,"
    },
    {
      "block_id": "prov-29-4",
      "type": "verse",
      "number": 4,
      "text": "By justice a king gives stability to the land,"
    },
    {
      "block_id": "prov-29-5",
      "type": "verse",
      "number": 5,
      "text": "Whoever flatters a neighbor"
    },
    {
      "block_id": "prov-29-6",
      "type": "verse",
      "number": 6,
      "text": "In the transgression of the evil there is a snare,"
    },
    {
      "block_id": "prov-29-7",
      "type": "verse",
      "number": 7,
      "text": "The righteous know the rights of the poor;"
    },
    {
      "block_id": "prov-29-8",
      "type": "verse",
      "number": 8,
      "text": "Scoffers set a city aflame,"
    },
    {
      "block_id": "prov-29-9",
      "type": "verse",
      "number": 9,
      "text": "If the wise go to law with fools,"
    },
    {
      "block_id": "prov-29-10",
      "type": "verse",
      "number": 10,
      "text": "The bloodthirsty hate the blameless,"
    },
    {
      "block_id": "prov-29-11",
      "type": "verse",
      "number": 11,
      "text": "A fool gives full vent to anger,"
    },
    {
      "block_id": "prov-29-12",
      "type": "verse",
      "number": 12,
      "text": "If a ruler listens to falsehood,"
    },
    {
      "block_id": "prov-29-13",
      "type": "verse",
      "number": 13,
      "text": "The poor and the oppressor have this in common:"
    },
    {
      "block_id": "prov-29-14",
      "type": "verse",
      "number": 14,
      "text": "If a king judges the poor with equity,"
    },
    {
      "block_id": "prov-29-15",
      "type": "verse",
      "number": 15,
      "text": "The rod and reproof give wisdom,"
    },
    {
      "block_id": "prov-29-16",
      "type": "verse",
      "number": 16,
      "text": "When the wicked are in authority, transgression increases,"
    },
    {
      "block_id": "prov-29-17",
      "type": "verse",
      "number": 17,
      "text": "Discipline your children, and they will give you rest;"
    },
    {
      "block_id": "prov-29-18",
      "type": "verse",
      "number": 18,
      "text": "Where there is no prophecy, the people cast off restraint,"
    },
    {
      "block_id": "prov-29-19",
      "type": "verse",
      "number": 19,
      "text": "By mere words slaves are not disciplined,"
    },
    {
      "block_id": "prov-29-20",
      "type": "verse",
      "number": 20,
      "text": "Do you see someone who is hasty in speech?"
    },
    {
      "block_id": "prov-29-21",
      "type": "verse",
      "number": 21,
      "text": "A slave pampered from childhood"
    },
    {
      "block_id": "prov-29-22",
      "type": "verse",
      "number": 22,
      "text": "One given to anger stirs up strife,"
    },
    {
      "block_id": "prov-29-23",
      "type": "verse",
      "number": 23,
      "text": "A person’s pride will bring humiliation,"
    },
    {
      "block_id": "prov-29-24",
      "type": "verse",
      "number": 24,
      "text": "To be a partner of a thief is to hate one’s own life;"
    },
    {
      "block_id": "prov-29-25",
      "type": "verse",
      "number": 25,
      "text": "The fear of others lays a snare,"
    },
    {
      "block_id": "prov-29-26",
      "type": "verse",
      "number": 26,
      "text": "Many seek the favor of a ruler,"
    },
    {
      "block_id": "prov-29-27",
      "type": "verse",
      "number": 27,
      "text": "The unjust are an abomination to the righteous,"
    }
  ]
}