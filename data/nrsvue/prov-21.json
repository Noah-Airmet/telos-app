{
  "document_id": "prov-21",
  "title": "Proverbs 21",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-21-1",
      "type": "verse",
      "number": 1,
      "text": "The king’s heart is a stream of water in the hand of the Lord;"
    },
    {
      "block_id": "prov-21-2",
      "type": "verse",
      "number": 2,
      "text": "All deeds are right in the sight of the doer,"
    },
    {
      "block_id": "prov-21-3",
      "type": "verse",
      "number": 3,
      "text": "To do righteousness and justice"
    },
    {
      "block_id": "prov-21-4",
      "type": "verse",
      "number": 4,
      "text": "Haughty eyes and a proud heart—"
    },
    {
      "block_id": "prov-21-5",
      "type": "verse",
      "number": 5,
      "text": "The plans of the diligent lead surely to abundance,"
    },
    {
      "block_id": "prov-21-6",
      "type": "verse",
      "number": 6,
      "text": "The getting of treasures by a lying tongue"
    },
    {
      "block_id": "prov-21-7",
      "type": "verse",
      "number": 7,
      "text": "The violence of the wicked will sweep them away"
    },
    {
      "block_id": "prov-21-8",
      "type": "verse",
      "number": 8,
      "text": "The way of the guilty is crooked,"
    },
    {
      "block_id": "prov-21-9",
      "type": "verse",
      "number": 9,
      "text": "It is better to live in a corner of the housetop"
    },
    {
      "block_id": "prov-21-10",
      "type": "verse",
      "number": 10,
      "text": "The souls of the wicked desire evil;"
    },
    {
      "block_id": "prov-21-11",
      "type": "verse",
      "number": 11,
      "text": "When a scoffer is punished, the simple become wiser;"
    },
    {
      "block_id": "prov-21-12",
      "type": "verse",
      "number": 12,
      "text": "The Righteous One observes the house of the wicked;"
    },
    {
      "block_id": "prov-21-13",
      "type": "verse",
      "number": 13,
      "text": "If you close your ear to the cry of the poor,"
    },
    {
      "block_id": "prov-21-14",
      "type": "verse",
      "number": 14,
      "text": "A gift in secret averts anger,"
    },
    {
      "block_id": "prov-21-15",
      "type": "verse",
      "number": 15,
      "text": "When justice is done, it is a joy to the righteous"
    },
    {
      "block_id": "prov-21-16",
      "type": "verse",
      "number": 16,
      "text": "Whoever wanders from the way of understanding"
    },
    {
      "block_id": "prov-21-17",
      "type": "verse",
      "number": 17,
      "text": "Whoever loves pleasure will suffer want;"
    },
    {
      "block_id": "prov-21-18",
      "type": "verse",
      "number": 18,
      "text": "The wicked is a ransom for the righteous"
    },
    {
      "block_id": "prov-21-19",
      "type": "verse",
      "number": 19,
      "text": "It is better to live in a desert land"
    },
    {
      "block_id": "prov-21-20",
      "type": "verse",
      "number": 20,
      "text": "Precious treasure remains in the house of the wise,"
    },
    {
      "block_id": "prov-21-21",
      "type": "verse",
      "number": 21,
      "text": "Whoever pursues righteousness and kindness"
    },
    {
      "block_id": "prov-21-22",
      "type": "verse",
      "number": 22,
      "text": "One wise person went up against a city of warriors"
    },
    {
      "block_id": "prov-21-23",
      "type": "verse",
      "number": 23,
      "text": "To watch over mouth and tongue"
    },
    {
      "block_id": "prov-21-24",
      "type": "verse",
      "number": 24,
      "text": "The proud, haughty person, named Scoffer,"
    },
    {
      "block_id": "prov-21-25",
      "type": "verse",
      "number": 25,
      "text": "The craving of the lazy person is fatal,"
    },
    {
      "block_id": "prov-21-26",
      "type": "verse",
      "number": 26,
      "text": "All day long the wicked covet,"
    },
    {
      "block_id": "prov-21-27",
      "type": "verse",
      "number": 27,
      "text": "The sacrifice of the wicked is an abomination;"
    },
    {
      "block_id": "prov-21-28",
      "type": "verse",
      "number": 28,
      "text": "A false witness will perish,"
    },
    {
      "block_id": "prov-21-29",
      "type": "verse",
      "number": 29,
      "text": "The wicked put on a bold face,"
    },
    {
      "block_id": "prov-21-30",
      "type": "verse",
      "number": 30,
      "text": "No wisdom, no understanding, no counsel"
    },
    {
      "block_id": "prov-21-31",
      "type": "verse",
      "number": 31,
      "text": "The horse is made ready for the day of battle,"
    }
  ]
}