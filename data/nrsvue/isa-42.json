{
  "document_id": "isa-42",
  "title": "Isaiah 42",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-42-1",
      "type": "verse",
      "number": 1,
      "text": "Here is my servant, whom I uphold,"
    },
    {
      "block_id": "isa-42-2",
      "type": "verse",
      "number": 2,
      "text": "He will not cry out or lift up his voice"
    },
    {
      "block_id": "isa-42-3",
      "type": "verse",
      "number": 3,
      "text": "a bruised reed he will not break,"
    },
    {
      "block_id": "isa-42-4",
      "type": "verse",
      "number": 4,
      "text": "He will not grow faint or be crushed"
    },
    {
      "block_id": "isa-42-5",
      "type": "verse",
      "number": 5,
      "text": "Thus says God, the Lord,"
    },
    {
      "block_id": "isa-42-6",
      "type": "verse",
      "number": 6,
      "text": "I am the Lord; I have called you in righteousness;"
    },
    {
      "block_id": "isa-42-7",
      "type": "verse",
      "number": 7,
      "text": "to open the eyes that are blind,"
    },
    {
      "block_id": "isa-42-8",
      "type": "verse",
      "number": 8,
      "text": "I am the Lord; that is my name;"
    },
    {
      "block_id": "isa-42-9",
      "type": "verse",
      "number": 9,
      "text": "See, the former things have come to pass,"
    },
    {
      "block_id": "isa-42-10",
      "type": "verse",
      "number": 10,
      "text": "Sing to the Lord a new song,"
    },
    {
      "block_id": "isa-42-11",
      "type": "verse",
      "number": 11,
      "text": "Let the desert and its towns lift up their voice,"
    },
    {
      "block_id": "isa-42-12",
      "type": "verse",
      "number": 12,
      "text": "Let them give glory to the Lord"
    },
    {
      "block_id": "isa-42-13",
      "type": "verse",
      "number": 13,
      "text": "The Lord goes forth like a soldier;"
    },
    {
      "block_id": "isa-42-14",
      "type": "verse",
      "number": 14,
      "text": "For a long time I have held my peace;"
    },
    {
      "block_id": "isa-42-15",
      "type": "verse",
      "number": 15,
      "text": "I will lay waste mountains and hills"
    },
    {
      "block_id": "isa-42-16",
      "type": "verse",
      "number": 16,
      "text": "I will lead the blind"
    },
    {
      "block_id": "isa-42-17",
      "type": "verse",
      "number": 17,
      "text": "They shall be turned back and utterly put to shame—"
    },
    {
      "block_id": "isa-42-18",
      "type": "verse",
      "number": 18,
      "text": "Listen, you who are deaf,"
    },
    {
      "block_id": "isa-42-19",
      "type": "verse",
      "number": 19,
      "text": "Who is blind but my servant"
    },
    {
      "block_id": "isa-42-20",
      "type": "verse",
      "number": 20,
      "text": "He sees many things, but he does not observe them;"
    },
    {
      "block_id": "isa-42-21",
      "type": "verse",
      "number": 21,
      "text": "The Lord was pleased, for the sake of his righteousness,"
    },
    {
      "block_id": "isa-42-22",
      "type": "verse",
      "number": 22,
      "text": "But this is a people robbed and plundered;"
    },
    {
      "block_id": "isa-42-23",
      "type": "verse",
      "number": 23,
      "text": "Who among you will give heed to this;"
    },
    {
      "block_id": "isa-42-24",
      "type": "verse",
      "number": 24,
      "text": "Who gave up Jacob to the spoiler"
    },
    {
      "block_id": "isa-42-25",
      "type": "verse",
      "number": 25,
      "text": "So he poured upon him the heat of his anger"
    }
  ]
}