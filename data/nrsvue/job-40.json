{
  "document_id": "job-40",
  "title": "Job 40",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-40-heading-job’s-response-to-go",
      "type": "heading",
      "text": "Job’s Response to God"
    },
    {
      "block_id": "job-40-heading-god’s-challenge-to-j",
      "type": "heading",
      "text": "God’s Challenge to Job"
    },
    {
      "block_id": "job-40-1",
      "type": "verse",
      "number": 1,
      "text": "And the Lord said to Job:"
    },
    {
      "block_id": "job-40-2",
      "type": "verse",
      "number": 2,
      "text": "“Shall a faultfinder contend with the Almighty?"
    },
    {
      "block_id": "job-40-3",
      "type": "verse",
      "number": 3,
      "text": "Then Job answered the Lord:"
    },
    {
      "block_id": "job-40-4",
      "type": "verse",
      "number": 4,
      "text": "“See, I am of small account; what shall I answer you?"
    },
    {
      "block_id": "job-40-5",
      "type": "verse",
      "number": 5,
      "text": "I have spoken once, and I will not answer,"
    },
    {
      "block_id": "job-40-6",
      "type": "verse",
      "number": 6,
      "text": "Then the Lord answered Job out of the whirlwind:"
    },
    {
      "block_id": "job-40-7",
      "type": "verse",
      "number": 7,
      "text": "“Gird up your loins like a man;"
    },
    {
      "block_id": "job-40-8",
      "type": "verse",
      "number": 8,
      "text": "Will you even put me in the wrong?"
    },
    {
      "block_id": "job-40-9",
      "type": "verse",
      "number": 9,
      "text": "Have you an arm like God,"
    },
    {
      "block_id": "job-40-10",
      "type": "verse",
      "number": 10,
      "text": "“Deck yourself with majesty and dignity;"
    },
    {
      "block_id": "job-40-11",
      "type": "verse",
      "number": 11,
      "text": "Pour out the overflowings of your anger,"
    },
    {
      "block_id": "job-40-12",
      "type": "verse",
      "number": 12,
      "text": "Look on all who are proud and bring them low;"
    },
    {
      "block_id": "job-40-13",
      "type": "verse",
      "number": 13,
      "text": "Hide them all in the dust together;"
    },
    {
      "block_id": "job-40-14",
      "type": "verse",
      "number": 14,
      "text": "Then I will also acknowledge to you"
    },
    {
      "block_id": "job-40-15",
      "type": "verse",
      "number": 15,
      "text": "“Look at Behemoth,"
    },
    {
      "block_id": "job-40-16",
      "type": "verse",
      "number": 16,
      "text": "Its strength is in its loins"
    },
    {
      "block_id": "job-40-17",
      "type": "verse",
      "number": 17,
      "text": "It makes its tail stiff like a cedar;"
    },
    {
      "block_id": "job-40-18",
      "type": "verse",
      "number": 18,
      "text": "Its bones are tubes of bronze,"
    },
    {
      "block_id": "job-40-19",
      "type": "verse",
      "number": 19,
      "text": "“It is the first of the great acts of God;"
    },
    {
      "block_id": "job-40-20",
      "type": "verse",
      "number": 20,
      "text": "For the mountains yield food for it"
    },
    {
      "block_id": "job-40-21",
      "type": "verse",
      "number": 21,
      "text": "Under the lotus plants it lies,"
    },
    {
      "block_id": "job-40-22",
      "type": "verse",
      "number": 22,
      "text": "The lotus trees cover it for shade;"
    },
    {
      "block_id": "job-40-23",
      "type": "verse",
      "number": 23,
      "text": "Even if the river is turbulent, it is not frightened;"
    },
    {
      "block_id": "job-40-24",
      "type": "verse",
      "number": 24,
      "text": "Can one take it with hooks"
    }
  ]
}