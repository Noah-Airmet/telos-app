{
  "document_id": "ps-116",
  "title": "Psalms 116",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-116-1",
      "type": "verse",
      "number": 1,
      "text": "I love the Lord because he has heard"
    },
    {
      "block_id": "ps-116-2",
      "type": "verse",
      "number": 2,
      "text": "Because he inclined his ear to me,"
    },
    {
      "block_id": "ps-116-3",
      "type": "verse",
      "number": 3,
      "text": "The snares of death encompassed me;"
    },
    {
      "block_id": "ps-116-4",
      "type": "verse",
      "number": 4,
      "text": "Then I called on the name of the Lord,"
    },
    {
      "block_id": "ps-116-5",
      "type": "verse",
      "number": 5,
      "text": "Gracious is the Lord and righteous;"
    },
    {
      "block_id": "ps-116-6",
      "type": "verse",
      "number": 6,
      "text": "The Lord protects the simple;"
    },
    {
      "block_id": "ps-116-7",
      "type": "verse",
      "number": 7,
      "text": "Return, O my soul, to your rest,"
    },
    {
      "block_id": "ps-116-8",
      "type": "verse",
      "number": 8,
      "text": "For you have delivered my soul from death,"
    },
    {
      "block_id": "ps-116-9",
      "type": "verse",
      "number": 9,
      "text": "I walk before the Lord"
    },
    {
      "block_id": "ps-116-10",
      "type": "verse",
      "number": 10,
      "text": "I kept my faith, even when I said,"
    },
    {
      "block_id": "ps-116-11",
      "type": "verse",
      "number": 11,
      "text": "I said in my consternation,"
    },
    {
      "block_id": "ps-116-12",
      "type": "verse",
      "number": 12,
      "text": "What shall I return to the Lord"
    },
    {
      "block_id": "ps-116-13",
      "type": "verse",
      "number": 13,
      "text": "I will lift up the cup of salvation"
    },
    {
      "block_id": "ps-116-14",
      "type": "verse",
      "number": 14,
      "text": "I will pay my vows to the Lord"
    },
    {
      "block_id": "ps-116-15",
      "type": "verse",
      "number": 15,
      "text": "Precious in the sight of the Lord"
    },
    {
      "block_id": "ps-116-16",
      "type": "verse",
      "number": 16,
      "text": "O Lord, I am your servant;"
    },
    {
      "block_id": "ps-116-17",
      "type": "verse",
      "number": 17,
      "text": "I will offer to you a thanksgiving sacrifice"
    },
    {
      "block_id": "ps-116-18",
      "type": "verse",
      "number": 18,
      "text": "I will pay my vows to the Lord"
    },
    {
      "block_id": "ps-116-19",
      "type": "verse",
      "number": 19,
      "text": "in the courts of the house of the Lord,"
    }
  ]
}