{
  "document_id": "isa-50",
  "title": "Isaiah 50",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-50-1",
      "type": "verse",
      "number": 1,
      "text": "Thus says the Lord:"
    },
    {
      "block_id": "isa-50-2",
      "type": "verse",
      "number": 2,
      "text": "Why was no one there when I came?"
    },
    {
      "block_id": "isa-50-3",
      "type": "verse",
      "number": 3,
      "text": "I clothe the heavens with blackness"
    },
    {
      "block_id": "isa-50-4",
      "type": "verse",
      "number": 4,
      "text": "The Lord God has given me"
    },
    {
      "block_id": "isa-50-5",
      "type": "verse",
      "number": 5,
      "text": "The Lord God has opened my ear,"
    },
    {
      "block_id": "isa-50-6",
      "type": "verse",
      "number": 6,
      "text": "I gave my back to those who struck me"
    },
    {
      "block_id": "isa-50-7",
      "type": "verse",
      "number": 7,
      "text": "The Lord God helps me;"
    },
    {
      "block_id": "isa-50-8",
      "type": "verse",
      "number": 8,
      "text": "he who vindicates me is near."
    },
    {
      "block_id": "isa-50-9",
      "type": "verse",
      "number": 9,
      "text": "It is the Lord God who helps me;"
    },
    {
      "block_id": "isa-50-10",
      "type": "verse",
      "number": 10,
      "text": "Who among you fears the Lord"
    },
    {
      "block_id": "isa-50-11",
      "type": "verse",
      "number": 11,
      "text": "But all of you are kindlers of fire,"
    }
  ]
}