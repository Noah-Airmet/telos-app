{
  "document_id": "ps-9",
  "title": "Psalms 9",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-9-1",
      "type": "verse",
      "number": 1,
      "text": "I will give thanks to the Lord with my whole heart;"
    },
    {
      "block_id": "ps-9-2",
      "type": "verse",
      "number": 2,
      "text": "I will be glad and exult in you;"
    },
    {
      "block_id": "ps-9-3",
      "type": "verse",
      "number": 3,
      "text": "When my enemies turned back,"
    },
    {
      "block_id": "ps-9-4",
      "type": "verse",
      "number": 4,
      "text": "For you have maintained my just cause;"
    },
    {
      "block_id": "ps-9-5",
      "type": "verse",
      "number": 5,
      "text": "You have rebuked the nations; you have destroyed the wicked;"
    },
    {
      "block_id": "ps-9-6",
      "type": "verse",
      "number": 6,
      "text": "The enemies have vanished in everlasting ruins;"
    },
    {
      "block_id": "ps-9-7",
      "type": "verse",
      "number": 7,
      "text": "But the Lord sits enthroned forever;"
    },
    {
      "block_id": "ps-9-8",
      "type": "verse",
      "number": 8,
      "text": "He judges the world with righteousness;"
    },
    {
      "block_id": "ps-9-9",
      "type": "verse",
      "number": 9,
      "text": "The Lord is a stronghold for the oppressed,"
    },
    {
      "block_id": "ps-9-10",
      "type": "verse",
      "number": 10,
      "text": "And those who know your name put their trust in you,"
    },
    {
      "block_id": "ps-9-11",
      "type": "verse",
      "number": 11,
      "text": "Sing praises to the Lord, who dwells in Zion."
    },
    {
      "block_id": "ps-9-12",
      "type": "verse",
      "number": 12,
      "text": "For he who avenges blood is mindful of them;"
    },
    {
      "block_id": "ps-9-13",
      "type": "verse",
      "number": 13,
      "text": "Be gracious to me, O Lord."
    },
    {
      "block_id": "ps-9-14",
      "type": "verse",
      "number": 14,
      "text": "so that I may recount all your praises"
    },
    {
      "block_id": "ps-9-15",
      "type": "verse",
      "number": 15,
      "text": "The nations have sunk in the pit that they made;"
    },
    {
      "block_id": "ps-9-16",
      "type": "verse",
      "number": 16,
      "text": "The Lord has made himself known; he has executed judgment;"
    },
    {
      "block_id": "ps-9-17",
      "type": "verse",
      "number": 17,
      "text": "The wicked shall depart to Sheol,"
    },
    {
      "block_id": "ps-9-18",
      "type": "verse",
      "number": 18,
      "text": "For the needy shall not always be forgotten,"
    },
    {
      "block_id": "ps-9-19",
      "type": "verse",
      "number": 19,
      "text": "Rise up, O Lord! Do not let mortals prevail;"
    },
    {
      "block_id": "ps-9-20",
      "type": "verse",
      "number": 20,
      "text": "Put them in fear, O Lord;"
    }
  ]
}