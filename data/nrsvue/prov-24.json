{
  "document_id": "prov-24",
  "title": "Proverbs 24",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "prov-24-1",
      "type": "verse",
      "number": 1,
      "text": "Do not envy the wicked,"
    },
    {
      "block_id": "prov-24-2",
      "type": "verse",
      "number": 2,
      "text": "for their minds devise violence,"
    },
    {
      "block_id": "prov-24-3",
      "type": "verse",
      "number": 3,
      "text": "By wisdom a house is built,"
    },
    {
      "block_id": "prov-24-4",
      "type": "verse",
      "number": 4,
      "text": "by knowledge the rooms are filled"
    },
    {
      "block_id": "prov-24-5",
      "type": "verse",
      "number": 5,
      "text": "Wise warriors are mightier than strong ones"
    },
    {
      "block_id": "prov-24-6",
      "type": "verse",
      "number": 6,
      "text": "for by wise guidance you can wage your war,"
    },
    {
      "block_id": "prov-24-7",
      "type": "verse",
      "number": 7,
      "text": "Wisdom is too high for fools;"
    },
    {
      "block_id": "prov-24-8",
      "type": "verse",
      "number": 8,
      "text": "Whoever plans to do evil"
    },
    {
      "block_id": "prov-24-9",
      "type": "verse",
      "number": 9,
      "text": "The devising of folly is sin,"
    },
    {
      "block_id": "prov-24-10",
      "type": "verse",
      "number": 10,
      "text": "If you faint in the day of adversity,"
    },
    {
      "block_id": "prov-24-11",
      "type": "verse",
      "number": 11,
      "text": "if you hold back from rescuing those taken away to death,"
    },
    {
      "block_id": "prov-24-12",
      "type": "verse",
      "number": 12,
      "text": "if you say, “Look, we did not know this”—"
    },
    {
      "block_id": "prov-24-13",
      "type": "verse",
      "number": 13,
      "text": "My child, eat honey, for it is good,"
    },
    {
      "block_id": "prov-24-14",
      "type": "verse",
      "number": 14,
      "text": "Know that wisdom is such to your soul;"
    },
    {
      "block_id": "prov-24-15",
      "type": "verse",
      "number": 15,
      "text": "Do not lie in wait like an outlaw against the home of the righteous;"
    },
    {
      "block_id": "prov-24-16",
      "type": "verse",
      "number": 16,
      "text": "for though they fall seven times, they will rise again,"
    },
    {
      "block_id": "prov-24-17",
      "type": "verse",
      "number": 17,
      "text": "Do not rejoice when your enemies fall,"
    },
    {
      "block_id": "prov-24-18",
      "type": "verse",
      "number": 18,
      "text": "lest the Lord see it and be displeased"
    },
    {
      "block_id": "prov-24-19",
      "type": "verse",
      "number": 19,
      "text": "Do not fret because of evildoers."
    },
    {
      "block_id": "prov-24-20",
      "type": "verse",
      "number": 20,
      "text": "for the evil have no future;"
    },
    {
      "block_id": "prov-24-21",
      "type": "verse",
      "number": 21,
      "text": "My child, fear the Lord and the king,"
    },
    {
      "block_id": "prov-24-22",
      "type": "verse",
      "number": 22,
      "text": "for disaster comes from them suddenly,"
    },
    {
      "block_id": "prov-24-23",
      "type": "verse",
      "number": 23,
      "text": "These also are sayings of the wise:"
    },
    {
      "block_id": "prov-24-24",
      "type": "verse",
      "number": 24,
      "text": "Whoever says to the wicked, “You are innocent,”"
    },
    {
      "block_id": "prov-24-25",
      "type": "verse",
      "number": 25,
      "text": "but those who rebuke the wicked will have delight,"
    },
    {
      "block_id": "prov-24-26",
      "type": "verse",
      "number": 26,
      "text": "One who gives an honest answer"
    },
    {
      "block_id": "prov-24-27",
      "type": "verse",
      "number": 27,
      "text": "Prepare your work outside;"
    },
    {
      "block_id": "prov-24-28",
      "type": "verse",
      "number": 28,
      "text": "Do not be a witness against your neighbor without cause,"
    },
    {
      "block_id": "prov-24-29",
      "type": "verse",
      "number": 29,
      "text": "Do not say, “I will do to others as they have done to me;"
    },
    {
      "block_id": "prov-24-30",
      "type": "verse",
      "number": 30,
      "text": "I passed by the field of one who was lazy,"
    },
    {
      "block_id": "prov-24-31",
      "type": "verse",
      "number": 31,
      "text": "and see, it was all overgrown with thorns;"
    },
    {
      "block_id": "prov-24-32",
      "type": "verse",
      "number": 32,
      "text": "Then I saw and considered it;"
    },
    {
      "block_id": "prov-24-33",
      "type": "verse",
      "number": 33,
      "text": "A little sleep, a little slumber,"
    },
    {
      "block_id": "prov-24-34",
      "type": "verse",
      "number": 34,
      "text": "and poverty will come upon you like a robber,"
    }
  ]
}