{
  "document_id": "ps-41",
  "title": "Psalms 41",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-41-1",
      "type": "verse",
      "number": 1,
      "text": "Happy are those who consider the poor;"
    },
    {
      "block_id": "ps-41-2",
      "type": "verse",
      "number": 2,
      "text": "The Lord protects them and keeps them alive;"
    },
    {
      "block_id": "ps-41-3",
      "type": "verse",
      "number": 3,
      "text": "The Lord sustains them on their sickbed;"
    },
    {
      "block_id": "ps-41-4",
      "type": "verse",
      "number": 4,
      "text": "As for me, I said, “O Lord, be gracious to me;"
    },
    {
      "block_id": "ps-41-5",
      "type": "verse",
      "number": 5,
      "text": "My enemies wonder in malice"
    },
    {
      "block_id": "ps-41-6",
      "type": "verse",
      "number": 6,
      "text": "And when they come to see me, they utter empty words"
    },
    {
      "block_id": "ps-41-7",
      "type": "verse",
      "number": 7,
      "text": "All who hate me whisper together about me;"
    },
    {
      "block_id": "ps-41-8",
      "type": "verse",
      "number": 8,
      "text": "They think that a deadly thing has fastened on me,"
    },
    {
      "block_id": "ps-41-9",
      "type": "verse",
      "number": 9,
      "text": "Even my close friend in whom I trusted,"
    },
    {
      "block_id": "ps-41-10",
      "type": "verse",
      "number": 10,
      "text": "But you, O Lord, be gracious to me,"
    },
    {
      "block_id": "ps-41-11",
      "type": "verse",
      "number": 11,
      "text": "By this I know that you are pleased with me:"
    },
    {
      "block_id": "ps-41-12",
      "type": "verse",
      "number": 12,
      "text": "But you have upheld me because of my integrity"
    },
    {
      "block_id": "ps-41-13",
      "type": "verse",
      "number": 13,
      "text": "Blessed be the Lord, the God of Israel,"
    }
  ]
}