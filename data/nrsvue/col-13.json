{
  "document_id": "col-13",
  "title": "Colossians 13",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-13-1",
      "type": "verse",
      "number": 1,
      "text": "Whoever touches pitch gets dirty,"
    },
    {
      "block_id": "col-13-2",
      "type": "verse",
      "number": 2,
      "text": "Do not lift a weight too heavy for you"
    },
    {
      "block_id": "col-13-3",
      "type": "verse",
      "number": 3,
      "text": "A rich person does wrong and even adds insults;"
    },
    {
      "block_id": "col-13-4",
      "type": "verse",
      "number": 4,
      "text": "Rich people will exploit you if you can be of use to them,"
    },
    {
      "block_id": "col-13-5",
      "type": "verse",
      "number": 5,
      "text": "If you own something, they will live with you;"
    },
    {
      "block_id": "col-13-6",
      "type": "verse",
      "number": 6,
      "text": "When they need you, they will deceive you"
    },
    {
      "block_id": "col-13-7",
      "type": "verse",
      "number": 7,
      "text": "They will embarrass you with their delicacies,"
    },
    {
      "block_id": "col-13-8",
      "type": "verse",
      "number": 8,
      "text": "Take care not to be led astray"
    },
    {
      "block_id": "col-13-9",
      "type": "verse",
      "number": 9,
      "text": "When the influential invite you, be reserved,"
    },
    {
      "block_id": "col-13-10",
      "type": "verse",
      "number": 10,
      "text": "Do not be forward, or you may be rebuffed;"
    },
    {
      "block_id": "col-13-11",
      "type": "verse",
      "number": 11,
      "text": "Do not try to treat them as equals"
    },
    {
      "block_id": "col-13-12",
      "type": "verse",
      "number": 12,
      "text": "Cruel are those who do not keep your secrets;"
    },
    {
      "block_id": "col-13-13",
      "type": "verse",
      "number": 13,
      "text": "Be on your guard and very careful,"
    },
    {
      "block_id": "col-13-15",
      "type": "verse",
      "number": 15,
      "text": "Every creature loves its like"
    },
    {
      "block_id": "col-13-16",
      "type": "verse",
      "number": 16,
      "text": "All living beings associate with their own kind,"
    },
    {
      "block_id": "col-13-17",
      "type": "verse",
      "number": 17,
      "text": "What does a wolf have in common with a lamb?"
    },
    {
      "block_id": "col-13-18",
      "type": "verse",
      "number": 18,
      "text": "What peace is there between a hyena and a dog,"
    },
    {
      "block_id": "col-13-19",
      "type": "verse",
      "number": 19,
      "text": "Wild asses in the wilderness are the prey of lions;"
    },
    {
      "block_id": "col-13-20",
      "type": "verse",
      "number": 20,
      "text": "Humility is an abomination to the proud;"
    },
    {
      "block_id": "col-13-21",
      "type": "verse",
      "number": 21,
      "text": "When the rich person totters, he is supported by friends,"
    },
    {
      "block_id": "col-13-22",
      "type": "verse",
      "number": 22,
      "text": "If the rich person slips, many come to the rescue;"
    },
    {
      "block_id": "col-13-23",
      "type": "verse",
      "number": 23,
      "text": "The rich person speaks, and all are silent;"
    },
    {
      "block_id": "col-13-24",
      "type": "verse",
      "number": 24,
      "text": "Riches are good if they are free from sin;"
    },
    {
      "block_id": "col-13-25",
      "type": "verse",
      "number": 25,
      "text": "The heart changes the countenance"
    },
    {
      "block_id": "col-13-26",
      "type": "verse",
      "number": 26,
      "text": "The sign of a happy heart is a cheerful face,"
    }
  ]
}