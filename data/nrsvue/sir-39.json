{
  "document_id": "sir-39",
  "title": "Sirach 39",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "sir-39-1",
      "type": "verse",
      "number": 1,
      "text": "They seek out the wisdom of all the ancients"
    },
    {
      "block_id": "sir-39-2",
      "type": "verse",
      "number": 2,
      "text": "they preserve the sayings of the famous"
    },
    {
      "block_id": "sir-39-3",
      "type": "verse",
      "number": 3,
      "text": "they seek out the hidden meanings of proverbs"
    },
    {
      "block_id": "sir-39-4",
      "type": "verse",
      "number": 4,
      "text": "They serve among the great"
    },
    {
      "block_id": "sir-39-5",
      "type": "verse",
      "number": 5,
      "text": "They set their hearts to rise early"
    },
    {
      "block_id": "sir-39-6",
      "type": "verse",
      "number": 6,
      "text": "If the great Lord is willing,"
    },
    {
      "block_id": "sir-39-7",
      "type": "verse",
      "number": 7,
      "text": "The Lord will direct their counsel and knowledge"
    },
    {
      "block_id": "sir-39-8",
      "type": "verse",
      "number": 8,
      "text": "They will show the discipline of their training"
    },
    {
      "block_id": "sir-39-9",
      "type": "verse",
      "number": 9,
      "text": "Many will praise their understanding;"
    },
    {
      "block_id": "sir-39-10",
      "type": "verse",
      "number": 10,
      "text": "Nations will speak of their wisdom,"
    },
    {
      "block_id": "sir-39-11",
      "type": "verse",
      "number": 11,
      "text": "If they live long, they will leave a name greater than a thousand,"
    },
    {
      "block_id": "sir-39-12",
      "type": "verse",
      "number": 12,
      "text": "I have more on my mind to express;"
    },
    {
      "block_id": "sir-39-13",
      "type": "verse",
      "number": 13,
      "text": "Listen to me, my faithful children, and blossom"
    },
    {
      "block_id": "sir-39-14",
      "type": "verse",
      "number": 14,
      "text": "Send out fragrance like incense"
    },
    {
      "block_id": "sir-39-15",
      "type": "verse",
      "number": 15,
      "text": "Ascribe majesty to his name"
    },
    {
      "block_id": "sir-39-16",
      "type": "verse",
      "number": 16,
      "text": "“All the works of the Lord are very good,"
    },
    {
      "block_id": "sir-39-17",
      "type": "verse",
      "number": 17,
      "text": "No one can say, ‘What is this?’ or ‘Why is that?’—"
    },
    {
      "block_id": "sir-39-18",
      "type": "verse",
      "number": 18,
      "text": "At his command, his purpose is fulfilled,"
    },
    {
      "block_id": "sir-39-19",
      "type": "verse",
      "number": 19,
      "text": "The works of all are before him,"
    },
    {
      "block_id": "sir-39-20",
      "type": "verse",
      "number": 20,
      "text": "From age to age he observes all,"
    },
    {
      "block_id": "sir-39-21",
      "type": "verse",
      "number": 21,
      "text": "No one can say, ‘What is this?’ or ‘Why is that?’—"
    },
    {
      "block_id": "sir-39-22",
      "type": "verse",
      "number": 22,
      "text": "“His blessing covers the dry land like a river"
    },
    {
      "block_id": "sir-39-23",
      "type": "verse",
      "number": 23,
      "text": "The nations will inherit his wrath,"
    },
    {
      "block_id": "sir-39-24",
      "type": "verse",
      "number": 24,
      "text": "To the faithful his ways are straight"
    },
    {
      "block_id": "sir-39-25",
      "type": "verse",
      "number": 25,
      "text": "From the beginning good things were created for the good"
    },
    {
      "block_id": "sir-39-26",
      "type": "verse",
      "number": 26,
      "text": "The basic necessities of human life"
    },
    {
      "block_id": "sir-39-27",
      "type": "verse",
      "number": 27,
      "text": "All these are good for the godly,"
    },
    {
      "block_id": "sir-39-28",
      "type": "verse",
      "number": 28,
      "text": "“There are winds created for vengeance,"
    },
    {
      "block_id": "sir-39-29",
      "type": "verse",
      "number": 29,
      "text": "Fire and hail and famine and pestilence—"
    },
    {
      "block_id": "sir-39-30",
      "type": "verse",
      "number": 30,
      "text": "the fangs of wild animals and scorpions and vipers"
    },
    {
      "block_id": "sir-39-31",
      "type": "verse",
      "number": 31,
      "text": "They take delight in doing his bidding,"
    },
    {
      "block_id": "sir-39-32",
      "type": "verse",
      "number": 32,
      "text": "So from the beginning I have been steadfast"
    },
    {
      "block_id": "sir-39-33",
      "type": "verse",
      "number": 33,
      "text": "All the works of the Lord are good,"
    },
    {
      "block_id": "sir-39-34",
      "type": "verse",
      "number": 34,
      "text": "No one can say, “This is not as good as that,”"
    },
    {
      "block_id": "sir-39-35",
      "type": "verse",
      "number": 35,
      "text": "So now sing praise with all your heart and voice,"
    }
  ]
}