{
  "document_id": "hos-7",
  "title": "Hosea 7",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "hos-7-1",
      "type": "verse",
      "number": 1,
      "text": "when I would heal Israel,"
    },
    {
      "block_id": "hos-7-2",
      "type": "verse",
      "number": 2,
      "text": "But they do not consider"
    },
    {
      "block_id": "hos-7-3",
      "type": "verse",
      "number": 3,
      "text": "By their wickedness they make the king glad,"
    },
    {
      "block_id": "hos-7-4",
      "type": "verse",
      "number": 4,
      "text": "They are all adulterers;"
    },
    {
      "block_id": "hos-7-5",
      "type": "verse",
      "number": 5,
      "text": "On the day of our king the officials"
    },
    {
      "block_id": "hos-7-6",
      "type": "verse",
      "number": 6,
      "text": "For they are kindled like an oven; their heart burns within them;"
    },
    {
      "block_id": "hos-7-7",
      "type": "verse",
      "number": 7,
      "text": "All of them are hot as an oven,"
    },
    {
      "block_id": "hos-7-8",
      "type": "verse",
      "number": 8,
      "text": "Ephraim mixes himself with the peoples;"
    },
    {
      "block_id": "hos-7-9",
      "type": "verse",
      "number": 9,
      "text": "Foreigners devour his strength,"
    },
    {
      "block_id": "hos-7-10",
      "type": "verse",
      "number": 10,
      "text": "Israel’s pride testifies against him;"
    },
    {
      "block_id": "hos-7-11",
      "type": "verse",
      "number": 11,
      "text": "Ephraim has become like a dove,"
    },
    {
      "block_id": "hos-7-12",
      "type": "verse",
      "number": 12,
      "text": "As they go, I will cast my net over them;"
    },
    {
      "block_id": "hos-7-13",
      "type": "verse",
      "number": 13,
      "text": "Woe to them, for they have strayed from me!"
    },
    {
      "block_id": "hos-7-14",
      "type": "verse",
      "number": 14,
      "text": "They do not cry to me from the heart,"
    },
    {
      "block_id": "hos-7-15",
      "type": "verse",
      "number": 15,
      "text": "It was I who trained and strengthened their arms,"
    },
    {
      "block_id": "hos-7-16",
      "type": "verse",
      "number": 16,
      "text": "They turn to that which does not profit;"
    }
  ]
}