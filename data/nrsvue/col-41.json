{
  "document_id": "col-41",
  "title": "Colossians 41",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "col-41-1",
      "type": "verse",
      "number": 1,
      "text": "O death, how bitter is the thought of you"
    },
    {
      "block_id": "col-41-2",
      "type": "verse",
      "number": 2,
      "text": "O death, how welcome is your sentence"
    },
    {
      "block_id": "col-41-3",
      "type": "verse",
      "number": 3,
      "text": "Do not fear death’s decree for you;"
    },
    {
      "block_id": "col-41-4",
      "type": "verse",
      "number": 4,
      "text": "This is the Lord’s decree for all flesh;"
    },
    {
      "block_id": "col-41-5",
      "type": "verse",
      "number": 5,
      "text": "The children of sinners are abominable children,"
    },
    {
      "block_id": "col-41-6",
      "type": "verse",
      "number": 6,
      "text": "The inheritance of the children of sinners will perish,"
    },
    {
      "block_id": "col-41-7",
      "type": "verse",
      "number": 7,
      "text": "Children will blame an ungodly father,"
    },
    {
      "block_id": "col-41-8",
      "type": "verse",
      "number": 8,
      "text": "Woe to you, the ungodly,"
    },
    {
      "block_id": "col-41-9",
      "type": "verse",
      "number": 9,
      "text": "You will beget them only for groaning."
    },
    {
      "block_id": "col-41-10",
      "type": "verse",
      "number": 10,
      "text": "Whatever comes from earth returns to earth,"
    },
    {
      "block_id": "col-41-11",
      "type": "verse",
      "number": 11,
      "text": "The breath of humans is in their bodies,"
    },
    {
      "block_id": "col-41-12",
      "type": "verse",
      "number": 12,
      "text": "Have regard for your name, since it will outlive you"
    },
    {
      "block_id": "col-41-13",
      "type": "verse",
      "number": 13,
      "text": "The days of a good life are numbered,"
    },
    {
      "block_id": "col-41-14",
      "type": "verse",
      "number": 14,
      "text": "My children, be true to your training and be at peace;"
    },
    {
      "block_id": "col-41-15",
      "type": "verse",
      "number": 15,
      "text": "Better are those who hide their folly"
    },
    {
      "block_id": "col-41-16",
      "type": "verse",
      "number": 16,
      "text": "Therefore show respect for my words,"
    },
    {
      "block_id": "col-41-17",
      "type": "verse",
      "number": 17,
      "text": "Be ashamed of sexual immorality before your father or mother"
    },
    {
      "block_id": "col-41-18",
      "type": "verse",
      "number": 18,
      "text": "of a crime before a judge or magistrate"
    },
    {
      "block_id": "col-41-19",
      "type": "verse",
      "number": 19,
      "text": "and of theft in the place where you live."
    },
    {
      "block_id": "col-41-20",
      "type": "verse",
      "number": 20,
      "text": "and of silence before those who greet you,"
    },
    {
      "block_id": "col-41-21",
      "type": "verse",
      "number": 21,
      "text": "and of rejecting the appeal of a relative,"
    },
    {
      "block_id": "col-41-22",
      "type": "verse",
      "number": 22,
      "text": "of meddling with his female servant—"
    }
  ]
}