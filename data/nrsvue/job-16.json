{
  "document_id": "job-16",
  "title": "Job 16",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "job-16-heading-job-reaffirms-his-in",
      "type": "heading",
      "text": "Job Reaffirms His Innocence"
    },
    {
      "block_id": "job-16-1",
      "type": "verse",
      "number": 1,
      "text": "Then Job answered:"
    },
    {
      "block_id": "job-16-2",
      "type": "verse",
      "number": 2,
      "text": "“I have heard many such things;"
    },
    {
      "block_id": "job-16-3",
      "type": "verse",
      "number": 3,
      "text": "Have windy words no limit?"
    },
    {
      "block_id": "job-16-4",
      "type": "verse",
      "number": 4,
      "text": "I also could talk as you do,"
    },
    {
      "block_id": "job-16-5",
      "type": "verse",
      "number": 5,
      "text": "I could encourage you with my mouth,"
    },
    {
      "block_id": "job-16-6",
      "type": "verse",
      "number": 6,
      "text": "“If I speak, my pain is not assuaged,"
    },
    {
      "block_id": "job-16-7",
      "type": "verse",
      "number": 7,
      "text": "Surely now God has worn me out;"
    },
    {
      "block_id": "job-16-8",
      "type": "verse",
      "number": 8,
      "text": "And he has shriveled me up,"
    },
    {
      "block_id": "job-16-9",
      "type": "verse",
      "number": 9,
      "text": "He has torn me in his wrath and hated me;"
    },
    {
      "block_id": "job-16-10",
      "type": "verse",
      "number": 10,
      "text": "They have gaped at me with their mouths;"
    },
    {
      "block_id": "job-16-11",
      "type": "verse",
      "number": 11,
      "text": "God gives me up to the evil"
    },
    {
      "block_id": "job-16-12",
      "type": "verse",
      "number": 12,
      "text": "I was at ease, and he broke me in two;"
    },
    {
      "block_id": "job-16-13",
      "type": "verse",
      "number": 13,
      "text": "his archers surround me."
    },
    {
      "block_id": "job-16-14",
      "type": "verse",
      "number": 14,
      "text": "He bursts upon me again and again;"
    },
    {
      "block_id": "job-16-15",
      "type": "verse",
      "number": 15,
      "text": "I have sewed sackcloth upon my skin"
    },
    {
      "block_id": "job-16-16",
      "type": "verse",
      "number": 16,
      "text": "My face is red with weeping,"
    },
    {
      "block_id": "job-16-17",
      "type": "verse",
      "number": 17,
      "text": "though there is no violence in my hands,"
    },
    {
      "block_id": "job-16-18",
      "type": "verse",
      "number": 18,
      "text": "“O earth, do not cover my blood;"
    },
    {
      "block_id": "job-16-19",
      "type": "verse",
      "number": 19,
      "text": "Even now my witness is in heaven,"
    },
    {
      "block_id": "job-16-20",
      "type": "verse",
      "number": 20,
      "text": "My friends scorn me;"
    },
    {
      "block_id": "job-16-21",
      "type": "verse",
      "number": 21,
      "text": "that he would maintain the right of a mortal with God,"
    },
    {
      "block_id": "job-16-22",
      "type": "verse",
      "number": 22,
      "text": "For when a few years have come,"
    }
  ]
}