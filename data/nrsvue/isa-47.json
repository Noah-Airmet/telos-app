{
  "document_id": "isa-47",
  "title": "Isaiah 47",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "isa-47-1",
      "type": "verse",
      "number": 1,
      "text": "Come down and sit in the dust,"
    },
    {
      "block_id": "isa-47-2",
      "type": "verse",
      "number": 2,
      "text": "Take the millstones and grind meal;"
    },
    {
      "block_id": "isa-47-3",
      "type": "verse",
      "number": 3,
      "text": "Your nakedness shall be uncovered,"
    },
    {
      "block_id": "isa-47-4",
      "type": "verse",
      "number": 4,
      "text": "Our Redeemer—the Lord of hosts is his name—"
    },
    {
      "block_id": "isa-47-5",
      "type": "verse",
      "number": 5,
      "text": "Sit in silence, and go into darkness,"
    },
    {
      "block_id": "isa-47-6",
      "type": "verse",
      "number": 6,
      "text": "I was angry with my people;"
    },
    {
      "block_id": "isa-47-7",
      "type": "verse",
      "number": 7,
      "text": "You said, “I shall be mistress forever,”"
    },
    {
      "block_id": "isa-47-8",
      "type": "verse",
      "number": 8,
      "text": "Now therefore hear this, you lover of pleasures,"
    },
    {
      "block_id": "isa-47-9",
      "type": "verse",
      "number": 9,
      "text": "both these things shall come upon you"
    },
    {
      "block_id": "isa-47-10",
      "type": "verse",
      "number": 10,
      "text": "You felt secure in your wickedness;"
    },
    {
      "block_id": "isa-47-11",
      "type": "verse",
      "number": 11,
      "text": "But evil shall come upon you,"
    },
    {
      "block_id": "isa-47-12",
      "type": "verse",
      "number": 12,
      "text": "Stand fast in your enchantments"
    },
    {
      "block_id": "isa-47-13",
      "type": "verse",
      "number": 13,
      "text": "You are wearied with your many consultations;"
    },
    {
      "block_id": "isa-47-14",
      "type": "verse",
      "number": 14,
      "text": "See, they are like stubble;"
    },
    {
      "block_id": "isa-47-15",
      "type": "verse",
      "number": 15,
      "text": "Such to you are those with whom you have labored,"
    }
  ]
}