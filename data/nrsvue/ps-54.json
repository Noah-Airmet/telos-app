{
  "document_id": "ps-54",
  "title": "Psalms 54",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-54-1",
      "type": "verse",
      "number": 1,
      "text": "Save me, O God, by your name,"
    },
    {
      "block_id": "ps-54-2",
      "type": "verse",
      "number": 2,
      "text": "Hear my prayer, O God;"
    },
    {
      "block_id": "ps-54-3",
      "type": "verse",
      "number": 3,
      "text": "For the insolent have risen against me;"
    },
    {
      "block_id": "ps-54-4",
      "type": "verse",
      "number": 4,
      "text": "But surely, God is my helper;"
    },
    {
      "block_id": "ps-54-5",
      "type": "verse",
      "number": 5,
      "text": "He will repay my enemies for their evil."
    },
    {
      "block_id": "ps-54-6",
      "type": "verse",
      "number": 6,
      "text": "With a freewill offering I will sacrifice to you;"
    },
    {
      "block_id": "ps-54-7",
      "type": "verse",
      "number": 7,
      "text": "For he has delivered me from every trouble,"
    }
  ]
}