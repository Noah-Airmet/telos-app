{
  "document_id": "ps-96",
  "title": "Psalms 96",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-96-1",
      "type": "verse",
      "number": 1,
      "text": "O sing to the Lord a new song;"
    },
    {
      "block_id": "ps-96-2",
      "type": "verse",
      "number": 2,
      "text": "Sing to the Lord; bless his name;"
    },
    {
      "block_id": "ps-96-3",
      "type": "verse",
      "number": 3,
      "text": "Declare his glory among the nations,"
    },
    {
      "block_id": "ps-96-4",
      "type": "verse",
      "number": 4,
      "text": "For great is the Lord and greatly to be praised;"
    },
    {
      "block_id": "ps-96-5",
      "type": "verse",
      "number": 5,
      "text": "For all the gods of the peoples are idols,"
    },
    {
      "block_id": "ps-96-6",
      "type": "verse",
      "number": 6,
      "text": "Honor and majesty are before him;"
    },
    {
      "block_id": "ps-96-7",
      "type": "verse",
      "number": 7,
      "text": "Ascribe to the Lord, O families of the peoples,"
    },
    {
      "block_id": "ps-96-8",
      "type": "verse",
      "number": 8,
      "text": "Ascribe to the Lord the glory due his name;"
    },
    {
      "block_id": "ps-96-9",
      "type": "verse",
      "number": 9,
      "text": "Worship the Lord in holy splendor;"
    },
    {
      "block_id": "ps-96-10",
      "type": "verse",
      "number": 10,
      "text": "Say among the nations, “The Lord is king!"
    },
    {
      "block_id": "ps-96-11",
      "type": "verse",
      "number": 11,
      "text": "Let the heavens be glad, and let the earth rejoice;"
    },
    {
      "block_id": "ps-96-12",
      "type": "verse",
      "number": 12,
      "text": "let the field exult and everything in it."
    },
    {
      "block_id": "ps-96-13",
      "type": "verse",
      "number": 13,
      "text": "before the Lord, for he is coming,"
    }
  ]
}