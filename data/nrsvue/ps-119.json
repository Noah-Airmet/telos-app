{
  "document_id": "ps-119",
  "title": "Psalms 119",
  "type": "scripture",
  "translation": "NRSVue",
  "blocks": [
    {
      "block_id": "ps-119-1",
      "type": "verse",
      "number": 1,
      "text": "Happy are those whose way is blameless,"
    },
    {
      "block_id": "ps-119-2",
      "type": "verse",
      "number": 2,
      "text": "Happy are those who keep his decrees,"
    },
    {
      "block_id": "ps-119-3",
      "type": "verse",
      "number": 3,
      "text": "who also do no wrong"
    },
    {
      "block_id": "ps-119-4",
      "type": "verse",
      "number": 4,
      "text": "You have commanded your precepts"
    },
    {
      "block_id": "ps-119-5",
      "type": "verse",
      "number": 5,
      "text": "O that my ways may be steadfast"
    },
    {
      "block_id": "ps-119-6",
      "type": "verse",
      "number": 6,
      "text": "Then I shall not be put to shame,"
    },
    {
      "block_id": "ps-119-7",
      "type": "verse",
      "number": 7,
      "text": "I will praise you with an upright heart,"
    },
    {
      "block_id": "ps-119-8",
      "type": "verse",
      "number": 8,
      "text": "I will observe your statutes;"
    },
    {
      "block_id": "ps-119-9",
      "type": "verse",
      "number": 9,
      "text": "How can young people keep their way pure?"
    },
    {
      "block_id": "ps-119-10",
      "type": "verse",
      "number": 10,
      "text": "With my whole heart I seek you;"
    },
    {
      "block_id": "ps-119-11",
      "type": "verse",
      "number": 11,
      "text": "I treasure your word in my heart,"
    },
    {
      "block_id": "ps-119-12",
      "type": "verse",
      "number": 12,
      "text": "Blessed are you, O Lord;"
    },
    {
      "block_id": "ps-119-13",
      "type": "verse",
      "number": 13,
      "text": "With my lips I declare"
    },
    {
      "block_id": "ps-119-14",
      "type": "verse",
      "number": 14,
      "text": "I delight in the way of your decrees"
    },
    {
      "block_id": "ps-119-15",
      "type": "verse",
      "number": 15,
      "text": "I will meditate on your precepts"
    },
    {
      "block_id": "ps-119-16",
      "type": "verse",
      "number": 16,
      "text": "I will delight in your statutes;"
    },
    {
      "block_id": "ps-119-17",
      "type": "verse",
      "number": 17,
      "text": "Deal bountifully with your servant,"
    },
    {
      "block_id": "ps-119-18",
      "type": "verse",
      "number": 18,
      "text": "Open my eyes, so that I may behold"
    },
    {
      "block_id": "ps-119-19",
      "type": "verse",
      "number": 19,
      "text": "I live as an alien in the land;"
    },
    {
      "block_id": "ps-119-20",
      "type": "verse",
      "number": 20,
      "text": "My soul is consumed with longing"
    },
    {
      "block_id": "ps-119-21",
      "type": "verse",
      "number": 21,
      "text": "You rebuke the insolent, accursed ones,"
    },
    {
      "block_id": "ps-119-22",
      "type": "verse",
      "number": 22,
      "text": "take away from me their scorn and contempt,"
    },
    {
      "block_id": "ps-119-23",
      "type": "verse",
      "number": 23,
      "text": "Even though princes sit plotting against me,"
    },
    {
      "block_id": "ps-119-24",
      "type": "verse",
      "number": 24,
      "text": "Your decrees are my delight;"
    },
    {
      "block_id": "ps-119-25",
      "type": "verse",
      "number": 25,
      "text": "My soul clings to the dust;"
    },
    {
      "block_id": "ps-119-26",
      "type": "verse",
      "number": 26,
      "text": "When I told of my ways, you answered me;"
    },
    {
      "block_id": "ps-119-27",
      "type": "verse",
      "number": 27,
      "text": "Make me understand the way of your precepts,"
    },
    {
      "block_id": "ps-119-28",
      "type": "verse",
      "number": 28,
      "text": "My soul melts away for sorrow;"
    },
    {
      "block_id": "ps-119-29",
      "type": "verse",
      "number": 29,
      "text": "Put false ways far from me,"
    },
    {
      "block_id": "ps-119-30",
      "type": "verse",
      "number": 30,
      "text": "I have chosen the way of faithfulness;"
    },
    {
      "block_id": "ps-119-31",
      "type": "verse",
      "number": 31,
      "text": "I cling to your decrees, O Lord;"
    },
    {
      "block_id": "ps-119-32",
      "type": "verse",
      "number": 32,
      "text": "I run the way of your commandments,"
    },
    {
      "block_id": "ps-119-33",
      "type": "verse",
      "number": 33,
      "text": "Teach me, O Lord, the way of your statutes,"
    },
    {
      "block_id": "ps-119-34",
      "type": "verse",
      "number": 34,
      "text": "Give me understanding, that I may keep your law"
    },
    {
      "block_id": "ps-119-35",
      "type": "verse",
      "number": 35,
      "text": "Lead me in the path of your commandments,"
    },
    {
      "block_id": "ps-119-36",
      "type": "verse",
      "number": 36,
      "text": "Turn my heart to your decrees"
    },
    {
      "block_id": "ps-119-37",
      "type": "verse",
      "number": 37,
      "text": "Turn my eyes from looking at vanities;"
    },
    {
      "block_id": "ps-119-38",
      "type": "verse",
      "number": 38,
      "text": "Confirm to your servant your promise,"
    },
    {
      "block_id": "ps-119-39",
      "type": "verse",
      "number": 39,
      "text": "Turn away the disgrace that I dread,"
    },
    {
      "block_id": "ps-119-40",
      "type": "verse",
      "number": 40,
      "text": "See, I have longed for your precepts;"
    },
    {
      "block_id": "ps-119-41",
      "type": "verse",
      "number": 41,
      "text": "Let your steadfast love come to me, O Lord,"
    },
    {
      "block_id": "ps-119-42",
      "type": "verse",
      "number": 42,
      "text": "Then I shall have an answer for those who taunt me,"
    },
    {
      "block_id": "ps-119-43",
      "type": "verse",
      "number": 43,
      "text": "Do not take the word of truth utterly out of my mouth,"
    },
    {
      "block_id": "ps-119-44",
      "type": "verse",
      "number": 44,
      "text": "I will keep your law continually,"
    },
    {
      "block_id": "ps-119-45",
      "type": "verse",
      "number": 45,
      "text": "I shall walk at liberty,"
    },
    {
      "block_id": "ps-119-46",
      "type": "verse",
      "number": 46,
      "text": "I will also speak of your decrees before kings"
    },
    {
      "block_id": "ps-119-47",
      "type": "verse",
      "number": 47,
      "text": "I find my delight in your commandments"
    },
    {
      "block_id": "ps-119-48",
      "type": "verse",
      "number": 48,
      "text": "I revere your commandments, which I love,"
    },
    {
      "block_id": "ps-119-49",
      "type": "verse",
      "number": 49,
      "text": "Remember your word to your servant,"
    },
    {
      "block_id": "ps-119-50",
      "type": "verse",
      "number": 50,
      "text": "This is my comfort in my distress,"
    },
    {
      "block_id": "ps-119-51",
      "type": "verse",
      "number": 51,
      "text": "The arrogant utterly deride me,"
    },
    {
      "block_id": "ps-119-52",
      "type": "verse",
      "number": 52,
      "text": "When I think of your ordinances from of old,"
    },
    {
      "block_id": "ps-119-53",
      "type": "verse",
      "number": 53,
      "text": "Hot indignation seizes me because of the wicked,"
    },
    {
      "block_id": "ps-119-54",
      "type": "verse",
      "number": 54,
      "text": "Your statutes have been my songs"
    },
    {
      "block_id": "ps-119-55",
      "type": "verse",
      "number": 55,
      "text": "I remember your name in the night, O Lord,"
    },
    {
      "block_id": "ps-119-56",
      "type": "verse",
      "number": 56,
      "text": "This blessing has fallen to me,"
    },
    {
      "block_id": "ps-119-57",
      "type": "verse",
      "number": 57,
      "text": "The Lord is my portion;"
    },
    {
      "block_id": "ps-119-58",
      "type": "verse",
      "number": 58,
      "text": "I implore your favor with all my heart;"
    },
    {
      "block_id": "ps-119-59",
      "type": "verse",
      "number": 59,
      "text": "When I think of your ways,"
    },
    {
      "block_id": "ps-119-60",
      "type": "verse",
      "number": 60,
      "text": "I hurry and do not delay"
    },
    {
      "block_id": "ps-119-61",
      "type": "verse",
      "number": 61,
      "text": "Though the cords of the wicked ensnare me,"
    },
    {
      "block_id": "ps-119-62",
      "type": "verse",
      "number": 62,
      "text": "At midnight I rise to praise you,"
    },
    {
      "block_id": "ps-119-63",
      "type": "verse",
      "number": 63,
      "text": "I am a companion of all who fear you,"
    },
    {
      "block_id": "ps-119-64",
      "type": "verse",
      "number": 64,
      "text": "The earth, O Lord, is full of your steadfast love;"
    },
    {
      "block_id": "ps-119-65",
      "type": "verse",
      "number": 65,
      "text": "You have dealt well with your servant,"
    },
    {
      "block_id": "ps-119-66",
      "type": "verse",
      "number": 66,
      "text": "Teach me good judgment and knowledge,"
    },
    {
      "block_id": "ps-119-67",
      "type": "verse",
      "number": 67,
      "text": "Before I was humbled I went astray,"
    },
    {
      "block_id": "ps-119-68",
      "type": "verse",
      "number": 68,
      "text": "You are good and do good;"
    },
    {
      "block_id": "ps-119-69",
      "type": "verse",
      "number": 69,
      "text": "The arrogant smear me with lies,"
    },
    {
      "block_id": "ps-119-70",
      "type": "verse",
      "number": 70,
      "text": "Their hearts are thick like fat,"
    },
    {
      "block_id": "ps-119-71",
      "type": "verse",
      "number": 71,
      "text": "It is good for me that I was humbled,"
    },
    {
      "block_id": "ps-119-72",
      "type": "verse",
      "number": 72,
      "text": "The law of your mouth is better to me"
    },
    {
      "block_id": "ps-119-73",
      "type": "verse",
      "number": 73,
      "text": "Your hands have made and fashioned me;"
    },
    {
      "block_id": "ps-119-74",
      "type": "verse",
      "number": 74,
      "text": "Those who fear you shall see me and rejoice,"
    },
    {
      "block_id": "ps-119-75",
      "type": "verse",
      "number": 75,
      "text": "I know, O Lord, that your judgments are right"
    },
    {
      "block_id": "ps-119-76",
      "type": "verse",
      "number": 76,
      "text": "Let your steadfast love become my comfort"
    },
    {
      "block_id": "ps-119-77",
      "type": "verse",
      "number": 77,
      "text": "Let your mercy come to me, that I may live,"
    },
    {
      "block_id": "ps-119-78",
      "type": "verse",
      "number": 78,
      "text": "Let the arrogant be put to shame,"
    },
    {
      "block_id": "ps-119-79",
      "type": "verse",
      "number": 79,
      "text": "Let those who fear you turn to me,"
    },
    {
      "block_id": "ps-119-80",
      "type": "verse",
      "number": 80,
      "text": "May my heart be blameless in your statutes,"
    },
    {
      "block_id": "ps-119-81",
      "type": "verse",
      "number": 81,
      "text": "My soul languishes for your salvation;"
    },
    {
      "block_id": "ps-119-82",
      "type": "verse",
      "number": 82,
      "text": "My eyes fail with watching for your promise;"
    },
    {
      "block_id": "ps-119-83",
      "type": "verse",
      "number": 83,
      "text": "For I have become like a wineskin in the smoke,"
    },
    {
      "block_id": "ps-119-84",
      "type": "verse",
      "number": 84,
      "text": "How long must your servant endure?"
    },
    {
      "block_id": "ps-119-85",
      "type": "verse",
      "number": 85,
      "text": "The arrogant have dug pitfalls for me;"
    },
    {
      "block_id": "ps-119-86",
      "type": "verse",
      "number": 86,
      "text": "All your commandments are enduring;"
    },
    {
      "block_id": "ps-119-87",
      "type": "verse",
      "number": 87,
      "text": "They have almost made an end of me on earth,"
    },
    {
      "block_id": "ps-119-88",
      "type": "verse",
      "number": 88,
      "text": "In your steadfast love spare my life,"
    },
    {
      "block_id": "ps-119-89",
      "type": "verse",
      "number": 89,
      "text": "The Lord exists forever;"
    },
    {
      "block_id": "ps-119-90",
      "type": "verse",
      "number": 90,
      "text": "Your faithfulness endures to all generations;"
    },
    {
      "block_id": "ps-119-91",
      "type": "verse",
      "number": 91,
      "text": "By your appointment they stand today,"
    },
    {
      "block_id": "ps-119-92",
      "type": "verse",
      "number": 92,
      "text": "If your law had not been my delight,"
    },
    {
      "block_id": "ps-119-93",
      "type": "verse",
      "number": 93,
      "text": "I will never forget your precepts,"
    },
    {
      "block_id": "ps-119-94",
      "type": "verse",
      "number": 94,
      "text": "I am yours; save me,"
    },
    {
      "block_id": "ps-119-95",
      "type": "verse",
      "number": 95,
      "text": "The wicked lie in wait to destroy me,"
    },
    {
      "block_id": "ps-119-96",
      "type": "verse",
      "number": 96,
      "text": "I have seen a limit to all perfection,"
    },
    {
      "block_id": "ps-119-97",
      "type": "verse",
      "number": 97,
      "text": "Oh, how I love your law!"
    },
    {
      "block_id": "ps-119-98",
      "type": "verse",
      "number": 98,
      "text": "Your commandment makes me wiser than my enemies,"
    },
    {
      "block_id": "ps-119-99",
      "type": "verse",
      "number": 99,
      "text": "I have more understanding than all my teachers,"
    },
    {
      "block_id": "ps-119-100",
      "type": "verse",
      "number": 100,
      "text": "I understand more than the aged,"
    },
    {
      "block_id": "ps-119-101",
      "type": "verse",
      "number": 101,
      "text": "I hold back my feet from every evil way,"
    },
    {
      "block_id": "ps-119-102",
      "type": "verse",
      "number": 102,
      "text": "I do not turn away from your ordinances,"
    },
    {
      "block_id": "ps-119-103",
      "type": "verse",
      "number": 103,
      "text": "How sweet are your words to my taste,"
    },
    {
      "block_id": "ps-119-104",
      "type": "verse",
      "number": 104,
      "text": "Through your precepts I get understanding;"
    },
    {
      "block_id": "ps-119-105",
      "type": "verse",
      "number": 105,
      "text": "Your word is a lamp to my feet"
    },
    {
      "block_id": "ps-119-106",
      "type": "verse",
      "number": 106,
      "text": "I have sworn an oath and confirmed it,"
    },
    {
      "block_id": "ps-119-107",
      "type": "verse",
      "number": 107,
      "text": "I am severely afflicted;"
    },
    {
      "block_id": "ps-119-108",
      "type": "verse",
      "number": 108,
      "text": "Accept my offerings of praise, O Lord,"
    },
    {
      "block_id": "ps-119-109",
      "type": "verse",
      "number": 109,
      "text": "I hold my life in my hand continually,"
    },
    {
      "block_id": "ps-119-110",
      "type": "verse",
      "number": 110,
      "text": "The wicked have laid a snare for me,"
    },
    {
      "block_id": "ps-119-111",
      "type": "verse",
      "number": 111,
      "text": "Your decrees are my heritage forever;"
    },
    {
      "block_id": "ps-119-112",
      "type": "verse",
      "number": 112,
      "text": "I incline my heart to perform your statutes"
    },
    {
      "block_id": "ps-119-113",
      "type": "verse",
      "number": 113,
      "text": "I hate the double-minded,"
    },
    {
      "block_id": "ps-119-114",
      "type": "verse",
      "number": 114,
      "text": "You are my hiding place and my shield;"
    },
    {
      "block_id": "ps-119-115",
      "type": "verse",
      "number": 115,
      "text": "Go away from me, you evildoers,"
    },
    {
      "block_id": "ps-119-116",
      "type": "verse",
      "number": 116,
      "text": "Uphold me according to your promise, that I may live,"
    },
    {
      "block_id": "ps-119-117",
      "type": "verse",
      "number": 117,
      "text": "Hold me up, that I may be safe"
    },
    {
      "block_id": "ps-119-118",
      "type": "verse",
      "number": 118,
      "text": "You spurn all who go astray from your statutes,"
    },
    {
      "block_id": "ps-119-119",
      "type": "verse",
      "number": 119,
      "text": "All the wicked of the earth I count as dross;"
    },
    {
      "block_id": "ps-119-120",
      "type": "verse",
      "number": 120,
      "text": "My flesh trembles for fear of you,"
    },
    {
      "block_id": "ps-119-121",
      "type": "verse",
      "number": 121,
      "text": "I have done what is just and right;"
    },
    {
      "block_id": "ps-119-122",
      "type": "verse",
      "number": 122,
      "text": "Guarantee your servant’s well-being;"
    },
    {
      "block_id": "ps-119-123",
      "type": "verse",
      "number": 123,
      "text": "My eyes fail from watching for your salvation"
    },
    {
      "block_id": "ps-119-124",
      "type": "verse",
      "number": 124,
      "text": "Deal with your servant according to your steadfast love,"
    },
    {
      "block_id": "ps-119-125",
      "type": "verse",
      "number": 125,
      "text": "I am your servant; give me understanding,"
    },
    {
      "block_id": "ps-119-126",
      "type": "verse",
      "number": 126,
      "text": "It is time for the Lord to act,"
    },
    {
      "block_id": "ps-119-127",
      "type": "verse",
      "number": 127,
      "text": "Truly I love your commandments"
    },
    {
      "block_id": "ps-119-128",
      "type": "verse",
      "number": 128,
      "text": "Truly I direct my steps by all your precepts;"
    },
    {
      "block_id": "ps-119-129",
      "type": "verse",
      "number": 129,
      "text": "Your decrees are wonderful;"
    },
    {
      "block_id": "ps-119-130",
      "type": "verse",
      "number": 130,
      "text": "The unfolding of your words gives light;"
    },
    {
      "block_id": "ps-119-131",
      "type": "verse",
      "number": 131,
      "text": "With open mouth I pant,"
    },
    {
      "block_id": "ps-119-132",
      "type": "verse",
      "number": 132,
      "text": "Turn to me and be gracious to me,"
    },
    {
      "block_id": "ps-119-133",
      "type": "verse",
      "number": 133,
      "text": "Keep my steps steady according to your promise,"
    },
    {
      "block_id": "ps-119-134",
      "type": "verse",
      "number": 134,
      "text": "Redeem me from human oppression,"
    },
    {
      "block_id": "ps-119-135",
      "type": "verse",
      "number": 135,
      "text": "Make your face shine upon your servant,"
    },
    {
      "block_id": "ps-119-136",
      "type": "verse",
      "number": 136,
      "text": "My eyes shed streams of tears"
    },
    {
      "block_id": "ps-119-137",
      "type": "verse",
      "number": 137,
      "text": "You are righteous, O Lord,"
    },
    {
      "block_id": "ps-119-138",
      "type": "verse",
      "number": 138,
      "text": "You have appointed your decrees in righteousness"
    },
    {
      "block_id": "ps-119-139",
      "type": "verse",
      "number": 139,
      "text": "My zeal consumes me"
    },
    {
      "block_id": "ps-119-140",
      "type": "verse",
      "number": 140,
      "text": "Your promise is well tried,"
    },
    {
      "block_id": "ps-119-141",
      "type": "verse",
      "number": 141,
      "text": "I am small and despised,"
    },
    {
      "block_id": "ps-119-142",
      "type": "verse",
      "number": 142,
      "text": "Your righteousness is an everlasting righteousness,"
    },
    {
      "block_id": "ps-119-143",
      "type": "verse",
      "number": 143,
      "text": "Trouble and anguish have come upon me,"
    },
    {
      "block_id": "ps-119-144",
      "type": "verse",
      "number": 144,
      "text": "Your decrees are righteous forever;"
    },
    {
      "block_id": "ps-119-145",
      "type": "verse",
      "number": 145,
      "text": "With my whole heart I cry; answer me, O Lord."
    },
    {
      "block_id": "ps-119-146",
      "type": "verse",
      "number": 146,
      "text": "I cry to you; save me,"
    },
    {
      "block_id": "ps-119-147",
      "type": "verse",
      "number": 147,
      "text": "I rise before dawn and cry for help;"
    },
    {
      "block_id": "ps-119-148",
      "type": "verse",
      "number": 148,
      "text": "My eyes are awake before each watch of the night,"
    },
    {
      "block_id": "ps-119-149",
      "type": "verse",
      "number": 149,
      "text": "In your steadfast love hear my voice;"
    },
    {
      "block_id": "ps-119-150",
      "type": "verse",
      "number": 150,
      "text": "Those who persecute me with evil purpose draw near;"
    },
    {
      "block_id": "ps-119-151",
      "type": "verse",
      "number": 151,
      "text": "Yet you are near, O Lord,"
    },
    {
      "block_id": "ps-119-152",
      "type": "verse",
      "number": 152,
      "text": "Long ago I learned from your decrees"
    },
    {
      "block_id": "ps-119-153",
      "type": "verse",
      "number": 153,
      "text": "Look on my misery and rescue me,"
    },
    {
      "block_id": "ps-119-154",
      "type": "verse",
      "number": 154,
      "text": "Plead my cause and redeem me;"
    },
    {
      "block_id": "ps-119-155",
      "type": "verse",
      "number": 155,
      "text": "Salvation is far from the wicked,"
    },
    {
      "block_id": "ps-119-156",
      "type": "verse",
      "number": 156,
      "text": "Great is your mercy, O Lord;"
    },
    {
      "block_id": "ps-119-157",
      "type": "verse",
      "number": 157,
      "text": "Many are my persecutors and my adversaries,"
    },
    {
      "block_id": "ps-119-158",
      "type": "verse",
      "number": 158,
      "text": "I look at the faithless with disgust"
    },
    {
      "block_id": "ps-119-159",
      "type": "verse",
      "number": 159,
      "text": "Consider how I love your precepts;"
    },
    {
      "block_id": "ps-119-160",
      "type": "verse",
      "number": 160,
      "text": "The sum of your word is truth,"
    },
    {
      "block_id": "ps-119-161",
      "type": "verse",
      "number": 161,
      "text": "Princes persecute me without cause,"
    },
    {
      "block_id": "ps-119-162",
      "type": "verse",
      "number": 162,
      "text": "I rejoice at your word"
    },
    {
      "block_id": "ps-119-163",
      "type": "verse",
      "number": 163,
      "text": "I hate and abhor falsehood,"
    },
    {
      "block_id": "ps-119-164",
      "type": "verse",
      "number": 164,
      "text": "Seven times a day I praise you"
    },
    {
      "block_id": "ps-119-165",
      "type": "verse",
      "number": 165,
      "text": "Great peace have those who love your law;"
    },
    {
      "block_id": "ps-119-166",
      "type": "verse",
      "number": 166,
      "text": "I hope for your salvation, O Lord,"
    },
    {
      "block_id": "ps-119-167",
      "type": "verse",
      "number": 167,
      "text": "My soul keeps your decrees;"
    },
    {
      "block_id": "ps-119-168",
      "type": "verse",
      "number": 168,
      "text": "I keep your precepts and decrees,"
    },
    {
      "block_id": "ps-119-169",
      "type": "verse",
      "number": 169,
      "text": "Let my cry come before you, O Lord;"
    },
    {
      "block_id": "ps-119-170",
      "type": "verse",
      "number": 170,
      "text": "Let my supplication come before you;"
    },
    {
      "block_id": "ps-119-171",
      "type": "verse",
      "number": 171,
      "text": "My lips will pour forth praise,"
    },
    {
      "block_id": "ps-119-172",
      "type": "verse",
      "number": 172,
      "text": "My tongue will sing of your promise,"
    },
    {
      "block_id": "ps-119-173",
      "type": "verse",
      "number": 173,
      "text": "Let your hand be ready to help me,"
    },
    {
      "block_id": "ps-119-174",
      "type": "verse",
      "number": 174,
      "text": "I long for your salvation, O Lord,"
    },
    {
      "block_id": "ps-119-175",
      "type": "verse",
      "number": 175,
      "text": "Let me live that I may praise you,"
    },
    {
      "block_id": "ps-119-176",
      "type": "verse",
      "number": 176,
      "text": "I have gone astray like a lost sheep; seek out your servant,"
    }
  ]
}